// forge:scaffold one-shot — JWT validator; canonical pattern in `forge skill load packs`.
package jwtauth

import (
	"context"
	"crypto/rsa"
	"fmt"
	"log/slog"
	"sync"

	"github.com/golang-jwt/jwt/v5"
	"github.com/MicahParks/keyfunc/v3"

	"{{.ModulePath}}/pkg/middleware"
)

// Validator validates JWT tokens using JWKS, static keys, or HMAC secrets.
type Validator struct {
	jwks          keyfunc.Keyfunc
	jwksCancel    context.CancelFunc // Cancels the JWKS refresh goroutine on Close.
	issuer        string
	audience      string
	signingMethod string
	hmacSecret    []byte         // For HMAC signing (dev/simple setups)
	rsaKey        *rsa.PublicKey // For static RSA key
	logger        *slog.Logger
	mu            sync.RWMutex
}

// ValidatorConfig configures the JWT validator.
type ValidatorConfig struct {
	JWKSURL       string // JWKS endpoint (e.g., https://auth.example.com/.well-known/jwks.json)
	Issuer        string // Expected issuer claim
	Audience      string // Expected audience claim
	SigningMethod string // RS256, ES256, HS256
	HMACSecret    string // For HMAC-based signing (simple setups)
	RSAPublicKey  string // PEM-encoded RSA public key (static key)
}

// NewValidator creates a validator. Supports 3 modes:
//  1. JWKS URL (recommended for production — auto-rotating keys)
//  2. Static RSA/ECDSA public key
//  3. HMAC shared secret (dev/simple setups)
func NewValidator(cfg ValidatorConfig, logger *slog.Logger) (*Validator, error) {
	v := &Validator{
		issuer:        cfg.Issuer,
		audience:      cfg.Audience,
		signingMethod: cfg.SigningMethod,
		logger:        logger,
	}

	if cfg.JWKSURL != "" {
		ctx, cancel := context.WithCancel(context.Background())
		jwks, err := keyfunc.NewDefaultCtx(ctx, []string{cfg.JWKSURL})
		if err != nil {
			cancel()
			return nil, fmt.Errorf("fetching JWKS: %w", err)
		}
		v.jwks = jwks
		v.jwksCancel = cancel
		logger.Info("JWT validator initialized with JWKS", "url", cfg.JWKSURL)
	} else if cfg.HMACSecret != "" {
		v.hmacSecret = []byte(cfg.HMACSecret)
		logger.Info("JWT validator initialized with HMAC secret")
	} else if cfg.RSAPublicKey != "" {
		key, err := jwt.ParseRSAPublicKeyFromPEM([]byte(cfg.RSAPublicKey))
		if err != nil {
			return nil, fmt.Errorf("parsing RSA public key: %w", err)
		}
		v.rsaKey = key
		logger.Info("JWT validator initialized with static RSA key")
	} else {
		return nil, fmt.Errorf("jwt-auth: one of JWKS_URL, HMAC_SECRET, or RSA_PUBLIC_KEY must be set")
	}

	return v, nil
}

// ValidateToken validates a JWT and returns Claims.
func (v *Validator) ValidateToken(tokenString string) (*middleware.Claims, error) {
	opts := []jwt.ParserOption{
		jwt.WithValidMethods([]string{v.signingMethod}),
	}
	if v.issuer != "" {
		opts = append(opts, jwt.WithIssuer(v.issuer))
	}
	if v.audience != "" {
		opts = append(opts, jwt.WithAudience(v.audience))
	}

	token, err := jwt.Parse(tokenString, v.keyFunc, opts...)
	if err != nil {
		return nil, fmt.Errorf("invalid token: %w", err)
	}

	claims, ok := token.Claims.(jwt.MapClaims)
	if !ok || !token.Valid {
		return nil, fmt.Errorf("invalid token claims")
	}

	return v.extractClaims(claims), nil
}

func (v *Validator) keyFunc(token *jwt.Token) (interface{}, error) {
	if v.jwks != nil {
		return v.jwks.Keyfunc(token)
	}
	if v.hmacSecret != nil {
		return v.hmacSecret, nil
	}
	if v.rsaKey != nil {
		return v.rsaKey, nil
	}
	return nil, fmt.Errorf("no signing key configured")
}

func (v *Validator) extractClaims(mc jwt.MapClaims) *middleware.Claims {
	c := &middleware.Claims{}
	if sub, ok := mc["sub"].(string); ok {
		c.UserID = sub
	}
	if email, ok := mc["email"].(string); ok {
		c.Email = email
	}
	if orgID, ok := mc["org_id"].(string); ok {
		c.OrgID = orgID
	}
	if role, ok := mc["role"].(string); ok {
		c.Role = role
	}
	// Handle roles as string array
	if roles, ok := mc["roles"].([]interface{}); ok {
		for _, r := range roles {
			if s, ok := r.(string); ok {
				c.Roles = append(c.Roles, s)
			}
		}
	}
	return c
}

// Close cleans up JWKS background goroutine.
func (v *Validator) Close() {
	if v.jwksCancel != nil {
		v.jwksCancel()
	}
}
