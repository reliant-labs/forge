package messaging

import "context"

// MessageStatus holds delivery status information for a tracked message.
type MessageStatus struct {
	MessageSID string
	Status     string // queued, sending, sent, delivered, undelivered, failed
	To         string
	From       string
	ErrorCode  string
	ErrorMsg   string
	Direction  string // outbound, inbound
}

// StatusCallback represents an incoming Twilio status webhook payload.
type StatusCallback struct {
	MessageSID    string
	MessageStatus string
	To            string
	From          string
	ErrorCode     string
	ErrorMessage  string
}

// Service defines the messaging contract for SMS and voice operations.
type Service interface {
	// SendSMS sends an SMS message and returns the Twilio message SID.
	SendSMS(ctx context.Context, to, body string) (string, error)

	// SendVoice initiates an outbound voice call with TwiML instructions
	// and returns the Twilio call SID.
	SendVoice(ctx context.Context, to, twiml string) (string, error)

	// GetMessageStatus returns the current delivery status of a message.
	GetMessageStatus(ctx context.Context, messageSID string) (*MessageStatus, error)

	// HandleStatusCallback processes an incoming Twilio status webhook.
	HandleStatusCallback(ctx context.Context, callback StatusCallback) error
}
