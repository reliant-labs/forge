package messaging

import (
	"context"
	"fmt"
	"log/slog"

	"{{ .ModulePath }}/pkg/twilio"
)

// TwilioService implements the Service interface using the Twilio client.
type TwilioService struct {
	client *twilio.Client
	logger *slog.Logger
}

// NewTwilioService creates a new messaging service backed by Twilio.
func NewTwilioService(client *twilio.Client, logger *slog.Logger) *TwilioService {
	return &TwilioService{
		client: client,
		logger: logger,
	}
}

// SendSMS sends an SMS message via Twilio.
func (s *TwilioService) SendSMS(ctx context.Context, to, body string) (string, error) {
	sid, err := s.client.SendSMS(to, body)
	if err != nil {
		return "", fmt.Errorf("messaging: send SMS: %w", err)
	}

	s.logger.InfoContext(ctx, "message sent", "to", to, "sid", sid, "direction", "outbound")
	return sid, nil
}

// SendVoice initiates a voice call via Twilio.
func (s *TwilioService) SendVoice(ctx context.Context, to, twiml string) (string, error) {
	sid, err := s.client.SendVoice(to, twiml)
	if err != nil {
		return "", fmt.Errorf("messaging: send voice: %w", err)
	}

	s.logger.InfoContext(ctx, "voice call initiated", "to", to, "sid", sid)
	return sid, nil
}

