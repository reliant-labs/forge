name: Build & Push Images

on:
  push:
    branches: [main]
  workflow_dispatch:
    inputs:
      image_tag:
        description: "Override image tag (default: sha-<short>)"
        required: false
        type: string

concurrency:
  group: build-images-${{"{{"}} github.ref {{"}}"}}
  cancel-in-progress: true

# Supply chain hardening (M-12):
#   * id-token is required for sigstore/cosign's OIDC keyless signing
#     (https://docs.sigstore.dev/cosign/signing/overview/#keyless-signing).
#   * attestations is required by actions/attest-build-provenance@v1 to
#     upload the SLSA provenance statement.
# `contents: read` and `packages: write` are kept minimal so a malicious
# push can't escalate.
permissions:
  contents: read
  packages: write
  id-token: write
  attestations: write

env:
  {{- if eq .Registry "ghcr"}}
  REGISTRY: "ghcr.io/${{"{{"}} github.repository_owner {{"}}"}}"
  {{- else if eq .Registry "gar"}}
  REGISTRY: "${{"{{"}} vars.GAR_REGISTRY {{"}}"}}"
  {{- else if eq .Registry "ecr"}}
  REGISTRY: "${{"{{"}} vars.ECR_REGISTRY {{"}}"}}"
  {{- else}}
  REGISTRY: "ghcr.io/${{"{{"}} github.repository_owner {{"}}"}}"
  {{- end}}

jobs:
  build-push:
    name: Build & Push
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          {{- if eq .Registry "ghcr"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- else if eq .Registry "gar"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: _json_key
          password: ${{"{{"}} secrets.GAR_JSON_KEY {{"}}"}}
          {{- else}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- end}}

      - name: Determine image tag
        id: tag
        run: |
          if [ -n "${{"{{"}} github.event.inputs.image_tag {{"}}"}}" ]; then
            echo "custom=true" >> "$GITHUB_OUTPUT"
            echo "tag=${{"{{"}} github.event.inputs.image_tag {{"}}"}}" >> "$GITHUB_OUTPUT"
          else
            echo "custom=false" >> "$GITHUB_OUTPUT"
            echo "tag=sha-$(echo ${{"{{"}} github.sha {{"}}"}} | cut -c1-7)" >> "$GITHUB_OUTPUT"
          fi

      - name: Docker meta
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}
          tags: |
            type=sha,prefix=sha-
            type=ref,event=branch
            type=raw,value=latest,enable=${{"{{"}} github.ref == format('refs/heads/{0}', 'main') {{"}}"}}
            type=semver,pattern={{"{{"}}version{{"}}"}}
            type=raw,value=${{"{{"}} steps.tag.outputs.tag {{"}}"}},enable=${{"{{"}} steps.tag.outputs.custom {{"}}"}}

      - name: Build and push
        id: build
        uses: docker/build-push-action@v6
        with:
          context: .
          file: Dockerfile
          push: true
          tags: ${{"{{"}} steps.meta.outputs.tags {{"}}"}}
          labels: ${{"{{"}} steps.meta.outputs.labels {{"}}"}}
          cache-from: type=gha,scope={{.ProjectName}}
          cache-to: type=gha,scope={{.ProjectName}},mode=max

      # ── Supply chain: SBOM + signing + provenance (M-12) ────────────
      # These steps run AFTER the image is pushed and use the immutable
      # digest reported by build-push-action. Using the digest (not a
      # mutable tag) ensures the SBOM/signature/attestation are bound to
      # the exact bytes we pushed.

      - name: Install cosign
        uses: sigstore/cosign-installer@v3

      - name: Sign image with cosign (keyless, OIDC)
        env:
          # `--yes` skips the interactive transparency-log confirmation;
          # required for non-interactive CI runs.
          COSIGN_EXPERIMENTAL: "1"
          DIGEST: ${{"{{"}} steps.build.outputs.digest {{"}}"}}
          IMAGE: ${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}
        run: cosign sign --yes "${IMAGE}@${DIGEST}"

      - name: Generate SBOM (SPDX JSON)
        uses: anchore/sbom-action@v0
        with:
          image: ${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}@${{"{{"}} steps.build.outputs.digest {{"}}"}}
          format: spdx-json
          artifact-name: sbom-{{.ProjectName}}.spdx.json
          output-file: sbom-{{.ProjectName}}.spdx.json

      - name: Upload SBOM artifact
        uses: actions/upload-artifact@v4
        with:
          name: sbom-{{.ProjectName}}
          path: sbom-{{.ProjectName}}.spdx.json
          if-no-files-found: error

      - name: Attest build provenance
        uses: actions/attest-build-provenance@v1
        with:
          subject-name: ${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}
          subject-digest: ${{"{{"}} steps.build.outputs.digest {{"}}"}}
          push-to-registry: true
{{- if .VulnDocker}}

  trivy-scan:
    name: Vulnerability Scan
    needs: build-push
    runs-on: ubuntu-latest
    steps:
      - name: Get short SHA
        id: sha
        run: echo "short=$(echo ${{"{{"}} github.sha {{"}}"}} | cut -c1-7)" >> "$GITHUB_OUTPUT"

      - name: Run Trivy vulnerability scanner
        uses: aquasecurity/trivy-action@v0.35.0
        with:
          image-ref: ${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}:sha-${{"{{"}} steps.sha.outputs.short {{"}}"}}
          format: table
          exit-code: "1"
          severity: CRITICAL,HIGH
{{- end}}
{{- if .HasFrontends}}

  build-push-frontends:
    name: Build & Push Frontends
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          {{- if eq .Registry "ghcr"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- else if eq .Registry "gar"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: _json_key
          password: ${{"{{"}} secrets.GAR_JSON_KEY {{"}}"}}
          {{- else}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- end}}

      - name: Build and push frontend images
        run: |
          SHORT_SHA=$(echo ${{"{{"}} github.sha {{"}}"}} | cut -c1-7)
          for dockerfile in frontends/*/Dockerfile; do
            if [ -f "$dockerfile" ]; then
              fe_dir=$(dirname "$dockerfile")
              fe_name=$(basename "$fe_dir")
              echo "Building $fe_name"
              docker buildx build \
                --push \
                -f "$dockerfile" \
                -t "${{"{{"}} env.REGISTRY {{"}}"}}/$fe_name:sha-$SHORT_SHA" \
                -t "${{"{{"}} env.REGISTRY {{"}}"}}/$fe_name:${{"{{"}} github.ref_name {{"}}"}}" \
                {{- /* Tag as latest only on main branch */}}
                $(if [ "${{"{{"}} github.ref {{"}}"}}" = "refs/heads/main" ]; then echo "-t ${{"{{"}} env.REGISTRY {{"}}"}}/$fe_name:latest"; fi) \
                --cache-from type=gha,scope=$fe_name \
                --cache-to type=gha,mode=max,scope=$fe_name \
                "$fe_dir"
            fi
          done
{{- end}}

  summary:
    name: Build Summary
    needs:
      - build-push
      {{- if .VulnDocker}}
      - trivy-scan
      {{- end}}
      {{- if .HasFrontends}}
      - build-push-frontends
      {{- end}}
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Summary
        run: |
          echo "## Build Images Summary" >> "$GITHUB_STEP_SUMMARY"
          echo "" >> "$GITHUB_STEP_SUMMARY"
          echo "| Image | Status |" >> "$GITHUB_STEP_SUMMARY"
          echo "|-------|--------|" >> "$GITHUB_STEP_SUMMARY"
          echo "| {{.ProjectName}} | ${{"{{"}} needs.build-push.result {{"}}"}} |" >> "$GITHUB_STEP_SUMMARY"
          {{- if .VulnDocker}}
          echo "| trivy scan | ${{"{{"}} needs.trivy-scan.result {{"}}"}} |" >> "$GITHUB_STEP_SUMMARY"
          {{- end}}
          {{- if .HasFrontends}}
          echo "| frontends | ${{"{{"}} needs.build-push-frontends.result {{"}}"}} |" >> "$GITHUB_STEP_SUMMARY"
          {{- end}}
          echo "" >> "$GITHUB_STEP_SUMMARY"
          echo "**Commit:** \`${{"{{"}} github.sha {{"}}"}}\`" >> "$GITHUB_STEP_SUMMARY"
          echo "**Tag:** \`sha-$(echo ${{"{{"}} github.sha {{"}}"}} | cut -c1-7)\`" >> "$GITHUB_STEP_SUMMARY"