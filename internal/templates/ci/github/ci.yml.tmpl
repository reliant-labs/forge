# Code generated by forge. DO NOT EDIT.
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: {{.PermContents | default "read"}}

concurrency:
  group: ci-${{"{{"}} github.ref {{"}}"}}
  cancel-in-progress: true

# Go version is read from go.mod's `go` directive via setup-go's
# `go-version-file` input so CI stays in sync with the project's declared
# version without a duplicate env var that drifts.

jobs:
{{- if or .LintGolangci .LintBuf .LintFrontend}}
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
{{- if .LintGolangci}}
      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m
          only-new-issues: true
{{- end}}
{{- if and .LintBuf .HasServices}}
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
      - name: Buf lint
        run: buf lint
{{- end}}
{{- if and .LintFrontend .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: '{{(index .Frontends 0).Path}}/package.json'
          cache: 'npm'
          cache-dependency-path: |
{{- range .Frontends}}
            {{.Path}}/package-lock.json
{{- end}}
{{- range .Frontends}}
      - name: Lint {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && npm run lint
      - name: Typecheck {{.Name}}
        working-directory: {{.Path}}
        # tsc --noEmit is not covered by eslint; without a dedicated
        # step, type errors only surface at `next build` time in
        # production deploys. Keep this step right after lint so
        # authors see type failures on the same PR that introduced
        # them.
        run: npm run typecheck
{{- end}}
{{- end}}
{{- end}}

  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go tests
        run: go test {{if .TestRace}}-race {{end}}-count=1 ./...
{{- if .TestCoverage}}
      - name: Go test coverage
        run: go test -coverprofile=coverage.out -covermode=atomic ./...
      - name: Upload coverage
        uses: actions/upload-artifact@v4
        with:
          name: coverage
          path: coverage.out
{{- end}}
{{- if .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: '{{(index .Frontends 0).Path}}/package.json'
          cache: 'npm'
          cache-dependency-path: |
{{- range .Frontends}}
            {{.Path}}/package-lock.json
{{- end}}
{{- range .Frontends}}
      - name: Test {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && npx vitest run
{{- end}}
{{- end}}

  build:
    name: Build
{{- if or .LintGolangci .LintBuf .LintFrontend}}
    needs: [lint, test]
{{- else}}
    needs: [test]
{{- end}}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go build
        # -trimpath makes builds reproducible across runners;
        # -buildvcs=true stamps the commit/dirty flag into runtime
        # debug/buildinfo so deployed binaries can be correlated to a
        # source commit without a separate manifest. Both flags must
        # match the Dockerfile / Taskfile so CI, Docker, and local
        # binaries hash identically from the same source.
        run: go build -trimpath -buildvcs=true ./cmd/...
{{- if .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: '{{(index .Frontends 0).Path}}/package.json'
          cache: 'npm'
          cache-dependency-path: |
{{- range .Frontends}}
            {{.Path}}/package-lock.json
{{- end}}
{{- range .Frontends}}
      - name: Build {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && NODE_ENV=production npm run build
{{- end}}
{{- end}}

  verify-generated:
    name: Verify Generated Code
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
{{- if .HasServices}}
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
{{- end}}
      - name: Install forge
        # Version is stamped at scaffold time from the forge binary that
        # produced the project. CI installs that exact ref so this step is
        # reproducible:
        #   1. Tagged/pseudo-version build → pin by module version.
        #   2. Local `dev` build with a known git SHA → pin by SHA
        #      (`go install ...@<sha>` is a valid ref).
        #   3. Neither available → fall back to @main (regenerate from a
        #      tagged release to eliminate this branch).
{{- if and .ForgeVersion (ne .ForgeVersion "dev")}}
        run: go install github.com/reliant-labs/forge/cmd/forge@{{.ForgeVersion}}
{{- else if and .ForgeGitCommit (ne .ForgeGitCommit "unknown")}}
        run: go install github.com/reliant-labs/forge/cmd/forge@{{.ForgeGitCommit}}
{{- else}}
        # TODO: regenerate from a tagged forge release to pin this install.
        run: go install github.com/reliant-labs/forge/cmd/forge@main
{{- end}}
      - name: Verify generated code
        run: forge ci verify-generated
{{- if .HasKCL}}

  validate-kcl:
    name: Validate KCL
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Cache KCL CLI
        uses: actions/cache@v4
        id: kcl-cache
        with:
          path: ~/.kcl
          key: kcl-cli-${{"{{"}} runner.os {{"}}"}}

      - name: Install KCL
        if: steps.kcl-cache.outputs.cache-hit != 'true'
        run: curl -fsSL https://kcl-lang.io/script/install-cli.sh | bash

      - name: Add KCL to PATH
        run: echo "$HOME/.kcl/bin" >> $GITHUB_PATH
      - name: Validate KCL manifests
        run: forge ci validate-kcl
{{- end}}
{{- if or .VulnGo .VulnNPM}}

  vuln-scan:
    name: Vulnerability Scan
{{- if or .LintGolangci .LintBuf .LintFrontend}}
    needs: [lint, test]
{{- else}}
    needs: [test]
{{- end}}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if .VulnGo}}
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Install govulncheck
        # Pinned explicitly: @latest makes CI non-reproducible and lets a
        # compromised upstream release silently alter scan results. The
        # Dependabot config watches this file so bumps arrive as PRs.
        run: go install golang.org/x/vuln/cmd/govulncheck@v1.1.4
      - name: Go vulnerability check
        run: forge ci vuln-scan --go
{{- end}}
{{- if and .VulnNPM .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: '{{(index .Frontends 0).Path}}/package.json'
          cache: 'npm'
          cache-dependency-path: |
{{- range .Frontends}}
            {{.Path}}/package-lock.json
{{- end}}
      - name: NPM vulnerability check
        run: forge ci vuln-scan --npm
{{- end}}
{{- end}}
{{- if .LicenseCheck}}

  license-check:
    name: License Compliance
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Install go-licenses
        run: go install github.com/google/go-licenses@v1.6.0
      - name: Check licenses
        run: go-licenses check ./... --disallowed_types=forbidden,restricted
{{- end}}

  docker-build:
    name: Docker Build
    needs: [build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Build project image
        uses: docker/build-push-action@v6
        with:
          context: .
          file: Dockerfile
          load: true
          tags: {{.ProjectName}}:ci
          cache-from: type=gha,scope=ci-{{.ProjectName}}
          cache-to: type=gha,scope=ci-{{.ProjectName}},mode=max
{{- if .VulnDocker}}
      - name: Trivy scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: '{{.ProjectName}}:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL
{{- end}}
{{- if .HasFrontends}}
{{- range .Frontends}}
      - name: Build {{.Name}} image
        uses: docker/build-push-action@v6
        with:
          context: {{.Path}}
          file: {{.Path}}/Dockerfile
          load: true
          tags: {{$.ProjectName}}/{{.Name}}:ci
          cache-from: type=gha,scope=ci-{{.Name}}
          cache-to: type=gha,scope=ci-{{.Name}},mode=max
{{- if $.VulnDocker}}
      - name: Trivy scan {{.Name}}
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: '{{$.ProjectName}}/{{.Name}}:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL
{{- end}}
{{- end}}
{{- end}}
{{- if .E2EEnabled}}

  e2e:
    name: E2E Tests
    needs: [docker-build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if eq .E2ERuntime "docker-compose"}}
      - name: Run E2E tests
        run: docker compose -f docker-compose.e2e.yml up --abort-on-container-exit --exit-code-from e2e
      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-results
          path: test-results/
{{- else if eq .E2ERuntime "k3d"}}
      - name: Create k3d cluster
        uses: AbsaOSS/k3d-action@v2
        with:
          cluster-name: e2e
      - name: Build and load images
        run: |
          docker build -t {{.ProjectName}}:ci .
          k3d image import {{.ProjectName}}:ci -c e2e
{{- range .Frontends}}
          if [ -f "{{.Path}}/Dockerfile" ]; then
            docker build -t {{$.ProjectName}}/{{.Name}}:ci {{.Path}}
            k3d image import {{$.ProjectName}}/{{.Name}}:ci -c e2e
          fi
{{- end}}
      - name: Deploy and test
        run: |
          kubectl apply -f deploy/k8s/e2e/
          kubectl wait --for=condition=ready pod -l app={{.ProjectName}} --timeout=120s
          go test -tags=e2e ./test/e2e/...
      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-results
          path: test-results/
{{- end}}
{{- end}}
{{- range .ExtraJobs}}

  {{.Name}}:
    name: {{.Name}}
{{- if .Needs}}
    needs: [{{range $i, $n := .Needs}}{{if $i}}, {{end}}{{$n}}{{end}}]
{{- end}}
    runs-on: {{.RunsOn | default "ubuntu-latest"}}
    steps:
      - uses: actions/checkout@v4
{{- range .Steps}}
{{- if .Uses}}
      - name: {{.Name}}
        uses: {{.Uses}}
{{- if .With}}
        with:
{{- range $k, $v := .With}}
          {{$k}}: '{{$v}}'
{{- end}}
{{- end}}
{{- else}}
      - name: {{.Name}}
        run: {{.Run}}
{{- end}}
{{- end}}
{{- end}}