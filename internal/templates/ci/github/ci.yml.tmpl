# Code generated by forge. DO NOT EDIT.
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: {{.PermContents | default "read"}}

concurrency:
  group: ci-${{"{{"}} github.ref {{"}}"}}
  cancel-in-progress: true

env:
  GO_VERSION: '{{.GoVersion | default "1.25"}}'

jobs:
{{- if or .LintGolangci .LintBuf .LintFrontend}}
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{"{{"}} env.GO_VERSION {{"}}"}}
{{- if .LintGolangci}}
      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m
          only-new-issues: true
{{- end}}
{{- if and .LintBuf .HasServices}}
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
      - name: Buf lint
        run: buf lint
{{- end}}
{{- if and .LintFrontend .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
{{- range .Frontends}}
      - name: Lint {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && npm run lint
{{- end}}
{{- end}}
{{- end}}

  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{"{{"}} env.GO_VERSION {{"}}"}}
      - name: Go tests
        run: go test {{if .TestRace}}-race {{end}}-count=1 ./...
{{- if .TestCoverage}}
      - name: Go test coverage
        run: go test -coverprofile=coverage.out -covermode=atomic ./...
      - name: Upload coverage
        uses: actions/upload-artifact@v4
        with:
          name: coverage
          path: coverage.out
{{- end}}
{{- if .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
{{- range .Frontends}}
      - name: Test {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && npx vitest run
{{- end}}
{{- end}}

  build:
    name: Build
{{- if or .LintGolangci .LintBuf .LintFrontend}}
    needs: [lint, test]
{{- else}}
    needs: [test]
{{- end}}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{"{{"}} env.GO_VERSION {{"}}"}}
      - name: Go build
        run: go build ./cmd/...
{{- if .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
{{- range .Frontends}}
      - name: Build {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && NODE_ENV=production npm run build
{{- end}}
{{- end}}

  verify-generated:
    name: Verify Generated Code
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: ${{"{{"}} env.GO_VERSION {{"}}"}}
{{- if .HasServices}}
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
{{- end}}
      - name: Install forge
        run: go install github.com/reliant-labs/forge/cmd/forge@latest
      - name: Generate code
        run: forge generate
      - name: Check for uncommitted changes
        run: |
          if ! git diff --exit-code; then
            echo "::error::Generated code is out of date. Run 'forge generate' and commit the changes."
            exit 1
          fi
{{- if .HasKCL}}

  validate-kcl:
    name: Validate KCL
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install KCL
        run: |
          curl -fsSL https://kcl-lang.io/script/install-cli.sh | bash
          echo "$HOME/.kcl/bin" >> $GITHUB_PATH
{{- range .Environments}}
      - name: Validate {{.}} manifests
        run: kcl run deploy/kcl/{{.}}/main.k > /dev/null
{{- end}}
{{- end}}
{{- if or .VulnGo .VulnNPM}}

  vuln-scan:
    name: Vulnerability Scan
{{- if or .LintGolangci .LintBuf .LintFrontend}}
    needs: [lint, test]
{{- else}}
    needs: [test]
{{- end}}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if .VulnGo}}
      - uses: actions/setup-go@v5
        with:
          go-version: ${{"{{"}} env.GO_VERSION {{"}}"}}
      - name: Install govulncheck
        run: go install golang.org/x/vuln/cmd/govulncheck@latest
      - name: Go vulnerability check
        run: govulncheck ./...
{{- end}}
{{- if and .VulnNPM .HasFrontends}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
{{- range .Frontends}}
      - name: NPM audit {{.Name}}
        working-directory: {{.Path}}
        run: npm ci && npm audit --audit-level=high
{{- end}}
{{- end}}
{{- end}}

  docker-build:
    name: Docker Build
    needs: [build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Build project image
        run: |
          if [ -f "Dockerfile" ]; then
            echo "Building {{.ProjectName}}"
            docker buildx build --load -f Dockerfile -t "{{.ProjectName}}:ci" .
          fi
{{- if .VulnDocker}}
      - name: Trivy scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: '{{.ProjectName}}:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL
{{- end}}
{{- if .HasFrontends}}
{{- range .Frontends}}
      - name: Build {{.Name}} image
        run: |
          if [ -f "{{.Path}}/Dockerfile" ]; then
            docker buildx build --load -f "{{.Path}}/Dockerfile" -t "{{$.ProjectName}}/{{.Name}}:ci" "{{.Path}}"
          fi
{{- if $.VulnDocker}}
      - name: Trivy scan {{.Name}}
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: '{{$.ProjectName}}/{{.Name}}:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL
{{- end}}
{{- end}}
{{- end}}
{{- if .E2EEnabled}}

  e2e:
    name: E2E Tests
    needs: [docker-build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if eq .E2ERuntime "docker-compose"}}
      - name: Run E2E tests
        run: docker compose -f docker-compose.e2e.yml up --abort-on-container-exit --exit-code-from e2e
      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-results
          path: test-results/
{{- else if eq .E2ERuntime "k3d"}}
      - name: Create k3d cluster
        uses: AbsaOSS/k3d-action@v2
        with:
          cluster-name: e2e
      - name: Build and load images
        run: |
          docker build -t {{.ProjectName}}:ci .
          k3d image import {{.ProjectName}}:ci -c e2e
{{- range .Frontends}}
          if [ -f "{{.Path}}/Dockerfile" ]; then
            docker build -t {{$.ProjectName}}/{{.Name}}:ci {{.Path}}
            k3d image import {{$.ProjectName}}/{{.Name}}:ci -c e2e
          fi
{{- end}}
      - name: Deploy and test
        run: |
          kubectl apply -f deploy/k8s/e2e/
          kubectl wait --for=condition=ready pod -l app={{.ProjectName}} --timeout=120s
          go test -tags=e2e ./test/e2e/...
      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-results
          path: test-results/
{{- end}}
{{- end}}
{{- range .ExtraJobs}}

  {{.Name}}:
    name: {{.Name}}
{{- if .Needs}}
    needs: [{{range $i, $n := .Needs}}{{if $i}}, {{end}}{{$n}}{{end}}]
{{- end}}
    runs-on: {{.RunsOn | default "ubuntu-latest"}}
    steps:
      - uses: actions/checkout@v4
{{- range .Steps}}
{{- if .Uses}}
      - name: {{.Name}}
        uses: {{.Uses}}
{{- if .With}}
        with:
{{- range $k, $v := .With}}
          {{$k}}: '{{$v}}'
{{- end}}
{{- end}}
{{- else}}
      - name: {{.Name}}
        run: {{.Run}}
{{- end}}
{{- end}}
{{- end}}
