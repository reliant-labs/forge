# yours: scaffolded once, never touched again — forge will not overwrite this file.
# This CI workflow is a starting point you own — add jobs, secrets, and steps freely.
# `forge generate` re-creates it only if you delete it first.
# Source: internal/templates/ci/github/dependabot.yml.tmpl.
version: 2
updates:
  - package-ecosystem: gomod
    directory: /
    schedule:
      interval: weekly
    open-pull-requests-limit: 10

  # The generated protobuf module lives under /gen with its own go.mod.
  - package-ecosystem: gomod
    directory: /gen
    schedule:
      interval: weekly
    open-pull-requests-limit: 10
{{- if .FrontendName}}

  # Frontend workspace may vendor Go tooling in the future (dev-only).
  - package-ecosystem: gomod
    directory: /frontends/{{.FrontendName}}
    schedule:
      interval: weekly
    open-pull-requests-limit: 10

  - package-ecosystem: npm
    directory: /frontends/{{.FrontendName}}
    schedule:
      interval: weekly
    open-pull-requests-limit: 10
{{- end}}

  - package-ecosystem: docker
    directory: /
    schedule:
      interval: weekly
    open-pull-requests-limit: 5

  - package-ecosystem: github-actions
    directory: /
    schedule:
      interval: weekly
    open-pull-requests-limit: 5