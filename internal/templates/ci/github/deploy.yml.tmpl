# Code generated by forge. DO NOT EDIT.
# Triggers:
#   * workflow_run (after "Build & Push Images" on main)
#     → automatically promotes to the first env with `auto: true` (typically
#       "staging"). Other envs ignore this trigger.
#   * push tag v*
#     → runs the retag-release + deploy-release jobs, promoting the image
#       to the last env (typically "prod").
#   * workflow_dispatch
#     → lets a human promote any env on demand.
name: Deploy
{{- if .Environments}}

on:
  workflow_run:
    workflows: ["Build & Push Images"]
    types: [completed]
    branches: [main]
  push:
    tags: ["v*"]
  workflow_dispatch:
    inputs:
      environment:
        description: "Target environment"
        required: true
        type: choice
        options:
          {{- range .Environments}}
          - {{.Name}}
          {{- end}}
      image_tag:
        description: "Image tag to deploy (e.g. sha-abc1234 or v1.0.0)"
        required: true
        type: string

permissions:
  contents: read
  packages: write

env:
  {{- if eq .Registry "ghcr"}}
  REGISTRY: "ghcr.io/${{"{{"}} github.repository_owner {{"}}"}}"
  {{- else if eq .Registry "gar"}}
  REGISTRY: "${{"{{"}} vars.GAR_REGISTRY {{"}}"}}"
  {{- else if eq .Registry "ecr"}}
  REGISTRY: "${{"{{"}} vars.ECR_REGISTRY {{"}}"}}"
  {{- else}}
  REGISTRY: "ghcr.io/${{"{{"}} github.repository_owner {{"}}"}}"
  {{- end}}
  PROJECT: "{{.ProjectName}}"

jobs:
  {{- $data := .}}
  {{- $prevJob := ""}}
  {{- range $i, $env := .Environments}}

  deploy-{{$env.Name}}:
    name: Deploy to {{$env.Name | title}}
    runs-on: ubuntu-latest
    {{- if and $data.Concurrency true}}
    concurrency:
      group: deploy-{{$env.Name}}
      cancel-in-progress: {{$data.CancelInProgress}}
    {{- end}}
    {{- if and (gt $i 0) (not $env.Auto)}}
    needs: [deploy-{{(index $data.Environments (add $i -1)).Name}}]
    {{- end}}
    # Auto-deploy envs (e.g. staging) fire on workflow_run success after
    # "Build & Push Images" completes on main. Every env also accepts an
    # explicit workflow_dispatch targeted at it. Prod-style envs without
    # `auto: true` must be dispatched manually or reached via a v* tag
    # (handled by the deploy-release job below).
    if: >-
      {{- if $env.Auto}}
      (github.event_name == 'workflow_run' && github.event.workflow_run.conclusion == 'success') ||
      {{- end}}
      (github.event_name == 'workflow_dispatch' && github.event.inputs.environment == '{{$env.Name}}')
    {{- if $env.Protection}}
    environment:
      name: {{$env.Name}}
      {{- if $env.URL}}
      url: {{$env.URL}}
      {{- end}}
    {{- end}}
    steps:
      - uses: actions/checkout@v4

      - name: Configure kubectl
        uses: azure/setup-kubectl@v4

      - name: Set kubeconfig
        env:
          KUBECONFIG_CONTENTS: ${{"{{"}} secrets.KUBECONFIG {{"}}"}}
        run: |
          mkdir -p $HOME/.kube
          printf '%s' "$KUBECONFIG_CONTENTS" > $HOME/.kube/config
          chmod 600 $HOME/.kube/config

      - name: Determine image tag
        id: tag
        run: |
          if [ "${{"{{"}} github.event_name {{"}}"}}" = "workflow_dispatch" ]; then
            echo "tag=${{"{{"}} github.event.inputs.image_tag {{"}}"}}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=sha-$(echo ${{"{{"}} github.event.workflow_run.head_sha {{"}}"}} | cut -c1-7)" >> "$GITHUB_OUTPUT"
          fi

      - name: Cache KCL CLI
        uses: actions/cache@v4
        id: kcl-cache
        with:
          path: ~/.kcl
          key: kcl-cli-${{"{{"}} runner.os {{"}}"}}

      - name: Install KCL
        if: steps.kcl-cache.outputs.cache-hit != 'true'
        run: curl -fsSL https://kcl-lang.io/script/install-cli.sh | bash

      - name: Add KCL to PATH
        run: echo "$HOME/.kcl/bin" >> "$GITHUB_PATH"
      {{- if and $data.MigrationTest (ne $env.Name "staging")}}

      - name: Test migrations
        run: |
          echo "Running migration dry-run for {{$env.Name}}..."
          kcl run deploy/kcl/{{$env.Name}}/main.k \
            -D image_tag=${{"{{"}} steps.tag.outputs.tag {{"}}"}} \
            -D registry=${{"{{"}} env.REGISTRY {{"}}"}} \
            -D migration_dry_run=true | \
            kubectl apply --dry-run=server -f -
      {{- end}}

      - name: Deploy to {{$env.Name}}
        run: |
          kcl run deploy/kcl/{{$env.Name}}/main.k \
            -D image_tag=${{"{{"}} steps.tag.outputs.tag {{"}}"}} \
            -D registry=${{"{{"}} env.REGISTRY {{"}}"}} | \
            kubectl apply --server-side -f -

      - name: Wait for rollouts
        run: |
          for deploy in $(kubectl get deployments -l app.kubernetes.io/part-of=${{"{{"}} env.PROJECT {{"}}"}} -o name); do
            kubectl rollout status "$deploy" --timeout=300s
          done

      - name: Verify health endpoints
        # M-13: previously this step used `curl … || echo Warning` which
        # always exited 0, silently masking a bad deploy. Now each service
        # is probed up to 12 times (2 minutes total) and the step exits
        # non-zero on final failure, failing the workflow as it should.
        run: |
          set -euo pipefail
          failed=0
          for svc in $(kubectl get svc -l app.kubernetes.io/part-of=${{"{{"}} env.PROJECT {{"}}"}} -o name); do
            svc_name=$(echo "$svc" | sed 's|service/||')
            echo "Probing http://$svc_name/healthz ..."
            attempt_ok=0
            for i in $(seq 1 12); do
              if kubectl run health-check-"$svc_name"-"$i" --rm -i --restart=Never \
                   --image=curlimages/curl:latest -- \
                   curl -sf "http://$svc_name/healthz"; then
                echo "  ✓ $svc_name healthy (attempt $i)"
                attempt_ok=1
                break
              fi
              echo "  attempt $i failed, retrying in 10s..."
              sleep 10
            done
            if [ "$attempt_ok" -ne 1 ]; then
              echo "  ✗ $svc_name health check failed after 12 attempts" >&2
              failed=1
            fi
          done
          if [ "$failed" -ne 0 ]; then
            exit 1
          fi
  {{- end}}

  retag-release:
    name: Retag for Release
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')
    outputs:
      version: ${{"{{"}} steps.version.outputs.tag {{"}}"}}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Get version tag
        id: version
        run: echo "tag=${GITHUB_REF#refs/tags/}" >> "$GITHUB_OUTPUT"

      - name: Install crane
        uses: imjasonh/setup-crane@v0.4

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          {{- if eq .Registry "ghcr"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- else if eq .Registry "gar"}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: _json_key
          password: ${{"{{"}} secrets.GAR_JSON_KEY {{"}}"}}
          {{- else}}
          registry: ${{"{{"}} env.REGISTRY {{"}}"}}
          username: ${{"{{"}} github.actor {{"}}"}}
          password: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}
          {{- end}}

      - name: Retag images
        run: |
          SHA_TAG="sha-$(git rev-parse --short HEAD)"
          VERSION="${{"{{"}} steps.version.outputs.tag {{"}}"}}"
          echo "Retagging {{.ProjectName}}: $SHA_TAG -> $VERSION, latest"
          crane tag "${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}:$SHA_TAG" "$VERSION"
          crane tag "${{"{{"}} env.REGISTRY {{"}}"}}/{{.ProjectName}}:$SHA_TAG" "latest"
          {{- if .HasFrontends}}
          for fe_dir in frontends/*/; do
            fe_name=$(basename "$fe_dir")
            echo "Retagging $fe_name: $SHA_TAG -> $VERSION, latest"
            crane tag "${{"{{"}} env.REGISTRY {{"}}"}}/$fe_name:$SHA_TAG" "$VERSION"
            crane tag "${{"{{"}} env.REGISTRY {{"}}"}}/$fe_name:$SHA_TAG" "latest"
          done
          {{- end}}

  deploy-release:
    name: Deploy Release
    needs: retag-release
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')
    {{- $lastEnv := index .Environments (add (len .Environments) -1)}}
    {{- if $lastEnv.Protection}}
    environment:
      name: {{$lastEnv.Name}}
      {{- if $lastEnv.URL}}
      url: {{$lastEnv.URL}}
      {{- end}}
    {{- end}}
    {{- if .Concurrency}}
    concurrency:
      group: deploy-{{$lastEnv.Name}}
      cancel-in-progress: false
    {{- end}}
    steps:
      - uses: actions/checkout@v4

      - name: Configure kubectl
        uses: azure/setup-kubectl@v4

      - name: Set kubeconfig
        env:
          KUBECONFIG_CONTENTS: ${{"{{"}} secrets.KUBECONFIG {{"}}"}}
        run: |
          mkdir -p $HOME/.kube
          printf '%s' "$KUBECONFIG_CONTENTS" > $HOME/.kube/config
          chmod 600 $HOME/.kube/config

      - name: Cache KCL CLI
        uses: actions/cache@v4
        id: kcl-cache
        with:
          path: ~/.kcl
          key: kcl-cli-${{"{{"}} runner.os {{"}}"}}

      - name: Install KCL
        if: steps.kcl-cache.outputs.cache-hit != 'true'
        run: curl -fsSL https://kcl-lang.io/script/install-cli.sh | bash

      - name: Add KCL to PATH
        run: echo "$HOME/.kcl/bin" >> "$GITHUB_PATH"
      {{- if .MigrationTest}}

      - name: Test migrations
        run: |
          echo "Running migration dry-run for {{$lastEnv.Name}}..."
          kcl run deploy/kcl/{{$lastEnv.Name}}/main.k \
            -D image_tag=${{"{{"}} needs.retag-release.outputs.version {{"}}"}} \
            -D registry=${{"{{"}} env.REGISTRY {{"}}"}} \
            -D migration_dry_run=true | \
            kubectl apply --dry-run=server -f -
      {{- end}}

      - name: Deploy to {{$lastEnv.Name}}
        run: |
          kcl run deploy/kcl/{{$lastEnv.Name}}/main.k \
            -D image_tag=${{"{{"}} needs.retag-release.outputs.version {{"}}"}} \
            -D registry=${{"{{"}} env.REGISTRY {{"}}"}} | \
            kubectl apply --server-side -f -

      - name: Wait for rollouts
        run: |
          for deploy in $(kubectl get deployments -l app.kubernetes.io/part-of=${{"{{"}} env.PROJECT {{"}}"}} -o name); do
            kubectl rollout status "$deploy" --timeout=300s
          done

      - name: Verify health endpoints
        # M-13: mirror the retry loop used by the per-env deploy job above.
        # Release deploys must also fail the workflow on a bad rollout —
        # the previous `|| echo Warning` always exited 0 and let broken
        # production pushes succeed silently.
        run: |
          set -euo pipefail
          failed=0
          for svc in $(kubectl get svc -l app.kubernetes.io/part-of=${{"{{"}} env.PROJECT {{"}}"}} -o name); do
            svc_name=$(echo "$svc" | sed 's|service/||')
            echo "Probing http://$svc_name/healthz ..."
            attempt_ok=0
            for i in $(seq 1 12); do
              if kubectl run health-check-"$svc_name"-"$i" --rm -i --restart=Never \
                   --image=curlimages/curl:latest -- \
                   curl -sf "http://$svc_name/healthz"; then
                echo "  ✓ $svc_name healthy (attempt $i)"
                attempt_ok=1
                break
              fi
              echo "  attempt $i failed, retrying in 10s..."
              sleep 10
            done
            if [ "$attempt_ok" -ne 1 ]; then
              echo "  ✗ $svc_name health check failed after 12 attempts" >&2
              failed=1
            fi
          done
          if [ "$failed" -ne 0 ]; then
            exit 1
          fi
{{- end}}