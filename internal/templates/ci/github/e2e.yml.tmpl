{{- else if eq .Runtime "k3d"}}

      - name: Create k3d cluster
        uses: AbsaOSS/k3d-action@v2
        with:
          cluster-name: e2e
          args: --no-lb

      - name: Build images
        run: |
          docker build -t {{.ProjectName}}:e2e .
{{- if .HasFrontends}}
          for dockerfile in frontends/*/Dockerfile; do
