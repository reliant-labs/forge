name: E2E Tests

# E2E is expensive (environment stand-up) so it is opt-in on PRs:
# - Push to main: always run
# - Pull request: only when labeled `run-e2e`
# - Manual: always available via workflow_dispatch
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
    types: [opened, synchronize, reopened, labeled]
  workflow_dispatch:

concurrency:
  group: e2e-${{"{{"}} github.ref {{"}}"}}
  cancel-in-progress: true

# Go version is read from go.mod via setup-go's `go-version-file` input
# so CI and the project stay in sync without a separate env var that drifts.

jobs:
  e2e:
    # Label-gate PRs so routine PRs don't pay the e2e cost. Non-PR events
    # (push to main, workflow_dispatch) always run.
    if: ${{"{{"}} github.event_name != 'pull_request' || contains(github.event.pull_request.labels.*.name, 'run-e2e') {{"}}"}}
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
{{- if .HasFrontends}}

      - uses: actions/setup-node@v4
        with:
{{- if .FrontendPath}}
          node-version-file: '{{.FrontendPath}}/package.json'
{{- else}}
          node-version: '20'
{{- end}}
{{- end}}

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Install Task
        uses: arduino/setup-task@v2
        with:
          version: 3.x
          repo-token: ${{"{{"}} secrets.GITHUB_TOKEN {{"}}"}}

      - name: Install dependencies
        run: task deps
{{- if eq .Runtime "docker-compose"}}

      - name: Build binary
        run: task build

      - name: Start infrastructure
        run: docker compose -f docker-compose.yml up -d --wait
        timeout-minutes: 5

      - name: Run E2E tests
        run: task test:e2e
        env:
          E2E: "true"

      - name: Dump logs on failure
        if: failure()
        run: docker compose -f docker-compose.yml logs --tail=200

      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-logs
          path: |
