{{- if .HasFrontends}}
          for dockerfile in frontends/*/Dockerfile; do
            if [ -f "$dockerfile" ]; then
              fe_name=$(basename "$(dirname "$dockerfile")")
              k3d image import "{{.ProjectName}}/$fe_name:e2e" -c e2e
            fi
          done
{{- end}}

      - name: Install KCL
