//go:build ignore

package {{.OperatorPackage}}

import (
	"context"
	"testing"

	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
	"k8s.io/apimachinery/pkg/runtime"
	"k8s.io/apimachinery/pkg/types"
	ctrl "sigs.k8s.io/controller-runtime"
	"sigs.k8s.io/controller-runtime/pkg/client"
	"sigs.k8s.io/controller-runtime/pkg/client/fake"

	{{.APIPackage}} "{{.Module}}/api/{{.Version}}"
)

// new{{.TypeName}}TestController constructs a controller wired to a
// fake client seeded with the supplied objects. The fake client is
// fast and hermetic and is the recommended unit-test path; for
// integration coverage that needs a real API server, layer on
// controllertest.New from forge/pkg/controller/controllertest.
func new{{.TypeName}}TestController(t *testing.T, seed ...{{.APIPackage}}.{{.TypeName}}) *{{.ControllerType}} {
	t.Helper()
	s := runtime.NewScheme()
	if err := {{.APIPackage}}.AddToScheme(s); err != nil {
		t.Fatalf("add scheme: %v", err)
	}
	objs := make([]client.Object, 0, len(seed))
	for i := range seed {
		objs = append(objs, &seed[i])
	}
	c := fake.NewClientBuilder().
		WithScheme(s).
		WithObjects(objs...).
		WithStatusSubresource(&{{.APIPackage}}.{{.TypeName}}{}).
		Build()
	r := New{{.ControllerType}}()
	r.Client = c
	r.Scheme = s
	return r
}

func Test{{.TypeName}}Reconcile_NotFound(t *testing.T) {
	r := new{{.TypeName}}TestController(t)
	res, err := r.Reconcile(context.Background(), ctrl.Request{
		NamespacedName: types.NamespacedName{Name: "nonexistent", Namespace: "default"},
	})
	if err != nil {
		t.Errorf("NotFound should not error: %v", err)
	}
	if res.Requeue {
		t.Error("NotFound should not requeue")
	}
}

func Test{{.TypeName}}Reconcile_HappyPath(t *testing.T) {
	obj := {{.APIPackage}}.{{.TypeName}}{
		ObjectMeta: metav1.ObjectMeta{Name: "test", Namespace: "default"},
	}
	r := new{{.TypeName}}TestController(t, obj)
	_, err := r.Reconcile(context.Background(), ctrl.Request{
		NamespacedName: types.NamespacedName{Name: "test", Namespace: "default"},
	})
	if err != nil {
		t.Errorf("happy-path reconcile should not error: %v", err)
	}
}
