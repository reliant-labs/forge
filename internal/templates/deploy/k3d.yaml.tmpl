apiVersion: k3d.io/v1alpha5
kind: Simple
metadata:
  name: {{.ProjectName}}
servers: 1
agents: 0
registries:
  create:
    name: {{.ProjectName}}-registry
    host: "0.0.0.0"
    hostPort: "5050"
  # Inline containerd registries.yaml. Maps the host-side push name
  # (`localhost:5050`) AND the canonical k3d-internal name
  # (`registry.localhost:5000`) to the cluster-local registry endpoint
  # so in-cluster `kubectl pull` succeeds for images pushed via
  # `docker push localhost:5050/<image>`. Without this, host pushes
  # work but pods ImagePullBackOff because `localhost:5050` resolves
  # to nothing inside the node container.
  config: |
    mirrors:
      "registry.localhost:5000":
        endpoint:
          - http://registry.localhost:5000
      "registry.localhost:5050":
        endpoint:
          - http://registry.localhost:5000
      "localhost:5050":
        endpoint:
          - http://registry.localhost:5000
# Host port -> loadbalancer mappings are auto-generated from your
# project's Gateway listeners (see deploy/kcl/ingress.k) and merged
# in at `forge dev cluster up` time from deploy/k3d-ports.yaml. Don't
# hand-declare a `ports:` block here unless you need a mapping the
# Gateway listeners don't cover — on host-port collisions, the
# generated fragment wins.
options:
  k3d:
    wait: true
    timeout: "60s"
  k3s:
    extraArgs:
      - arg: --disable=traefik,metrics-server
        nodeFilters:
          - server:*
  kubeconfig:
    updateDefaultKubeconfig: true
    switchCurrentContext: true