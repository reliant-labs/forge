"""
Development environment configuration for {{.ProjectName}} (binary=shared).

This project ships ONE Docker image; each typed Service is a separate
Deployment that runs the same binary with a different cobra
subcommand. The shared image lives at `/app/{{.ProjectName}}` and
each Service's `command` selects its subcommand.

See `deploy/kcl/dev/main.k` (binary=per-service shape) for the
two-output `output` / `manifests` contract documentation.
"""

import forge

import deploy.kcl.dev.config_gen as cfg
{{- if .IngressEnabled}}
import deploy.kcl.dev.ingress as ing
{{- end}}

# Shared env vars layered into every service.
_shared_env = forge.COMMON_ENV + cfg.APP_ENV + [
    forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
]

_dev_k8s = forge.K8sCluster {
    cluster = "k3d-{{.ProjectName}}"
    namespace = "{{.ProjectName}}-dev"
    # Overridable via `kcl run -D registry=...`.
    registry = option("registry") or "localhost:5050"
    replicas = 1
    ports = [8080]
}

_bundle = forge.Bundle {
    services = [
{{- range .Services}}
        forge.Service {
            name = "{{$.ProjectName}}-{{.Name}}"
            image = "{{$.ProjectName}}"
            command = ["/app/{{$.ProjectName}}", "{{.Name}}"]
            env_vars = _shared_env + [
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{$.ProjectName}}-{{.Name}}"}
            ]
            deploy = _dev_k8s
        }
{{- end}}
    ]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

output = forge.render(_bundle)

_env = forge.RenderEnv {
    cluster = _dev_k8s
    image_tag = forge.image_tag("dev")
    network_policies = False
}
manifests = forge.render_manifests(_bundle, _env)
