"""
Development environment configuration for {{.ProjectName}} (binary=shared).

This project ships ONE Docker image; each component is a separate
Deployment that runs the same binary with a different cobra subcommand
(`/app/{{.ProjectName}} <name>`). Workloads are expanded from
`deploy/kcl/components_gen.json` by the forge.components KCL schema
hierarchy — the only difference from the per-service shape is that
servers/workers here run their cobra subcommand. See `dev/main.k` for
the `manifests` / `output` two-output contract.
"""

import forge
import forge.components as fc

import deploy.kcl.dev.config_gen as cfg
{{- if .IngressEnabled}}
import deploy.kcl.dev.ingress as ing
{{- end}}

_registry = forge.registry("localhost:5050")
_namespace = "{{.ProjectName}}-dev"
_cluster = forge.ClusterTarget {
    cluster = "k3d-{{.ProjectName}}"
    namespace = _namespace
    registry = _registry
}

# Base env every component sees, assembled with forge.env_merge (name-keyed,
# LAST-wins) so a later layer overrides an earlier one by name instead of the
# `+`-concat footgun (which emits duplicate keys kubectl rejects).
_base_env = forge.env_merge(forge.env_merge(forge.COMMON_ENV, cfg.APP_ENV), [
    forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
])

# binary=shared: EVERY component runs the shared image with its cobra
# subcommand. Binaries already carry that command from forge; for
# server/worker/cron components we overlay it here so one image serves
# all of them.
_components = [c | {
    image = "{{.ProjectName}}"
    registry = _registry
    namespace = _namespace
    replicas = 1
    command = c.command if c.command else ["/app/{{.ProjectName}}", c.name]
    env_vars = forge.env_merge(_base_env, [forge.EnvVar {name = "OTEL_SERVICE_NAME", value = c.name}])
} for c in fc.load_components(fc.COMPONENTS_GEN)]

_component_env = fc.ComponentEnv {
    namespace = _namespace
    registry = _registry
    image_tag = forge.image_tag("dev")
    network_policies = False
}

_support = forge.Bundle {
    cluster_target = _cluster
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

manifests = fc.render_components(_components, _component_env) \
    + forge.render_support(_support)

_svc_components = [c for c in _components if c.kind in ["server", "worker"]]
_bin_components = [c for c in _components if c.kind == "binary"]
_cron_components = [c for c in _components if c.kind == "cron"]
_op_components = [c for c in _components if c.kind == "operator"]

_bundle = forge.Bundle {
    cluster_target = _cluster
    services = [forge.RenderedWorkload {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = _cluster.deploy | {ports = [p.port for p in c.ports]}
    } for c in _svc_components] + [forge.RenderedWorkload {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = forge.BuildOnly {}
    } for c in _bin_components]
    cronjobs = [forge.CronJob {
        name = c.name
        image = "{{.ProjectName}}"
        schedule = c.schedule
        command = c.command
        env_vars = c.env_vars
    } for c in _cron_components]
    operators = [forge.Operator {
        name = c.name
        image = "{{.ProjectName}}"
        crds = c.crds
        env_vars = c.env_vars
    } for c in _op_components]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

output = forge.render(_bundle)
