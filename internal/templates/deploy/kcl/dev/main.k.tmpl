"""
Development environment configuration for {{.ProjectName}}.

DEPLOY-AS-DATA: forge no longer hand-writes a `forge.Service` per
component here. It serializes the denormalized component base shape to
`deploy/kcl/components_gen.json`, and the forge.components KCL schema
hierarchy (Server / Worker / Cron / Operator / Binary) owns ALL
normalization into k8s resources. This file LOADS that data, overlays
the per-env knobs (replicas, registry, resources, secrets), and renders.

Two outputs:

  * `manifests` — Kubernetes manifest list rendered for the env from
    components_gen.json + the forge.components schemas. Pipe to
    `kubectl apply -f -` or `forge deploy dev`. Select with
    `kcl run deploy/kcl/dev -S manifests --format yaml`.

  * `output` — JSON contract the forge CLI consumes (`forge build`,
    `forge up`, `forge deploy`) for host-vs-cluster dispatch + builds.
    Bridged from the same component data. Select with
    `kcl run deploy/kcl/dev -S output --format json`.

Per-env tag/registry overrides are consumed by `forge.image_tag(env)`
(reads `option("image_tag")`) and the `registry` field. The forge CLI
passes `-D image_tag=` on every build/deploy.

Path note: `forge.components.load_components` reads
components_gen.json relative to the project root — the directory forge
runs `kcl run deploy/kcl/<env>` from, and where the documented manual
command `kcl run deploy/kcl/dev` is run from.
"""

import forge
import forge.components as fc

# Per-environment config (generated from forge.yaml + proto annotations).
# Run `forge generate` to refresh after editing forge.yaml or the config
# proto. Hand-editing this file is not recommended.
import deploy.kcl.dev.config_gen as cfg
{{- if .IngressEnabled}}

# Gateway API ingress topology — user-owned. Base lives in
# `deploy/kcl/ingress.k`; this env may override hosts, ports, or TLS.
import deploy.kcl.dev.ingress as ing
{{- end}}

# Env-wide deploy target. Overridable via `kcl run -D registry=...`.
# Local dev defaults to the k3d registry created by `deploy/k3d.yaml`.
_registry = option("registry") or "localhost:5050"
_namespace = "{{.ProjectName}}-dev"
_cluster = forge.ClusterTarget {
    cluster = "k3d-{{.ProjectName}}"
    namespace = _namespace
    registry = _registry
}

# Base env every component sees (COMMON_ENV + per-env config_gen).
_base_env = forge.COMMON_ENV + cfg.APP_ENV + [
    forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
]

# Load the denormalized components forge emitted and overlay the dev
# knobs. The `|` merge layers per-env config onto each loaded component;
# all components run the project image (one image, cobra subcommands per
# binary).
_components = [c | {
    image = "{{.ProjectName}}"
    registry = _registry
    namespace = _namespace
    replicas = 1
    env_vars = _base_env + [forge.EnvVar {name = "OTEL_SERVICE_NAME", value = c.name}]
} for c in fc.load_components(fc.COMPONENTS_GEN)]

_component_env = fc.ComponentEnv {
    namespace = _namespace
    registry = _registry
    image_tag = forge.image_tag("dev")
    network_policies = False
}

# Support resources (ConfigMaps + ingress) come from a Bundle the forge
# render layer projects; the workloads come from the component
# expansion. render_support omits namespace/netpol (render_components
# owns those).
_support = forge.Bundle {
    cluster_target = _cluster
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

# k8s manifests for `kubectl apply -f -`.
manifests = fc.render_components(_components, _component_env) \
    + forge.render_support(_support)

# JSON contract consumed by forge build/run/deploy. Bridges the loaded
# components into forge.Service / CronJob / Operator entities so the
# build + host/cluster dispatch contract is unchanged. Binaries deploy
# build-only (forge orchestrates them via the CLI); servers/workers run
# in-cluster.
_svc_components = [c for c in _components if c.kind in ["server", "worker"]]
_bin_components = [c for c in _components if c.kind == "binary"]
_cron_components = [c for c in _components if c.kind == "cron"]
_op_components = [c for c in _components if c.kind == "operator"]

_bundle = forge.Bundle {
    cluster_target = _cluster
    services = [forge.Service {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = _cluster.deploy | {ports = [p.port for p in c.ports]}
        if c.build:
            build = forge.build_of(c.build)
    } for c in _svc_components] + [forge.Service {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = forge.BuildOnly {}
        if c.build:
            build = forge.build_of(c.build)
    } for c in _bin_components]
    cronjobs = [forge.CronJob {
        name = c.name
        image = "{{.ProjectName}}"
        schedule = c.schedule
        command = c.command
        env_vars = c.env_vars
    } for c in _cron_components]
    operators = [forge.Operator {
        name = c.name
        image = "{{.ProjectName}}"
        crds = c.crds
        env_vars = c.env_vars
    } for c in _op_components]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

output = forge.render(_bundle)
