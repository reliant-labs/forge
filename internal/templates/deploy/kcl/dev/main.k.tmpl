"""
Development environment configuration for {{.ProjectName}}.

This file declares typed forge entities (Service / Operator / Frontend
/ CronJob). The schemas live in the upstream `forge` KCL module pinned
in `deploy/kcl/kcl.mod`. Run `forge upgrade` to bump the module
version.

Two outputs:

  * `output` — JSON contract that the forge CLI consumes
    (`forge build`, `forge run`, `forge deploy`).
    Select with `kcl run dev -S output --format json`.

  * `manifests` — Kubernetes manifest list rendered for the env.
    Pipe to `kubectl apply -f -` or `forge deploy dev`.

Top-level identifiers `image_tag` and `registry` are overridable via
`kcl run -D image_tag=<tag> -D registry=<registry> ...` because KCL's -D
flag only binds top-level names, not nested struct fields.
"""

import forge

# Per-environment config (generated from forge.yaml + proto annotations).
# Run `forge generate` to refresh after editing forge.yaml or the config
# proto. Hand-editing this file is not recommended.
import deploy.kcl.dev.config_gen as cfg
{{- if .IngressEnabled}}

# Gateway API ingress topology — user-owned. Base lives in
# `deploy/kcl/ingress.k`; this env may override hosts, ports, or TLS.
import deploy.kcl.dev.ingress as ing
{{- end}}

# Overridable via `kcl run -D image_tag=...`
_image_tag = option("image_tag") or "latest"

# Overridable via `kcl run -D registry=...`. Local dev defaults to the k3d
# registry created by `deploy/k3d.yaml`.
_registry = option("registry") or "localhost:5050"

_dev_k8s = forge.K8sCluster {
    cluster = "k3d-{{.ProjectName}}"
    namespace = "{{.ProjectName}}-dev"
    registry = _registry
    replicas = 1
    ports = [8080]
}

_bundle = forge.Bundle {
    services = [
        forge.Service {
            name = "{{.ProjectName}}"
            image = "{{.ProjectName}}"
            env_vars = forge.COMMON_ENV + cfg.APP_ENV + [
                forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{.ProjectName}}"}
            ]
            deploy = _dev_k8s
        }
        # Binaries declared via `forge add binary <name>`. Each runs the
        # same image with a different cobra subcommand. They project as
        # BuildOnly services because forge handles their orchestration
        # via the CLI, not k8s manifests.
{{- range .Binaries}}
        forge.Service {
            name = "{{$.ProjectName}}-{{.Name}}"
            image = "{{$.ProjectName}}"
            command = ["/app/{{$.ProjectName}}", "{{.Name}}"]
            env_vars = forge.COMMON_ENV + cfg.APP_ENV + [
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{$.ProjectName}}-{{.Name}}"}
            ]
            deploy = forge.BuildOnly {}
        }
{{- end}}
    ]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

# JSON contract consumed by forge build/run/deploy.
output = forge.render(_bundle)

# k8s manifests for `kubectl apply -f -`.
_env = forge.RenderEnv {
    namespace = "{{.ProjectName}}-dev"
    image_registry = _registry
    image_tag = _image_tag
    network_policies = False
}
manifests = forge.render_manifests(_bundle, _env)
