"""
Production environment configuration for {{.ProjectName}} (binary=shared).

Top-level identifiers `image_tag` and `registry` are overridable via
`kcl run -D image_tag=<tag> -D registry=<registry> ...`.

This project ships ONE Docker image; each service is a Deployment that
runs the same binary with a different cobra subcommand.
"""

import deploy.kcl.schema
import deploy.kcl.base
import deploy.kcl.render

import deploy.kcl.prod.config_gen as cfg

_image_tag = option("image_tag") or "stable"

# Default placeholder so a missing `-D registry=...` from CI fails
# visibly rather than silently deploying from an unrelated _registry.
_registry = option("registry") or "ghcr.io/OWNER"

_multi = schema.MultiServiceApplication {
    name = "{{.ProjectName}}"
    image = "{{.ProjectName}}"
    command = ["/app/{{.ProjectName}}"]
    shared_env_vars = base.COMMON_ENV + cfg.APP_ENV + [
        schema.EnvVar {
            name = "SERVICE_NAME"
            value = "{{.ProjectName}}"
        }
    ]
    services = [
{{- range .Services}}
        schema.SubCommandService {
            name = "{{$.ProjectName}}-{{.Name}}"
            args = ["{{.Name}}"]
            replicas = 3
            ports = [
                schema.ServicePort {
                    name = "http"
                    port = 80
                    target_port = 8080
                }
            ]
            resources = schema.Resources {
                cpu_request = "500m"
                memory_request = "512Mi"
                cpu_limit = "2000m"
                memory_limit = "1Gi"
            }
            env_vars = [
                schema.EnvVar {
                    name = "OTEL_SERVICE_NAME"
                    value = "{{$.ProjectName}}-{{.Name}}"
                }
            ]
            health_check = schema.HealthCheck {
                liveness_path = "/healthz"
                readiness_path = "/readyz"
                http_port = 8080
            }
            autoscaling = schema.AutoScaling {
                enabled = True
                min_replicas = 3
                max_replicas = 10
                cpu_target = 80
            }
            pdb = schema.PodDisruptionBudget {
                enabled = True
                min_available = 2
            }
        }
{{- end}}
    ]
}

_env = schema.Environment {
    name = "prod"
    namespace = "{{.ProjectName}}-prod"
    image_registry = _registry
    image_tag = _image_tag
    network_policies = True
    # Generated ConfigMap(s) carrying non-sensitive per-env config.
    # Sensitive fields project to externally-managed Secrets via
    # `secret_ref` and are intentionally NOT generated here.
    config_maps = cfg.CONFIG_MAPS
    applications = render.multi_service_apps(_multi)
}

manifests = render.render_environment(_env)
