"""
Staging environment configuration for {{.ProjectName}} (binary=shared).

One image, N Deployments — each runs the shared binary with a different
cobra subcommand. See dev/main.k for the `output` / `manifests`
contract.
"""

import forge

import deploy.kcl.staging.config_gen as cfg
{{- if .IngressEnabled}}
import deploy.kcl.staging.ingress as ing
{{- end}}

_image_tag = option("image_tag") or "staging"
_registry = option("registry") or "ghcr.io/OWNER"

_shared_env = forge.COMMON_ENV + cfg.APP_ENV + [
    forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
]

_staging_k8s = forge.K8sCluster {
    # Set to the kubectl context name for the staging cluster.
    cluster = "{{.ProjectName}}-staging"
    namespace = "{{.ProjectName}}-staging"
    registry = _registry
    replicas = 2
    ports = [8080]
    resources = forge.Resources {
        cpu_request = "250m"
        memory_request = "256Mi"
        cpu_limit = "1000m"
        memory_limit = "512Mi"
    }
}

_bundle = forge.Bundle {
    services = [
{{- range .Services}}
        forge.Service {
            name = "{{$.ProjectName}}-{{.Name}}"
            image = "{{$.ProjectName}}"
            command = ["/app/{{$.ProjectName}}", "{{.Name}}"]
            env_vars = _shared_env + [
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{$.ProjectName}}-{{.Name}}"}
            ]
            deploy = _staging_k8s
        }
{{- end}}
    ]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

output = forge.render(_bundle)

_env = forge.RenderEnv {
    namespace = "{{.ProjectName}}-staging"
    image_registry = _registry
    image_tag = _image_tag
    network_policies = True
}
manifests = forge.render_manifests(_bundle, _env)
