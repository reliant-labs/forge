"""
Staging environment configuration for {{.ProjectName}}.

Top-level identifiers `image_tag` and `registry` are overridable via
`kcl run -D image_tag=<tag> -D registry=<registry> ...` because KCL's -D
flag only binds top-level names, not nested struct fields.
"""

import deploy.kcl.schema
import deploy.kcl.base
import deploy.kcl.render

# Overridable via `kcl run -D image_tag=...`
image_tag = option("image_tag") or "staging"

# Overridable via `kcl run -D registry=...`. The default is intentionally
# a placeholder ("ghcr.io/OWNER") so that failing to pass -D registry=...
# from CI surfaces as a visibly wrong image reference rather than silently
# deploying from an unrelated default registry. CI passes
# `-D registry=$REGISTRY` where REGISTRY is derived from the GitHub owner.
registry = option("registry") or "ghcr.io/OWNER"

env = schema.Environment {
    name = "staging"
    namespace = "{{.ProjectName}}-staging"
    image_registry = registry
    image_tag = image_tag
    network_policies = True
    applications = {
        "{{.ProjectName}}" = schema.Application {
            name = "{{.ProjectName}}"
            image = "{{.ProjectName}}"
            replicas = 2
            ports = [
                schema.ServicePort {
                    name = "http"
                    port = 80
                    target_port = 8080
                }
            ]
            resources = schema.Resources {
                cpu_request = "250m"
                memory_request = "256Mi"
                cpu_limit = "1000m"
                memory_limit = "512Mi"
            }
            env_vars = base.COMMON_ENV + [
                schema.EnvVar {
                    name = "SERVICE_NAME"
                    value = "{{.ProjectName}}"
                }
                schema.EnvVar {
                    name = "OTEL_SERVICE_NAME"
                    value = "{{.ProjectName}}"
                }
                schema.EnvVar {
                    name = "LOG_LEVEL"
                    value = "info"
                }
            ]
            health_check = schema.HealthCheck {
                liveness_path = "/healthz"
                readiness_path = "/readyz"
                http_port = 8080
            }
            autoscaling = schema.AutoScaling {
                enabled = True
                min_replicas = 2
                max_replicas = 5
                cpu_target = 80
            }
        }
    }
}

manifests = render.render_environment(env)