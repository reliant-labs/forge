"""
Staging environment configuration for {{.ProjectName}}.

DEPLOY-AS-DATA: workloads are expanded from
`deploy/kcl/components_gen.json` by the forge.components KCL schema
hierarchy. See the per-env header in `dev/main.k` for the `manifests` /
`output` two-output contract.

Per-env tag/registry overrides are consumed by `forge.image_tag(env)`
(reads `option("image_tag")`) and the `registry` field. The forge CLI
passes `-D image_tag=` on every build/deploy.
"""

import forge
import forge.components as fc

import deploy.kcl.staging.config_gen as cfg
{{- if .IngressEnabled}}
import deploy.kcl.staging.ingress as ing
{{- end}}

# Overridable via `kcl run -D registry=...`. The default is a visibly
# placeholder ("ghcr.io/OWNER") so a missing CI `-D registry=` surfaces
# as a wrong image reference rather than silently deploying from an
# unrelated registry.
_registry = forge.registry("ghcr.io/OWNER")
_namespace = "{{.ProjectName}}-staging"
_replicas = 2
_resources = forge.Resources {
    cpu_request = "250m"
    memory_request = "256Mi"
    cpu_limit = "1000m"
    memory_limit = "512Mi"
}
_cluster = forge.ClusterTarget {
    # Set to the kubectl context name for the staging cluster.
    cluster = "{{.ProjectName}}-staging"
    namespace = _namespace
    registry = _registry
}

# Base env every component sees, assembled with forge.env_merge (name-keyed,
# LAST-wins) so a later layer overrides an earlier one by name instead of the
# `+`-concat footgun (which emits duplicate keys kubectl rejects).
_base_env = forge.env_merge(forge.env_merge(forge.COMMON_ENV, cfg.APP_ENV), [
    forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
])

_components = [c | {
    image = "{{.ProjectName}}"
    registry = _registry
    namespace = _namespace
    replicas = _replicas
    resources = _resources
    env_vars = forge.env_merge(_base_env, [forge.EnvVar {name = "OTEL_SERVICE_NAME", value = c.name}])
} for c in fc.load_components(fc.COMPONENTS_GEN)]

_component_env = fc.ComponentEnv {
    namespace = _namespace
    registry = _registry
    image_tag = forge.image_tag("staging")
    network_policies = True
}

_support = forge.Bundle {
    cluster_target = _cluster
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

manifests = fc.render_components(_components, _component_env) \
    + forge.render_support(_support)

_svc_components = [c for c in _components if c.kind in ["server", "worker"]]
_bin_components = [c for c in _components if c.kind == "binary"]
_cron_components = [c for c in _components if c.kind == "cron"]
_op_components = [c for c in _components if c.kind == "operator"]

_bundle = forge.Bundle {
    cluster_target = _cluster
    services = [forge.Service {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = _cluster.deploy | {replicas = _replicas, resources = _resources, ports = [p.port for p in c.ports]}
        if c.build:
            build = forge.build_of(c.build)
    } for c in _svc_components] + [forge.Service {
        name = c.name
        image = "{{.ProjectName}}"
        command = c.command
        env_vars = c.env_vars
        deploy = forge.BuildOnly {}
        if c.build:
            build = forge.build_of(c.build)
    } for c in _bin_components]
    cronjobs = [forge.CronJob {
        name = c.name
        image = "{{.ProjectName}}"
        schedule = c.schedule
        command = c.command
        env_vars = c.env_vars
    } for c in _cron_components]
    operators = [forge.Operator {
        name = c.name
        image = "{{.ProjectName}}"
        crds = c.crds
        env_vars = c.env_vars
    } for c in _op_components]
    config_maps = cfg.CONFIG_MAPS
{{- if .IngressEnabled}}
    gateways = ing.GATEWAYS
    http_routes = ing.HTTP_ROUTES
    grpc_routes = ing.GRPC_ROUTES
{{- end}}
}

output = forge.render(_bundle)
