"""
Staging environment configuration for {{.ProjectName}}.

See the per-env header comment in `dev/main.k` for the
`output` / `manifests` two-output contract.

Top-level identifiers `image_tag` and `registry` are overridable via
`kcl run -D image_tag=<tag> -D registry=<registry> ...`.
"""

import forge

# Per-environment config (generated from forge.yaml + proto annotations).
import deploy.kcl.staging.config_gen as cfg

# Overridable via `kcl run -D image_tag=...`
_image_tag = option("image_tag") or "staging"

# Overridable via `kcl run -D registry=...`. The default is a visibly
# placeholder ("ghcr.io/OWNER") so that failing to pass -D registry=...
# from CI surfaces as a wrong image reference rather than silently
# deploying from an unrelated default registry.
_registry = option("registry") or "ghcr.io/OWNER"

_staging_k8s = forge.K8sCluster {
    # Set to the kubectl context name for the staging cluster.
    cluster = "{{.ProjectName}}-staging"
    namespace = "{{.ProjectName}}-staging"
    registry = _registry
    replicas = 2
    ports = [8080]
    resources = forge.Resources {
        cpu_request = "250m"
        memory_request = "256Mi"
        cpu_limit = "1000m"
        memory_limit = "512Mi"
    }
}

_bundle = forge.Bundle {
    services = [
        forge.Service {
            name = "{{.ProjectName}}"
            image = "{{.ProjectName}}"
            env_vars = forge.COMMON_ENV + cfg.APP_ENV + [
                forge.EnvVar {name = "SERVICE_NAME", value = "{{.ProjectName}}"}
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{.ProjectName}}"}
            ]
            deploy = _staging_k8s
        }
{{- range .Binaries}}
        forge.Service {
            name = "{{$.ProjectName}}-{{.Name}}"
            image = "{{$.ProjectName}}"
            command = ["/app/{{$.ProjectName}}", "{{.Name}}"]
            env_vars = forge.COMMON_ENV + cfg.APP_ENV + [
                forge.EnvVar {name = "OTEL_SERVICE_NAME", value = "{{$.ProjectName}}-{{.Name}}"}
            ]
            deploy = forge.BuildOnly {}
        }
{{- end}}
    ]
    config_maps = cfg.CONFIG_MAPS
}

output = forge.render(_bundle)

_env = forge.RenderEnv {
    namespace = "{{.ProjectName}}-staging"
    image_registry = _registry
    image_tag = _image_tag
    network_policies = True
}
manifests = forge.render_manifests(_bundle, _env)
