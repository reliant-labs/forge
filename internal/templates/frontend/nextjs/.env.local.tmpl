# API base URL override. Leave unset in dev — forge bakes the service's
# ACTUAL dev port (from forge.yaml) into src/lib/apiurl_gen.ts and
# regenerates it on every `forge generate`, so it can't drift the way a
# hardcoded value here does. Set this only for non-default setups
# (remote backend, tunnels, staging).
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_MOCK_API=true
NEXT_PUBLIC_OTEL_ENDPOINT=
NEXT_TELEMETRY_DISABLED=1
