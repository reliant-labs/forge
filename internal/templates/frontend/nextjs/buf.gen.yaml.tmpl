version: v2
plugins:
  - remote: buf.build/bufbuild/es
    out: frontends/{{.FrontendName}}/src/gen
    # include_imports is a plugin-level field in buf.gen.yaml v2 (same
    # level as `out:` / `opt:`), not an `opt:` entry — bufbuild/es rejects
    # unknown options. This ensures transitive proto imports (e.g.
    # forge/v1/forge.proto referenced by service_pb.ts) are emitted
    # alongside first-party stubs, otherwise tsc fails with missing
    # modules.
    include_imports: true
    # import_extension=.js produces ESM-compatible relative imports that
    # Next.js/TypeScript resolve correctly with `moduleResolution: bundler`.
    opt:
      - target=ts
      - import_extension=.js