{{- /*
  next.config.ts scaffold — branches on the frontend's `output:` field in
  forge.yaml. Defaults to "static" (the common case: a Next.js shell that
  calls a Go backend via Connect RPC, no server-side rendering needed in
  production). Standalone and server modes are opt-in.

  Branches:
    static     — production export (`output: "export"` gated on
                 NODE_ENV=production); dev stays as `next dev`. No Node
                 runtime in prod → drop the build artifacts on a CDN or
                 object store.
    standalone — self-contained Node server (`.next/standalone/server.js`).
                 Pair with the generated Dockerfile.
    server     — neither; full Next.js dev AND prod (`next start`).

  All three branches emit the same base-path block: `basePath` and
  `assetPrefix` (same value) default to forge.yaml's
  `frontends[].base_path` and are overridable via the single canonical
  env var NEXT_PUBLIC_BASE_PATH. The static branch additionally fails
  the production build when forge.yaml declares a base_path but the
  override empties it — a static export would bake root-mounted URLs
  that 404 behind the proxy.
*/ -}}
{{- if eq .Output "standalone" -}}
import path from "node:path";

import bundleAnalyzer from "@next/bundle-analyzer";

import type { NextConfig } from "next";

const withBundleAnalyzer = bundleAnalyzer({
  enabled: process.env.ANALYZE === "true",
});

// Path prefix this frontend is mounted under (e.g. "/admin" behind a
// reverse proxy that blends several apps on one host). Empty = served
// from the host root.
//
// Sources, in order:
//   1. NEXT_PUBLIC_BASE_PATH — the ONLY env var forge reads for the
//      base path. The NEXT_PUBLIC_ prefix is load-bearing: Next.js
//      inlines such vars into the client bundle, so the generated
//      browser-side helper (src/lib/basepath_gen.ts) reads the SAME
//      name. One name everywhere; a second variant would silently be
//      ignored.
//   2. forge.yaml `frontends[].base_path`, baked in by forge: "{{.BasePath}}".
const basePath = process.env.NEXT_PUBLIC_BASE_PATH ?? "{{.BasePath}}";

const nextConfig: NextConfig = {
  // basePath prefixes routes and <Link>/router URLs; assetPrefix (same
  // value) prefixes /_next/* asset and RSC chunk URLs. Omitting
  // assetPrefix lets some chunk URLs skip the prefix — the JS 404s
  // behind the proxy and React never hydrates.
  ...(basePath ? { basePath, assetPrefix: basePath } : {}),
  // "standalone" emits a self-contained Node server at
  // .next/standalone/server.js plus a pruned node_modules tree. This is
  // the shape the Dockerfile copies into the runner image.
  output: "standalone",
  // outputFileTracingRoot pins the tracing base directory to this frontend's
  // own folder. Without this, Next.js walks up looking for a workspace root
  // (e.g. a lockfile in the repo root) and emits the standalone bundle under
  // `.next/standalone/<relative-path>/server.js`, which the Dockerfile's
  // `COPY --from=builder /app/.next/standalone ./` cannot locate at runtime.
  outputFileTracingRoot: path.join(__dirname),
  webpack: (config) => {
    // protobuf-es generates imports with .js extensions (e.g. './foo_pb.js').
    // Next.js with moduleResolution: bundler can't resolve .js to .ts files
    // without this alias mapping.
    config.resolve.extensionAlias = {
      '.js': ['.ts', '.tsx', '.js', '.jsx'],
    };
    return config;
  },
};

export default withBundleAnalyzer(nextConfig);
{{- else if eq .Output "server" -}}
import bundleAnalyzer from "@next/bundle-analyzer";

import type { NextConfig } from "next";

const withBundleAnalyzer = bundleAnalyzer({
  enabled: process.env.ANALYZE === "true",
});

// Path prefix this frontend is mounted under (e.g. "/admin" behind a
// reverse proxy that blends several apps on one host). Empty = served
// from the host root.
//
// Sources, in order:
//   1. NEXT_PUBLIC_BASE_PATH — the ONLY env var forge reads for the
//      base path. The NEXT_PUBLIC_ prefix is load-bearing: Next.js
//      inlines such vars into the client bundle, so the generated
//      browser-side helper (src/lib/basepath_gen.ts) reads the SAME
//      name. One name everywhere; a second variant would silently be
//      ignored.
//   2. forge.yaml `frontends[].base_path`, baked in by forge: "{{.BasePath}}".
const basePath = process.env.NEXT_PUBLIC_BASE_PATH ?? "{{.BasePath}}";

const nextConfig: NextConfig = {
  // No `output:` field — full Next.js for both dev and prod. Production
  // builds are served via `next start` (or a managed host like Vercel).
  // Use this when you need server components, server actions, ISR, or
  // request-time `redirect()` / `cookies()` in production.
  //
  // basePath prefixes routes and <Link>/router URLs; assetPrefix (same
  // value) prefixes /_next/* asset and RSC chunk URLs. Omitting
  // assetPrefix lets some chunk URLs skip the prefix — the JS 404s
  // behind the proxy and React never hydrates.
  ...(basePath ? { basePath, assetPrefix: basePath } : {}),
  webpack: (config) => {
    // protobuf-es generates imports with .js extensions (e.g. './foo_pb.js').
    // Next.js with moduleResolution: bundler can't resolve .js to .ts files
    // without this alias mapping.
    config.resolve.extensionAlias = {
      '.js': ['.ts', '.tsx', '.js', '.jsx'],
    };
    return config;
  },
};

export default withBundleAnalyzer(nextConfig);
{{- else -}}
import bundleAnalyzer from "@next/bundle-analyzer";

import type { NextConfig } from "next";

const withBundleAnalyzer = bundleAnalyzer({
  enabled: process.env.ANALYZE === "true",
});

// Path prefix this frontend is mounted under (e.g. "/admin" behind a
// reverse proxy that blends several apps on one host). Empty = served
// from the host root.
//
// Sources, in order:
//   1. NEXT_PUBLIC_BASE_PATH — the ONLY env var forge reads for the
//      base path. The NEXT_PUBLIC_ prefix is load-bearing: Next.js
//      inlines such vars into the client bundle, so the generated
//      browser-side helper (src/lib/basepath_gen.ts) reads the SAME
//      name. One name everywhere; a second variant would silently be
//      ignored.
//   2. forge.yaml `frontends[].base_path`, baked in by forge: "{{.BasePath}}".
const basePath = process.env.NEXT_PUBLIC_BASE_PATH ?? "{{.BasePath}}";
{{- if .BasePath}}

// forge.yaml declares base_path: "{{.BasePath}}" for this frontend, and a
// static export bakes the prefix into every emitted URL at build time. If
// NEXT_PUBLIC_BASE_PATH overrides it to "" the build would silently emit
// root-mounted URLs that 404 behind the proxy (and there is no server at
// runtime to compensate). A wrong silent default is worse than an error —
// fail the production build loudly. To genuinely serve this frontend from
// the root, remove base_path from forge.yaml and run `forge generate`.
if (process.env.NODE_ENV === "production" && basePath === "") {
  throw new Error(
    "frontend {{.FrontendName}}: forge.yaml declares base_path \"{{.BasePath}}\" but " +
      "NEXT_PUBLIC_BASE_PATH is empty at build time; refusing to bake a " +
      "root-mounted static export. Unset the override (or remove base_path " +
      "from forge.yaml and re-run `forge generate`).",
  );
}
{{- end}}

const nextConfig: NextConfig = {
  // basePath prefixes routes and <Link>/router URLs; assetPrefix (same
  // value) prefixes /_next/* asset and RSC chunk URLs. Omitting
  // assetPrefix lets some chunk URLs skip the prefix — the JS 404s
  // behind the proxy and React never hydrates.
  ...(basePath ? { basePath, assetPrefix: basePath } : {}),
  // Production: static export. This frontend is a pure UI shell — all data,
  // auth, and business logic live in a backend (the Go Connect RPC services
  // under handlers/<name>/). Running a Node sidecar to serve skeleton HTML
  // before hydration is pure overhead, so production builds emit `out/`
  // (static HTML + JS + CSS) which can be served straight from a CDN or
  // object store. No server-side runtime in prod → smaller attack surface,
  // free edge caching, no Node image to patch.
  //
  // Development: full Next.js dev server (HMR, rewrites, server components
  // for future flexibility). The conditional below keeps `next dev`
  // unchanged when NODE_ENV !== "production".
  //
  // To opt into a Node sidecar runtime, set `output: standalone` on this
  // frontend in forge.yaml and re-scaffold (or hand-edit this file to use
  // `output: "standalone"` + `outputFileTracingRoot`).
  ...(process.env.NODE_ENV === "production" ? { output: "export" } : {}),
  webpack: (config) => {
    // protobuf-es generates imports with .js extensions (e.g. './foo_pb.js').
    // Next.js with moduleResolution: bundler can't resolve .js to .ts files
    // without this alias mapping.
    config.resolve.extensionAlias = {
      '.js': ['.ts', '.tsx', '.js', '.jsx'],
    };
    return config;
  },
};

export default withBundleAnalyzer(nextConfig);
{{- end }}
