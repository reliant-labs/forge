        <p className="mt-1 text-sm text-gray-500">
          Add services with CRUD RPCs and run <code className="rounded bg-gray-100 px-1.5 py-0.5 text-xs font-mono">forge generate</code> to populate this dashboard.
        </p>
      </div>
    );
  }

  return (
    <div className="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {{- range .Pages}}
