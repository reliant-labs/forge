// forge:scaffold one-shot
//
// Sidebar nav — yours to edit. Forge writes this file once at scaffold
// time and never overwrites it (Tier-2). The route data lives in
// `nav_gen.tsx`, which forge regenerates from `forge.yaml` every run.
//
// Common edits:
//   - filter ALL_ROUTES (e.g. only show admin routes for admin users)
//   - reorder entries
//   - attach a custom icon per route via the `icon` map below
//   - add static routes that aren't backed by a service

"use client";

import { ChevronLeft, LayoutDashboard, Table2 } from "lucide-react";
import Link from "next/link";
import { usePathname } from "next/navigation";

import { ALL_ROUTES, type RouteSpec } from "@/components/nav_gen";
import { useUiStore } from "@/stores/ui-store";

// Curated nav items. Default: show every generated route preceded by the
// Dashboard home link. Edit this list to prune/reorder. Icons come from
// lucide-react — swap any entry for another icon component.
const navItems: Array<RouteSpec & { icon?: string }> = [
  { path: "/", label: "Dashboard", labelLower: "dashboard", slug: "", labelSingular: "Dashboard", hasCreate: false, icon: "dashboard" },
  ...ALL_ROUTES.map((r) => ({ ...r, icon: "entity" })),
];

function NavIcon({ type }: { type?: string }) {
  if (type === "dashboard") {
    return <LayoutDashboard aria-hidden className="h-4 w-4 shrink-0" strokeWidth={1.5} />;
  }
  return <Table2 aria-hidden className="h-4 w-4 shrink-0" strokeWidth={1.5} />;
}

function CollapseIcon({ collapsed }: { collapsed: boolean }) {
  return (
    <ChevronLeft
      aria-hidden
      className={`h-4 w-4 transition-transform ${collapsed ? "rotate-180" : ""}`}
      strokeWidth={1.5}
    />
  );
}

export function Nav() {
  const pathname = usePathname();
  const collapsed = useUiStore((s) => s.sidebarCollapsed);
  const toggleSidebar = useUiStore((s) => s.toggleSidebar);

  return (
    <nav
      className={`flex shrink-0 flex-col border-r border-gray-200 bg-gray-50 transition-[width] duration-200 ${
        collapsed ? "w-16" : "w-60"
      }`}
    >
      {/* Brand */}
      <div className="flex h-14 items-center border-b border-gray-200 px-5">
        {!collapsed && (
          <span className="text-lg font-bold tracking-tight text-gray-900">
            {{.ProjectName}}
          </span>
        )}
      </div>

      {/* Navigation */}
      <div className="flex-1 overflow-y-auto px-3 py-4">
        {!collapsed && (
          <p className="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
            Navigation
          </p>
        )}
        <ul className="space-y-0.5">
          {navItems.map((item) => {
            const isActive =
              pathname === item.path ||
              (item.path !== "/" && pathname.startsWith(item.path));
            return (
              <li key={item.path}>
                <Link
                  href={item.path}
                  title={collapsed ? item.label : undefined}
                  className={`flex items-center rounded-md px-3 py-2 text-sm transition-colors ${
                    collapsed ? "justify-center" : "gap-2.5"
                  } ${
                    isActive
                      ? "bg-blue-50 font-medium text-blue-700"
                      : "text-gray-600 hover:bg-gray-100 hover:text-gray-900"
                  }`}
                >
                  <NavIcon type={item.icon} />
                  {!collapsed && item.label}
                </Link>
              </li>
            );
          })}
        </ul>
      </div>

      {/* Collapse toggle */}
      <div className="border-t border-gray-200 px-3 py-3">
        <button
          onClick={toggleSidebar}
          className={`flex w-full items-center rounded-md px-3 py-2 text-sm text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-900 ${
            collapsed ? "justify-center" : "gap-2.5"
          }`}
        >
          <CollapseIcon collapsed={collapsed} />
          {!collapsed && "Collapse"}
        </button>
      </div>
    </nav>
  );
}
