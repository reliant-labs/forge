import { createConnectTransport } from "@connectrpc/connect-web";
import { createClient, type Transport, type Interceptor } from "@connectrpc/connect";
import type { DescService } from "@bufbuild/protobuf";
import { SpanStatusCode, trace, context, propagation } from "@opentelemetry/api";

// The API URL is read from the NEXT_PUBLIC_API_URL environment variable.
// In development this defaults to the local backend server.
const baseUrl =
  process.env.NEXT_PUBLIC_API_URL ?? "{{.ApiUrl}}";

// Module-level token getter, wired up by AuthTokenBridge in providers.tsx.
let _getToken: () => Promise<string | null> = async () => null;

export function setAuthTokenGetter(fn: () => Promise<string | null>) {
  _getToken = fn;
}

// Auth interceptor that attaches the bearer token to every request.
const authInterceptor: Interceptor = (next) => async (req) => {
  const token = await _getToken();
  if (token) {
    req.header.set("Authorization", `Bearer ${token}`);
  }
  return next(req);
};

// Tracing interceptor that propagates W3C trace context to backend.
const tracingInterceptor: Interceptor = (next) => async (req) => {
  const tracer = trace.getTracer("connect-rpc");
  const span = tracer.startSpan(`rpc ${req.method.name}`);

  return context.with(trace.setSpan(context.active(), span), async () => {
    // Inject traceparent header
    const headers: Record<string, string> = {};
    propagation.inject(context.active(), headers);
    for (const [key, value] of Object.entries(headers)) {
      req.header.set(key, value);
    }

    try {
      const res = await next(req);
      span.end();
      return res;
    } catch (err) {
      const error = err as Error;
      span.recordException(error);
      span.setStatus({
        code: SpanStatusCode.ERROR,
        message: error.message,
      });
      span.end();
      throw err;
    }
  });
};

function buildTransport(): Transport {
  // NEXT_PUBLIC_MOCK_API has three modes:
  //   "true"   — pure mock. All RPCs hit the mock transport. No backend
  //              contacted. Use for offline UI dev and CI tests.
  //   "hybrid" — scenarios overlay a real backend. Unmatched RPCs (when
  //              the active scenario has passthrough:true) forward to the
  //              real transport. Use for LLM / Chrome MCP debugging.
  //   anything else (default) — real backend, real auth.
  const mode = process.env.NEXT_PUBLIC_MOCK_API;

  if (mode === "true") {
    // Dynamic require to avoid bundling mock data in production builds.
    // eslint-disable-next-line @typescript-eslint/no-require-imports
    const { createMockTransport } = require("@/lib/mock-transport");
    return createMockTransport();
  }

  if (mode === "hybrid") {
    const real = createConnectTransport({
      baseUrl,
      interceptors: [authInterceptor, tracingInterceptor],
    });
    // eslint-disable-next-line @typescript-eslint/no-require-imports
    const { createMockTransport } = require("@/lib/mock-transport");
    return createMockTransport(real);
  }

  return createConnectTransport({
    baseUrl,
    interceptors: [authInterceptor, tracingInterceptor],
  });
}

export const transport = buildTransport();

/**
 * connectClient creates a typed Connect client for a given service descriptor.
 *
 * Usage:
 *   import { UserService } from "../gen/user/v1/user_pb";
 *
 *   const client = connectClient(UserService);
 *   const user = await client.getUser({ id: "1" });
 */
export function connectClient<S extends DescService>(service: S) {
  return createClient(service, transport);
}
