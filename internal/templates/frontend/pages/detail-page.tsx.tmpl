"use client";

// forge:scaffold one-shot — detail page emitted by `forge add page`. See `forge skill load frontend/pages` for canonical patterns.
{{- if or .HasUpdate .HasDelete}}
import { {{if .HasDelete}}Trash2{{end}}{{if and .HasDelete .HasUpdate}}, {{end}}{{if .HasUpdate}}SquarePen{{end}}{{if .HasDelete}}, TriangleAlert{{end}} } from "lucide-react";
{{- end}}
import Link from "next/link";
import { useParams, useRouter } from "next/navigation";
{{- if .HasDelete}}
import { useState } from "react";
{{- end}}
import { z } from "zod";

import AlertBanner from "@/components/ui/alert_banner";
{{- if .HasBadgeColumns}}
import Badge from "@/components/ui/badge";
{{- end}}
import KeyValueList from "@/components/ui/key_value_list";
{{- if .HasDelete}}
import Modal from "@/components/ui/modal";
{{- end}}
import PageHeader from "@/components/ui/page_header";
import SkeletonLoader from "@/components/ui/skeleton_loader";
import { use{{.GetRPC}}{{if .HasDelete}}, use{{.DeleteRPC}}{{end}} } from "{{.HooksImportPath}}";
import { {{if .HasBadgeColumns}}enumBadgeVariant, {{end}}formatValue, userMessage } from "@/lib/format-utils";

// Route params are an external boundary — validate, don't cast. See the
// `frontend/patterns` skill ("Typed boundaries"). Swap `min(1)` for
// `z.string().uuid()` if your IDs are UUIDs.
const paramsSchema = z.object({ id: z.string().min(1) });

export default function {{.EntityName}}DetailPage() {
  const router = useRouter();
  const { id } = paramsSchema.parse(useParams());
  {{- if .HasDelete}}
  const [showDeleteConfirm, setShowDeleteConfirm] = useState(false);
  {{- end}}

  const { data, isLoading, error } = use{{.GetRPC}}({ id });
  {{- if .HasDelete}}
  // The generated hook already invalidates the {{.EntityName | lower}} query scope on
  // success — no manual cache invalidation needed here. Failure surfaces
  // via the app-wide error-toast chokepoint (query-client.ts).
  const deleteMutation = use{{.DeleteRPC}}({
    onSuccess: () => router.push("/{{.EntitySlug}}"),
  });
  {{- end}}

  if (isLoading) return <SkeletonLoader variant="list-item" count={5} />;
  if (error) return (
    <div className="px-4 py-8">
      <AlertBanner variant="error" message={userMessage(error)} />
      <Link href="/{{.EntitySlug}}" className="mt-4 inline-flex text-sm text-blue-600 underline hover:text-blue-800">
        Back to {{.EntityNamePlural | lower}}
      </Link>
    </div>
  );

  // Typed access: the generator knows the response wraps the entity in
  // `{{.EntityName | camelCase}}` — no `?? data` hedging, no Record<string, unknown> cast.
  const item = data?.{{.EntityName | camelCase}};
  const title = {{if .DisplayField}}item?.{{.DisplayField}} || {{end}}String(item?.{{.PkFieldCamel}} ?? "{{.EntityName}}");

  // Typed field rows — one entry per renderable proto field, declared by
  // the generator instead of reflected out of Object.entries at runtime.
  const fields = item
    ? [
{{- range .Columns}}
        {
          label: "{{.Label}}",
{{- if .IsBadge}}
          value: <Badge label={String(item.{{.Name}})} variant={enumBadgeVariant(String(item.{{.Name}}))} />,
{{- else}}
          value: formatValue(item.{{.Name}}),
{{- end}}
        },
{{- end}}
      ]
    : [];

  const actions: Array<{ label: string; href?: string; variant?: "primary" | "secondary" | "danger"; icon?: React.ReactNode; onClick?: () => void }> = [
    {{- if .HasUpdate}}
    {
      label: "Edit",
      href: `/{{.EntitySlug}}/${id}/edit`,
      variant: "secondary" as const,
      icon: <SquarePen aria-hidden className="h-4 w-4" strokeWidth={1.5} />,
    },
    {{- end}}
    {{- if .HasDelete}}
    {
      label: "Delete",
      onClick: () => setShowDeleteConfirm(true),
      variant: "danger" as const,
      icon: <Trash2 aria-hidden className="h-4 w-4" strokeWidth={1.5} />,
    },
    {{- end}}
  ];

  return (
    <div>
      <PageHeader
        title={title}
        breadcrumbs={[
          { label: "{{.EntityNamePlural}}", href: "/{{.EntitySlug}}" },
          { label: title },
        ]}
        actions={actions}
      />

      <KeyValueList groups={[{ fields }]} />

      {{- if .HasDelete}}
      <Modal
        open={showDeleteConfirm}
        onClose={() => setShowDeleteConfirm(false)}
        title="Delete {{.EntityName}}"
        description="Are you sure you want to delete this {{.EntityName | lower}}? This action cannot be undone."
        footer={
          <>
            <button
              onClick={() => setShowDeleteConfirm(false)}
              className="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50"
            >
              Cancel
            </button>
            <button
              onClick={() => deleteMutation.mutate({ id })}
              disabled={deleteMutation.isPending}
              className="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 disabled:opacity-50"
            >
              {deleteMutation.isPending ? "Deleting..." : "Delete"}
            </button>
          </>
        }
      >
        <div className="flex h-10 w-10 items-center justify-center rounded-full bg-red-100">
          <TriangleAlert aria-hidden className="h-5 w-5 text-red-600" strokeWidth={1.5} />
        </div>
      </Modal>
      {{- end}}
    </div>
  );
}
