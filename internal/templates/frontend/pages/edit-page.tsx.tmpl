"use client";

// forge:scaffold one-shot — edit page emitted by `forge add page`. See `forge skill load frontend/pages` for canonical patterns.
{{- if .HasDateUpdateFields}}
import { timestampFromDate } from "@bufbuild/protobuf/wkt";
{{- end}}
import { zodResolver } from "@hookform/resolvers/zod";
import Link from "next/link";
import { useParams, useRouter } from "next/navigation";
import { useForm } from "react-hook-form";
import { z } from "zod";

import AlertBanner from "@/components/ui/alert_banner";
import PageHeader from "@/components/ui/page_header";
import SkeletonLoader from "@/components/ui/skeleton_loader";
import { use{{.GetRPC}}, use{{.UpdateRPC}} } from "{{.HooksImportPath}}";
import { {{if .HasDateUpdateFields}}toDatetimeLocal, {{end}}userMessage } from "@/lib/format-utils";

const schema = z.object({
  {{- range .UpdateFields}}
  {{- if eq .Type "checkbox"}}
  {{.Name}}: z.boolean().default(false),
  {{- else if eq .Type "number"}}
  {{.Name}}: z.coerce.number(),
  {{- else if eq .Type "date"}}
  {{.Name}}: z.string(){{if .Required}}.min(1, "Required"){{end}},
  {{- else}}
  {{.Name}}: z.string(){{if .Required}}.min(1, "Required"){{end}},
  {{- end}}
  {{- end}}
});

type FormValues = z.infer<typeof schema>;

// Route params are an external boundary — validate, don't cast.
const paramsSchema = z.object({ id: z.string().min(1) });

export default function Edit{{.EntityName}}Page() {
  const router = useRouter();
  const { id } = paramsSchema.parse(useParams());

  const { data, isLoading, error: fetchError } = use{{.GetRPC}}({ id });
  // Typed access: the response wraps the entity in `{{.EntityName | camelCase}}` —
  // no `?? data` hedging, no Record<string, unknown> cast.
  const item = data?.{{.EntityName | camelCase}};

  const mutation = use{{.UpdateRPC}}({
    onSuccess: () => router.push(`/{{.EntitySlug}}/${id}`),
    // The error renders inline below — opt out of the app-wide error
    // toast so the failure isn't announced twice.
    meta: { silenceErrorToast: true },
  });

  const { register, handleSubmit, formState: { errors, isDirty } } = useForm<FormValues>({
    resolver: zodResolver(schema),
    values: item
      ? {
          {{- range .UpdateFields}}
          {{- if eq .Type "checkbox"}}
          {{.Name}}: Boolean(item.{{.Name}}),
          {{- else if eq .Type "number"}}
          {{.Name}}: Number(item.{{.Name}} ?? 0),
          {{- else if eq .Type "date"}}
          {{.Name}}: toDatetimeLocal(item.{{.Name}}),
          {{- else if .IsRepeated}}
          {{.Name}}: (item.{{.Name}} ?? []).join(", "),
          {{- else}}
          {{.Name}}: String(item.{{.Name}} ?? ""),
          {{- end}}
          {{- end}}
        }
      : undefined,
  });

  function onSubmit(values: FormValues) {
    // Typed end-to-end: date strings become proto Timestamps and 64-bit
    // ints become bigints BEFORE mutate(), so the request matches the
    // schema instead of being cast into shape.
    mutation.mutate({
      id,
      ...values,
      {{- range .UpdateFields}}
      {{- if eq .Type "date"}}
      {{.Name}}: values.{{.Name}} ? timestampFromDate(new Date(values.{{.Name}})) : undefined,
      {{- else if .IsBigInt}}
      {{.Name}}: BigInt(Math.trunc(values.{{.Name}})),
      {{- else if .IsRepeated}}
      // Repeated scalar: comma-separated text input → the array the RPC expects.
      {{.Name}}: values.{{.Name}}.split(",").map((s) => s.trim()).filter(Boolean){{if .RepeatedNumeric}}.map(Number){{end}},
      {{- end}}
      {{- end}}
    });
  }

  // Loading is its own state — bail explicitly. Do not derive booleans from
  // `!isLoading && X` and act on them; that gate is false during the load
  // window AND when the load returns a falsy value, which races and wipes
  // real state. See `frontend/state` ("Loading is not the negative of success").
  //
  // For type-checker-enforced exhaustiveness, see `useQueryResource` in
  // `src/hooks/use-query-resource.ts` — it returns a discriminated union
  // `{ status: 'loading' } | { status: 'error', error } | { status: 'success', data }`
  // that forces a switch over all three states.
  if (isLoading) return <div className="mx-auto max-w-xl px-4 py-8"><SkeletonLoader variant="form-field" count={4} /></div>;

  if (fetchError) {
    return (
      <div className="mx-auto max-w-xl px-4 py-8">
        <AlertBanner variant="error" message={userMessage(fetchError)} />
        <Link href="/{{.EntitySlug}}" className="mt-4 inline-flex text-sm text-blue-600 underline hover:text-blue-800">
          Back to {{.EntityNamePlural | lower}}
        </Link>
      </div>
    );
  }

  const title = {{if .DisplayField}}item?.{{.DisplayField}} || {{end}}String(item?.{{.PkFieldCamel}} ?? id);

  return (
    <div className="mx-auto max-w-xl px-4 py-8">
      <PageHeader
        title="Edit {{.EntityName}}"
        breadcrumbs={[
          { label: "{{.EntityNamePlural}}", href: "/{{.EntitySlug}}" },
          { label: title, href: `/{{.EntitySlug}}/${id}` },
          { label: "Edit" },
        ]}
      />

      {mutation.error && (
        <div className="mb-6">
          <AlertBanner variant="error" message={userMessage(mutation.error)} dismissible onDismiss={() => mutation.reset()} />
        </div>
      )}

      <form onSubmit={handleSubmit(onSubmit)} className="space-y-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        {{- range .UpdateFields}}
        {{- if eq .Type "checkbox"}}
        <div className="flex items-center gap-3">
          <input
            type="checkbox"
            id="{{.Name}}"
            {...register("{{.Name}}")}
            className="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
          />
          <label htmlFor="{{.Name}}" className="text-sm font-medium text-gray-700">
            {{.Label}}
          </label>
        </div>
        {{- else if eq .Type "textarea"}}
        <div>
          <label htmlFor="{{.Name}}" className="mb-1 block text-sm font-medium text-gray-700">
            {{.Label}}{{if .Required}} *{{end}}
          </label>
          <textarea
            id="{{.Name}}"
            {...register("{{.Name}}")}
            rows={4}
            className={`block w-full rounded-lg border px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 ${errors.{{.Name}} ? "border-red-300" : "border-gray-300"}`}
          />
          {errors.{{.Name}} && <p className="mt-1 text-sm text-red-600">{errors.{{.Name}}.message}</p>}
        </div>
        {{- else if eq .Type "date"}}
        <div>
          <label htmlFor="{{.Name}}" className="mb-1 block text-sm font-medium text-gray-700">
            {{.Label}}{{if .Required}} *{{end}}
          </label>
          <input
            type="datetime-local"
            id="{{.Name}}"
            {...register("{{.Name}}")}
            className={`block w-full rounded-lg border px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 ${errors.{{.Name}} ? "border-red-300" : "border-gray-300"}`}
          />
          {errors.{{.Name}} && <p className="mt-1 text-sm text-red-600">{errors.{{.Name}}.message}</p>}
        </div>
        {{- else}}
        <div>
          <label htmlFor="{{.Name}}" className="mb-1 block text-sm font-medium text-gray-700">
            {{.Label}}{{if .Required}} *{{end}}
          </label>
          <input
            type="{{.Type}}"
            id="{{.Name}}"
            {...register("{{.Name}}")}
            className={`block w-full rounded-lg border px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 ${errors.{{.Name}} ? "border-red-300" : "border-gray-300"}`}
          />
          {errors.{{.Name}} && <p className="mt-1 text-sm text-red-600">{errors.{{.Name}}.message}</p>}
        </div>
        {{- end}}
        {{- end}}

        <div className="flex items-center justify-end gap-3 border-t border-gray-200 pt-6">
          <Link
            href={`/{{.EntitySlug}}/${id}`}
            className="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
          >
            Cancel
          </Link>
          <button
            type="submit"
            disabled={mutation.isPending || !isDirty}
            className="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50"
          >
            {mutation.isPending ? "Saving..." : "Save Changes"}
          </button>
        </div>
      </form>
    </div>
  );
}
