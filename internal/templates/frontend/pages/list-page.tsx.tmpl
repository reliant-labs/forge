"use client";

// forge:scaffold one-shot — list page emitted by `forge add page`. See `forge skill load frontend/pages` for canonical patterns.
// {{.EntityNamePlural}} list page — generated by `forge add page`.
//
// Conventions baked in (see frontend/state + frontend/pages skills):
//   - Server data via the generated React Query hook; never copy into Zustand.
//   - Typed columns: the generator knows {{.EntityName}}'s fields from the proto
//     descriptor, so columns are declared (and type-checked against the
//     entity) instead of reflected out of Object.keys at runtime.
{{- if .SearchFields}}
//   - Filters/search live in URL search params (link-shareable, refresh-survives).
//     A local draft mirror lets the user type without firing a query per keystroke.
{{- end}}
//   - Structural markup uses the @/components/ui/table primitives — never
//     hand-rolled <table> markup.
//   - 3-state rendering: loading / error / success-or-empty.

{{- if .HasCreate}}
import { Inbox, Plus } from "lucide-react";
import Link from "next/link";
{{- else}}
import { Inbox } from "lucide-react";
{{- end}}
{{- if .SearchFields}}
import { useRouter, useSearchParams } from "next/navigation";
import { useCallback, useEffect, useState } from "react";
import { z } from "zod";
{{- else}}
import { useRouter } from "next/navigation";
{{- end}}

import AlertBanner from "@/components/ui/alert_banner";
{{- if .HasBadgeColumns}}
import Badge from "@/components/ui/badge";
{{- end}}
import PageHeader from "@/components/ui/page_header";
{{- if .SearchFields}}
import SearchInput from "@/components/ui/search_input";
{{- end}}
import SkeletonLoader from "@/components/ui/skeleton_loader";
import Table, {
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { use{{.ListRPC}} } from "{{.HooksImportPath}}";
import { {{if .HasBadgeColumns}}enumBadgeVariant, {{end}}formatValue, userMessage } from "@/lib/format-utils";
{{- if .SearchFields}}
import { useTypedSearchParams } from "@/lib/search-schemas";
{{- end}}

import type { {{.EntityName}} } from "{{.EntityTypeImportPath}}";
import type { ReactNode } from "react";

// ---- Typed columns ----
// One entry per renderable proto field. Adding/removing a field in the
// proto and re-running `forge generate --force --reset-tier2` regenerates
// this list; hand-edit freely otherwise (the file is yours).
type Column = {
  key: keyof {{.EntityName}} & string;
  header: string;
  render: (item: {{.EntityName}}) => ReactNode;
};

const columns = [
{{- range .Columns}}
  {
    key: "{{.Name}}",
    header: "{{.Label}}",
{{- if .IsBadge}}
    render: (item) => <Badge label={String(item.{{.Name}})} variant={enumBadgeVariant(String(item.{{.Name}}))} />,
{{- else}}
    render: (item) => formatValue(item.{{.Name}}),
{{- end}}
  },
{{- end}}
] satisfies Column[];
{{- if .SearchFields}}

// Client-side search filters over the entity's string fields only —
// type-checked against {{.EntityName}} so a renamed proto field fails the build
// instead of silently searching nothing.
const searchFields = [{{range $i, $f := .SearchFields}}{{if $i}}, {{end}}"{{$f}}"{{end}}] as const satisfies readonly (keyof {{.EntityName}} & string)[];
{{- end}}

function EmptyState() {
  return (
    <div className="rounded-lg border border-dashed border-gray-300 p-12 text-center">
      <Inbox aria-hidden className="mx-auto h-10 w-10 text-gray-400" strokeWidth={1.5} />
      <p className="mt-3 text-sm font-medium text-gray-900">No {{.EntityNamePlural | lower}} yet</p>
      <p className="mt-1 text-sm text-gray-500">Get started by creating a new {{.EntityName | lower}}.</p>
      {{- if .HasCreate}}
      <Link
        href="/{{.EntitySlug}}/new"
        className="mt-4 inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700"
      >
        Create {{.EntityName}}
      </Link>
      {{- end}}
    </div>
  );
}
{{- if .SearchFields}}

// ---- URL-backed filter schema ----
// One schema per route — extend this when adding filters instead of reaching
// for raw `searchParams.get(...)`. See `frontend/state` ("Search params are
// typed boundaries"). Examples to add later:
//   status: z.enum(["all", "active", "archived"]).optional().default("all"),
//   page: z.coerce.number().int().min(1).optional().default(1),
const searchSchema = z.object({
  q: z.string().optional().default(""),
});
{{- end}}

export default function {{.EntityNamePlural}}Page() {
  const router = useRouter();
{{- if .SearchFields}}
  const searchParams = useSearchParams();

  // ---- URL-backed filter state ----
  // Durable filters belong in the URL per the frontend/state skill — link
  // sharing, browser back/forward, and refresh all "just work".
  const { q: search } = useTypedSearchParams(searchSchema);

  // Local draft state so typing doesn't update the URL on every keystroke.
  // The committed value lands in the URL on debounce.
  const [draft, setDraft] = useState(search);

  // Keep the draft in sync if the URL changes externally (e.g. back button).
  useEffect(() => {
    setDraft(search);
  }, [search]);

  const setSearchParam = useCallback(
    (value: string) => {
      const params = new URLSearchParams(searchParams.toString());
      if (value) {
        params.set("q", value);
      } else {
        params.delete("q");
      }
      const qs = params.toString();
      router.replace(qs ? `?${qs}` : "?", { scroll: false });
    },
    [router, searchParams],
  );

  // Debounce draft -> URL by 200ms so we don't thrash history.
  useEffect(() => {
    if (draft === search) return;
    const t = setTimeout(() => setSearchParam(draft), 200);
    return () => clearTimeout(t);
  }, [draft, search, setSearchParam]);
{{- end}}

  const { data, isLoading, error } = use{{.ListRPC}}({});

  if (isLoading) return <div className="px-4 py-8"><SkeletonLoader variant="table-row" count={5} /></div>;
  if (error) return <div className="px-4 py-8"><AlertBanner variant="error" message={userMessage(error)} /></div>;

  const items = data?.{{.EntityNamePlural | camelCase}} ?? [];
{{- if .SearchFields}}

  const filtered = search
    ? items.filter((item) =>
        searchFields.some((key) =>
          String(item[key]).toLowerCase().includes(search.toLowerCase()),
        ),
      )
    : items;
{{- else}}

  const filtered = items;
{{- end}}

  return (
    <div>
      <PageHeader
        title="{{.EntityNamePlural}}"
        subtitle={`${items.length} {{.EntityNamePlural | lower}} total`}
        actions={[
          {{- if .HasCreate}}
          {
            label: "Create {{.EntityName}}",
            href: "/{{.EntitySlug}}/new",
            variant: "primary" as const,
            icon: <Plus aria-hidden className="h-4 w-4" strokeWidth={2} />,
          },
          {{- end}}
        ]}
      />
{{- if .SearchFields}}

      <div className="mb-4">
        <SearchInput
          value={draft}
          onChange={setDraft}
          placeholder="Search {{.EntityNamePlural | lower}}..."
        />
      </div>
{{- end}}

      {filtered.length === 0 ? (
        {{- if .SearchFields}}
        search ? (
          <div className="rounded-lg border border-dashed border-gray-300 p-8 text-center">
            <p className="text-sm text-gray-500">No {{.EntityNamePlural | lower}} matching &ldquo;{search}&rdquo;</p>
          </div>
        ) : (
          <EmptyState />
        )
        {{- else}}
        <EmptyState />
        {{- end}}
      ) : (
        <Table>
          <TableHeader>
            <TableRow>
              {columns.map((col) => (
                <TableHead key={col.key}>{col.header}</TableHead>
              ))}
            </TableRow>
          </TableHeader>
          <TableBody>
            {filtered.map((item, idx) => (
              <TableRow
                key={String(item.{{.PkFieldCamel}})}
                striped={idx % 2 === 1}
                clickable
                onClick={() => router.push(`/{{.EntitySlug}}/${item.{{.PkFieldCamel}}}`)}
              >
                {columns.map((col) => (
                  <TableCell key={col.key}>{col.render(item)}</TableCell>
                ))}
              </TableRow>
            ))}
          </TableBody>
        </Table>
      )}
    </div>
  );
}
