import { useEffect } from "react";
import { Stack } from "expo-router";
import { StatusBar } from "expo-status-bar";
import { QueryClientProvider } from "@tanstack/react-query";
import { queryClient } from "../src/lib/query-client";
import { EventBusProvider } from "../src/lib/event-context";
import { AuthContextProvider, useAuth } from "../src/lib/auth/context";
import { setAuthTokenGetter } from "../src/lib/connect";

/** Wires the auth provider's token getter to the Connect transport. */
function AuthTokenBridge() {
  const { getToken } = useAuth();

  useEffect(() => {
    setAuthTokenGetter(getToken);
  }, [getToken]);

  return null;
}

export default function RootLayout() {
  const isDev = process.env.NODE_ENV === "development";

  return (
    <QueryClientProvider client={queryClient}>
      <EventBusProvider devMode={isDev}>
        <AuthContextProvider>
          <AuthTokenBridge />
          <Stack>
            <Stack.Screen name="index" options={{"{{"}} title: "{{.FrontendName}}" {{"}}"}} />
          </Stack>
          <StatusBar style="auto" />
        </AuthContextProvider>
      </EventBusProvider>
    </QueryClientProvider>
  );
}
