import { createConnectTransport } from "@connectrpc/connect-web";
import { createClient, type Transport, type Interceptor } from "@connectrpc/connect";
import type { DescService } from "@bufbuild/protobuf";

// The API URL is read from the EXPO_PUBLIC_API_URL environment variable.
// In development this defaults to the local backend server.
const baseUrl =
  process.env.EXPO_PUBLIC_API_URL ?? "{{.ApiUrl}}";

// Module-level token getter, wired up by AuthTokenBridge in _layout.tsx.
let _getToken: () => Promise<string | null> = async () => null;

export function setAuthTokenGetter(fn: () => Promise<string | null>) {
  _getToken = fn;
}

// Auth interceptor that attaches the bearer token to every request.
const authInterceptor: Interceptor = (next) => async (req) => {
  const token = await _getToken();
  if (token) {
    req.header.set("Authorization", `Bearer ${token}`);
  }
  return next(req);
};

function buildTransport(): Transport {
  return createConnectTransport({
    baseUrl,
    interceptors: [authInterceptor],
  });
}

export const transport = buildTransport();
{{- if .Workspaces}}

// Wire the workspace-shared hooks package to this frontend's Transport.
// The hooks package is DOM-free; each frontend hands its Transport over
// once at module load so generated hooks resolve against the right
// network layer.
import { setApiTransport } from "{{.HooksPackage}}";
setApiTransport(transport);
{{- end}}

/**
 * connectClient creates a typed Connect client for a given service descriptor.
 *
 * Usage:
{{- if .Workspaces}}
 *   import { UserService } from "{{.ApiPackage}}/services/users/v1/users_pb";
{{- else}}
 *   import { UserService } from "../gen/user/v1/user_pb";
{{- end}}
 *
 *   const client = connectClient(UserService);
 *   const user = await client.getUser({ id: "1" });
 */
export function connectClient<S extends DescService>(service: S) {
  return createClient(service, transport);
}
