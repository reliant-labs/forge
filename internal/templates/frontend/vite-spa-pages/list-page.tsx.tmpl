// forge:scaffold one-shot — list page emitted by `forge add page`. See `forge skill load frontend/pages` for canonical patterns.
// {{.EntityNamePlural}} list page — generated by `forge add page`.
//
// Conventions baked in (see frontend/state + frontend/pages skills):
//   - Server data via the generated React Query hook; never copy into Zustand.
//   - Filters/search live in URL search params (link-shareable, refresh-survives).
//     A local draft mirror lets the user type without firing a query per keystroke.
//   - Structural markup uses the @/components/ui/table primitives — never
//     hand-rolled <table> markup.
//   - 3-state rendering: loading / error / success-or-empty.
//
// Tanstack-router notes:
//   - The search schema is declared on the ROUTE in src/routes.tsx via
//     `validateSearch: searchSchema.parse`. This component reads typed
//     values via `useSearch({ from: '/{{.EntitySlug}}' })`. Do NOT reach
//     for `window.location.search` here.

import { use{{.ListRPC}} } from "{{.HooksImportPath}}";
import { Link, useNavigate, useSearch } from "@tanstack/react-router";
import { useCallback, useEffect, useState } from "react";
import PageHeader from "@/components/ui/page_header";
import Badge from "@/components/ui/badge";
import SkeletonLoader from "@/components/ui/skeleton_loader";
import SearchInput from "@/components/ui/search_input";
import AlertBanner from "@/components/ui/alert_banner";
import Table, {
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { formatValue, isEnumLike, enumBadgeVariant } from "@/lib/format-utils";

function EmptyState() {
  return (
    <div className="rounded-lg border border-dashed border-gray-300 p-12 text-center">
      <svg className="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
      </svg>
      <p className="mt-3 text-sm font-medium text-gray-900">No {{.EntityNamePlural | lower}} yet</p>
      <p className="mt-1 text-sm text-gray-500">Get started by creating a new {{.EntityName | lower}}.</p>
      {{- if .HasCreate}}
      <Link
        to="/{{.EntitySlug}}/new"
        className="mt-4 inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700"
      >
        Create {{.EntityName}}
      </Link>
      {{- end}}
    </div>
  );
}

export default function {{.EntityNamePlural}}Page() {
  const navigate = useNavigate();

  // ---- URL-backed filter state ----
  // Schema is declared on the route in src/routes.tsx; this hook returns
  // the typed search object. Cast to a shape with `q` so this template is
  // self-contained even before the route is wired.
  const search = useSearch({ strict: false }) as { q?: string };
  const q = search.q ?? "";

  // Local draft state so typing doesn't update the URL on every keystroke.
  const [draft, setDraft] = useState(q);

  useEffect(() => {
    setDraft(q);
  }, [q]);

  const setSearchParam = useCallback(
    (value: string) => {
      void navigate({
        to: ".",
        search: (prev: Record<string, unknown>) => ({
          ...prev,
          q: value ? value : undefined,
        }),
        replace: true,
      });
    },
    [navigate],
  );

  // Debounce draft -> URL by 200ms so we don't thrash history.
  useEffect(() => {
    if (draft === q) return;
    const t = setTimeout(() => setSearchParam(draft), 200);
    return () => clearTimeout(t);
  }, [draft, q, setSearchParam]);

  const { data, isLoading, error } = use{{.ListRPC}}({});

  if (isLoading) return <div className="px-4 py-8"><SkeletonLoader variant="table-row" count={5} /></div>;
  if (error) return <div className="px-4 py-8"><AlertBanner variant="error" message={error.message} /></div>;

  const items = data?.{{.EntityNamePlural | camelCase}} ?? [];

  const filtered = q
    ? items.filter((item: Record<string, unknown>) =>
        Object.values(item).some((v) =>
          String(v).toLowerCase().includes(q.toLowerCase())
        )
      )
    : items;

  const columns = items.length > 0
    ? Object.keys(items[0] as Record<string, unknown>).filter((k) => k !== "$typeName")
    : [];

  return (
    <div>
      <PageHeader
        title="{{.EntityNamePlural}}"
        subtitle={`${items.length} {{.EntityNamePlural | lower}} total`}
        actions={[
          {{- if .HasCreate}}
          {
            label: "Create {{.EntityName}}",
            href: "/{{.EntitySlug}}/new",
            variant: "primary" as const,
            icon: (
              <svg className="h-4 w-4" fill="none" viewBox="0 0 24 24" strokeWidth={2} stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            ),
          },
          {{- end}}
        ]}
      />

      <div className="mb-4">
        <SearchInput
          value={draft}
          onChange={setDraft}
          placeholder="Search {{.EntityNamePlural | lower}}..."
        />
      </div>

      {filtered.length === 0 ? (
        q ? (
          <div className="rounded-lg border border-dashed border-gray-300 p-8 text-center">
            <p className="text-sm text-gray-500">No {{.EntityNamePlural | lower}} matching &ldquo;{q}&rdquo;</p>
          </div>
        ) : (
          <EmptyState />
        )
      ) : (
        <Table>
          <TableHeader>
            <TableRow>
              {columns.map((col) => (
                <TableHead key={col}>
                  {col.replace(/([A-Z])/g, " $1").replace(/^./, (s) => s.toUpperCase())}
                </TableHead>
              ))}
            </TableRow>
          </TableHeader>
          <TableBody>
            {filtered.map((item: Record<string, unknown>, idx: number) => (
              <TableRow
                key={String(item.id ?? item.name ?? idx)}
                striped={idx % 2 === 1}
                clickable
                onClick={() => void navigate({ to: `/{{.EntitySlug}}/$id`, params: { id: String(item.id) } })}
              >
                {columns.map((col) => (
                  <TableCell key={col}>
                    {isEnumLike(col, item[col]) ? (
                      <Badge label={String(item[col])} variant={enumBadgeVariant(String(item[col]))} />
                    ) : (
                      formatValue(item[col])
                    )}
                  </TableCell>
                ))}
              </TableRow>
            ))}
          </TableBody>
        </Table>
      )}
    </div>
  );
}
