// yours: scaffolded once, never touched again — forge will not overwrite this file
//
// Tanstack-router setup for the {{.FrontendName}} SPA. Forge writes this
// file once at scaffold time and never overwrites it. New routes added by
// `forge add page <Entity>` are appended in the marker block below.
//
// Routing model
// -------------
// We use the code-based router (createRootRoute / createRoute / addChildren)
// rather than file-based routing. The code-based form keeps the route tree
// inspectable in one place and lets the page generator stitch new entity
// routes into the same array without touching anything else.
//
// Common edits:
//   - Replace <App /> with your own root layout
//   - Add static routes (login, settings) above the FORGE-ROUTES marker
//   - Filter or reorder ALL_ROUTES in the marker block
//
// Conventions
//   - Search-param validation lives on the route via `validateSearch: schema`.
//     Read it inside the component with `useSearch({ from: '/<route-id>' })`.
//   - Path params: `parseParams: z.object({...}).parse` on the route.

import {
  createRootRoute,
  createRoute,
  createRouter,
  Outlet,
} from "@tanstack/react-router";

import App from "./App";

// Root route — renders the app shell (<App />) and an <Outlet /> for
// matched children.
export const rootRoute = createRootRoute({
  component: () => (
    <App>
      <Outlet />
    </App>
  ),
});

// Index route — the welcome / dashboard landing page. Replace with your own
// dashboard component once you have services with CRUD entities and have
// run `forge generate` to scaffold them.
const indexRoute = createRoute({
  getParentRoute: () => rootRoute,
  path: "/",
  component: function Index() {
    return (
      <div className="mx-auto max-w-3xl p-8">
        <h1 className="text-3xl font-bold tracking-tight text-gray-900">
          Welcome to {{.FrontendName}}
        </h1>
        <p className="mt-3 text-sm text-gray-600">
          This is a Vite + React + tanstack-router scaffold generated by
          forge. Add a service with CRUD RPCs and run
          {" "}<code className="rounded bg-gray-100 px-1.5 py-0.5 text-xs font-mono">forge generate</code>{" "}
          to populate entity routes.
        </p>
      </div>
    );
  },
});

// ── FORGE-ROUTES: BEGIN (managed by `forge add page` and `forge generate`) ──
// Entity routes are appended below this marker. Hand-editing inside this
// block is allowed, but `forge generate` may re-stitch entries — keep the
// markers intact.
//
// Format expected by the page generator: one `createRoute({...})` call
// per entity, assigned to a const, followed by an entry pushed onto
// `generatedRoutes`. Example:
//
//   const tasksListRoute = createRoute({
//     getParentRoute: () => rootRoute,
//     path: "/tasks",
//     component: lazy(() => import("@/pages/tasks/List")),
//   });
//   generatedRoutes.push(tasksListRoute);
//
// `unknown[]` keeps the array assignable without forcing every entry
// through a single concrete route generic — tanstack-router types each
// `createRoute` call against its own search/param shape, and a single
// homogenous element type would force every entity route into the same
// shape.
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const generatedRoutes: any[] = [];
// ── FORGE-ROUTES: END ──

const routeTree = rootRoute.addChildren([indexRoute, ...generatedRoutes]);

export const router = createRouter({ routeTree });

// Register router type for autocomplete and type-safe Link / navigate.
declare module "@tanstack/react-router" {
  interface Register {
    router: typeof router;
  }
}
