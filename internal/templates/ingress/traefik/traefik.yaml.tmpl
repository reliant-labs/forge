# Forge-vendored Traefik install. Refresh procedure:
#
#   1. Bump VERSION (sibling file) to the new traefik=vX.Y.Z.
#   2. Pull the upstream traefik-helm-chart at that tag, run
#      `helm template traefik --set providers.kubernetesGateway.enabled=true`,
#      strip release-name annotations.
#   3. Reconcile this file's resources against the templated output.
#
# What's here: namespace, ServiceAccount, ClusterRole + binding for
# Gateway API resources, Deployment running the pinned traefik image
# with --providers.kubernetesgateway=true, and a ClusterIP Service
# Traefik exposes its proxied listeners on. We deliberately omit the
# dashboard/IngressRoute CRDs — projects on the forge Gateway API
# path don't need them, and skipping keeps the install surface area
# small and audit-friendly.
#
# This file is rendered per-project at `forge dev cluster up` time by
# internal/cli/dev_cluster_ingress.go: the dev env's KCL Gateway
# listeners are projected into `.Entrypoints`, and one
# `--entrypoints.<name>.address=:<port>` arg, one containerPort, and
# one Service port are emitted per listener. Traefik v3.2's
# kubernetesgateway provider does NOT dynamically create listener
# sockets from Gateway.spec.listeners[*].port — each port needs a
# matching static entrypoint declared at install time. Adding or
# removing a Gateway listener requires a re-run of
# `forge dev cluster up` to pick up the new entrypoints (idempotent).
---
apiVersion: v1
kind: Namespace
metadata:
  name: traefik-system
  labels:
    app.kubernetes.io/managed-by: forge
    app.kubernetes.io/part-of: forge-ingress
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: traefik
  namespace: traefik-system
  labels:
    app.kubernetes.io/managed-by: forge
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: traefik
  labels:
    app.kubernetes.io/managed-by: forge
rules:
  - apiGroups: [""]
    resources: ["services", "endpoints", "secrets", "namespaces", "configmaps"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["discovery.k8s.io"]
    resources: ["endpointslices"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["gateway.networking.k8s.io"]
    resources:
      - gatewayclasses
      - gateways
      - httproutes
      - grpcroutes
      - referencegrants
      - tlsroutes
      - tcproutes
    verbs: ["get", "list", "watch"]
  - apiGroups: ["gateway.networking.k8s.io"]
    resources:
      - gatewayclasses/status
      - gateways/status
      - httproutes/status
      - grpcroutes/status
      - tlsroutes/status
      - tcproutes/status
    verbs: ["update", "patch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: traefik
  labels:
    app.kubernetes.io/managed-by: forge
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: traefik
subjects:
  - kind: ServiceAccount
    name: traefik
    namespace: traefik-system
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: traefik
  namespace: traefik-system
  labels:
    app.kubernetes.io/name: traefik
    app.kubernetes.io/managed-by: forge
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: traefik
  template:
    metadata:
      labels:
        app.kubernetes.io/name: traefik
    spec:
      serviceAccountName: traefik
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: traefik
          # Pinned per VERSION sibling file. Refresh in lockstep.
          image: traefik:v3.2.1
          args:
            - --providers.kubernetesgateway=true
            - --log.level=INFO
            - --accesslog=true
            - --metrics.prometheus=true
            - --ping=true
            {{- range .Entrypoints }}
            - --entrypoints.{{ .Name }}.address=:{{ .Port }}
            {{- end }}
          ports:
            - name: ping
              containerPort: 8080
              protocol: TCP
            {{- range .Entrypoints }}
            - name: {{ .Name }}
              containerPort: {{ .Port }}
              # hostPort binds the k3d node's port directly to this
              # pod's port. Without it, the k3d serverlb nginx forwards
              # host:<port> -> node:<port>, but nothing on the node
              # listens there — the cluster-IP Service below is reachable
              # only via its ClusterIP, which the serverlb can't see. The
              # symptom is curl on the host getting an "empty reply from
              # server" (TCP connects to the k3d LB but the proxied
              # node:<port> backend is silent). hostPort is the
              # canonical single-node-k3d ingress fix: Traefik's pod
              # becomes the node-level listener for each entrypoint.
              hostPort: {{ .Port }}
              protocol: TCP
            {{- end }}
          # Listener ports above are derived from the dev env's KCL
          # Gateway resources at `forge dev cluster up` time. The k3d
          # port mapping (driven by deploy/k3d-ports.yaml) exposes the
          # listener ports through to the host.
          livenessProbe:
            httpGet:
              path: /ping
              port: ping
            initialDelaySeconds: 10
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /ping
              port: ping
            initialDelaySeconds: 5
            failureThreshold: 1
          resources:
            requests:
              cpu: 100m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
          securityContext:
            runAsNonRoot: true
            runAsUser: 65532
            runAsGroup: 65532
            readOnlyRootFilesystem: true
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
              add: ["NET_BIND_SERVICE"]
---
apiVersion: v1
kind: Service
metadata:
  name: traefik
  namespace: traefik-system
  labels:
    app.kubernetes.io/name: traefik
    app.kubernetes.io/managed-by: forge
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: traefik
  # One Service port per Gateway listener (templated from .Entrypoints
  # at install time). The k3d loadbalancer maps host ports to this
  # Service; without explicit ports here, the in-cluster forward has
  # nothing to land on and curl returns HTTP 000.
  ports:
    - name: ping
      port: 8080
      targetPort: ping
      protocol: TCP
    {{- range .Entrypoints }}
    - name: {{ .Name }}
      port: {{ .Port }}
      targetPort: {{ .Name }}
      protocol: TCP
    {{- end }}
