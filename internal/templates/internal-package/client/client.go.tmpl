package {{.Name}}

import (
	"context"
	"fmt"
	"io"
	"log/slog"
	"net/http"
	"time"

	"{{.Module}}/pkg/config"
)

// Deps contains the dependencies for the {{.Name}} client.
type Deps struct {
	Logger *slog.Logger
	Config *config.Config
}

// client implements Service by calling the external API.
type client struct {
	deps    Deps
	http    *http.Client
	baseURL string
}

// New creates a new {{.Name}} client.
func New(deps Deps) Service {
	return &client{
		deps: deps,
		http: &http.Client{
			Timeout: 30 * time.Second,
		},
		// TODO: Set your base URL from config:
		// baseURL: deps.Config.{{.Name | pascalCase}}BaseURL,
		baseURL: "https://api.example.com",
	}
}

// HealthCheck verifies connectivity to the external service.
func (c *client) HealthCheck(ctx context.Context) error {
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, c.baseURL+"/health", nil)
	if err != nil {
		return fmt.Errorf("create request: %w", err)
	}

	resp, err := c.do(req)
	if err != nil {
		return fmt.Errorf("health check: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		return fmt.Errorf("health check returned status %d", resp.StatusCode)
	}
	return nil
}

// do executes an HTTP request with standard headers.
func (c *client) do(req *http.Request) (*http.Response, error) {
	req.Header.Set("Content-Type", "application/json")
	// TODO: Add authentication header from config:
	// req.Header.Set("Authorization", "Bearer "+c.deps.Config.{{.Name | pascalCase}}APIKey)

	resp, err := c.http.Do(req)
	if err != nil {
		return nil, fmt.Errorf("{{.Name}} request %s %s: %w", req.Method, req.URL.Path, err)
	}

	if resp.StatusCode >= 400 {
		body, _ := io.ReadAll(io.LimitReader(resp.Body, 1024))
		resp.Body.Close()
		return nil, fmt.Errorf("{{.Name}} %s %s returned %d: %s", req.Method, req.URL.Path, resp.StatusCode, string(body))
	}

	return resp, nil
}
