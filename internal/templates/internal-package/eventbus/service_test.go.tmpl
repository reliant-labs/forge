package {{.Name}}

import (
	"context"
	"log/slog"
	"testing"

	"{{.Module}}/pkg/config"
)

func TestPublishSubscribe(t *testing.T) {
	bus := New(Deps{
		Logger: slog.Default(),
		Config: &config.Config{},
	})

	ctx := context.Background()
	received := make(chan Event, 1)

	err := bus.Subscribe(ctx, "test.topic", func(ctx context.Context, e Event) error {
		received <- e
		return nil
	})
	if err != nil {
		t.Fatalf("Subscribe failed: %v", err)
	}

	evt := Event{ID: "1", Type: "test.created", Payload: []byte(`{"foo":"bar"}`)}
	if err := bus.Publish(ctx, "test.topic", evt); err != nil {
		t.Fatalf("Publish failed: %v", err)
	}

	select {
	case got := <-received:
		if got.ID != evt.ID {
			t.Errorf("got event ID %q, want %q", got.ID, evt.ID)
		}
	default:
		t.Fatal("no event received")
	}
}
