//	        "SELECT user_id, email, org_id, role FROM api_keys WHERE key = $1 AND revoked_at IS NULL", key).
//	        Scan(&claims.UserID, &claims.Email, &claims.OrgID, &claims.Role)
//	    if err != nil {
//	        return nil, fmt.Errorf("invalid API key")
//	    }
//	    return &claims, nil
//	}
//
// Then install it (pkg/app/post_bootstrap.go):
//
//	middleware.SetGeneratedKeyValidator(&DBKeyValidator{db: app.DB})
