package middleware

// KeyValidator is aliased from auth.KeyValidator in auth_gen.go.
//
// To wire API-key auth, implement KeyValidator with your storage backend
// (database, cache, etc.) and install it via
// middleware.SetGeneratedKeyValidator from pkg/app/setup.go or
// pkg/app/post_bootstrap.go (both run before the listener binds). The
// generated cmd/server.go already mounts the header-aware interceptor;
// until your validator is installed, API-key requests fail closed.
//
// Example implementation:
//
//	type DBKeyValidator struct {
//	    db *sql.DB
//	}
