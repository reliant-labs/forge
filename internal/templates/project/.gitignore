cmd/version.go
cmd/otel.go
pkg/middleware/recovery.go
pkg/middleware/logging.go
pkg/middleware/http.go
pkg/middleware/audit.go
pkg/middleware/authz.go

# Forge internal state
.forge/
# But keep checksums.json — it tracks what forge generated so other
# developers' `forge generate` can detect user modifications.
!.forge/checksums.json

# Reliant / forge project conventions
#
# The following files encode shared project conventions for LLM-driven
# development and are INTENTIONALLY committed to the repository, not ignored:
#
#   .reliant/          — forge-managed conventions, project metadata, skills
#   reliant.md         — user-owned project memory file
#   .mcp.json          — project-level MCP server config
#   .mcp.json.example  — documentation of opt-in MCP servers
#
# Do not add these to .gitignore. If you need to keep local-only overrides,
# create a `.mcp.local.json` or similar and ignore that instead.