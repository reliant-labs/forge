// app_extras.go is YOUR code — forge generate will never overwrite it.
//
// AppExtras is embedded into the forge-owned *App struct as a pointer
// (see pkg/app/app_gen.go). Any field you add here is reachable via
// `app.<Field>` thanks to Go's field promotion, so call sites stay
// uniform whether the field is forge-managed (DB, ORM) or user-managed
// (anything you add below).
//
// To add a new dependency:
//   1. Declare the field on AppExtras here.
//   2. Construct it in pkg/app/setup.go and assign `app.<Field> = ...`.
//   3. Add a matching field to the consuming service's `Deps` struct in
//      handlers/<svc>/service.go.
//   4. Run `forge generate` — wire_gen resolves the field by exact-name
//      match against AppExtras and emits `<Field>: app.<Field>`.
//
// Example:
//
//	type AppExtras struct {
//	    Repo  db.Repository
//	    Audit audit.Sink
//	    Stripe *stripe.Client
//	}
//
//forge:scaffold one-shot
//forge:allow
package app

// AppExtras is the user-owned extension surface for *App. Add fields
// here as you grow the application; setup.go assigns them, wire_gen
// reads them.
type AppExtras struct {
	// Add user-extension fields here. The struct can be empty until
	// the first dependency outgrows the bare {Logger, Config} pair.
}
