// Runtime body for the {{.Name}} binary. The cobra entry point lives
// in cmd/{{.Package}}.go and delegates here via Runner.Run.
//
// The default scaffold is a long-running process that blocks until
// ctx is cancelled (typically by SIGINT/SIGTERM in production).
// Replace the body of Run with your binary's actual loop —
// reverse-proxy serve, NATS-consumer dispatch, sweeper tick, etc.
//
// Patterns the scaffold deliberately solves (so you don't have to):
//   - Construction-time validateDeps gate (in contract.go::New).
//   - Graceful-shutdown via ctx — the cobra adapter wires SIGINT
//     into ctx and Run is the propagation point.
//   - Compile-time interface compliance (`var _ Service = (*Runner)(nil)`).
package {{.Package}}

import (
	"context"
)

// Runner is the concrete Service implementation. Hold all binary-
// specific runtime state on this struct (caches, connections,
// goroutine wait groups). The cobra adapter constructs one Runner
// per process via New(deps) and calls Run once.
type Runner struct {
	deps Deps
}

// Compile-time check: Runner must implement Service.
var _ Service = (*Runner)(nil)

// Name returns the binary identifier used in structured logs.
func (r *Runner) Name() string { return "{{.Name}}" }

