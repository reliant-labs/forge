func (r *Runner) Run(ctx context.Context) error {
	r.deps.Logger.Info("{{.Name}} runtime entered (placeholder Run body)")

	// TODO: Implement your binary's runtime loop. The placeholder body
	// blocks on ctx so the scaffold compiles and exits cleanly on
