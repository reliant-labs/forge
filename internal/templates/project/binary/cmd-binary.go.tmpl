// forge:scaffold one-shot — binary cobra subcommand; canonical pattern in `forge skill load binaries`.
// {{.Name}} cobra subcommand. Forge-scaffolded entry point for the
// {{.Name}} binary; the runtime body lives in
// internal/{{.Package}}/{{.Package}}.go where it can be unit-tested
// without a cobra fixture.
//
// Hand-edit this file to add binary-specific flags or environment
// variables. The wiring is intentionally thin: load config, build
// dependencies, hand off to {{.Package}}.New(deps).Run(ctx). If your
// binary grows past 50 LOC of glue here, prefer pushing it into the
// internal/{{.Package}}/ package and keep this file as the cobra adapter.
//
// See the binaries skill (`forge skill load binaries`) for when to use
// `forge add binary` vs `forge add worker` vs `forge add service`.
package main

import (
	"context"
	"fmt"
	"log/slog"
	"os"
	"os/signal"
	"syscall"

	"github.com/spf13/cobra"

	"{{.Module}}/internal/{{.Package}}"
	"{{.Module}}/pkg/config"
)

// {{.Package}}Cmd is the cobra subcommand for the {{.Name}} binary.
//
// It is intentionally registered against the same rootCmd as
// `cmd/server.go`'s `serverCmd` so a single binary build serves every
// process shape (server, operator, this binary). At deploy time KCL
// emits one Deployment per binary that invokes the matching subcommand.
var {{.Package}}Cmd = &cobra.Command{
	Use:   "{{.Name}}",
	Short: "Run the {{.Name}} binary",
	Long: `Run the {{.Name}} binary.

Long-running process scaffolded via 'forge add binary {{.Name}}'. The
runtime loop lives in internal/{{.Package}}/. Hand-edit
internal/{{.Package}}/{{.Package}}.go to implement the actual logic;
this file is the thin cobra wrapper.`,
	RunE: run{{.Package | pascalCase}},
}

func init() {
	// Reuse the server's flag set so the same env-var driven Config
	// (DATABASE_URL, NATS, log level, OTel, etc.) is available to the
	// binary without re-loading. Drop this line if your binary takes
	// a strict subset; add binary-specific flags below.
	{{.Package}}Cmd.Flags().AddFlagSet(serverCmd.Flags())
	rootCmd.AddCommand({{.Package}}Cmd)
}

func run{{.Package | pascalCase}}(cmd *cobra.Command, _ []string) error {
	cfg, err := config.Load(cmd)
	if err != nil {
		return fmt.Errorf("load config: %w", err)
	}
	if verr := cfg.Validate(); verr != nil {
		return fmt.Errorf("invalid configuration: %w", verr)
	}

	logger := slog.New(slog.NewJSONHandler(os.Stdout, nil))
	logger = logger.With("binary", "{{.Name}}")

	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	svc, err := {{.Package}}.New({{.Package}}.Deps{
		Logger: logger,
		Config: cfg,
	})
	if err != nil {
		return fmt.Errorf("construct {{.Name}}: %w", err)
	}

	logger.Info("{{.Name}} starting")
	if err := svc.Run(ctx); err != nil {
		logger.Error("{{.Name}} run error", "error", err)
		return err
	}
	logger.Info("{{.Name}} stopped cleanly")
	return nil
}
