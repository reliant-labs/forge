// Bootstrap constructs all packages and services and registers every
// service on the mux. Identical to BootstrapOnly with an empty filter.
//
// Wiring shape (2026-06 appkit table migration): appkit.Run calls the
// user-owned Setup(app, cfg) first (edit pkg/app/setup.go — never
// overwritten by generate; it builds infrastructure, assigns it onto
// App fields, and may populate app.Hooks), then each row constructs
// via codegen'd wireXxxDeps(app, cfg, logger, ...) so validateDeps()
// gates the complete dep set at New().
func Bootstrap(mux *http.ServeMux, logger *slog.Logger, cfg *config.Config, opts ...connect.HandlerOption) (*App, error) {
	return BootstrapOnly(mux, logger, cfg, nil, opts...)
}

