	// inside wireXxxDeps; the mount closures re-read the same instance so
	// interceptor + handler stay in lockstep. cfg.Mode() is THE dev-mode
	// gate (typed, zero value Production, derived from ENVIRONMENT in
	// pkg/config) — the same value the auth middleware and auth packs
	// receive by injection, so the three gates can never disagree.
	devMode := cfg.Mode().IsDev()
	// Loud-by-default dev-mode banner: when devMode is on the per-service
	// Authorizer is swapped to middleware.DevAuthorizer{} (allow-all).
	// A prod manifest that accidentally sets ENVIRONMENT=development gets
	// a screaming Warn at every container start instead of silently
	// shipping with authz disabled.
	if devMode {
		logger.Warn("DEV MODE — authorization checks disabled (DevAuthorizer is allow-all); set ENVIRONMENT to anything other than \"development\" in non-dev environments",
{{- if index .ConfigFields "Environment"}}
			"environment", cfg.Environment,
{{- end}}
		)
