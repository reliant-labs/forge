{{- end}}
		},
{{- end}}
{{- if .Services}}
		// Service rows come from the user-owned registration file
		// (pkg/app/services.go). Serving a service = listing its
		// serviceRow there; the row constructors themselves are
		// generated guardrails in pkg/app/services_gen.go.
		Services: RegisteredServices(app, cfg, logger, devMode, opts...),
{{- end}}
{{- if .Workers}}
		// Workers — construction passes through app.Hooks.ConstructWorker.
		Workers: []appkit.WorkerDef{
{{- range .Workers}}
			{Name: "{{.Name}}", Construct: func() error {
