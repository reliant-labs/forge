{{- if .HasLogger}}
					Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
					Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
					{{.DepsField}}: app.{{.DepsField}},
{{- end}}
				})
				if err != nil {
					return fmt.Errorf("initializing {{.ImportPath}}: %w", err)
				}
				app.Packages.{{.FieldName}} = {{.VarName}}Impl
{{- else}}
				app.Packages.{{.FieldName}} = {{.Alias}}.New({{.Alias}}.Deps{
{{- if .HasLogger}}
					Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
					Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
					{{.DepsField}}: app.{{.DepsField}},
{{- end}}
