		// Hooks are read AFTER Setup so setup.go assignments are observed.
		Setup: func() error { return Setup(app, cfg) },
		Hooks: func() *appkit.Hooks { return &app.Hooks },
{{- if .DiagnosticsEnabled}}
{{- if .StrictWiringEnabled}}
		// forge.yaml features.strict_wiring: diagnostics exit the process.
		Diagnostics: appkit.DiagnosticsStrict,
{{- else}}
		// forge.yaml features.diagnostics: warn-log unwired scaffolds.
		Diagnostics: appkit.DiagnosticsLog,
{{- end}}
{{- end}}
{{- if .Packages}}
		// Internal packages — constructed before services, in row order.
		Packages: []appkit.PackageDef{
{{- range .Packages}}
			{Name: "{{.Name}}", Construct: func() error {
{{- if .CanonicalAppField}}
