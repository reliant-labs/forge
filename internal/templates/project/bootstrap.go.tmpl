				// cannot auto-wire from App/AppExtras, so constructing
				// here would yield a second, half-built instance.
				// User-owned setup.go builds the canonical, fully-wired
				// {{.Alias}}.Service on app.{{.CanonicalAppField}} — and
				// Setup runs before this table — so alias the slot to it.
				app.Packages.{{.FieldName}} = app.{{.CanonicalAppField}}
{{- else if .Fallible}}
