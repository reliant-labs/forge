{{- if .Fallible}}
				{{.Package}}Wkr, err := {{.Alias}}.New({{.Package}}WkrDeps)
				if err != nil {
					return fmt.Errorf("initializing {{.Package}} worker: %w", err)
				}
				app.Workers.{{.FieldName}} = {{.Package}}Wkr
{{- else}}
				app.Workers.{{.FieldName}} = {{.Alias}}.New({{.Package}}WkrDeps)
{{- end}}
				return nil
			}},
{{- end}}
		},
{{- end}}
{{- if .Operators}}
		// Operators — constructed here; manager hookup is in RunOperators.
		Operators: []appkit.OperatorDef{
{{- range .Operators}}
			{Name: "{{.Name}}", Construct: func() error {
				{{.Package}}OpDeps := wireOperator{{.FieldName}}Deps(app, cfg, logger)
{{- if .Fallible}}
				{{.Package}}Op, err := {{.Alias}}.New({{.Package}}OpDeps)
				if err != nil {
					return fmt.Errorf("initializing {{.Package}} operator: %w", err)
				}
				app.Operators.{{.FieldName}} = {{.Package}}Op
{{- else}}
				app.Operators.{{.FieldName}} = {{.Alias}}.New({{.Package}}OpDeps)
{{- end}}
				return nil
			}},
{{- end}}
		},
{{- end}}
{{- if and .RESTEnabled .Services}}
		// REST (forge.yaml api.rest): appkit builds the vanguard transcoder
