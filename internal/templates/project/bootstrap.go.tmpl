{{- if .Services}}
		Services: &Services{},
{{- end}}
{{- if .Workers}}
		Workers:  &Workers{},
{{- end}}
{{- if .Operators}}
		Operators: &Operators{},
{{- end}}
{{- if .Packages}}
		Packages: &Packages{},
{{- end}}
