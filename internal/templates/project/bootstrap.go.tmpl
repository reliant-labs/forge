// Code generated by forge. DO NOT EDIT.
// Source: forge.yaml (services, workers, operators, packages) + proto/services/*.
//
// To customize: edit pkg/app/setup.go (user-owned, //forge:allow). This
// bootstrap.go is regenerated on every `forge generate` and any edits
// here are blown away.
//
// The App struct itself lives in pkg/app/app_gen.go (forge-owned base
// shape) + pkg/app/app_extras.go (user-owned extensions). bootstrap.go
// only knows how to ALLOCATE & POPULATE *App; the struct definition is
// hoisted so the user-extension story is purely "add a field to
// AppExtras + assign in setup.go".
package app

import (
	"context"
	"fmt"
	"log/slog"
	"maps"
	"net/http"
	"slices"

	"connectrpc.com/connect"
{{- if and .RESTEnabled .Services}}
	"connectrpc.com/vanguard"
{{- end}}
{{- if .Operators}}
	ctrl "sigs.k8s.io/controller-runtime"
{{- end}}

{{- if .DiagnosticsEnabled}}
	"github.com/reliant-labs/forge/pkg/diagnostics"
{{- end}}
	"github.com/reliant-labs/forge/pkg/serverkit"
	"{{.Module}}/pkg/config"
{{- if .Services}}
	"{{.Module}}/pkg/middleware"
{{- end}}
{{/* Import paths use .ImportPath (the directory leaf as it exists ON
     DISK, resolved by codegen's disk-first resolver) — never .Package,
     which is the Go package CLAUSE and may legally differ from the
     directory name (workers/engine_shadow may declare `package
     engineshadow`). .Alias keeps every selector site working whatever
     the clause is. */}}
{{- range .Services}}
	{{.Alias}} "{{$.Module}}/handlers/{{.ImportPath}}"
{{- end}}
{{- if and .RESTEnabled .Services}}
{{- range .ConnectImports}}
	"{{.}}"
{{- end}}
{{- end}}
{{- range .Workers}}
	{{.Alias}} "{{$.Module}}/workers/{{.ImportPath}}"
{{- end}}
{{- range .Operators}}
	{{.Alias}} "{{$.Module}}/operators/{{.ImportPath}}"
{{- end}}
{{- range .Packages}}
	{{.Alias}} "{{$.Module}}/internal/{{.ImportPath}}"
{{- end}}
)
{{if .Packages}}
// Packages holds all constructed internal package instances.
type Packages struct {
{{- range .Packages}}
	{{.FieldName}} {{.Alias}}.Service
{{- end}}
}
{{end}}
// Services holds all constructed service instances.
type Services struct {
{{- range .Services}}
	{{.FieldName}} *{{.Alias}}.Service
{{- end}}
}

// WorkerInstance wraps a worker with its lifecycle methods.
type WorkerInstance struct {
	name   string
	start  func(ctx context.Context) error
	stop   func(ctx context.Context) error
}

// Name returns the worker's identifier.
func (w *WorkerInstance) Name() string { return w.name }

// Start blocks until ctx is cancelled.
func (w *WorkerInstance) Start(ctx context.Context) error { return w.start(ctx) }

// Stop is called during graceful shutdown.
func (w *WorkerInstance) Stop(ctx context.Context) error { return w.stop(ctx) }
{{if .Workers}}
// Workers holds all constructed worker instances.
type Workers struct {
{{- range .Workers}}
	{{.FieldName}} *{{.Alias}}.Worker
{{- end}}
}
{{end}}
// OperatorInstance wraps an operator controller for lifecycle management.
// Emitted unconditionally so cmd/server.go's operator-gating helper
// compiles even when the project has no operators yet.
type OperatorInstance struct {
	name string
{{- if .Operators}}
	setupWithManager func(mgr ctrl.Manager) error
{{- end}}
}

// Name returns the operator's identifier.
func (o *OperatorInstance) Name() string { return o.name }
{{- if .Operators}}

// SetupWithManager registers the controller with the manager.
func (o *OperatorInstance) SetupWithManager(mgr ctrl.Manager) error { return o.setupWithManager(mgr) }

// Operators holds all constructed operator controller instances.
type Operators struct {
{{- range .Operators}}
	{{.FieldName}} *{{.Alias}}.Controller
{{- end}}
}
{{- end}}
// WorkerList returns all workers as a slice for serverkit lifecycle
// management. WorkerInstance satisfies serverkit.Worker by virtue of its
// Name/Start/Stop methods, so the slice element type is the interface.
func (a *App) WorkerList() []serverkit.Worker {
{{- if .Workers}}
	return []serverkit.Worker{
{{- range .Workers}}
		&WorkerInstance{name: "{{.Name}}", start: a.Workers.{{.FieldName}}.Start, stop: a.Workers.{{.FieldName}}.Stop},
{{- end}}
	}
{{- else}}
	return nil
{{- end}}
}
// OperatorList returns all operators as a slice for serverkit lifecycle
// gating. OperatorInstance satisfies serverkit.Operator via its Name
// method. Emitted unconditionally so the serverkit Application contract
// is satisfied even in projects with no operators (returns nil there).
func (a *App) OperatorList() []serverkit.Operator {
{{- if .Operators}}
	return []serverkit.Operator{
{{- range .Operators}}
		&OperatorInstance{name: "{{.Name}}", setupWithManager: a.Operators.{{.FieldName}}.SetupWithManager},
{{- end}}
	}
{{- else}}
	return nil
{{- end}}
}
{{if .Operators}}
// HasOperators returns true if the application has any operators configured.
func (a *App) HasOperators() bool {
	return len(a.OperatorList()) > 0
}

// RunOperators creates a controller manager, registers all operator controllers,
// and starts the manager. It blocks until ctx is cancelled or an error occurs.
// The caller (serverkit) runs this in a goroutine.
//
// healthProbeAddr is forwarded from serverkit.Config.OperatorHealthProbeAddr;
// when non-empty it binds a /healthz + /readyz listener on that address for
// the controller-runtime manager. Empty leaves the manager without a probe
// listener (the default — vanilla forge projects don't bind one).
//
// In environments with no Kubernetes cluster reachable (vanilla docker
// compose dev, fresh laptop, CI without a kind/k3d cluster), kubeconfig
// resolution returns an error rather than panicking — the binary continues
// without operators rather than crashing the whole process. NATS already
// degrades this way; this matches that pattern.
func (a *App) RunOperators(ctx context.Context, logger *slog.Logger, healthProbeAddr string) error {
	cfg, err := ctrl.GetConfig()
	if err != nil {
		logger.Warn("operators disabled: no Kubernetes cluster reachable", "error", err)
		return nil
	}

	mgr, err := ctrl.NewManager(cfg, ctrl.Options{
		LeaderElection:         true,
		LeaderElectionID:       "{{$.Module}}-leader",
		HealthProbeBindAddress: healthProbeAddr,
	})
	if err != nil {
		return fmt.Errorf("creating controller manager: %w", err)
	}

	// Register CRD schemes
{{- range .Operators}}
	if err := {{.Alias}}.AddToScheme(mgr.GetScheme()); err != nil {
		return fmt.Errorf("adding {{.Name}} scheme: %w", err)
	}
{{- end}}

	// Setup controllers. OperatorList returns serverkit.Operator values;
	// we type-assert back to *OperatorInstance to reach SetupWithManager
	// (the controller-runtime entry point isn't part of the serverkit
	// interface — it's implementation-specific to this codegen shape).
	for _, op := range a.OperatorList() {
		inst, ok := op.(*OperatorInstance)
		if !ok {
			return fmt.Errorf("operator %q has unexpected type %T", op.Name(), op)
		}
		if err := inst.SetupWithManager(mgr); err != nil {
			return fmt.Errorf("setting up controller %q: %w", op.Name(), err)
		}
		logger.Info("registered operator controller", "controller", op.Name())
	}

	logger.Info("starting controller manager")
	return mgr.Start(ctx)
}
{{else}}
// HasOperators returns true if the application has any operators configured.
func (a *App) HasOperators() bool {
	return false
}

// RunOperators is a no-op when no operators are configured.
// Signature matches serverkit.Application (with healthProbeAddr) so the
// generated App satisfies the interface unconditionally.
func (a *App) RunOperators(ctx context.Context, logger *slog.Logger, healthProbeAddr string) error {
	return nil
}
{{end}}
// Shutdown gracefully shuts down all services and packages.
// Add cleanup here if your application acquires resources that need explicit teardown.
// For each service that holds resources, call its Close/Shutdown method:
{{- range .Services}}
//   if err := a.Services.{{.FieldName}}.Close(); err != nil { return err }
{{- end}}
func (a *App) Shutdown(ctx context.Context) error {
	return nil
}

// Bootstrap constructs all packages and services, registers services with the mux.
//
// Wiring shape (2026-05-07 wire-gen migration):
//   1. Allocate &App with Logger/Config so user-owned Setup() can reach
//      both. Setup builds infrastructure (DB pool, NATS, audit sink) and
//      assigns the results onto user-extendable App fields.
//   2. Construct services via codegen'd wireXxxDeps(app, cfg, logger,
//      devMode), which assembles the FULL Deps from app.<Field> lookups.
//      validateDeps() then gates the complete dep set at New(), so per-RPC
//      `if s.deps.Repo == nil` boilerplate is unnecessary.
//   3. Register each *Service on the mux.
//
// The pre-2026-05-07 ApplyDeps two-phase is gone — wire_gen.go reads from
// *App directly instead of mutating the *Service post-registration.
func Bootstrap(mux *http.ServeMux, logger *slog.Logger, cfg *config.Config, opts ...connect.HandlerOption) (*App, error) {
	app := &App{
{{- if .Services}}
		Services: &Services{},
{{- end}}
{{- if .Workers}}
		Workers:  &Workers{},
{{- end}}
{{- if .Operators}}
		Operators: &Operators{},
{{- end}}
{{- if .Packages}}
		Packages: &Packages{},
{{- end}}
		// AppExtras is embedded as a pointer (see pkg/app/app_gen.go) so
		// user fields are reachable via `app.<Field>` field promotion.
		// Always allocate — Setup may assign promoted fields, and an
		// empty AppExtras is the conventional zero-value.
		AppExtras: &AppExtras{},
	}

	// User customizations — edit pkg/app/setup.go (never overwritten by
	// generate). Setup builds infrastructure (DB pool, NATS, audit) and
	// assigns it onto user-extendable App fields. wire_gen below reads
	// those fields back when constructing each service's Deps.
	if err := Setup(app, cfg); err != nil {
		return nil, fmt.Errorf("setup: %w", err)
	}
{{- if .DiagnosticsEnabled}}

	// Emit any unwired-scaffold diagnostics the codegen pipeline
	// recorded in pkg/app/diagnostics_gen.go's init(). One structured
	// warn log line per registered entry, then a summary roll-up. The
	// emit happens AFTER Setup so the operator can read the warnings
	// before any service / worker starts.
	//
	// Toggled by `forge.yaml: features.diagnostics: true` — default off
	// so existing projects don't suddenly start logging warns on regen.
	// `features.strict_wiring: true` swaps LogEmitter for StrictEmitter,
	// which os.Exit(1)s after the summary when any diagnostic is
	// registered (production-grade enforcement).
{{- if .StrictWiringEnabled}}
	diagnostics.Default.Boot(diagnostics.NewStrictEmitter(diagnostics.NewLogEmitter(logger)))
{{- else}}
	diagnostics.Default.Boot(diagnostics.NewLogEmitter(logger))
{{- end}}
{{- end}}
{{if .Packages}}
	// Construct internal packages (services may depend on them).
{{- range .Packages}}
{{- if .Fallible}}
	{{.VarName}}Impl, err := {{.Alias}}.New({{.Alias}}.Deps{
{{- if .HasLogger}}
		Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
		Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
		{{.DepsField}}: app.{{.DepsField}},
{{- end}}
	})
	if err != nil {
		return nil, fmt.Errorf("initializing {{.ImportPath}}: %w", err)
	}
{{- else}}
	{{.VarName}}Impl := {{.Alias}}.New({{.Alias}}.Deps{
{{- if .HasLogger}}
		Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
		Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
		{{.DepsField}}: app.{{.DepsField}},
{{- end}}
	})
{{- end}}
	app.Packages.{{.FieldName}} = {{.VarName}}Impl
{{- end}}
{{end}}
{{- if .Services}}
{{- if index .ConfigFields "Environment"}}
	devMode := cfg.Environment == "development"
{{- else}}
	devMode := false
{{- end}}
	// Loud-by-default dev-mode banner: when devMode is on the per-service
	// Authorizer is swapped to middleware.DevAuthorizer{} (allow-all).
	// A prod manifest that accidentally sets ENVIRONMENT=development gets
	// a screaming Warn at every container start instead of silently
	// shipping with authz disabled.
	if devMode {
		logger.Warn("DEV MODE — authorization checks disabled (DevAuthorizer is allow-all); set ENVIRONMENT to anything other than \"development\" in non-dev environments",
			"environment", cfg.Environment,
		)
	}
{{- end}}
{{- range .Services}}
	// wireXxxDeps assembles the full Deps from app fields + cfg.
	// devMode flows in so the Authorizer field gets swapped to
	// middleware.DevAuthorizer{} in development. The same Authorizer
	// instance is then re-read from Deps to install AuthzInterceptor
	// on the mux — sharing the instance keeps interceptor + handler
	// in lockstep when the swap happens.
	{{.Package}}Deps := wire{{.FieldName}}Deps(app, cfg, logger, devMode)
	{{.Package}}Svc, err := {{.Alias}}.New({{.Package}}Deps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} service: %w", err)
	}
	app.Services.{{.FieldName}} = {{.Package}}Svc
	{{.Package}}Opts := slices.Concat(opts, []connect.HandlerOption{connect.WithInterceptors(
		middleware.AuthzInterceptor({{.Package}}Deps.Authorizer),
	)})
	app.Services.{{.FieldName}}.Register(mux, {{.Package}}Opts...)
	app.Services.{{.FieldName}}.RegisterHTTP(mux, middleware.HTTPStack(logger))
{{- if .HasWebhooks}}
	// Auto-wire generated webhook routes (forge.yaml declares webhooks
	// for this service). RegisterWebhookRoutes is emitted by forge in
	// handlers/{{.Package}}/webhook_routes_gen.go; the user-owned
	// RegisterHTTP stub is left untouched so user-added REST/callback
	// handlers continue to work alongside the generated webhooks.
	app.Services.{{.FieldName}}.RegisterWebhookRoutes(mux, middleware.HTTPStack(logger))
{{- end}}
{{- end}}
{{if .Workers}}
{{- range .Workers}}
	// wireWorker{{.FieldName}}Deps assembles the full Deps from app
	// fields + cfg, mirroring the per-service wireXxxDeps shape so
	// runtime collaborators (k8s client, NATS, etc.) reach the worker
	// before its first Start().
	{{.Package}}WkrDeps := wireWorker{{.FieldName}}Deps(app, cfg, logger)
{{- if .Fallible}}
	{{.Package}}Wkr, err := {{.Alias}}.New({{.Package}}WkrDeps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} worker: %w", err)
	}
	app.Workers.{{.FieldName}} = {{.Package}}Wkr
{{- else}}
	app.Workers.{{.FieldName}} = {{.Alias}}.New({{.Package}}WkrDeps)
{{- end}}
{{- end}}
{{end}}
{{- if .Operators}}
	// Construct operators (controllers are wired to the manager in cmd-server.go)
{{- range .Operators}}
	// wireOperator{{.FieldName}}Deps assembles the full Deps from app
	// fields + cfg, mirroring the per-service wireXxxDeps shape so
	// runtime collaborators (k8s client, audit logger, etc.) reach the
	// controller before SetupWithManager.
	{{.Package}}OpDeps := wireOperator{{.FieldName}}Deps(app, cfg, logger)
{{- if .Fallible}}
	{{.Package}}Op, err := {{.Alias}}.New({{.Package}}OpDeps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} operator: %w", err)
	}
	app.Operators.{{.FieldName}} = {{.Package}}Op
{{- else}}
	app.Operators.{{.FieldName}} = {{.Alias}}.New({{.Package}}OpDeps)
{{- end}}
{{- end}}
{{end}}
{{- if and .RESTEnabled .Services}}
	// REST transcoder: vanguard wraps the Connect mux and translates
	// REST↔Connect at runtime based on google.api.http annotations on
	// RPCs. The wrapped handler is stored on the App; serverkit reads it
	// via app.RESTHandler() (defined in app_gen.go) and serves it in place
	// of the bare mux when non-nil.
	// CRUD RPCs gain default REST URLs via the crud-gen annotation pass;
	// hand-written RPCs need the annotation in their .proto to participate.
	{
		vanguardSvcs := []*vanguard.Service{
{{- range .Services}}
			vanguard.NewService({{.ConnectPkg}}.{{.ProtoServiceName}}Name, mux),
{{- end}}
		}
		transcoder, terr := vanguard.NewTranscoder(vanguardSvcs)
		if terr != nil {
			return nil, fmt.Errorf("init vanguard REST transcoder: %w", terr)
		}
		app.restHandler = transcoder
	}
{{- end}}
	return app, nil
}

// BootstrapOnly constructs services and registers the named ones on the mux.
//
// In binary=per-service mode (default), ALL services are constructed (they're
// lightweight structs) and only the ones in `names` are mounted on the mux.
// This prevents nil pointer panics when code references a service that wasn't
// in the requested set.
//
// In binary=shared mode (forge.yaml `binary: shared`), only the services in
// `names` are constructed AND mounted; other services' constructors are
// skipped. This makes per-service cobra subcommands (e.g. `./<project> api`)
// genuinely scope-down their dependency graph at process boot, not just their
// handler registration. Pass an empty `names` slice to mount everything (the
// canonical `./<bin> server` behavior).
func BootstrapOnly(mux *http.ServeMux, logger *slog.Logger, cfg *config.Config, names []string, opts ...connect.HandlerOption) (*App, error) {
	nameSet := make(map[string]bool, len(names))
	for _, n := range names {
		nameSet[n] = true
	}
{{- if .Services}}
	// runAll is true when no names are specified — preserves the
	// "Bootstrap == BootstrapOnly with empty filter" identity for
	// callers like `./<bin> server` that want every service. Only emitted
	// when the project has services, since runAll is consumed exclusively
	// by the per-service `if runAll || nameSet[...]` mux-registration
	// guard below; in service-less projects it would be `declared and not
	// used`.
	runAll := len(names) == 0
{{- end}}

	// Warn about unknown names
	known := map[string]bool{
{{- range .Services}}
		"{{.Name}}": true,
{{- end}}
{{- range .Workers}}
		"{{.Name}}": true,
{{- end}}
{{- range .Operators}}
		"{{.Name}}": true,
{{- end}}
	}
	for _, n := range names {
		if !known[n] {
			logger.Warn("unknown service/worker/operator name, ignoring", "name", n, "known", slices.Collect(maps.Keys(known)))
		}
	}
	// Loud filter banner: when a filter is active, name BOTH the
	// registered AND excluded services/workers/operators. Silently
	// 404-ing on excluded RPCs was a real debug-time-sink — naming the
	// excluded set up front catches "the server doesn't even register
	// this RPC" in seconds instead of after a CORS/proxy/auth rabbit
	// hole.
	if len(names) > 0 {
		var registered, excluded []string
		for name := range known {
			if nameSet[name] {
				registered = append(registered, name)
			} else {
				excluded = append(excluded, name)
			}
		}
		slices.Sort(registered)
		slices.Sort(excluded)
		logger.Warn("server filter active — RPCs for excluded names will return 404",
			"registered", registered,
			"excluded", excluded,
		)
	}
	app := &App{
{{- if .Services}}
		Services: &Services{},
{{- end}}
{{- if .Workers}}
		Workers:  &Workers{},
{{- end}}
{{- if .Operators}}
		Operators: &Operators{},
{{- end}}
{{- if .Packages}}
		Packages: &Packages{},
{{- end}}
		// AppExtras is embedded as a pointer (see pkg/app/app_gen.go) so
		// user fields are reachable via `app.<Field>` field promotion.
		// Always allocate — Setup may assign promoted fields, and an
		// empty AppExtras is the conventional zero-value.
		AppExtras: &AppExtras{},
	}

	// User customizations — edit pkg/app/setup.go (never overwritten by generate).
	// Setup runs BEFORE service construction so wireXxxDeps can read app fields.
	if err := Setup(app, cfg); err != nil {
		return nil, fmt.Errorf("setup: %w", err)
	}
{{- if .DiagnosticsEnabled}}

	// Emit unwired-scaffold diagnostics after Setup (see Bootstrap for
	// the full rationale). Same emit path; same feature gates.
{{- if .StrictWiringEnabled}}
	diagnostics.Default.Boot(diagnostics.NewStrictEmitter(diagnostics.NewLogEmitter(logger)))
{{- else}}
	diagnostics.Default.Boot(diagnostics.NewLogEmitter(logger))
{{- end}}
{{- end}}
{{if .Packages}}
	// Construct internal packages (always — services may depend on them
	// regardless of which services are selected).
{{- range .Packages}}
{{- if .Fallible}}
	{{.VarName}}Impl, err := {{.Alias}}.New({{.Alias}}.Deps{
{{- if .HasLogger}}
		Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
		Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
		{{.DepsField}}: app.{{.DepsField}},
{{- end}}
	})
	if err != nil {
		return nil, fmt.Errorf("initializing {{.ImportPath}}: %w", err)
	}
{{- else}}
	{{.VarName}}Impl := {{.Alias}}.New({{.Alias}}.Deps{
{{- if .HasLogger}}
		Logger: logger.With("package", "{{.Name}}"),
{{- end}}
{{- if .HasConfig}}
		Config: cfg,
{{- end}}
{{- range .AppFieldRefs}}
		{{.DepsField}}: app.{{.DepsField}},
{{- end}}
	})
{{- end}}
	app.Packages.{{.FieldName}} = {{.VarName}}Impl
{{- end}}
{{end}}
{{- if .Services}}
{{- if index .ConfigFields "Environment"}}
	devMode := cfg.Environment == "development"
{{- else}}
	devMode := false
{{- end}}
	// Loud-by-default dev-mode banner — see Bootstrap above for the
	// rationale. BootstrapOnly is reached by per-service subcommands and
	// host runners alike, so it gets the same banner so neither path
	// silently ships with authz disabled.
	if devMode {
		logger.Warn("DEV MODE — authorization checks disabled (DevAuthorizer is allow-all); set ENVIRONMENT to anything other than \"development\" in non-dev environments",
			"environment", cfg.Environment,
		)
	}
{{- end}}
	// Construct services. In binary=per-service mode (default), ALL services
	// are constructed up-front (they're cheap given wire_gen pulls deps from
	// app fields already populated by Setup); we only filter at
	// mux-registration time. In binary=shared mode the services list is
	// already filtered above. devMode flows through wireXxxDeps so the
	// service-owned Authorizer field gets the DevAuthorizer swap; the
	// AuthzInterceptor on the mux re-reads that same instance from Deps.
{{- range .Services}}
	{{.Package}}Deps := wire{{.FieldName}}Deps(app, cfg, logger, devMode)
	{{.Package}}Svc, err := {{.Alias}}.New({{.Package}}Deps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} service: %w", err)
	}
	app.Services.{{.FieldName}} = {{.Package}}Svc
	if runAll || nameSet["{{.Name}}"] {
		{{.Package}}Opts := slices.Concat(opts, []connect.HandlerOption{connect.WithInterceptors(
			middleware.AuthzInterceptor({{.Package}}Deps.Authorizer),
		)})
		app.Services.{{.FieldName}}.Register(mux, {{.Package}}Opts...)
		app.Services.{{.FieldName}}.RegisterHTTP(mux, middleware.HTTPStack(logger))
{{- if .HasWebhooks}}
		// Auto-wire generated webhook routes (see top-of-file comment).
		app.Services.{{.FieldName}}.RegisterWebhookRoutes(mux, middleware.HTTPStack(logger))
{{- end}}
	}
{{- end}}
{{if .Workers}}
	// Construct workers (always — they're cheap; wire_gen pulls deps
	// from app fields already populated by Setup).
{{- range .Workers}}
	{{.Package}}WkrDeps := wireWorker{{.FieldName}}Deps(app, cfg, logger)
{{- if .Fallible}}
	{{.Package}}Wkr, err := {{.Alias}}.New({{.Package}}WkrDeps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} worker: %w", err)
	}
	app.Workers.{{.FieldName}} = {{.Package}}Wkr
{{- else}}
	app.Workers.{{.FieldName}} = {{.Alias}}.New({{.Package}}WkrDeps)
{{- end}}
{{- end}}
{{end}}
{{- if .Operators}}
	// Construct operators (always — they're cheap)
{{- range .Operators}}
	{{.Package}}OpDeps := wireOperator{{.FieldName}}Deps(app, cfg, logger)
{{- if .Fallible}}
	{{.Package}}Op, err := {{.Alias}}.New({{.Package}}OpDeps)
	if err != nil {
		return nil, fmt.Errorf("initializing {{.Package}} operator: %w", err)
	}
	app.Operators.{{.FieldName}} = {{.Package}}Op
{{- else}}
	app.Operators.{{.FieldName}} = {{.Alias}}.New({{.Package}}OpDeps)
{{- end}}
{{- end}}
{{end}}
{{- if and .RESTEnabled .Services}}
	// REST transcoder: vanguard wraps the Connect mux and translates
	// REST↔Connect at runtime based on google.api.http annotations on
	// RPCs. The wrapped handler is stored on the App; serverkit reads it
	// via app.RESTHandler() (defined in app_gen.go) and serves it in place
	// of the bare mux when non-nil.
	// CRUD RPCs gain default REST URLs via the crud-gen annotation pass;
	// hand-written RPCs need the annotation in their .proto to participate.
	{
		vanguardSvcs := []*vanguard.Service{
{{- range .Services}}
			vanguard.NewService({{.ConnectPkg}}.{{.ProtoServiceName}}Name, mux),
{{- end}}
		}
		transcoder, terr := vanguard.NewTranscoder(vanguardSvcs)
		if terr != nil {
			return nil, fmt.Errorf("init vanguard REST transcoder: %w", terr)
		}
		app.restHandler = transcoder
	}
{{- end}}
	return app, nil
}