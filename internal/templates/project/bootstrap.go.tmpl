		logger.Warn("operators disabled: no Kubernetes cluster reachable", "error", err)
		return nil
	}

	mgr, err := ctrl.NewManager(cfg, ctrl.Options{
		LeaderElection:   true,
		LeaderElectionID: "{{$.Module}}-leader",
	})
	if err != nil {
		return fmt.Errorf("creating controller manager: %w", err)
	}

	// Register CRD schemes
{{- range .Operators}}
	if err := {{.Alias}}.AddToScheme(mgr.GetScheme()); err != nil {
		return fmt.Errorf("adding {{.Name}} scheme: %w", err)
	}
{{- end}}

	// Setup controllers
	for _, op := range a.OperatorList() {
		if err := op.SetupWithManager(mgr); err != nil {
			return fmt.Errorf("setting up controller %q: %w", op.Name(), err)
		}
		logger.Info("registered operator controller", "controller", op.Name())
	}

	logger.Info("starting controller manager")
	return mgr.Start(ctx)
}
