{{- if .HasDatabase}}

// ensureDatabase backfills app.DB{{if .OrmEnabled}} and app.ORM{{end}} from cfg.DatabaseUrl when the
// user-owned Setup (pkg/app/setup.go) did not construct them. Setup wins
// when it does — this function only fills nil fields.
//
// Why here and not setup.go: setup.go is scaffolded ONCE and never
// rewritten, so a project that adds its first DB entity after scaffold
// time has a setup.go with no database wiring. bootstrap.go is Tier-1
// (regenerated every `forge generate`), so the construction follows the
// project's actual shape. With no DATABASE_URL the fields stay nil and
// each DB-dependent service fails its validateDeps gate AT BOOT with an
// actionable error — never a typed-nil panic on the first RPC.
func ensureDatabase(app *App, cfg *config.Config, logger *slog.Logger) error {
	if app.DB == nil {
		if cfg.DatabaseUrl == "" {
			logger.Warn("DATABASE_URL is not set — database-backed services will fail validateDeps at startup; set DATABASE_URL (see docker-compose.yml / .env.example) to serve them")
			return nil
		}
		db, err := sql.Open("pgx", cfg.DatabaseUrl)
		if err != nil {
			return fmt.Errorf("open database: %w", err)
		}
		db.SetMaxOpenConns(25)
		db.SetMaxIdleConns(5)
		db.SetConnMaxLifetime(5 * time.Minute)
		db.SetConnMaxIdleTime(1 * time.Minute)
		if err := db.Ping(); err != nil {
			db.Close()
			return fmt.Errorf("ping database (postgres DSN from DATABASE_URL): %w", err)
		}
		app.DB = db
	}
{{- if .OrmEnabled}}
	if app.ORM == nil && app.DB != nil {
		ormClient, err := orm.NewClientWithDB(app.DB, "postgres")
		if err != nil {
			return fmt.Errorf("create ORM client: %w", err)
		}
		app.ORM = ormClient
	}
{{- end}}
	return nil
}
