// RunOperators starts the controller manager with one row per operator.
// Manager behavior (kubeconfig resolution with graceful no-cluster
// degrade, leader election, scheme/controller registration) lives in
// operatorkit.Run. Blocks until ctx cancels — the caller (serverkit)
// runs it in a goroutine.
//
// healthProbeAddr is forwarded from serverkit.Config.OperatorHealthProbeAddr;
// when non-empty operatorkit binds a /healthz + /readyz listener on that
// address for the controller-runtime manager. Empty leaves the manager
// without a probe listener (the default — vanilla forge projects don't
// bind one).
func (a *App) RunOperators(ctx context.Context, logger *slog.Logger, healthProbeAddr string) error {
	return operatorkit.Run(ctx, logger, operatorkit.Options{
		LeaderElectionID:       "{{$.LeaderElectionID}}",
		HealthProbeBindAddress: healthProbeAddr,
	}, []operatorkit.Controller{
{{- range .Operators}}
		{Name: "{{.Name}}", AddToScheme: {{.Alias}}.AddToScheme, SetupWithManager: a.Operators.{{.FieldName}}.SetupWithManager},
{{- end}}
	})
}
{{else}}
