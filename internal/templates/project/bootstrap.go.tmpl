	// whatever rows RegisteredServices (pkg/app/services.go, user-owned)
	// returned into def.Services above. A filter name the project knows
	// but services.go does not list is a misconfiguration — fail loudly
	// instead of letting appkit's generic unknown-name warning serve
	// nothing. Checking def.Services (not a generated list) keeps the
	// guard truthful even when services.go was edited without a
	// regenerate.
	for _, n := range names {
		if !slices.Contains([]string{{"{"}}{{range $i, $n := .AllServiceNames}}{{if $i}}, {{end}}"{{$n}}"{{end}}{{"}"}}, n) {
			continue // not a service name — appkit.Run warns if unknown
		}
		registered := false
		for _, row := range def.Services {
			if row.Name == n {
				registered = true
				break
			}
		}
		if !registered {
			return nil, fmt.Errorf("service %q is not registered in pkg/app/services.go — this binary does not serve it; add its serviceRow line to RegisteredServices to serve it here (then `forge generate`), or run it from the binary that serves it", n)
		}
	}
{{- end}}
	if err := appkit.Run(def, mux, logger, appkit.Options{Only: names}); err != nil {
		return nil, err
	}
	return app, nil
}
