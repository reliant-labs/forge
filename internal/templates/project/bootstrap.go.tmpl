	// cfg.DevAuthBypass() itself — no devMode parameter threading).
	// cfg.DevAuthBypass() is THE bypass gate: dev mode AND AUTH_DEV_MODE=true,
	// never ENVIRONMENT alone — the same value the auth middleware and auth
	// packs receive by injection, so the gates can never disagree. Booting
	// in development WITHOUT AUTH_DEV_MODE keeps the real Authorizer.
	//
	// This banner must match the swap exactly: it fires only when authz is
	// ACTUALLY allow-all, so it never lies. A boot that explicitly bypassed
	// auth gets a screaming Warn at every container start.
	if cfg.DevAuthBypass() {
		logger.Warn("AUTH BYPASS — authorization checks disabled (DevAuthorizer is allow-all); gated on AUTH_DEV_MODE=true, never set it in non-dev environments",
{{- if index .ConfigFields "Environment"}}
