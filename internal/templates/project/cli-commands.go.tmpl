package cli

import (
	"github.com/spf13/cobra"
)

// userCommands returns additional top-level subcommands for this binary.
// internal/cli/root.go consumes it; forge never edits this file. Return nil
// (the default) for no extra commands.
func userCommands(deps Deps) []*cobra.Command {
	_ = deps
	return nil
}
