// restHandler wraps the Connect mux in a vanguard transcoder over the
// mounted services' Connect paths. Returns nil when nothing was mounted.
func restHandler(mux *http.ServeMux, connectPaths []string) http.Handler {
	if len(connectPaths) == 0 {
		return nil
	}
	svcs := make([]*vanguard.Service, 0, len(connectPaths))
	for _, p := range connectPaths {
		svcs = append(svcs, vanguard.NewService(p, mux))
	}
	transcoder, err := vanguard.NewTranscoder(svcs)
	if err != nil {
		slog.Error("init vanguard REST transcoder", "error", err)
		return nil
	}
	return transcoder
}
{{- end}}

// selectWorkers returns the subset of workers whose Name is in names. An
// empty/nil names slice returns all workers. Used ONLY by the
// `server [names...]` convenience selector — never on the typed run path.
func selectWorkers(all []serverkit.Worker, names []string) []serverkit.Worker {
	if len(names) == 0 {
		return all
	}
	want := make(map[string]bool, len(names))
	for _, n := range names {
		want[n] = true
	}
	out := make([]serverkit.Worker, 0, len(all))
	for _, w := range all {
		if want[w.Name()] {
			out = append(out, w)
		}
	}
	return out
}

