// buildProjectInterceptors returns the project-specific Connect interceptor
// chain layered AFTER observe.DefaultMiddlewares. Order: otelconnect
// (outermost) → rate-limit → auth → audit.
func buildProjectInterceptors(cfg *config.Config, authInterceptor connect.Interceptor) func(logger *slog.Logger) []connect.Interceptor {
	return func(logger *slog.Logger) []connect.Interceptor {
		projectInterceptors := []connect.Interceptor{
			authInterceptor,
			fmw.AuditInterceptor(logger, middleware.ClaimsFromContext),
		}
{{- if .AuthProviderExternal}}
		if !cfg.DevAuthBypass() {
			projectInterceptors = append([]connect.Interceptor{middleware.GeneratedAuthInterceptor()}, projectInterceptors...)
		}
{{- end}}
{{- if and (index .ConfigFields "RateLimitRps") (index .ConfigFields "RateLimitBurst")}}
		if rl := fmw.RateLimitInterceptor(fmw.RateLimitOptions{
			Rps:   int(cfg.RateLimitRps),
			Burst: int(cfg.RateLimitBurst),
		}, middleware.ClaimsFromContext); rl != nil {
			projectInterceptors = append([]connect.Interceptor{rl}, projectInterceptors...)
		}
{{- end}}
		if otelInt, oerr := otelconnect.NewInterceptor(); oerr == nil {
			projectInterceptors = append([]connect.Interceptor{otelInt}, projectInterceptors...)
		} else {
			logger.Error("failed to create otelconnect interceptor", "error", oerr)
		}
		return projectInterceptors
	}
}
