package main

import (
	"github.com/spf13/cobra"
)

// userCommands returns additional top-level subcommands for this
// binary. cmd/main.go consumes it; forge never edits this file.
// Return nil (the default) for no extra commands.
func userCommands() []*cobra.Command {
	return nil
}
