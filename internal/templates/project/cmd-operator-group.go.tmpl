package operators

import (
	"github.com/spf13/cobra"

	"{{.Module}}/cmd/{{.Bin}}/cmd"
	"{{.Module}}/internal/app"
	"{{.Module}}/pkg/config"
)

// New{{.FieldName}}Cmd is the cobra subcommand that runs only the {{.Name}} operator.
func New{{.FieldName}}Cmd(deps cmd.Deps) *cobra.Command {
	c := &cobra.Command{
		Use:   "{{.Name}}",
		Short: "Run only the {{.Name}} operator",
		Long:  "Run a supervisor process for only the {{.Name}} operator. No Connect services are mounted and no workers/other operators run; the DI graph still constructs everything so cross-component reads stay nil-safe.",
		RunE: func(c *cobra.Command, args []string) error {
			deps.Cmd = c
			return cmd.Serve(c.Context(), deps, cmd.ServeSpec{
				// MountNone by default — replace with the colocated service's typed
				// Mount if this operator serves an API (see the file header).
				Mount:     cmd.MountNone,
				Operators: func(c *app.Components) []app.OperatorEntry { return []app.OperatorEntry{c.Operator{{.FieldName}}()} },
			})
		},
	}
	config.RegisterFlags(c)
	return c
}
