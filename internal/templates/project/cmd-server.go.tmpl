package main

import (
	"context"
	"database/sql"
	"fmt"
	"log/slog"
	"net"
	"net/http"
	"os"
	"os/signal"
	"strings"
	"sync"
	"sync/atomic"
	"syscall"
	"time"

	"connectrpc.com/connect"
	"connectrpc.com/otelconnect"
	"golang.org/x/net/http2"
	"golang.org/x/net/http2/h2c"

	"{{.Module}}/pkg/app"
	"{{.Module}}/pkg/config"
	"{{.Module}}/pkg/middleware"
	"github.com/spf13/cobra"
)

var serverCmd = &cobra.Command{
	Use:   "server [services...]",
	Short: "Start the HTTP/Connect server",
	Long:  "Start the HTTP/Connect server. Optionally specify service names to register only a subset.",
	RunE:  runServer,
}

func init() {
	config.RegisterFlags(serverCmd)
	serverCmd.Flags().Bool("auto-migrate", false, "Run database migrations on startup")
	rootCmd.AddCommand(serverCmd)
}

func runServer(cmd *cobra.Command, args []string) error {
	// Load config from env vars and flags
	cfg, err := config.Load(cmd)
	if err != nil {
		return fmt.Errorf("failed to load config: %w", err)
	}

	// Configure logging
	var level slog.Level
	if uerr := level.UnmarshalText([]byte(cfg.LogLevel)); uerr != nil {
		return fmt.Errorf("invalid log level %q: %w", cfg.LogLevel, uerr)
	}
	logger := slog.New(slog.NewJSONHandler(os.Stdout, &slog.HandlerOptions{Level: level}))
	slog.SetDefault(logger)

	// OTel is optional — degrade gracefully if not configured.
	ctx := context.Background()
	shutdownOTel, metricsHandler, err := setupOTel(ctx)
	if err != nil {
		logger.Error("failed to initialize OpenTelemetry", "error", err)
		// Continue without telemetry — this is intentional.
	}

	// Auto-migrate: run pending database migrations if enabled
	autoMigrate := false
	if v, ok := os.LookupEnv("AUTO_MIGRATE"); ok && (v == "true" || v == "1") {
		autoMigrate = true
	} else if cmd.Flags().Changed("auto-migrate") {
		autoMigrate, _ = cmd.Flags().GetBool("auto-migrate")
	}
	if autoMigrate {
		dbURL := os.Getenv("DATABASE_URL")
		if dbURL == "" {
			return fmt.Errorf("AUTO_MIGRATE is enabled but DATABASE_URL is not set")
		}
		db, dbErr := sql.Open("pgx", dbURL)
		if dbErr != nil {
			return fmt.Errorf("failed to connect to database for migration: %w", dbErr)
		}
		if migrateErr := app.AutoMigrate(db, logger); migrateErr != nil {
			_ = db.Close()
			return fmt.Errorf("auto-migration failed: %w", migrateErr)
		}
		_ = db.Close()
		logger.Info("auto-migration completed successfully")
	}

	mux := http.NewServeMux()

	// Expose Prometheus metrics endpoint.
	if metricsHandler != nil {
		mux.Handle("/metrics", metricsHandler)
	}

	otelInterceptor, err := otelconnect.NewInterceptor()
	if err != nil {
		logger.Error("failed to create otelconnect interceptor", "error", err)
	}

	interceptors := []connect.Interceptor{
		middleware.RecoveryInterceptor(logger),
		middleware.AuthInterceptor(),
		middleware.AuditInterceptor(logger),
		middleware.LoggingInterceptor(logger),
	}
	if otelInterceptor != nil {
		interceptors = append([]connect.Interceptor{otelInterceptor}, interceptors...)
	}

	opts := []connect.HandlerOption{
		connect.WithInterceptors(interceptors...),
	}

	// Bootstrap packages and services
	var ready atomic.Bool
	var application *app.App
	{
		var bootstrapErr error
		if len(args) > 0 {
			application, bootstrapErr = app.BootstrapOnly(mux, logger, cfg, args, opts...)
		} else {
			application, bootstrapErr = app.Bootstrap(mux, logger, cfg, opts...)
		}
		if bootstrapErr != nil {
			return fmt.Errorf("bootstrap failed: %w", bootstrapErr)
		}
		if len(args) > 0 {
			logger.Info("started with service filter", "services", args)
		}
	}
	ready.Store(true)

	// Liveness probe: always 200 if the process is alive
	mux.HandleFunc("/healthz", func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
		_, _ = fmt.Fprintln(w, "ok")
	})

	// Readiness probe: 200 only after bootstrap completes
	mux.HandleFunc("/readyz", func(w http.ResponseWriter, r *http.Request) {
		if !ready.Load() {
			w.WriteHeader(http.StatusServiceUnavailable)
			return
		}
		w.WriteHeader(http.StatusOK)
		_, _ = fmt.Fprintln(w, "ok")
	})

	var handler http.Handler = mux
	// CORS: parse comma-separated origins from config.
	var corsOrigins []string
	if cfg.CorsOrigins != "" {
		for _, o := range strings.Split(cfg.CorsOrigins, ",") {
			if o = strings.TrimSpace(o); o != "" {
				corsOrigins = append(corsOrigins, o)
			}
		}
	}
	if len(corsOrigins) > 0 {
		handler = middleware.CORSMiddleware(corsOrigins)(handler)
	}
	handler = h2c.NewHandler(handler, &http2.Server{})

	addr := fmt.Sprintf(":%d", cfg.Port)
	srv := &http.Server{
		Addr:              addr,
		Handler:           handler,
		ReadHeaderTimeout: 10 * time.Second,
		ReadTimeout:       30 * time.Second,
		WriteTimeout:      60 * time.Second,
		IdleTimeout:       120 * time.Second,
	}

	// Graceful shutdown
	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	ln, err := (&net.ListenConfig{}).Listen(ctx, "tcp", addr)
	if err != nil {
		return fmt.Errorf("listen %s: %w", addr, err)
	}

	errCh := make(chan error, 1)
	go func() {
		logger.Info("server starting", "addr", addr)
		if err := srv.Serve(ln); err != nil && err != http.ErrServerClosed {
			errCh <- err
		}
	}()

	// Start workers in background goroutines
	workerCtx, workerCancel := context.WithCancel(ctx)
	defer workerCancel()
	var workerWg sync.WaitGroup

	// Build the set of requested names for filtering (empty = run all)
	nameSet := make(map[string]bool, len(args))
	for _, n := range args {
		nameSet[n] = true
	}

	for _, w := range application.WorkerList() {
		// If a name filter was provided, only start matching workers
		if len(nameSet) > 0 && !nameSet[w.Name()] {
			continue
		}
		workerWg.Add(1)
		go func(w interface {
			Name() string
			Start(context.Context) error
		}) {
			defer workerWg.Done()
			logger.Info("starting worker", "worker", w.Name())
			if err := w.Start(workerCtx); err != nil {
				logger.Error("worker error", "worker", w.Name(), "error", err)
			}
		}(w)
	}

	// Start controller manager for operators (if any)
	if application.HasOperators() {
		go func() {
			if err := application.RunOperators(ctx, logger); err != nil {
				logger.Error("controller manager failed", "error", err)
			}
		}()
	}

	select {
	case err := <-errCh:
		logger.Error("server error", "error", err)
		return fmt.Errorf("server failed: %w", err)
	case <-ctx.Done():
	}
	logger.Info("shutting down...")

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	// Stop workers first (cancel context + wait + call Stop)
	workerCancel()
	workerWg.Wait()
	for _, w := range application.WorkerList() {
		if len(nameSet) > 0 && !nameSet[w.Name()] {
			continue
		}
		if err := w.Stop(shutdownCtx); err != nil {
			logger.Error("worker stop error", "worker", w.Name(), "error", err)
		}
	}

	if err := application.Shutdown(shutdownCtx); err != nil {
		logger.Error("shutdown error", "error", err)
	}
	if err := srv.Shutdown(shutdownCtx); err != nil {
		logger.Error("server shutdown error", "error", err)
	}
	if shutdownOTel != nil {
		if err := shutdownOTel(shutdownCtx); err != nil {
			logger.Error("otel shutdown error", "error", err)
		}
	}
	return nil
}