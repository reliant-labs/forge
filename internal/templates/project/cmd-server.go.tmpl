// mountServices registers the selected services' routes on mux, reading
// each constructed instance off services via the data-only app.Inventory
// Mount closures. An empty names slice mounts every inventory row; a
// non-empty slice mounts only the named subset (names are display/selection
// keys, never construction keys). Returns the Connect paths of the rows
// actually mounted (for the REST transcoder).
func mountServices(services *app.Services, mux *http.ServeMux, cfg *config.Config, logger *slog.Logger, names []string, opts ...connect.HandlerOption) []string {
	want := make(map[string]bool, len(names))
	for _, n := range names {
		want[n] = true
	}
	mountAll := len(names) == 0
	var mounted []string
	for _, row := range app.Inventory {
		if !mountAll && !want[row.Name] {
			continue
		}
		row.Mount(services, mux, cfg, logger, opts...)
		mounted = append(mounted, row.ConnectPath)
	}
	return mounted
}
{{- if .RESTEnabled}}

// restHandler wraps the Connect mux in a vanguard transcoder over the
// mounted services' Connect paths so REST<->Connect translation happens at
// runtime from the google.api.http annotations. Returns nil when no
// services were mounted (nothing to transcode).
func restHandler(mux *http.ServeMux, connectPaths []string) http.Handler {
	if len(connectPaths) == 0 {
		return nil
	}
	svcs := make([]*vanguard.Service, 0, len(connectPaths))
	for _, p := range connectPaths {
		svcs = append(svcs, vanguard.NewService(p, mux))
	}
	transcoder, err := vanguard.NewTranscoder(svcs)
	if err != nil {
		slog.Error("init vanguard REST transcoder", "error", err)
		return nil
	}
	return transcoder
}
{{- end}}

// selectWorkers returns the subset of workers whose Name is in names.
// An empty names slice returns all workers (the canonical unfiltered
// `server` behavior). This replicates serverkit's old per-name worker
// gating, which moved up here when serverkit stopped receiving names.
func selectWorkers(all []serverkit.Worker, names []string) []serverkit.Worker {
	if len(names) == 0 {
		return all
	}
	want := make(map[string]bool, len(names))
	for _, n := range names {
		want[n] = true
	}
	out := make([]serverkit.Worker, 0, len(all))
	for _, w := range all {
		if want[w.Name()] {
			out = append(out, w)
		}
	}
	return out
}

// selectOperators returns the subset of operators whose Name is in
// names. An empty names slice returns all operators. This replicates
// serverkit's old shouldRunOperators name gating: a subcommand naming a
// non-operator service yields an EMPTY slice, so serverkit never starts
// the controller manager (avoiding the "not running in-cluster" noise).
func selectOperators(all []serverkit.Operator, names []string) []serverkit.Operator {
	if len(names) == 0 {
		return all
	}
	want := make(map[string]bool, len(names))
	for _, n := range names {
		want[n] = true
	}
	out := make([]serverkit.Operator, 0, len(all))
	for _, op := range all {
		if want[op.Name()] {
			out = append(out, op)
		}
	}
	return out
}

// projectServerkitConfig projects the project's typed *config.Config onto
// the vendor-neutral serverkit.Config so serverkit has no compile-time
// dependency on pkg/config. Each field is a one-to-one mapping; serverkit
// fills its own defaults for any zero-valued duration/cap.
func projectServerkitConfig(cfg *config.Config) (serverkit.Config, error) {
	skCfg := serverkit.Config{
{{- if index .ConfigFields "Port"}}
		Addr: fmt.Sprintf(":%d", cfg.Port),
{{- else}}
		Addr: ":8080",
{{- end}}
{{- if index .ConfigFields "PprofAddr"}}
		PprofAddr: cfg.PprofAddr,
{{- end}}
{{- if and (index .ConfigFields "TlsCertPath") (index .ConfigFields "TlsKeyPath")}}
		TLSCertPath: cfg.TlsCertPath,
		TLSKeyPath:  cfg.TlsKeyPath,
{{- end}}
{{- if index .ConfigFields "LogFormat"}}
		LogFormat: cfg.LogFormat,
{{- end}}
{{- if index .ConfigFields "Environment"}}
		Environment: cfg.Environment,
{{- end}}
{{- if index .ConfigFields "AutoMigrate"}}
		AutoMigrate: cfg.AutoMigrate,
{{- end}}
{{- if index .ConfigFields "DatabaseUrl"}}
		DatabaseURL: cfg.DatabaseUrl,
{{- end}}
{{- if index .ConfigFields "SecurityHeadersEnabled"}}
		SecurityHeaders: cfg.SecurityHeadersEnabled,
{{- end}}
{{- if index .ConfigFields "CorsAllowCredentials"}}
		CORSAllowCredentials: cfg.CorsAllowCredentials,
{{- end}}
	}

{{- if index .ConfigFields "LogLevel"}}

	if uerr := skCfg.LogLevel.UnmarshalText([]byte(cfg.LogLevel)); uerr != nil {
		return serverkit.Config{}, fmt.Errorf("invalid log level %q: %w", cfg.LogLevel, uerr)
	}
{{- end}}

{{- if index .ConfigFields "CorsOrigins"}}

	// CORS: parse comma-separated origins from config. The wildcard +
	// credentials combination is rejected by cfg.Validate() above so we
	// pass cfg.CorsAllowCredentials through unchecked.
	if cfg.CorsOrigins != "" {
		for _, o := range strings.Split(cfg.CorsOrigins, ",") {
			if o = strings.TrimSpace(o); o != "" {
				skCfg.CORSOrigins = append(skCfg.CORSOrigins, o)
			}
		}
	}
{{- end}}

{{- if index .ConfigFields "PreStopDelay"}}

	// Durations are time.Duration on the typed config — parsed (and
	// validated) exactly once in config.Load. Assign directly; a zero
	// value falls back to serverkit's documented default.
	skCfg.PreStopDelay = cfg.PreStopDelay
{{- end}}
{{- if index .ConfigFields "ShutdownTimeout"}}
	skCfg.ShutdownTimeout = cfg.ShutdownTimeout
{{- end}}

{{- if index .ConfigFields "DbMaxOpenConns"}}

	skCfg.DBPoolTuning.MaxOpenConns = int(cfg.DbMaxOpenConns)
{{- end}}
{{- if index .ConfigFields "DbMaxIdleConns"}}
	skCfg.DBPoolTuning.MaxIdleConns = int(cfg.DbMaxIdleConns)
{{- end}}
{{- if index .ConfigFields "DbConnMaxIdleTime"}}
	skCfg.DBPoolTuning.ConnMaxIdleTime = cfg.DbConnMaxIdleTime
{{- end}}
{{- if index .ConfigFields "DbConnMaxLifetime"}}
	skCfg.DBPoolTuning.ConnMaxLifetime = cfg.DbConnMaxLifetime
{{- end}}

	return skCfg, nil
}

// buildProjectInterceptors returns the project-specific Connect interceptor
// chain that serverkit layers AFTER its canonical observe.DefaultMiddlewares
// (recovery → request-id → logging → tracing → metrics). Order within the
// project chain: otelconnect (outermost — span-wraps everything below) →
// rate-limit (reject floods before token validation) → auth → audit.
//
// authInterceptor is constructed in runServer via
// middleware.NewAuthInterceptor, which ERRORS (aborting startup) when no
// auth provider is configured and no explicit opt-out was given. By the
// time this closure runs, auth is known-good.
//
// Captured-cfg closure so the per-RPC interceptor sees the latest config
// snapshot when the binary boots, even if a future hook starts re-reading.
func buildProjectInterceptors(cfg *config.Config, authInterceptor connect.Interceptor) func(logger *slog.Logger) []connect.Interceptor {
	return func(logger *slog.Logger) []connect.Interceptor {
		// Library interceptors that read the authenticated principal take
		// middleware.ClaimsFromContext — the project owns the claims
		// context key (pkg/middleware/middleware.go).
		projectInterceptors := []connect.Interceptor{
			authInterceptor,
			fmw.AuditInterceptor(logger, middleware.ClaimsFromContext),
		}
{{- if .AuthProviderExternal}}
		// auth.provider {{.AuthProvider}}: API keys arrive in a header,
		// not a bearer token, so the generated header-aware interceptor
		// (pkg/middleware/auth_gen.go) owns authentication; the authn
		// interceptor above it runs in passthrough (InstallGeneratedAuth
		// marked external auth). The generated interceptor is skipped only
		// under an explicit auth bypass (cfg.DevAuthBypass()), where dev
		// claims apply — a dev boot without AUTH_DEV_MODE keeps it on.
		if !cfg.DevAuthBypass() {
			projectInterceptors = append([]connect.Interceptor{middleware.GeneratedAuthInterceptor()}, projectInterceptors...)
		}
{{- end}}
{{- if and (index .ConfigFields "RateLimitRps") (index .ConfigFields "RateLimitBurst")}}
		if rl := fmw.RateLimitInterceptor(fmw.RateLimitOptions{
			Rps:   int(cfg.RateLimitRps),
			Burst: int(cfg.RateLimitBurst),
		}, middleware.ClaimsFromContext); rl != nil {
			projectInterceptors = append([]connect.Interceptor{rl}, projectInterceptors...)
		}
{{- end}}
		// otelconnect runs at the outermost edge so OTel spans wrap every
		// observability layer's work as well as the handler.
		if otelInt, oerr := otelconnect.NewInterceptor(); oerr == nil {
			projectInterceptors = append([]connect.Interceptor{otelInt}, projectInterceptors...)
		} else {
			logger.Error("failed to create otelconnect interceptor", "error", oerr)
		}
		return projectInterceptors
	}
}
