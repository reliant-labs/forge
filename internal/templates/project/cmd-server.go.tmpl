	// dev boot never silently disables authentication.
	if cfg.DevAuthBypass() {
		slog.Warn("AUTH BYPASS ACTIVE — authentication and authorization are DISABLED (dev claims injected). This is gated on AUTH_DEV_MODE=true; never set it in production.")
	}
	authInterceptor, err := middleware.NewAuthInterceptor(cfg.DevAuthBypass())
