import (
	"context"
	"database/sql"
	"errors"
	"fmt"
	"log/slog"
	"net"
	"net/http"
	"net/http/pprof"
	"os"
	"os/signal"
	"strings"
	"sync"
	"sync/atomic"
	"syscall"
	"time"

	"connectrpc.com/connect"
	"connectrpc.com/otelconnect"
	"golang.org/x/net/http2"
	"golang.org/x/net/http2/h2c"

	"{{.Module}}/pkg/app"
	"{{.Module}}/pkg/config"
	"{{.Module}}/pkg/middleware"
	_ "github.com/jackc/pgx/v5/stdlib" // registers the "pgx" sql driver for DATABASE_URL
	"github.com/spf13/cobra"
)

// defaultConnectMaxBytes bounds the size of a single Connect request or
// response payload. It applies to both receive (WithReadMaxBytes) and send
// (WithSendMaxBytes) directions on the generated handler options and caps
// untrusted input before it reaches service code. 4 MiB is large enough for
// typical JSON/protobuf payloads while rejecting obviously oversized
// requests. Override by editing the bootstrap call site if a larger limit is
// required for a specific deployment.
//
// TODO: plumb this through pkg/config once AppConfig gains a matching field.
const defaultConnectMaxBytes = 4 << 20 // 4 MiB

var serverCmd = &cobra.Command{
	Use:   "server [services...]",
	Short: "Start the HTTP/Connect server",
	Long:  "Start the HTTP/Connect server. Optionally specify service names to register only a subset.",
	RunE:  runServer,
}

func init() {
	config.RegisterFlags(serverCmd)
	rootCmd.AddCommand(serverCmd)
}

func runServer(cmd *cobra.Command, args []string) error {
	// Load config from env vars and flags, then run cross-field
	// validation. Validate catches combinations that can't be expressed
	// as per-field defaults (e.g. CORS wildcard + credentials) and
	// surfaces them before we bind the listener.
	cfg, err := config.Load(cmd)
	if err != nil {
		return fmt.Errorf("failed to load config: %w", err)
	}
	if verr := cfg.Validate(); verr != nil {
		return fmt.Errorf("invalid configuration: %w", verr)
	}

	// Configure logging. LOG_FORMAT picks between structured JSON (for
	// log aggregators) and human-friendly text (for local dev tails).
	// Any other value is rejected by Validate above, so the switch
	// default is unreachable unless Validate is bypassed.
	var level slog.Level
	if uerr := level.UnmarshalText([]byte(cfg.LogLevel)); uerr != nil {
		return fmt.Errorf("invalid log level %q: %w", cfg.LogLevel, uerr)
	}
	var logHandler slog.Handler
	switch cfg.LogFormat {
	case "text":
		logHandler = slog.NewTextHandler(os.Stdout, &slog.HandlerOptions{Level: level})
	default: // "json" (also the validated default)
		logHandler = slog.NewJSONHandler(os.Stdout, &slog.HandlerOptions{Level: level})
	}
	logHandler = middleware.NewTraceHandler(logHandler)
	logger := slog.New(logHandler)
	slog.SetDefault(logger)

	// OTel is optional — degrade gracefully if not configured.
	ctx := context.Background()
	shutdownOTel, metricsHandler, err := setupOTel(ctx)
	if err != nil {
		logger.Error("failed to initialize OpenTelemetry", "error", err)
		// Continue without telemetry — this is intentional.
	}

	// Warn loudly when running in development mode. Development mode enables
	// permissive defaults (e.g. authz allow-all) for local ergonomics — this
	// must never be used in production. The permissive behavior is selected
	// at Bootstrap time based on cfg.Environment.
	if cfg.Environment == "development" {
		logger.Warn("running in development mode — permissive authz defaults are enabled. NEVER set ENVIRONMENT=development in production.")
	}

	// Auto-migrate: run pending database migrations if cfg.AutoMigrate is true.
	// Precedence is handled by pkg/config: AUTO_MIGRATE env > --auto-migrate flag > default (false).
	if cfg.AutoMigrate {
		if cfg.DatabaseURL == "" {
			return fmt.Errorf("auto-migrate is enabled but DATABASE_URL is not set")
		}
		db, dbErr := sql.Open("pgx", cfg.DatabaseURL)
		if dbErr != nil {
			return fmt.Errorf("failed to connect to database for migration: %w", dbErr)
		}
		applyPoolTuning(db, cfg)
		if migrateErr := app.AutoMigrate(db, logger); migrateErr != nil {
			_ = db.Close()
			return fmt.Errorf("auto-migration failed: %w", migrateErr)
		}
		_ = db.Close()
		middleware.LogDBMigrationCompleted(ctx, logger)
	}

	mux := http.NewServeMux()

	// Expose Prometheus metrics endpoint.
	if metricsHandler != nil {
		mux.Handle("/metrics", metricsHandler)
	}

	otelInterceptor, err := otelconnect.NewInterceptor()
	if err != nil {
		logger.Error("failed to create otelconnect interceptor", "error", err)
	}

	interceptors := []connect.Interceptor{
		middleware.RecoveryInterceptor(logger),
		middleware.AuthInterceptor(),
		middleware.AuditInterceptor(logger),
		middleware.LoggingInterceptor(logger),
	}
	if rl := middleware.RateLimitInterceptor(middleware.RateLimitOptions{
		Rps:   int(cfg.RateLimitRps),
		Burst: int(cfg.RateLimitBurst),
	}); rl != nil {
		// Rate limiting runs before auth so anonymous floods are rejected
		// without doing token validation work. Disabled when
		// cfg.RateLimitRps <= 0.
		interceptors = append([]connect.Interceptor{rl}, interceptors...)
	}
	if otelInterceptor != nil {
		interceptors = append([]connect.Interceptor{otelInterceptor}, interceptors...)
	}

	opts := []connect.HandlerOption{
		connect.WithInterceptors(interceptors...),
		connect.WithReadMaxBytes(defaultConnectMaxBytes),
		connect.WithSendMaxBytes(defaultConnectMaxBytes),
	}

	// Bootstrap packages and services. Readiness flips AFTER the listener
	// successfully binds (see ln/Serve below) so /readyz is an accurate
	// signal to load balancers and probes — bootstrap completing on its own
	// is not enough; an un-bound process cannot actually serve traffic.
	var ready atomic.Bool
	var application *app.App
	{
		var bootstrapErr error
		if len(args) > 0 {
			application, bootstrapErr = app.BootstrapOnly(mux, logger, cfg, args, opts...)
		} else {
			application, bootstrapErr = app.Bootstrap(mux, logger, cfg, opts...)
		}
		if bootstrapErr != nil {
			return fmt.Errorf("bootstrap failed: %w", bootstrapErr)
		}
		if len(args) > 0 {
			logger.Info("started with service filter", "services", args)
		}
	}

	// Liveness probe: always 200 if the process is alive
	mux.HandleFunc("/healthz", func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
		_, _ = fmt.Fprintln(w, "ok")
	})

	// Readiness probe: 200 only after bootstrap completes
	mux.HandleFunc("/readyz", func(w http.ResponseWriter, r *http.Request) {
		if !ready.Load() {
			w.WriteHeader(http.StatusServiceUnavailable)
			return
		}
		w.WriteHeader(http.StatusOK)
		_, _ = fmt.Fprintln(w, "ok")
	})

	var handler http.Handler = mux
	// CORS: parse comma-separated origins from config. The wildcard +
	// credentials combination is rejected by cfg.Validate() above so we
	// can pass cfg.CorsAllowCredentials through unchecked here.
	var corsOrigins []string
	if cfg.CorsOrigins != "" {
		for _, o := range strings.Split(cfg.CorsOrigins, ",") {
			if o = strings.TrimSpace(o); o != "" {
				corsOrigins = append(corsOrigins, o)
			}
		}
	}
	if len(corsOrigins) > 0 {
		handler = middleware.CORSMiddleware(corsOrigins, cfg.CorsAllowCredentials)(handler)
	}

	// Security headers — OWASP defaults. Applied outside of CORS so that
	// preflight (OPTIONS) responses also carry them. HSTS is only emitted
	// in production; see pkg/middleware/security_headers.go for details.
	if cfg.SecurityHeadersEnabled {
		secCfg := middleware.DefaultSecurityHeadersConfig()
		secCfg.Enabled = true
		secCfg.Production = cfg.Environment != "development"
		handler = middleware.SecurityHeadersMiddleware(secCfg)(handler)
	}

	// RequestID runs at the outermost layer so every subsequent middleware
	// (CORS, security headers, logging) can see the correlation ID on
	// both inbound context and outbound response header. It must sit in
	// front of the logging interceptor for the ID to appear on log lines.
	handler = middleware.RequestIDMiddleware()(handler)

	handler = h2c.NewHandler(handler, &http2.Server{})

	addr := fmt.Sprintf(":%d", cfg.Port)
	srv := &http.Server{
		Addr:              addr,
		Handler:           handler,
		ReadHeaderTimeout: 10 * time.Second,
		ReadTimeout:       30 * time.Second,
		WriteTimeout:      60 * time.Second,
		IdleTimeout:       120 * time.Second,
		// Cap request header size. Go's default is 1 MiB; we set it
		// explicitly so the limit is obvious and easy to tune per deployment.
		MaxHeaderBytes: 1 << 20,
	}

	// Graceful shutdown
	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	ln, err := (&net.ListenConfig{}).Listen(ctx, "tcp", addr)
	if err != nil {
		return fmt.Errorf("listen %s: %w", addr, err)
	}

	// The listener is bound and accepting connections; flip readiness so
	// /readyz starts returning 200. Serve below hands off to the accept
	// loop without a second bind step.
	ready.Store(true)

	errCh := make(chan error, 1)
	go func() {
		middleware.LogServerListening(ctx, logger, slog.String("addr", addr), slog.Bool("tls", cfg.TLSCertPath != ""))
		// TLS is enabled when both cert and key paths are non-empty;
		// Validate() above guarantees the paths are either both set or
		// both empty, so we never ship an asymmetric config to here.
		var serveErr error
		if cfg.TLSCertPath != "" && cfg.TLSKeyPath != "" {
			serveErr = srv.ServeTLS(ln, cfg.TLSCertPath, cfg.TLSKeyPath)
		} else {
			serveErr = srv.Serve(ln)
		}
		if serveErr != nil && !errors.Is(serveErr, http.ErrServerClosed) {
			errCh <- serveErr
		}
	}()

	// Optional pprof endpoint on a separate listener. pprof must never be
	// mounted on the public handler — it exposes heap/goroutine/profile
	// endpoints that can leak memory contents and stall a running process.
	var pprofSrv *http.Server
	if cfg.PprofAddr != "" {
		pprofMux := http.NewServeMux()
		pprofMux.HandleFunc("/debug/pprof/", pprof.Index)
		pprofMux.HandleFunc("/debug/pprof/cmdline", pprof.Cmdline)
		pprofMux.HandleFunc("/debug/pprof/profile", pprof.Profile)
		pprofMux.HandleFunc("/debug/pprof/symbol", pprof.Symbol)
		pprofMux.HandleFunc("/debug/pprof/trace", pprof.Trace)
		pprofSrv = &http.Server{
			Addr:              cfg.PprofAddr,
			Handler:           pprofMux,
			ReadHeaderTimeout: 10 * time.Second,
		}
		pprofLn, lnErr := (&net.ListenConfig{}).Listen(ctx, "tcp", cfg.PprofAddr)
		if lnErr != nil {
			return fmt.Errorf("listen pprof %s: %w", cfg.PprofAddr, lnErr)
		}
		go func() {
			logger.Info("pprof server starting", "addr", cfg.PprofAddr)
			if err := pprofSrv.Serve(pprofLn); err != nil && !errors.Is(err, http.ErrServerClosed) {
				logger.Error("pprof server error", "error", err)
			}
		}()
	}

	// Start workers in background goroutines
	workerCtx, workerCancel := context.WithCancel(ctx)
	defer workerCancel()
	var workerWg sync.WaitGroup

	// Build the set of requested names for filtering (empty = run all)
	nameSet := make(map[string]bool, len(args))
	for _, n := range args {
		nameSet[n] = true
	}

	for _, w := range application.WorkerList() {
		// If a name filter was provided, only start matching workers
		if len(nameSet) > 0 && !nameSet[w.Name()] {
			continue
		}
		workerWg.Add(1)
		go func(w interface {
			Name() string
			Start(context.Context) error
		}) {
			defer workerWg.Done()
			middleware.LogWorkerStarting(workerCtx, logger, slog.String("worker", w.Name()))
			if err := w.Start(workerCtx); err != nil {
				middleware.LogWorkerError(workerCtx, logger, slog.String("worker", w.Name()), slog.Any("error", err))
			}
		}(w)
	}

	// Start controller manager for operators (if any)
	if application.HasOperators() {
		go func() {
			if err := application.RunOperators(ctx, logger); err != nil {
				logger.Error("controller manager failed", "error", err)
			}
		}()
	}

	select {
	case err := <-errCh:
		logger.Error("server error", "error", err)
		return fmt.Errorf("server failed: %w", err)
	case <-ctx.Done():
	}
	middleware.LogServerStopping(ctx, logger)

	// Graceful shutdown sequence:
	//   1. Flip readiness to false so /readyz starts failing.
	//   2. Sleep pre_stop_delay so load balancers observe the failing
	//      probe and stop routing new traffic to this replica.
	//   3. Begin srv.Shutdown, bounded by shutdown_timeout, so in-flight
	//      requests drain without accepting new ones.
	// Without step 1 + 2, srv.Shutdown stops accepting new conns
	// immediately but the LB keeps sending them until it next polls
	// /readyz — producing brief but real 502s on every rollout.
	ready.Store(false)

	preStop := 5 * time.Second
	if cfg.PreStopDelay != "" {
		if d, perr := time.ParseDuration(cfg.PreStopDelay); perr == nil {
			preStop = d
		}
	}
	if preStop > 0 {
		logger.Info("readiness flipped, waiting for LB drain", "pre_stop_delay", preStop)
		time.Sleep(preStop)
	}

	shutdownTimeout := 30 * time.Second
	if cfg.ShutdownTimeout != "" {
		if d, perr := time.ParseDuration(cfg.ShutdownTimeout); perr == nil {
			shutdownTimeout = d
		}
	}
	shutdownCtx, cancel := context.WithTimeout(context.Background(), shutdownTimeout)
	defer cancel()

	// Stop workers first (cancel context + wait + call Stop)
	workerCancel()
	workerWg.Wait()
	for _, w := range application.WorkerList() {
		if len(nameSet) > 0 && !nameSet[w.Name()] {
			continue
		}
		if err := w.Stop(shutdownCtx); err != nil {
			logger.Error("worker stop error", "worker", w.Name(), "error", err)
		}
	}

	if err := application.Shutdown(shutdownCtx); err != nil {
		logger.Error("shutdown error", "error", err)
	}
	if err := srv.Shutdown(shutdownCtx); err != nil {
		logger.Error("server shutdown error", "error", err)
	}
	if pprofSrv != nil {
		if err := pprofSrv.Shutdown(shutdownCtx); err != nil {
			logger.Error("pprof shutdown error", "error", err)
		}
	}
	if shutdownOTel != nil {
		if err := shutdownOTel(shutdownCtx); err != nil {
			logger.Error("otel shutdown error", "error", err)
		}
	}
	return nil
}

// applyPoolTuning applies connection-pool settings from config to an open
// *sql.DB. Values are read from cfg so operators can tune them per
// environment without recompiling. Defaults come from the generated proto.
func applyPoolTuning(db *sql.DB, cfg *config.Config) {
	if db == nil {
		return
	}
	if cfg.DBMaxOpenConns > 0 {
		db.SetMaxOpenConns(int(cfg.DBMaxOpenConns))
	}
	if cfg.DBMaxIdleConns > 0 {
		db.SetMaxIdleConns(int(cfg.DBMaxIdleConns))
	}
	if cfg.DBConnMaxIdleTime != "" {
		if d, err := time.ParseDuration(cfg.DBConnMaxIdleTime); err == nil {
			db.SetConnMaxIdleTime(d)
		}
	}
	if cfg.DBConnMaxLifetime != "" {
		if d, err := time.ParseDuration(cfg.DBConnMaxLifetime); err == nil {
			db.SetConnMaxLifetime(d)
		}
	}
}