	ctx := context.Background()

	// COMPOSITION SITE. serverkit no longer selects services, builds the
	// mux, sets up OTel, runs migrations, or builds the interceptor
	// chain — it takes an already-composed serverkit.Server. This shim
	// owns all of that, then hands the finished pieces to serverkit.Run.
