// projectServerkitConfig projects the project's typed *config.Config onto
// the vendor-neutral serverkit.Config so serverkit has no compile-time
// dependency on pkg/config. serverkit fills its own defaults for any
// zero-valued duration/cap.
func projectServerkitConfig(cfg *config.Config) (serverkit.Config, error) {
	skCfg := serverkit.Config{
{{- if index .ConfigFields "Port"}}
		Addr: fmt.Sprintf(":%d", cfg.Port),
{{- else}}
		Addr: ":8080",
{{- end}}
		// ServiceName is APP IDENTITY (the project name baked into a
		// generated constant), NOT a config field. serverkit reports it on
		// OTel traces/metrics (semconv service.name).
		ServiceName: ServiceName,
{{- if index .ConfigFields "OtlpEndpoint"}}
		OTLPEndpoint: cfg.OtlpEndpoint,
{{- end}}
{{- if index .ConfigFields "PprofAddr"}}
		PprofAddr: cfg.PprofAddr,
{{- end}}
{{- if and (index .ConfigFields "TlsCertPath") (index .ConfigFields "TlsKeyPath")}}
		TLSCertPath: cfg.TlsCertPath,
		TLSKeyPath:  cfg.TlsKeyPath,
{{- end}}
{{- if index .ConfigFields "LogFormat"}}
		LogFormat: cfg.LogFormat,
{{- end}}
{{- if index .ConfigFields "Environment"}}
		Environment: cfg.Environment,
{{- end}}
{{- if index .ConfigFields "AutoMigrate"}}
		AutoMigrate: cfg.AutoMigrate,
{{- end}}
{{- if index .ConfigFields "DatabaseUrl"}}
		DatabaseURL: cfg.DatabaseUrl,
		// sql.Open driver name for the auto-migrate connection. The
		// AutoMigrate block below opens the DB BEFORE serverkit.Run
		// normalizes the Config, so serverkit's own DBDriver="pgx" default
		// (Config.defaults(), applied at Run entry) hasn't fired — an unset
		// DBDriver reaches sql.Open as "" and fails `unknown driver ""`.
		// Pin it here to the pgx stdlib driver the project imports.
		DBDriver: "pgx",
{{- end}}
{{- if index .ConfigFields "SecurityHeadersEnabled"}}
		SecurityHeaders: cfg.SecurityHeadersEnabled,
{{- end}}
{{- if index .ConfigFields "CorsAllowCredentials"}}
		CORSAllowCredentials: cfg.CorsAllowCredentials,
{{- end}}
	}

{{- if index .ConfigFields "LogLevel"}}

	if uerr := skCfg.LogLevel.UnmarshalText([]byte(cfg.LogLevel)); uerr != nil {
		return serverkit.Config{}, fmt.Errorf("invalid log level %q: %w", cfg.LogLevel, uerr)
	}
{{- end}}

{{- if index .ConfigFields "CorsOrigins"}}

	if cfg.CorsOrigins != "" {
		for _, o := range strings.Split(cfg.CorsOrigins, ",") {
			if o = strings.TrimSpace(o); o != "" {
				skCfg.CORSOrigins = append(skCfg.CORSOrigins, o)
			}
		}
	}
{{- end}}

{{- if index .ConfigFields "PreStopDelay"}}

	skCfg.PreStopDelay = cfg.PreStopDelay.AsDuration()
{{- end}}
{{- if index .ConfigFields "ShutdownTimeout"}}
	skCfg.ShutdownTimeout = cfg.ShutdownTimeout.AsDuration()
{{- end}}

{{- if index .ConfigFields "DbMaxOpenConns"}}

	skCfg.DBPoolTuning.MaxOpenConns = int(cfg.DbMaxOpenConns)
{{- end}}
{{- if index .ConfigFields "DbMaxIdleConns"}}
	skCfg.DBPoolTuning.MaxIdleConns = int(cfg.DbMaxIdleConns)
{{- end}}
{{- if index .ConfigFields "DbConnMaxIdleTime"}}
	skCfg.DBPoolTuning.ConnMaxIdleTime = cfg.DbConnMaxIdleTime.AsDuration()
{{- end}}
{{- if index .ConfigFields "DbConnMaxLifetime"}}
	skCfg.DBPoolTuning.ConnMaxLifetime = cfg.DbConnMaxLifetime.AsDuration()
{{- end}}

	return skCfg, nil
}
