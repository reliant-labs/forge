// projectServiceFiles builds a *protoregistry.Files scoped to the PROJECT's
// own declared services (app.Inventory), for the RequireMounted completeness
// gate. It looks each inventory ConnectPath (a fully-qualified Connect service
// name) up in protoregistry.GlobalFiles and registers ONLY those services'
// parent FileDescriptors — so the gate sees exactly the services this binary
// is responsible for and ignores framework / transitively-imported proto
// (grpc.health, OTel collector). A missing descriptor is a hard error: the
// inventory and the gen packages must agree.
func projectServiceFiles() (*protoregistry.Files, error) {
	files := &protoregistry.Files{}
	seen := make(map[protoreflect.FullName]struct{})
	for _, info := range app.Inventory {
		desc, err := protoregistry.GlobalFiles.FindDescriptorByName(protoreflect.FullName(info.ConnectPath))
		if err != nil {
			return nil, fmt.Errorf("service %q (%s) not found in global proto registry: %w", info.Name, info.ConnectPath, err)
		}
		fd := desc.ParentFile()
		if _, ok := seen[fd.FullName()]; ok {
			continue
		}
		seen[fd.FullName()] = struct{}{}
		if rerr := files.RegisterFile(fd); rerr != nil {
			return nil, fmt.Errorf("registering file for service %q: %w", info.Name, rerr)
		}
	}
	return files, nil
}
{{- if .RESTEnabled}}

// restHandler wraps the Connect mux in a vanguard transcoder over the
// mounted services' Connect paths. Returns nil when nothing was mounted.
func restHandler(mux *http.ServeMux, connectPaths []string) http.Handler {
	if len(connectPaths) == 0 {
		return nil
	}
	svcs := make([]*vanguard.Service, 0, len(connectPaths))
	for _, p := range connectPaths {
		svcs = append(svcs, vanguard.NewService(p, mux))
	}
	transcoder, err := vanguard.NewTranscoder(svcs)
	if err != nil {
		slog.Error("init vanguard REST transcoder", "error", err)
		return nil
	}
	return transcoder
}
