# Production configuration for {{.Name}}
port: 8080
log-level: info
log-format: json
environment: production
auto-migrate: false
pprof-addr: ""
security-headers-enabled: true
rate-limit-rps: 100
rate-limit-burst: 200
db-max-open-conns: 25
db-max-idle-conns: 5
db-conn-max-idle-time: 5m
db-conn-max-lifetime: 30m
pre-stop-delay: 5s
shutdown-timeout: 30s
