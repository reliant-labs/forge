services:
  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    mem_limit: 512m
    cpus: 0.5
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{.ProjectName}}}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    ports:
      - "0:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - {{.ProjectName}}-net

  app:
    build:
      context: .
      target: dev
    restart: unless-stopped
    environment:
      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-{{.ProjectName}}}?sslmode=disable
      OTEL_EXPORTER_OTLP_ENDPOINT: http://lgtm:4317
      OTEL_SERVICE_NAME: {{.ProjectName}}
      ENVIRONMENT: development
      LOG_LEVEL: debug
      LOG_FORMAT: text
      AUTO_MIGRATE: "true"
      PPROF_ADDR: ":6060"
    ports:
      - "0:8080"
      - "0:6060"
    volumes:
      - .:/app
      - go_mod_cache:/go/pkg/mod
      - go_build_cache:/root/.cache/go-build
    depends_on:
      postgres:
        condition: service_healthy
      lgtm:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:8080/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 15s
    networks:
      - {{.ProjectName}}-net

  app-debug:
    build:
      context: .
      target: debug
    restart: unless-stopped
    environment:
      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-{{.ProjectName}}}?sslmode=disable
      OTEL_EXPORTER_OTLP_ENDPOINT: http://lgtm:4317
      OTEL_SERVICE_NAME: {{.ProjectName}}
      ENVIRONMENT: development
    ports:
      - "0:8080"
      - "0:2345"
    security_opt:
      - "apparmor=unconfined"
    cap_add:
      - SYS_PTRACE
    depends_on:
      postgres:
        condition: service_healthy
      lgtm:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:8080/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 30s
    profiles:
      - debug
    networks:
      - {{.ProjectName}}-net

  # Grafana Alloy — single collector for metrics, logs, and profiles.
  # Scrapes app services on the docker network and forwards to the LGTM stack.
  alloy:
    image: grafana/alloy:latest
    restart: unless-stopped
    volumes:
      - ./deploy/alloy-config.alloy:/etc/alloy/config.alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    command: ["run", "/etc/alloy/config.alloy"]
    depends_on:
      lgtm:
        condition: service_healthy
    networks:
      - {{.ProjectName}}-net

  # Grafana LGTM — all-in-one observability backend.
  # Bundles: Grafana (dashboards), Prometheus (metrics), Tempo (traces),
  #          Loki (logs), Pyroscope (continuous profiling), and an
  #          OpenTelemetry Collector.
  #
  # The app pushes traces via OTLP gRPC to lgtm:4317 on the docker network.
  # Only Grafana UI is exposed to the host (dynamic port).
  lgtm:
    image: grafana/otel-lgtm:latest
    restart: unless-stopped
    ports:
      - "0:3000"    # Grafana UI (dynamic host port)
    environment:
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: Admin
    volumes:
      - lgtm_data:/data
      - ./deploy/observability/grafana/dashboards:/grafana/dashboards
      - ./deploy/observability/grafana/provisioning:/etc/grafana/provisioning/dashboards
    healthcheck:
      test: ["CMD", "test", "-f", "/tmp/ready"]
      interval: 5s
      timeout: 1s
      retries: 30
      start_period: 30s
    networks:
      - {{.ProjectName}}-net

volumes:
  postgres_data:
  go_mod_cache:
  go_build_cache:
  lgtm_data:

networks:
  {{.ProjectName}}-net:
    driver: bridge