services:
  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    # mem_limit / cpus (compose v2 short form) keep local dev from letting
    # a runaway query chew through host memory or CPU — useful on laptops
    # where `docker compose up` shares resources with the IDE. The short
    # form works on every compose version shipped since 1.x; `deploy.
    # resources.limits` only applies under Swarm and was silently
    # ignored here. Raise these on dedicated build machines if you
    # import a large fixture.
    mem_limit: 512m
    cpus: 0.5
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-{{.ProjectName}}}
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
    ports:
      - "127.0.0.1:5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - {{.ProjectName}}-net

  app:
    build: .
    restart: unless-stopped
    environment:
      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-{{.ProjectName}}}?sslmode=disable
      PORT: ${PORT:-8080}
    ports:
      - "${PORT:-8080}:${PORT:-8080}"
    depends_on:
      postgres:
        condition: service_healthy
      jaeger:
        condition: service_healthy
    healthcheck:
      # /healthz is the in-process liveness endpoint (see cmd/server.go).
      # We shell out to wget (busybox/alpine) because the Go runtime base
      # images don't bundle curl; wget -q --spider is the portable equivalent.
      test: ["CMD-SHELL", "wget -q --spider http://localhost:${PORT:-8080}/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 10s
    networks:
      - {{.ProjectName}}-net

  app-debug:
    build:
      context: .
      target: debug
    restart: unless-stopped
    environment:
      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-{{.ProjectName}}}?sslmode=disable
      ENVIRONMENT: development
      PORT: ${PORT:-8080}
    ports:
      - "${PORT:-8080}:${PORT:-8080}"
      - "2345:2345"
    security_opt:
      - "apparmor=unconfined"
    cap_add:
      - SYS_PTRACE
    depends_on:
      postgres:
        condition: service_healthy
      jaeger:
        condition: service_healthy
    healthcheck:
      # Same endpoint as app; Delve attaches separately on :2345.
      test: ["CMD-SHELL", "wget -q --spider http://localhost:${PORT:-8080}/healthz || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 5
      # Debug binaries boot slower because Delve waits for an attach before
      # executing main; give it a longer grace period.
      start_period: 30s
    profiles:
      - debug
    networks:
      - {{.ProjectName}}-net

  jaeger:
    image: jaegertracing/all-in-one:1.64
    restart: unless-stopped
    ports:
      - "16686:16686"  # Jaeger UI
      - "4317:4317"    # OTLP gRPC
      - "14269:14269"  # Admin / health
    environment:
      COLLECTOR_OTLP_ENABLED: "true"
    healthcheck:
      # Jaeger exposes its health endpoint on port 14269 (admin HTTP). We
      # can't rely on curl/wget inside the jaeger image, so we probe the TCP
      # port with /dev/tcp (bash builtin) via sh -c; busybox sh supports it.
      test: ["CMD-SHELL", "timeout 1 sh -c '</dev/tcp/localhost/14269' || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 10s
    networks:
      - {{.ProjectName}}-net

volumes:
  postgres_data:

networks:
  {{.ProjectName}}-net:
    driver: bridge