syntax = "proto3";

package {{.Package}}.db.v1;

import "forge/v1/forge.proto";
import "google/protobuf/timestamp.proto";

option go_package = "github.com/{{.Package}}/gen/db/v1;dbv1";

// Example entity with Forge DB annotations.
//
// Migration-first workflow:
//   1. Author and review SQL migrations in db/migrations/.
//   2. Apply migrations to a target database.
//   3. Sync or validate proto DB entities against the migrated schema.
//   4. Regenerate code and use the resulting CRUD helpers in service code.
message ExampleEntity {
  // Message-level options define table-level metadata used by ORM codegen.
  option (forge.v1.entity) = {
    table: "example_entities"
    soft_delete: true
    timestamps: true
    indexes: [
      {
        name: "idx_status_created"
        fields: ["status", "created_at"]
      },
      {
        name: "idx_email"
        fields: ["email"]
        unique: true
      }
    ]
  };

  // Primary key field
  string id = 1 [(forge.v1.field) = {
    pk: true
  }];

  // Required text field
  string name = 2;

  // Email field with unique index (defined above)
  string email = 3 [(forge.v1.field) = {
    unique: true
  }];

  // Status field with default
  string status = 4 [(forge.v1.field) = {
    default_value: "'pending'"
  }];

  // JSON metadata (stored as JSONB in PostgreSQL)
  string metadata = 5 [(forge.v1.field) = {
    store: STORE_AS_JSONB
  }];

  // Timestamps
  google.protobuf.Timestamp created_at = 6 [(forge.v1.field) = {
    default_value: "NOW()"
  }];

  google.protobuf.Timestamp updated_at = 7 [(forge.v1.field) = {
    default_value: "NOW()"
  }];

  // Soft-delete timestamp (nullable)
  google.protobuf.Timestamp deleted_at = 8;
}

