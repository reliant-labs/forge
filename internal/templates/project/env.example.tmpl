# OpenTelemetry Configuration
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable tracing and metrics export.
# When unset, OpenTelemetry is disabled (no-op).
# Uncomment the next line to point at a local OTLP collector:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME is the advertised `service.name` resource attribute on
# every exported span/metric. Set by default so copying `.env.example` to
# `.env` produces a usable service identity; override per-deployment.
OTEL_SERVICE_NAME=demo