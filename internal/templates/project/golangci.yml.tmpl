# Forge lint configuration — calibrated conservative defaults for
# Go+Connect projects. The intent is "noise-free out of the box" —
# every enabled linter has a brief rationale below. Ratchet down per-project
# as the codebase matures.
#
# Adjust thresholds for your project:
#   Stricter (CRUD APIs):    cyclop 12, funlen 60, gocognit 15
#   Looser (internal/operators/billing): cyclop 20, funlen 120, gocognit 30
# Use path-based exclusions for complex subsystems rather than raising
# global thresholds.

version: "2"

run:
  timeout: 5m

linters:
  enable:
    # Correctness — high-signal, low-noise.
    - govet         # standard correctness vet set
    - errcheck      # catches unchecked error returns
    - staticcheck   # the SA / ST / S family — broadly accepted lints
    - unused        # dead code detection
    - ineffassign   # unused variable assignments
    - noctx         # http.Request without a context
    - misspell      # English spelling
    # Style — cross-project consistency.
    - gocritic      # opinionated style nits (diagnostic + style + perf tags)
    - revive        # broad replacement for golint, configurable per-rule
    - godot         # require trailing punctuation on top-level doc comments
    # Complexity — fail-loud when functions get away from us.
    # cyclop dropped: cyclomatic complexity duplicates gocognit (cognitive
    # complexity) — the better readability signal and the single complexity
    # gate. nestif/funlen cover the orthogonal nesting/length smells.
    - funlen        # function length cap
    - gocognit      # cognitive complexity (subjectively closer to readability)
    - nestif        # block-nesting depth
    - interfacebloat # cap interface method count
{{- if eq .TypedAccessGuard "error"}}
    # Typed-config guardrail (config.enforce_typed_access: error) — GATING:
    # os.Getenv / os.LookupEnv / os.Environ fail the build. Enabling forbidigo
    # HERE is what gates it: a plain `golangci-lint run` (the command CI runs
    # directly) fails on these findings. In `warn` mode forbidigo is
    # intentionally absent from this list and `forge lint` runs it as a
    # separate advisory (non-failing) step instead.
    - forbidigo
{{- end}}
  settings:
    govet:
      enable-all: true
      disable:
        - fieldalignment
        # `shadow` flags idiomatic `if err := f(); err != nil` patterns in
        # nested scopes that Go style allows — dozens of non-bug findings.
        - shadow
    revive:
      rules:
        - name: blank-imports
        - name: context-as-argument
        - name: dot-imports
        - name: error-return
        - name: error-strings
        - name: exported
        - name: increment-decrement
        - name: var-naming
        - name: unexported-return
        - name: argument-limit
          arguments: [8]
        - name: function-result-limit
          arguments: [4]
        - name: max-public-structs
          # 25 accommodates the forge-canonical interactor/adapter scaffold:
          # Service + collaborator interfaces (Source/Sink/...) + input/output
          # structs (RunInput/RunResult/Item/...) routinely hit 6+ public
          # types in a single package before any user code is added. CRUD
          # services accumulate request/response and entity types similarly.
          # Bump further if your package legitimately exposes more (e.g. a
          # flat config module); refactor if you're past 25 without one.
          arguments: [40]
        - name: max-control-nesting
          arguments: [5]
    cyclop:
      # MODERATE profile — the same bar forge holds itself to. Long
      # switch/CRUD/dispatch methods sit under 20; past that, extract a
      # helper (or, for genuine subsystems, use the path exclusions below).
      max-complexity: 20
      package-average: 6.0
      skip-tests: true
    funlen:
      lines: 150
      statements: 80
    gocognit:
      # Cognitive complexity ≠ cyclomatic complexity: nesting and short-
      # circuit chains weigh more. 40 catches genuine monsters without
      # punishing well-structured branchy validators/parsers.
      min-complexity: 80
    nestif:
      min-complexity: 8
    interfacebloat:
      max: 12
    godot:
      # Require sentence punctuation on top-level doc comments only;
      # inline TODOs / sentence fragments inside function bodies are fine.
      scope: declarations
      capital: false
      period: true
    gocritic:
      enabled-tags:
        - diagnostic
        - style
        - performance
      disabled-checks:
        # `hugeParam` flags struct-by-value args >80 bytes; we routinely
        # pass *Request / Deps structs by value as a deliberate API choice.
        - hugeParam
        # Pure-cosmetic checks: value-receiver ranges over config structs,
        # if/else over short two-arm branches, unnamed internal results,
        # combinable param types, single-case switches, len==0 tests. These
        # are style preferences, not defects — suppressed to keep `forge
        # lint` signal high (matches forge's own .golangci.yml).
        - rangeValCopy
        - ifElseChain
        - unnamedResult
        - paramTypeCombine
        - singleCaseSwitch
        - emptyStringTest
{{- if .TypedAccessGuard}}
    forbidigo:
      # Typed-config guardrail (forge.yaml: config.enforce_typed_access).
      # Steers humans and LLMs away from reading the environment directly and
      # toward forge's generated, dependency-injected typed config object.
      # The allowlisted loader package ({{.LoaderPackage}}) is excluded under
      # `exclusions.rules` below.
{{- if eq .TypedAccessGuard "warn"}}
      # ADVISORY mode. forbidigo is deliberately ABSENT from `linters.enable`
      # above, so a plain `golangci-lint run` — the command CI invokes
      # directly via golangci-lint-action — never fails on these findings.
      # `linters.enable` membership IS the gate, and CI is the consumer, which
      # is why the warn/error switch lives here (in this file) rather than in
      # `forge lint`. `forge lint` re-runs forbidigo as a separate non-failing
      # step (--enable-only=forbidigo --issues-exit-code=0) so the findings are
      # still visible locally. To make them GATE the build, set
      # `config.enforce_typed_access: error` in forge.yaml, then re-render this
      # file (it is scaffold-once / user-owned — `rm .golangci.yml && forge
      # upgrade`, or `forge upgrade --force` if you have no local edits).
{{- end}}
      forbid:
        - pattern: 'os\.Getenv'
          msg: >-
            Read configuration from the injected forge config object, not the
            environment directly. Declare new settings in
            proto/config/v1/*.proto with the (forge.v1.config) annotation, then
            run `forge generate` — forge produces a typed loader (pkg/config),
            fails fast when a required value is missing, and wires secrets
            automatically. To opt out: add //nolint:forbidigo on this line, or
            set config.enforce_typed_access to warn/off in forge.yaml.
        - pattern: 'os\.LookupEnv'
          msg: >-
            Read configuration from the injected forge config object, not the
            environment directly. Declare new settings in
            proto/config/v1/*.proto with the (forge.v1.config) annotation, then
            run `forge generate` — forge produces a typed loader (pkg/config),
            fails fast when a required value is missing, and wires secrets
            automatically. To opt out: add //nolint:forbidigo on this line, or
            set config.enforce_typed_access to warn/off in forge.yaml.
        - pattern: 'os\.Environ'
          msg: >-
            Read configuration from the injected forge config object, not the
            environment directly. Declare new settings in
            proto/config/v1/*.proto with the (forge.v1.config) annotation, then
            run `forge generate` — forge produces a typed loader (pkg/config),
            fails fast when a required value is missing, and wires secrets
            automatically. To opt out: add //nolint:forbidigo on this line, or
            set config.enforce_typed_access to warn/off in forge.yaml.
{{- end}}
  exclusions:
    paths:
      - gen
      # Generated, forge-owned files (mock_gen.go, authorizer_gen.go,
      # config_gen.go, ...). Never lint or hand-edit generated code —
      # forge regenerates it and edits would be lost / trip the stomp guard.
      - ".*_gen\\.go$"
      - ".*node_modules.*"
      - ".*frontends.*"
      - ".*\\.pb\\.go$"
      - ".*\\.connect\\.go$"
    rules:
      - path: _test\.go
        linters:
          - errcheck
          - gocritic
          - funlen
          - cyclop
          - gocognit
          - godot
      - path: cmd/
        linters:
          - cyclop
          - gocognit
          - funlen
      - path: internal/operators/
        linters:
          - funlen
          - gocognit
          - nestif
          - cyclop
{{- if .TypedAccessGuard}}
      # The generated config loader is the ONE package allowed to read the
      # environment directly (os.Getenv / os.LookupEnv); the typed-access
      # guardrail allowlists it so the loader itself is not flagged.
      - path: ^{{.LoaderPackage}}/
        linters:
          - forbidigo
{{- end}}

formatters:
  enable:
    - goimports
  settings:
    goimports:
      local-prefixes:
        - {{.Module}}