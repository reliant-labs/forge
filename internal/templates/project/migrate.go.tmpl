// Code generated by forge. DO NOT EDIT.
// Source: forge.yaml database configuration + db/migrations/.
//
// To customize: edit forge.yaml and re-run `forge generate`. Migration
// SQL lives in db/migrations/ (user-owned).
package app

import (
	"database/sql"
{{- if .HasMigrations}}
	"fmt"
	"io/fs"
{{- end}}
	"log/slog"
{{- if .HasMigrations}}

	forgedb "{{.ModulePath}}/db"
	"github.com/golang-migrate/migrate/v4"
	"github.com/golang-migrate/migrate/v4/database/postgres"
	"github.com/golang-migrate/migrate/v4/source/iofs"
{{- end}}
)

// AutoMigrate runs all pending database migrations.
// It is safe to call on every startup — already-applied migrations are
// skipped. Failure modes are LOUD: an unreadable embedded FS, an
// unreadable schema_migrations table, or a dirty schema all abort
// startup with an error instead of serving against a database in an
// unknown state.
func AutoMigrate(db *sql.DB, logger *slog.Logger) error {
{{- if .HasMigrations}}
	// An embedded-FS read error is a build/packaging bug (corrupt embed,
	// renamed dir) — fail. Only a genuinely empty migrations dir skips.
	entries, err := fs.ReadDir(forgedb.MigrationsFS, "migrations")
	if err != nil {
		return fmt.Errorf("reading embedded migrations: %w", err)
	}
	if len(entries) == 0 {
		logger.Info("no migration files found, skipping auto-migrate")
		return nil
	}

	sourceDriver, err := iofs.New(forgedb.MigrationsFS, "migrations")
	if err != nil {
		return fmt.Errorf("creating migration source: %w", err)
	}

	dbDriver, err := postgres.WithInstance(db, &postgres.Config{})
	if err != nil {
		return fmt.Errorf("creating migration db driver: %w", err)
	}

	m, err := migrate.NewWithInstance("iofs", sourceDriver, "postgres", dbDriver)
	if err != nil {
		return fmt.Errorf("creating migrator: %w", err)
	}

	// ErrNilVersion just means no migration has been applied yet; any
	// other Version error means schema_migrations is unreadable.
	version, dirty, verr := m.Version()
	if verr != nil && verr != migrate.ErrNilVersion {
		return fmt.Errorf("reading migration version: %w", verr)
	}
	logger.Info("migration status", "current_version", version, "dirty", dirty)

	// A dirty schema means a previous migration failed partway. Running
	// more migrations (or serving traffic) against it compounds the
	// damage — stop and make a human look.
	if dirty {
		return fmt.Errorf("database schema is dirty at version %d — a previous migration failed partway; inspect the database, fix the partial migration, then clear the dirty flag (e.g. `migrate force %d`) before restarting", version, version)
	}

	if err := m.Up(); err != nil && err != migrate.ErrNoChange {
		return fmt.Errorf("running migrations: %w", err)
	}

	newVersion, _, verr := m.Version()
	if verr != nil && verr != migrate.ErrNilVersion {
		return fmt.Errorf("reading migration version after apply: %w", verr)
	}
	if newVersion != version {
		logger.Info("migrations applied", "from_version", version, "to_version", newVersion)
	} else {
		logger.Info("no pending migrations")
	}
{{- else}}
	// No migration files embedded yet. Create SQL migration files in
	// db/migrations/ and run 'forge generate' to embed them.
	_ = db // will be used once migrations are embedded
	logger.Info("no migration files embedded, skipping auto-migrate")
{{- end}}

	return nil
}