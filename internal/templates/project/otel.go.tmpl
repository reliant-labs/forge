package main

import (
	"context"
	"net/http"
	"os"

	"github.com/reliant-labs/forge/pkg/observe"

	"{{.Module}}/pkg/config"
)

// setupOTel builds an observe.Config from the project's TYPED config (no
// os.Getenv here) and delegates to observe.Setup, which owns all OpenTelemetry
// SDK wiring (Prometheus reader + optional OTLP/gRPC trace & metric exporters).
//
// The OTLP endpoint and service name flow from pkg/config (config.proto fields
// OTLP_ENDPOINT / SERVICE_NAME), so per-env values are set through the app's
// config surface (KCL / env projection), not read from the environment here.
// When cfg.OTLPEndpoint is empty, observe.Setup wires the Prometheus-only path
// so /metrics still works.
//
// Returns a shutdown function, an http.Handler for /metrics, and any error.
func setupOTel(ctx context.Context, cfg *config.Config) (func(context.Context) error, http.Handler, error) {
	// service.instance.id is the only host-derived attribute; os.Hostname is
	// not an environment read (forbidigo targets os.Getenv/LookupEnv/Environ).
	instanceID, _ := os.Hostname()

	return observe.Setup(ctx, observe.Config{
		ServiceName:    cfg.ServiceName,
		ServiceVersion: version,
		OTLPEndpoint:   cfg.OTLPEndpoint,
		InstanceID:     instanceID,
	})
}
