// Infra is the OWNED provider set (FORGE_SHAPE_REDESIGN §2) — everything
// the generated injector (internal/app/inject_gen.go) cannot derive. The
// generated Build fills each component's Deps BY TYPE: from another
// constructed component, or from a field on THIS struct. So a collaborator
// the injector can't build itself becomes a field here, constructed in
// OpenInfra.
//
// Three categories of provider live here:
//
//  1. INFRA — DB pool, NATS conn, k8s client, third-party clients
//     (constructed in OpenInfra; nil-able on unset env).
//  2. ADAPTER — concrete wrappings, e.g.
//     `enforcement.NewDBRepository(repo)` assigned onto a field so the
//     injector binds it to a narrow Deps interface BY TYPE.
//  3. BINDING — explicit concrete->interface choices where the by-type
//     resolver would be ambiguous (two producers of one interface, or
//     in-process-service vs Connect-client selection).
//
// yours: scaffolded once, never touched again — forge will not overwrite this file
//
//forge:allow
type Infra struct {
	// Log and Cfg are the conventional sources Build wires for every
	// component's Logger / Config Deps field. Keep them named exactly.
	Log *slog.Logger
	Cfg *config.Config
{{- if .HasDatabase}}

	// DB is the shared database pool. A narrow per-component Repository
	// Deps field is filled from this by the injector when *sql.DB (or a
	// repository wrapping it) is assignable to that interface.
	DB *sql.DB
{{- if .OrmEnabled}}
	ORM *orm.Client
{{- end}}
{{- end}}

	// FORGE_SCAFFOLD: add a field here for every collaborator the injector
	// reported as "no provider" — a DB repository, a NATS publisher, a
	// third-party client, or an adapter wrapping. Construct it in
	// OpenInfra. The injector binds it to the consuming Deps field by TYPE,
	// so the field type only has to be ASSIGNABLE to the Deps field
	// (a concrete *db.PostgresRepository fills a narrow audit.Repository).
}

// OpenInfra builds the owned provider set: open every piece of
// infrastructure (DB/NATS/k8s/clients), wrap adapters, and pick explicit
// bindings. Build (inject_gen.go) then constructs the component graph from
// the returned *Infra. Two-phase / late-bound wiring goes in PostBuild
// (post_build.go), which runs after Build.
//
// yours: scaffolded once, never touched again — forge will not overwrite this file
//
//forge:allow
func OpenInfra(ctx context.Context, cfg *config.Config, logger *slog.Logger) (*Infra, error) {
	infra := &Infra{Log: logger, Cfg: cfg}
{{- if .HasDatabase}}

	db, err := openDatabase(cfg)
	if err != nil {
		return nil, fmt.Errorf("open database: %w", err)
	}
	infra.DB = db
{{- if .OrmEnabled}}
	if db != nil {
		ormClient, err := orm.NewClientWithDB(db, "postgres")
		if err != nil {
			return nil, fmt.Errorf("create ORM client: %w", err)
		}
		infra.ORM = ormClient
	}
{{- end}}
{{- else}}

	// FORGE_SCAFFOLD: construct infrastructure + adapters here and assign
	// them onto infra fields. Remove this comment after editing.
	_ = ctx
{{- end}}
	return infra, nil
}
{{if .HasDatabase}}
func openDatabase(cfg *config.Config) (*sql.DB, error) {
	dsn := cfg.DatabaseUrl
	if dsn == "" {
		slog.Warn("DATABASE_URL is not set, skipping database setup")
		return nil, nil
	}
	db, err := sql.Open("pgx", dsn)
	if err != nil {
		return nil, fmt.Errorf("sql.Open: %w", err)
	}
	db.SetMaxOpenConns(25)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(5 * time.Minute)
	db.SetConnMaxIdleTime(1 * time.Minute)
	if err := db.Ping(); err != nil {
		db.Close()
		return nil, fmt.Errorf("db.Ping: %w", err)
	}
	return db, nil
}
{{end}}