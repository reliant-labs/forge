// What THIS binary serves is code, not config.
//
// yours: scaffolded once, never touched again — forge will not overwrite this file
// Serving a service = listing its serviceRow line below. The row
// constructors are generated guardrails in pkg/app/services_gen.go
// (regenerated by `forge generate`); this list is the decision.
//
// To stop serving a service from this binary (types-only: its proto
// types, Connect client, and frontend hooks keep generating for
// callers), DELETE its line below and LEAVE A COMMENT naming the
// binary that serves it. The comment matters: forge treats any mention
// of the service name in this file as "deliberately not served here"
// and stops regenerating its handlers/ scaffold; a service name that
// appears nowhere in this file is treated as newly added instead.
//
// `forge add service <name>` generates the row constructor but never
// edits this file — add the printed line yourself to serve it.
package app

import (
	"log/slog"

	"connectrpc.com/connect"

	"github.com/reliant-labs/forge/pkg/appkit"
	"{{.Module}}/pkg/config"
)

// RegisteredServices lists what THIS binary serves. Serving a service
// = listing its row. Types-only (served elsewhere)? Delete the line
// and leave a comment saying where it lives.
func RegisteredServices(app *App, cfg *config.Config, logger *slog.Logger, devMode bool, opts ...connect.HandlerOption) []appkit.ServiceDef {
{{- if .Services}}
	return []appkit.ServiceDef{
{{- range .Services}}
		serviceRow{{.FieldName}}(app, cfg, logger, devMode, opts...),
{{- end}}
	}
{{- else}}
	return []appkit.ServiceDef{}
{{- end}}
}
