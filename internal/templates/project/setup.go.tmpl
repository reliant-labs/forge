package app

import (
{{- if .HasDatabase}}
	"database/sql"
	"fmt"
	"log/slog"
	"time"
{{end}}
	"{{.Module}}/pkg/config"
{{- if .HasDatabase}}

	"github.com/reliant-labs/forge/pkg/orm"
{{- end}}
{{- if eq .DatabaseDriver "postgres"}}

	_ "github.com/jackc/pgx/v5/stdlib"
{{- end}}
{{- if eq .DatabaseDriver "sqlite"}}

	_ "github.com/mattn/go-sqlite3"
{{- end}}
)

// Setup is called by the generated Bootstrap function after all services are
// constructed. Use this function to wire custom dependencies, add fields to
// service Deps structs, or perform any post-bootstrap initialization.
//
// This file is YOUR code — forge generate will never overwrite it.
//
//forge:allow
func Setup(app *App, cfg *config.Config) error {
{{- if .HasDatabase}}
	db, err := setupDatabase(cfg)
	if err != nil {
		return fmt.Errorf("failed to connect to database: %w", err)
	}
	app.DB = db

	if db != nil {
		ormClient, err := orm.NewClientWithDB(db, "{{.DatabaseDriver}}")
		if err != nil {
			return fmt.Errorf("failed to create ORM client: %w", err)
		}
		app.ORM = ormClient
	}
{{- else}}
	// Add your custom wiring here.
{{- end}}
	return nil
}
{{if .HasDatabase}}
func setupDatabase(cfg *config.Config) (*sql.DB, error) {
	dsn := cfg.DatabaseURL
	if dsn == "" {
		slog.Warn("DATABASE_URL is not set, skipping database setup")
		return nil, nil
	}

{{- if eq .DatabaseDriver "postgres"}}
	db, err := sql.Open("pgx", dsn)
{{- else}}
	db, err := sql.Open("{{.DatabaseDriver}}", dsn)
{{- end}}
	if err != nil {
		return nil, fmt.Errorf("sql.Open: %w", err)
	}

	// Connection pool settings
	db.SetMaxOpenConns(25)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(5 * time.Minute)
	db.SetConnMaxIdleTime(1 * time.Minute)

	if err := db.Ping(); err != nil {
		db.Close()
		return nil, fmt.Errorf("db.Ping: %w", err)
	}

	return db, nil
}
{{end}}