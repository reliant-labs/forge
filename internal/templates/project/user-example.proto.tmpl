syntax = "proto3";

package services.{{.ServicePackage}}.v1;

import "google/protobuf/field_mask.proto";
import "google/protobuf/timestamp.proto";
import "forge/v1/forge.proto";

option go_package = "{{.Module}}/gen/services/{{.ServicePackage}}/v1;{{.ServicePackage}}v1";

// {{.Name}} service with basic CRUD operations.
//
// RPC names follow the forge CRUD convention: <Verb><Entity> with
// <Verb><Entity>Request / <Verb><Entity>Response messages (List uses the
// plural: List<Entities>). The convention is load-bearing — forge's
// codegen keys on it to detect entities. An entity becomes REAL when its
// table exists in the applied schema (db/migrations): run
// `forge add entity item ...` to create the table, then `forge generate`
// projects the ORM, CRUD handlers, frontend hooks, mocks, nav routes and
// entity pages from the real columns. When you rename "Item" to your
// real entity, keep the <Verb><Entity> shape.
// Reference: forge skill load proto (CRUD RPC Naming Convention).
// Role is this project's starter authorization role enum. The Role string
// values (lowercased enum names, e.g. "admin", "member") are what the
// RoleResolver in internal/handlers/{{.ServicePackage}}/role_resolver.go returns
// and what the (forge.v1.method).required_roles annotations below name. Add or
// rename roles here as your access model grows. Authorization is enforced by
// forge/pkg/authz — see the forge `auth` skill.
enum Role {
  ROLE_UNSPECIFIED = 0;
  ROLE_ADMIN = 1;
  ROLE_MEMBER = 2;
}

service {{.ServiceName | pascalCase}}Service {
  option (forge.v1.service) = {
    name: "{{.ServiceName | pascalCase}}Service"
    version: "1.0.0"
    description: "{{.ServiceName | pascalCase}} management service"

    // Service-wide default authorization: every method that declares no
    // required_roles of its own requires "member". This makes the service
    // fail-closed by default — a forgotten annotation inherits this floor
    // rather than silently going open. The authz completeness lint still
    // requires each method to be explicitly authorized OR covered here.
    default_roles: ["member"]
  };

  // Create a new item — restricted to admins. The per-method required_roles
  // overrides the service default_roles above. This is the canonical example:
  // role policy is declared HERE, in the proto, and enforced by the single
  // shared authz interceptor reading these annotations off the descriptor.
  rpc CreateItem(CreateItemRequest) returns (CreateItemResponse) {
    option (forge.v1.method) = {
      auth_required: true
      idempotency_key: true
      required_roles: ["admin"]
    };
  }

  // Get item by ID — any member (inherits the service default_roles).
  rpc GetItem(GetItemRequest) returns (GetItemResponse) {
    option (forge.v1.method) = {
      auth_required: true
    };
  }

  // Update item — admins only.
  rpc UpdateItem(UpdateItemRequest) returns (UpdateItemResponse) {
    option (forge.v1.method) = {
      auth_required: true
      idempotency_key: true
      required_roles: ["admin"]
    };
  }

  // Delete item — admins only.
  rpc DeleteItem(DeleteItemRequest) returns (DeleteItemResponse) {
    option (forge.v1.method) = {
      auth_required: true
      idempotency_key: true
      required_roles: ["admin"]
    };
  }

  // List items with pagination — any member (inherits the service default).
  rpc ListItems(ListItemsRequest) returns (ListItemsResponse) {
    option (forge.v1.method) = {
      auth_required: true
    };
  }
}

// Main entity
message Item {
  string id = 1;
  string name = 2;
  string description = 3;
  bool active = 4;

  // Timestamp fields
  google.protobuf.Timestamp created_at = 5;
  google.protobuf.Timestamp updated_at = 6;
  google.protobuf.Timestamp deleted_at = 7;
}

// Request/Response messages
message CreateItemRequest {
  string name = 1;
  string description = 2;
}

message CreateItemResponse {
  Item item = 1;
}

message GetItemRequest {
  string id = 1;
}

message GetItemResponse {
  Item item = 1;
}

// Update follows the Google AIP-134 convention: the resource is passed by
// value and the caller specifies which fields to replace via update_mask.
// If update_mask is empty the handler must treat the request as a no-op
// (callers should always set the mask explicitly).
message UpdateItemRequest {
  // The resource to update. Its `id` field identifies the target row.
  Item item = 1;

  // Paths of the fields in `item` to replace. Use `*` to replace all
  // mutable fields. See https://google.aip.dev/134.
  google.protobuf.FieldMask update_mask = 2;
}

message UpdateItemResponse {
  Item item = 1;
}

message DeleteItemRequest {
  string id = 1;
  bool hard_delete = 2;
}

// DeleteItemResponse returns the id that was deleted plus the server-observed
// deletion time. This gives callers enough information to reconcile local
// caches without a follow-up GetItem.
message DeleteItemResponse {
  string id = 1;
  google.protobuf.Timestamp deleted_at = 2;
}

message ListItemsRequest {
  int32 page_size = 1;
  string page_token = 2;

  // Filters
  optional bool active = 3;
  optional string search = 4;

  // Sorting
  string order_by = 5;
  bool descending = 6;
}

message ListItemsResponse {
  repeated Item items = 1;
  string next_page_token = 2;

  // NOTE: total_count is approximate and can be expensive for large
  // datasets — many backends fall back to `COUNT(*)` which scans the
  // filtered index. For hot list endpoints consider either:
  //   (a) dropping this field and relying on cursor-based pagination, or
  //   (b) moving exact counts to a dedicated CountItems RPC so callers opt in.
  // See https://google.aip.dev/158 for the AIP position on this tradeoff.
  int32 total_count = 3;
}
