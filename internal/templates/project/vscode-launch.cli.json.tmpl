{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug {{.Name}} CLI",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/{{.Name}}",
      "args": [],
      "buildFlags": "-gcflags='all=-N -l'"
    },
    {
      "name": "Debug Current Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "buildFlags": "-gcflags='all=-N -l'"
    }
  ]
}
