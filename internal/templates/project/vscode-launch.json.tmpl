{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd",
      "args": ["server"],
      "env": {
        "ENVIRONMENT": "development",
        "PORT": "{{.ServicePort}}"
      },
      "buildFlags": "-gcflags='all=-N -l'"
    },
    {
      "name": "Attach to Delve",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "${workspaceFolder}",
      "port": 2345,
      "host": "127.0.0.1"
    },
    {
      "name": "Debug Current Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "env": {
        "ENVIRONMENT": "development"
      },
      "buildFlags": "-gcflags='all=-N -l'"
    }
  ]
}
