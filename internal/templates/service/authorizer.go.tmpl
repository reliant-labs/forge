package {{.Package}}

import (
	"context"

	"{{.Module}}/pkg/middleware"
)

// Authorizer handles access control for the {{.ServiceName}} service.
//
// By default it delegates to the GeneratedAuthorizer, whose tables carry
// the (forge.v1.method).auth_required flags from the proto. Role policy
// is NOT proto-driven (there is no required_roles annotation) — this
// file is where it lives: override the methods below to add role checks
// or any other custom authorization logic. forge generate never touches
// this file.
type Authorizer struct {
	generated *GeneratedAuthorizer
}

// NewAuthorizer creates a new Authorizer for this service.
func NewAuthorizer() *Authorizer {
	return &Authorizer{generated: NewGeneratedAuthorizer()}
}

// CanAccess implements the middleware.Authorizer interface.
// Default: delegates to the generated role-based authorizer.
// Override to add custom procedure-level authorization logic.
func (a *Authorizer) CanAccess(ctx context.Context, procedure string) error {
	return a.generated.CanAccess(ctx, procedure)
}

// Can checks if the user has permission to perform the action on the resource.
// Override this method to implement custom authorization logic beyond
// the generated role checks.
//
// Actions: middleware.ActionCreate, ActionRead, ActionUpdate, ActionDelete, ActionList.
// Resource: entity name in lowercase, e.g. "patient" or "invoice".
func (a *Authorizer) Can(ctx context.Context, claims *middleware.Claims, action, resource string) error {
	return a.generated.Can(ctx, claims, action, resource)
}
