package {{.Package}}

import (
	"context"

	"{{.Module}}/pkg/middleware"
)

// Authorizer handles access control for the {{.ServiceName}} service. It
// delegates to GeneratedAuthorizer (proto auth_required flags); role policy
// is code, not proto, so override the methods below to add it. forge
// generate never touches this file. See the forge `auth` skill.
type Authorizer struct {
	generated *GeneratedAuthorizer
}

// NewAuthorizer creates a new Authorizer for this service.
func NewAuthorizer() *Authorizer {
	return &Authorizer{generated: NewGeneratedAuthorizer()}
}

// CanAccess implements the middleware.Authorizer interface.
// Default: delegates to the generated role-based authorizer.
// Override to add custom procedure-level authorization logic.
func (a *Authorizer) CanAccess(ctx context.Context, procedure string) error {
	return a.generated.CanAccess(ctx, procedure)
}

// Can checks permission for an action on a resource. Override for custom
// logic. Actions: middleware.ActionCreate/Read/Update/Delete/List;
// resource is the lowercase entity name (e.g. "patient").
func (a *Authorizer) Can(ctx context.Context, claims *middleware.Claims, action, resource string) error {
	return a.generated.Can(ctx, claims, action, resource)
}
