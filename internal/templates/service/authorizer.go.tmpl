// Authorizer handles access control for the {{.ServiceName}} service.
// Each method listed below must be implemented with real authorization logic.
// The default implementation denies all access in production.
//
// To implement:
//  1. Extract user claims from context (e.g., from JWT middleware)
//  2. Check permissions against your authorization rules
//  3. Return nil to allow, or connect.NewError(connect.CodePermissionDenied, ...) to deny
type Authorizer struct {
	// Add dependencies needed for authorization (e.g., DB, policy engine)
	middleware.UnimplementedAuthorizer
}

// NewAuthorizer creates a new Authorizer for this service.
func NewAuthorizer() *Authorizer {
	return &Authorizer{}
}

// CanAccess implements the Authorizer interface.
// TODO: Implement authorization logic for each RPC procedure.
// In development mode, all requests are allowed.
// In production, implement real authorization checks here.
func (a *Authorizer) CanAccess(ctx context.Context, procedure string) error {
	if env := os.Getenv("ENVIRONMENT"); env == "development" || env == "dev" {
		return nil
	}
	return a.UnimplementedAuthorizer.CanAccess(ctx, procedure)
}
