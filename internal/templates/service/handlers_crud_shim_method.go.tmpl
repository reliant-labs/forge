// AIP-134: req.Msg.{{.UpdateMaskField}} is honored (concrete paths write
// only named columns; empty/"*" mask is a full replace; bad paths → InvalidArgument).
{{- else}}
// NOTE: no update_mask field → whole-row write. Add a
// `google.protobuf.FieldMask update_mask` for AIP-134 partial updates.
{{- end}}
{{- end}}
func (s *Service) {{.MethodName}}(
	ctx context.Context,
	req *connect.Request[pb.{{.InputType}}],
) (*connect.Response[pb.{{.OutputType}}], error) {
	return crud.Handle{{.Operation | title}}(s.crud{{.MethodName}}Op())(ctx, req)
