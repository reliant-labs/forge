// TestCRUD_{{.EntityName}}_Lifecycle exercises the full executed CRUD
// path for {{.EntityName}} end to end.
func TestCRUD_{{.EntityName}}_Lifecycle(t *testing.T) {
	db := crudTestDB(t)
	svc := app.NewTest{{$.TestHelperName}}(t, app.WithDB(db))
	ctx := crudTestCtx()

	// Two creates must produce two rows with distinct, non-empty IDs.
	first, err := svc.{{.CreateMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.CreateMethod.InputType}}{
{{- range .CreateFields}}
{{- if eq .Kind "scalar" "enum"}}
		{{.ProtoName}}: {{.TestValue}},
{{- end}}
{{- end}}
	}))
	if err != nil {
		t.Fatalf("create #1: %v", err)
	}
	second, err := svc.{{.CreateMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.CreateMethod.InputType}}{
{{- range .CreateFields}}
{{- if eq .Kind "scalar" "enum"}}
		{{.ProtoName}}: {{.TestValue}},
{{- end}}
{{- end}}
	}))
	if err != nil {
		t.Fatalf("create #2: %v", err)
	}
	id1 := first.Msg.Get{{.EntityName}}().Get{{.PkField}}()
	id2 := second.Msg.Get{{.EntityName}}().Get{{.PkField}}()
	if id1 == "" || id2 == "" {
		t.Fatalf("create returned empty id(s): %q, %q", id1, id2)
	}
	if id1 == id2 {
		t.Fatalf("two creates returned the same id %q — create must be an insert, never an upsert", id1)
	}
{{- if .HasTimestamps}}
	if first.Msg.Get{{.EntityName}}().GetCreatedAt() == nil {
		t.Errorf("created_at not set on create (timestamps: true)")
	}
{{- end}}

	// Get returns the created row.
	got, err := svc.{{.GetMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.GetMethod.InputType}}{ {{.PkField}}: id1}))
	if err != nil {
		t.Fatalf("get: %v", err)
	}
	if got.Msg.Get{{.EntityName}}().Get{{.PkField}}() != id1 {
		t.Errorf("get returned id %q, want %q", got.Msg.Get{{.EntityName}}().Get{{.PkField}}(), id1)
	}
{{- if .HasList}}

	// List sees both rows.
	listed, err := svc.{{.ListMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.ListMethod.InputType}}{
{{- if .ListMethod.HasPagination}}
		PageSize: 10,
{{- end}}
	}))
	if err != nil {
		t.Fatalf("list: %v", err)
	}
	if n := len(listed.Msg.Get{{.EntityName | plural}}()); n != 2 {
		t.Errorf("list returned %d rows, want 2", n)
	}
{{- end}}
{{- if and .HasUpdate (ne .MutableStringField "")}}

	// Update actually mutates: a re-read observes the change.
	row := got.Msg.Get{{.EntityName}}()
	row.{{.MutableStringField}} = "lifecycle-updated"
	if _, err := svc.{{.UpdateMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.UpdateMethod.InputType}}{ {{.UpdateEntityField}}: row})); err != nil {
		t.Fatalf("update: %v", err)
	}
	reread, err := svc.{{.GetMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.GetMethod.InputType}}{ {{.PkField}}: id1}))
	if err != nil {
		t.Fatalf("get after update: %v", err)
	}
	if v := reread.Msg.Get{{.EntityName}}().Get{{.MutableStringField}}(); v != "lifecycle-updated" {
		t.Errorf("update did not mutate: {{.MutableStringField}} = %q, want %q", v, "lifecycle-updated")
	}
{{- end}}
{{- if .HasDelete}}

	// Delete, then a get of the deleted id maps to a clean NotFound.
	if _, err := svc.{{.DeleteMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.DeleteMethod.InputType}}{ {{.PkField}}: id1})); err != nil {
		t.Fatalf("delete: %v", err)
	}
	_, err = svc.{{.GetMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.GetMethod.InputType}}{ {{.PkField}}: id1}))
	assertCleanError(t, "get after delete", err, connect.CodeNotFound)
{{- end}}

	// A never-existed id maps to a clean NotFound too.
	_, err = svc.{{.GetMethod.MethodName}}(ctx, connect.NewRequest(&pb.{{.GetMethod.InputType}}{ {{.PkField}}: "never-existed"}))
	assertCleanError(t, "get missing", err, connect.CodeNotFound)
}
{{- end}}
