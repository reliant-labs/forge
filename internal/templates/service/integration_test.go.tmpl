func TestIntegration{{.Name}}(t *testing.T) {
	if testing.Short() {
		t.Skip("skipping integration test in short mode")
	}

	client := testServer(t)

	tests := []struct {
		name    string
		req     *pb.{{.InputType}}
		wantErr bool
	}{
		{
			name:    "returns unimplemented",
			req:     &pb.{{.InputType}}{},
			wantErr: true, // Expect unimplemented error from stub
		},
		// TODO: Add integration test cases
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			resp, err := client.{{.Name}}(
				context.Background(),
				connect.NewRequest(tt.req),
			)

			if tt.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}

			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}

			if resp == nil {
				t.Fatal("expected non-nil response")
			}

			// TODO: Assert response fields
			_ = resp.Msg
		})
	}
}
