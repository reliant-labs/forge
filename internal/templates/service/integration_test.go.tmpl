package {{.ServiceName | lower}}_test

{{- if .Methods}}

import (
	"context"
	"testing"

	"connectrpc.com/connect"

	pb "{{.Module}}/gen/{{.ProtoImportPath}}/v1"
	{{.ProtoConnectPackage}} "{{.Module}}/gen/{{.ProtoImportPath}}/v1/{{.ProtoConnectPackage}}"
	"{{.Module}}/pkg/app"
)

// TestIntegration runs each RPC against the in-process test server and asserts
// that every method returns the expected error (unimplemented by default).
// Add method-specific behavior tests alongside this table as your service grows.
func TestIntegration(t *testing.T) {
	t.Parallel()

	if testing.Short() {
		t.Skip("skipping integration test in short mode")
	}

	_, client := app.NewTest{{.ServiceName | pascalCase}}Server(t)
	ctx := context.Background()

	tests := []struct {
		name    string
		call    func(client {{.ProtoConnectPackage}}.{{.HandlerName}}Client) error
		wantErr bool
	}{
{{- range .Methods}}
{{- if or .ClientStreaming .ServerStreaming}}
		// TODO: {{.Name}} is a streaming RPC — add a dedicated test (streaming tests don't fit this table).
{{- else}}
		{
			name: "{{.Name}}",
			call: func(c {{$.ProtoConnectPackage}}.{{$.HandlerName}}Client) error {
				_, err := c.{{.Name}}(ctx, connect.NewRequest(&pb.{{.InputType}}{}))
				return err
			},
			wantErr: true, // stub returns unimplemented; override when implemented
		},
{{- end}}
{{- end}}
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			t.Parallel()

			err := tt.call(client)
			if tt.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
		})
	}
}
{{- else}}

