package {{.ServiceName | lower}}_test

{{- if .Methods}}

import (
	"context"
	"testing"

	"connectrpc.com/connect"

	pb "{{.Module}}/gen/{{.ProtoImportPath}}/v1"
	{{.ProtoConnectPackage}} "{{.Module}}/gen/{{.ProtoImportPath}}/v1/{{.ProtoConnectPackage}}"
	"{{.Module}}/pkg/app"
)

// TestIntegration runs each RPC against the in-process test server and verifies
// that every method responds without panicking. Stubs return errors;
// implemented handlers may return success or business-logic errors — both are
// valid. This test stays correct regardless of implementation state.
func TestIntegration(t *testing.T) {
	t.Parallel()

	if testing.Short() {
		t.Skip("skipping integration test in short mode")
	}

	_, client := app.NewTest{{.ServiceName | pascalCase}}Server(t)
	ctx := context.Background()

	tests := []struct {
		name string
		call func(client {{.ProtoConnectPackage}}.{{.HandlerName}}Client) error
	}{
{{- range .Methods}}
{{- if or .ClientStreaming .ServerStreaming}}
		// TODO: {{.Name}} is a streaming RPC — add a dedicated test (streaming tests don't fit this table).
{{- else}}
		{
			name: "{{.Name}}",
			call: func(c {{$.ProtoConnectPackage}}.{{$.HandlerName}}Client) error {
				_, err := c.{{.Name}}(ctx, connect.NewRequest(&pb.{{.InputType}}{}))
				return err
			},
		},
{{- end}}
{{- end}}
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			t.Parallel()

			err := tt.call(client)
			// Accept both success and errors — stubs return CodeUnimplemented,
			// implemented handlers may return business errors or succeed.
			if err != nil {
				t.Logf("%s returned error (expected for stubs): %v", tt.name, err)
			}
		})
	}
}
{{- else}}

// forge-integration-test-placeholder: this file is regenerated once RPCs are
// defined in the proto file. Run 'forge generate' after adding RPCs.
{{- end}}
