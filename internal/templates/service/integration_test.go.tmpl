func TestIntegration_{{.Name}}(t *testing.T) {
	t.Parallel()
	_, client := app.NewTest{{$.TestHelperName}}Server(t)

	tdd.TableRPC(t, []tdd.Case[pb.{{.InputType}}, pb.{{.OutputType}}]{
		{
			Name: "happy path",
			Req:  connect.NewRequest(&pb.{{.InputType}}{}),
			// Stub returns CodeUnimplemented; relax/strengthen once the
			// real handler lands. Add a Check function to assert on the
			// response body for happy-path cases.
			WantErr: connect.CodeUnimplemented,
		},
	}, client.{{.Name}})
}
