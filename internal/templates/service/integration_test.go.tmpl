// testServer creates a real Connect server and returns a client connected to it.
func testServer(t *testing.T) {{.ProtoConnectPackage}}.{{.HandlerName}}Client {
	t.Helper()

	svc := {{.ServiceName | lower}}.New({{.ServiceName | lower}}.Deps{
		// TODO: Initialize test dependencies (mocks, test DB, etc.)
	})
	mux := http.NewServeMux()

	path, handler := {{.ProtoConnectPackage}}.New{{.HandlerName}}Handler(svc)
	mux.Handle(path, handler)

	server := httptest.NewUnstartedServer(h2c.NewHandler(mux, &http2.Server{}))
	server.EnableHTTP2 = true
	server.Start()
	t.Cleanup(server.Close)

	client := {{.ProtoConnectPackage}}.New{{.HandlerName}}Client(
		server.Client(),
		server.URL,
	)

	return client
}

