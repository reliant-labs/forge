	// No HTTP endpoints by default. Override to add webhook handlers, etc.
	// Example:
	//   mux.Handle("POST /api/webhooks/stripe", stack(http.HandlerFunc(s.HandleStripeWebhook)))
	//   mux.Handle("POST /api/callbacks/oauth", stack(http.HandlerFunc(s.HandleOAuthCallback)))
}

