// Deps holds dependencies for the {{.ServiceName}} service.
//
// Logger / Config / Authorizer are the bare-Deps set: forge's wire_gen
// always supplies them at New() time and validateDeps() rejects any
// missing one. Add your service-owned deps below; if a field's name
// matches a conventional source (Logger, Config, Authorizer) or an
// existing field on *App, wire_gen will pick it up automatically. If
// not, add a matching field to *App in pkg/app/app_extras.go and
// assign it in setup.go — wire_gen will resolve the next regenerate
// by exact-name match. See pkg/app/CONVENTIONS.md for the full story.
type Deps struct {
	Logger     *slog.Logger
	Config     *config.Config
	Authorizer middleware.Authorizer
	// Add your dependencies here.
	// Example: Repo Repository  // narrow DB surface
	// Example: Cache cache.Service
	//
	// If a field is required for production traffic, add a check in
	// validateDeps() below — wire_gen sources the field from *App at
	// startup, so the gate runs once at boot and per-RPC `if s.deps.X
	// == nil` boilerplate becomes unnecessary.
	//
	// If a field is INTENTIONALLY optional (rollback-only NATS
	// publisher, optional gateway features, etc.), tag it with the
	// `forge:optional-dep` directive on a comment line directly
	// above the field declaration. wire_gen will emit the typed zero
	// silently when no producer matches, and the marker tells
	// future-you (and the upgrade codemod) that any per-RPC
	// `if s.deps.X != nil { ... }` guard is intentional, not
	// boilerplate to be removed. Do NOT add a check in validateDeps()
	// for optional-dep fields. See the api/handlers skill for an
	// example.
}

// validateDeps returns an error if any required Deps field is nil.
// Bootstrap-supplied fields (Logger, Config, Authorizer) are always checked.
// Extend this list when you add a Deps field that must be set for the
// service to serve traffic — keeping the gate at construction time means
// individual RPC handlers don't have to litter themselves with nil-checks.
func (d Deps) validateDeps() error {
	if d.Logger == nil {
		return fmt.Errorf("{{.ServiceName}}: Deps.Logger is required")
	}
	if d.Config == nil {
		return fmt.Errorf("{{.ServiceName}}: Deps.Config is required")
	}
	if d.Authorizer == nil {
		return fmt.Errorf("{{.ServiceName}}: Deps.Authorizer is required")
	}
	// Add checks for your required Deps fields here. Example:
	//   if d.Repo == nil { return fmt.Errorf("{{.ServiceName}}: Deps.Repo is required") }
	return nil
}

// Service implements the {{.ServiceName}} Connect RPC service.
type Service struct {
	{{.ProtoConnectPackage}}.Unimplemented{{.HandlerName}}Handler
	deps Deps
}

// New creates a new {{.ServiceName}} service instance with the supplied Deps.
//
// Returns an error when validateDeps rejects the Deps shape (any nil
// required field). Forge's pkg/app/wire_gen.go assembles the full Deps
// struct from running App fields + cfg before this is called, so the
// validation gate runs once at startup; per-RPC nil-check boilerplate
// is unnecessary.
func New(deps Deps) (*Service, error) {
	if err := deps.validateDeps(); err != nil {
		return nil, err
	}
	return &Service{deps: deps}, nil
}

// Name returns the service name for logging and registry.
func (s *Service) Name() string {
	return "{{.ServiceName}}"
}

// Register registers the service handlers with the HTTP mux.
func (s *Service) Register(mux *http.ServeMux, opts ...connect.HandlerOption) {
	path, handler := {{.ProtoConnectPackage}}.New{{.HandlerName}}Handler(s, opts...)
	mux.Handle(path, handler)
}

// RegisterHTTP registers plain HTTP handlers (callbacks, REST endpoints,
// hand-rolled webhooks) with the given mux. The stack middleware provides
// recovery, logging, and audit. Auth is handled separately per-route since
// REST endpoints may use different auth mechanisms (e.g., webhook signatures
// vs JWT).
//
// Override this method when your service needs HTTP endpoints outside
// Connect RPC.
//
// NOTE: webhooks declared in forge.yaml are auto-wired by the generated
// bootstrap (see pkg/app/bootstrap.go: it calls
// `s.RegisterWebhookRoutes(mux, stack)` after this method when the service
// has webhooks). You do NOT need to call RegisterWebhookRoutes from here.
func (s *Service) RegisterHTTP(_ *http.ServeMux, _ func(http.Handler) http.Handler) {
	// No HTTP endpoints by default. Override to add hand-rolled REST
	// endpoints or callbacks. Webhook routes from forge.yaml are wired
	// automatically — leave them to webhook_routes_gen.go.
	// Example:
	//   mux.Handle("POST /api/callbacks/oauth", stack(http.HandlerFunc(s.HandleOAuthCallback)))
}

