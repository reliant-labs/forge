// Service implements the {{.ServiceName}} Connect RPC service.
type Service struct {
	{{.ProtoConnectPackage}}.Unimplemented{{.HandlerName}}Handler
	deps Deps
}

// New creates a new {{.ServiceName}} service instance.
func New(deps Deps) *Service {
	return &Service{deps: deps}
}

// Name returns the service name for logging and registry.
func (s *Service) Name() string {
	return "{{.ServiceName}}"
}

// Register registers the service handlers with the HTTP mux.
func (s *Service) Register(mux *http.ServeMux, opts ...connect.HandlerOption) {
	path, handler := {{.ProtoConnectPackage}}.New{{.HandlerName}}Handler(s, opts...)
	mux.Handle(path, handler)
}

// RegisterHTTP registers plain HTTP handlers (webhooks, callbacks, REST endpoints)
// with the given mux. The stack middleware provides recovery, logging, and audit.
// Auth is handled separately per-route since REST endpoints may use different
// auth mechanisms (e.g., webhook signatures vs JWT).
//
// Override this method when your service needs HTTP endpoints outside Connect RPC.
