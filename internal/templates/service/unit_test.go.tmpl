// TestAuthorizerDenyByDefault verifies the default Authorizer denies all
// requests so new services fail-closed until a real policy is written.
func TestAuthorizerDenyByDefault(t *testing.T) {
	t.Parallel()

	a := {{.ServicePackage}}.NewAuthorizer()
	if err := a.Can(context.Background(), nil, "", ""); err == nil {
		t.Fatal("expected default authorizer.Can to deny, got nil error")
	}
	if err := a.CanAccess(context.Background(), ""); err == nil {
		t.Fatal("expected default authorizer.CanAccess(\"\") to deny, got nil error")
	}
	if err := a.CanAccess(context.Background(), "/services.unknown.v1.UnknownService/UnknownMethod"); err == nil {
		t.Fatal("expected default authorizer.CanAccess(unknown procedure) to deny, got nil error")
	}
}

