func Test{{.Name}}(t *testing.T) {
	svc := newTestService(t)

	tests := []struct {
		name    string
		req     *pb.{{.InputType}}
		wantErr connect.Code
	}{
		{
			name:    "unimplemented",
			req:     &pb.{{.InputType}}{},
			wantErr: connect.CodeUnimplemented,
		},
		// TODO: Add test cases
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			resp, err := svc.{{.Name}}(
				context.Background(),
				connect.NewRequest(tt.req),
			)

			if tt.wantErr != 0 {
				if err == nil {
					t.Fatalf("expected error with code %v, got nil", tt.wantErr)
				}
				if code := connect.CodeOf(err); code != tt.wantErr {
					t.Errorf("expected code %v, got %v", tt.wantErr, code)
				}
				return
			}

			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}

			if resp == nil {
				t.Fatal("expected non-nil response")
			}

			// TODO: Assert response fields
			_ = resp.Msg
		})
	}
}
