package {{.ServiceName | lower}}_test

{{- if .Methods}}

import (
	"context"
	"testing"

	"connectrpc.com/connect"

	pb "{{.Module}}/gen/{{.ProtoPackage}}/v1"
	"{{.Module}}/handlers/{{.ServiceName | lower}}"
	"{{.Module}}/pkg/app"
)

// TestHandlers exercises each RPC against the service and verifies that each
// method responds without panicking. Stubs return CodeUnimplemented; once a
// handler is implemented it may return success or a business-logic error —
// both are valid. This test stays correct regardless of implementation state.
func TestHandlers(t *testing.T) {
	t.Parallel()

	svc := app.NewTest{{.ServiceName | pascalCase}}(t)
	ctx := context.Background()

	tests := []struct {
		name string
		call func() error
	}{
{{- range .Methods}}
{{- if or .ClientStreaming .ServerStreaming}}
		// TODO: {{.Name}} is a streaming RPC — add a dedicated test.
{{- else}}
		{
			name: "{{.Name}}",
			call: func() error {
				_, err := svc.{{.Name}}(ctx, connect.NewRequest(&pb.{{.InputType}}{}))
				return err
			},
		},
{{- end}}
{{- end}}
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			t.Parallel()

			err := tt.call()
			// Accept both success (nil) and expected errors.
			// Unimplemented stubs and implemented handlers are both valid.
			// Only unexpected panics (caught by the test runner) indicate failure.
			if err != nil {
				// Log the error for visibility but don't fail — the handler
				// may be a stub (CodeUnimplemented) or return a business error
				// (e.g. CodeNotFound for empty DB). Both are expected.
				t.Logf("%s returned error (expected for stubs): %v", tt.name, err)
			}
		})
	}
}

// TestAuthorizerDenyByDefault verifies that the default Authorizer denies
// all requests so new services fail-closed until a real policy is written.
func TestAuthorizerDenyByDefault(t *testing.T) {
	t.Parallel()

	a := {{.ServiceName | lower}}.NewAuthorizer()
	if err := a.Can(context.Background(), nil, "", ""); err == nil {
		t.Fatal("expected default authorizer.Can to deny, got nil error")
	}
	if err := a.CanAccess(context.Background(), ""); err == nil {
		t.Fatal("expected default authorizer.CanAccess to deny, got nil error")
	}
}

// TestNewTest{{.ServiceName | pascalCase}}WiresPermissiveAuthorizer verifies that
// the test factory gives services a non-nil, allow-all authorizer by default
// so CRUD handlers don't nil-panic before hitting business logic.
//
// Real authz behavior should be tested with WithAuthorizer(...) + a stub, or
// by injecting a full Deps via With{{.ServiceName | pascalCase}}Deps(...).
func TestNewTest{{.ServiceName | pascalCase}}WiresPermissiveAuthorizer(t *testing.T) {
	t.Parallel()

	// Construction alone would panic if Deps.Authorizer were nil and any
	// method dispatched through it — keep this test cheap so it stays a
	// regression guard on the test factory, not the handlers themselves.
	_ = app.NewTest{{.ServiceName | pascalCase}}(t)
}
