// TestAuthorizerUnknownMethodFailMode pins the authorizer's
// unknown-procedure contract. The generated RolesDecider FAILS CLOSED
// (the pkg/authz zero value): an unknown method — proto drift, a
// hand-mounted endpoint, or probe traffic — is DENIED, with a
// once-per-method slog.Warn naming the procedure so it can be added to
// the proto. Local-dev permissiveness comes from the bootstrap
// DevAuthorizer swap, never from the policy table. If this service
// really must serve procedures the table has never heard of, opt into
// authz.AllowUnknownMethods in authorizer.go and flip these assertions.
func TestAuthorizerUnknownMethodFailMode(t *testing.T) {
	t.Parallel()

	a := {{.ServicePackage}}.NewAuthorizer()
	if err := a.CanAccess(context.Background(), "/services.unknown.v1.UnknownService/UnknownMethod"); err == nil {
		t.Fatal("fail-closed default: unknown procedure must be denied, got nil error")
	}
	// Empty procedure is denied unconditionally regardless of FailMode —
	// Connect always passes a real procedure name, so an empty value is a
	// defensive bug check (see pkg/authz Authorizer.CanAccess).
	if err := a.CanAccess(context.Background(), ""); err == nil {
		t.Fatal("empty procedure must be denied unconditionally (pkg/authz defensive bug check), got nil error")
	}
}
