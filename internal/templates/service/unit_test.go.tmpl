// TestNewTest{{.TestHelperName}}AuthorizerChain verifies the test server
// mounts the production interceptor chain (middleware.AuthzInterceptor —
// see pkg/app/services_gen.go) and that the policy is the only delta from
// production: a deny-all authorizer rejects the call at the interceptor,
// while the default permissive one lets it through to the handler.
func TestNewTest{{.TestHelperName}}AuthorizerChain(t *testing.T) {
	t.Parallel()

	// Deny-all: rejected by the authz interceptor before the handler runs.
	_, denied := app.NewTest{{.TestHelperName}}Server(t, app.WithAuthorizer(denyAllAuthorizer{}))
	_, err := denied.{{$unary}}(context.Background(), connect.NewRequest(&pb.{{$unaryIn}}{}))
	tdd.AssertConnectError(t, err, connect.CodePermissionDenied)

	// Default permissive authorizer: the same call must get PAST the
	// interceptor. The handler itself may still fail (CodeUnimplemented
	// while scaffolded) — the assertion is that authz did not deny.
	_, allowed := app.NewTest{{.TestHelperName}}Server(t)
	_, err = allowed.{{$unary}}(context.Background(), connect.NewRequest(&pb.{{$unaryIn}}{}))
	if err != nil && connect.CodeOf(err) == connect.CodePermissionDenied {
		t.Fatalf("default test authorizer must be permissive, got deny: %v", err)
	}
}

// denyAllAuthorizer rejects every call — the negative pole for
// TestNewTest{{.TestHelperName}}AuthorizerChain.
type denyAllAuthorizer struct{}

func (denyAllAuthorizer) CanAccess(context.Context, string) error {
	return connect.NewError(connect.CodePermissionDenied, errors.New("deny-all test authorizer"))
}

func (denyAllAuthorizer) Can(context.Context, *middleware.Claims, string, string) error {
	return connect.NewError(connect.CodePermissionDenied, errors.New("deny-all test authorizer"))
}
