// Test{{.Name}}_Generated runs the canonical scaffold rows for {{.Name}}.
// Add more rows by appending tdd.RPCCase entries — never write a new
// Test<X> function for what is really a new row in this table.
func Test{{.Name}}_Generated(t *testing.T) {
	t.Parallel()
	svc := setup(t)

	tdd.RunRPCCases(t, []tdd.RPCCase[pb.{{.InputType}}, pb.{{.OutputType}}]{
		{
			// SELF-DESTRUCTING scaffold row: passes only while {{.Name}}
			// is the generated CodeUnimplemented stub. Implementing the
			// handler makes this row FAIL — replace it then with real
			// assertions, e.g.
			//   { Name: "happy_path", Req: ..., Ctx: app.AuthedContext(t),
			//     Check: func(t *testing.T, resp *connect.Response[pb.{{.OutputType}}]) { ... } },
			//   { Name: "missing_required_field", Req: ...,
			//     Ctx: app.AuthedContext(t), WantErr: connect.CodeInvalidArgument },
			// Ctx carries authenticated test claims (UserID "test-user",
			// role "admin") so middleware.GetUser sees a principal.
			Name:    "unimplemented_scaffold",
			Req:     connect.NewRequest(&pb.{{.InputType}}{}),
			Ctx:     app.AuthedContext(t),
			WantErr: connect.CodeUnimplemented,
		},
	}, svc.{{.Name}})
}
