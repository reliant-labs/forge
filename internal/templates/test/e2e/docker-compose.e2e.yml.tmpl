services:
  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_USER: test
      POSTGRES_PASSWORD: test
      POSTGRES_DB: {{.ProjectName}}_test
    ports:
      - "0:5432"
    tmpfs:
      - /var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U test -d {{.ProjectName}}_test"]
      interval: 2s
      timeout: 5s
      retries: 10
