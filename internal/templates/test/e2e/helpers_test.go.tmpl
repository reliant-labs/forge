// freePort finds an available TCP port on localhost.
func freePort() int {
	l, err := (&net.ListenConfig{}).Listen(context.Background(), "tcp", "localhost:0")
	if err != nil {
		panic(fmt.Sprintf("failed to find free port: %v", err))
	}
	defer l.Close()
	return l.Addr().(*net.TCPAddr).Port
}
{{- if .Methods}}

// newClient creates a Connect RPC client for the {{.ServiceName}} service.
//
// Connect error assertions in tests should use tdd.AssertConnectError
// from github.com/reliant-labs/forge/pkg/tdd; the in-package helper was
// removed in favor of the shared library.
func newClient(t *testing.T, baseURL string) {{.ServicePackage}}v1connect.{{.ProtoServiceName}}ServiceClient {
	t.Helper()
	return {{.ServicePackage}}v1connect.New{{.ProtoServiceName}}ServiceClient(
		http.DefaultClient,
		baseURL,
	)
}
{{- end}}

// Ensure the generated protobuf package import remains referenced.
var _ = pb.File_services_{{.ServicePackage}}_v1_{{.ServicePackage}}_proto
