// freePort finds an available TCP port on localhost.
func freePort() int {
	l, err := (&net.ListenConfig{}).Listen(context.Background(), "tcp", "localhost:0")
	if err != nil {
		panic(fmt.Sprintf("failed to find free port: %v", err))
	}
	defer l.Close()
	return l.Addr().(*net.TCPAddr).Port
}
{{- if .Methods}}

// newClient creates a Connect RPC client for the {{.ServiceName}} service.
func newClient(t *testing.T, baseURL string) {{.ServiceName}}v1connect.{{.ProtoServiceName}}ServiceClient {
	t.Helper()
	return {{.ServiceName}}v1connect.New{{.ProtoServiceName}}ServiceClient(
		http.DefaultClient,
		baseURL,
	)
}

// assertConnectError asserts that an error is a Connect error with the expected code.
func assertConnectError(t *testing.T, err error, expectedCode connect.Code) {
	t.Helper()
	if err == nil {
		t.Fatalf("expected connect error with code %v, got nil", expectedCode)
	}
	if code := connect.CodeOf(err); code != expectedCode {
		t.Errorf("expected connect code %v, got %v (error: %v)", expectedCode, code, err)
	}
}
