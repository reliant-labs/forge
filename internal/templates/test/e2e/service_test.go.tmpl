func Test{{$.ProtoServiceName}}Service_{{.Name}}ReturnsUnimplementedByDefault(t *testing.T) {
	client := newClient(t, baseURL)
	req := connect.NewRequest(&pb.{{.InputType}}{})

	_, err := client.{{.Name}}(context.Background(), req)
	assertConnectError(t, err, connect.CodeUnimplemented)
}
