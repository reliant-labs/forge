import (
	"context"
	"net/http"
	"testing"
{{- if .Methods}}

	"connectrpc.com/connect"

	"github.com/reliant-labs/forge/pkg/tdd"

	pb "{{.Module}}/gen/services/{{.ServicePackage}}/v1"
{{- end}}
)

// TestHealthCheck verifies the service binary starts and responds to health checks.
func TestHealthCheck(t *testing.T) {
	t.Parallel()

	req, err := http.NewRequestWithContext(context.Background(), http.MethodGet, baseURL+"/healthz", nil)
	if err != nil {
		t.Fatalf("failed to create health check request: %v", err)
	}
	resp, err := http.DefaultClient.Do(req)
	if err != nil {
		t.Fatalf("health check request failed: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		t.Fatalf("expected 200 from /healthz, got %d", resp.StatusCode)
	}
}
{{- if .Methods}}

// Per-RPC E2E tests scaffolded by forge. Each runs against the live
// service binary started in TestMain, using a Connect client built via
// the `newClient` helper in helpers_test.go.
//
// Library reference: github.com/reliant-labs/forge/pkg/tdd
// Skill: forge skill load testing/e2e
{{range .Methods}}
func Test{{$.ProtoServiceName}}Service_{{.Name}}(t *testing.T) {
	t.Parallel()
	client := newClient(t, baseURL)

	tdd.TableRPC(t, []tdd.Case[pb.{{.InputType}}, pb.{{.OutputType}}]{
		{
			Name:    "default stub returns Unimplemented",
			Req:     connect.NewRequest(&pb.{{.InputType}}{}),
			WantErr: connect.CodeUnimplemented,
		},
	}, client.{{.Name}})
}
{{end}}
