# syntax=docker/dockerfile:1

# Build stage.
#
# We pin to `golang:1.25-alpine` as the base because Docker Hub's `golang:*-alpine`
# tags can lag the latest stable Go release by days to weeks. The `go` directive
# in `go.mod` (currently `go 1.25`) combined with Go's default
# `GOTOOLCHAIN=auto` means the in-image toolchain will auto-download and use
# a newer Go toolchain at build time if `go.mod` requires one. This keeps the
# builder base stable while the effective compiler tracks `go.mod`.
FROM golang:1.25-alpine AS builder

# Let Go's toolchain manager fetch a newer toolchain when go.mod requires it.
# (This is the default on Go 1.21+, but we set it explicitly for clarity and
# so the image works even with GOTOOLCHAIN pre-set in a user's environment.)
ENV GOTOOLCHAIN=auto

RUN apk add --no-cache git

WORKDIR /app

# Copy go workspace files
COPY go.work go.work.sum* ./
COPY go.mod go.sum ./
COPY gen/go.mod gen/go.sum ./gen/

RUN go mod download

# Copy source
COPY . .

# Build with optimizations.
# -trimpath removes the host build directory from the embedded GOROOT/module
# paths so the binary is reproducible across machines.
# -buildvcs=true keeps the VCS stamp (commit, dirty flag) in the runtime
# debug/buildinfo output so operators can correlate a running binary to a
# source commit without a separate build manifest.
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg \
    CGO_ENABLED=0 go build -trimpath -buildvcs=true -ldflags="-s -w -X main.version=$(git describe --tags --always --dirty 2>/dev/null || echo dev)" -o /app/bin/demo ./cmd

# Debug build — full symbols, no inlining. We keep -trimpath and -buildvcs
# for parity with the release build so delve sessions reflect the same
# source layout and version stamp as production.
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg \
    CGO_ENABLED=0 go build -trimpath -buildvcs=true -gcflags="all=-N -l" -o /app/bin/demo-debug ./cmd

# Install Delve
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg \
    go install github.com/go-delve/delve/cmd/dlv@latest

# ── Debug stage (use with: docker build --target debug) ──
FROM alpine:3.21 AS debug

RUN apk --no-cache add ca-certificates

WORKDIR /app

COPY --from=builder /app/bin/demo-debug ./demo
COPY --from=builder /go/bin/dlv /usr/local/bin/dlv

EXPOSE 8080 2345

# Delve headless server — IDEs connect on :2345
CMD ["dlv", "exec", "--headless", "--listen=:2345", "--api-version=2", "--accept-multiclient", "--continue", "./demo", "--", "server"]

# ── Production stage (default) ──
FROM alpine:3.21 AS production

RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/bin/demo .

# Use non-root user
USER 65532:65532

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost:${PORT:-8080}/healthz || exit 1

CMD ["./demo", "server"]