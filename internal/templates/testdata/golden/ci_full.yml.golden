# Code generated by forge. DO NOT EDIT.
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

# Go version is read from go.mod's `go` directive via setup-go's
# `go-version-file` input so CI stays in sync with the project's declared
# version without a duplicate env var that drifts.

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m
          only-new-issues: true
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
      - name: Buf lint
        run: buf lint
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: 'frontends/web/package.json'
      - name: Lint web
        working-directory: frontends/web
        run: npm ci && npm run lint
      - name: Typecheck web
        working-directory: frontends/web
        # tsc --noEmit is not covered by eslint; without a dedicated
        # step, type errors only surface at `next build` time in
        # production deploys. Keep this step right after lint so
        # authors see type failures on the same PR that introduced
        # them.
        run: npm run typecheck

  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go tests
        run: go test -race -count=1 ./...
      - name: Go test coverage
        run: go test -coverprofile=coverage.out -covermode=atomic ./...
      - name: Upload coverage
        uses: actions/upload-artifact@v4
        with:
          name: coverage
          path: coverage.out
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: 'frontends/web/package.json'
      - name: Test web
        working-directory: frontends/web
        run: npm ci && npx vitest run

  build:
    name: Build
    needs: [lint, test]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go build
        # -trimpath makes builds reproducible across runners;
        # -buildvcs=true stamps the commit/dirty flag into runtime
        # debug/buildinfo so deployed binaries can be correlated to a
        # source commit without a separate manifest. Both flags must
        # match the Dockerfile / Taskfile so CI, Docker, and local
        # binaries hash identically from the same source.
        run: go build -trimpath -buildvcs=true ./cmd/...
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: 'frontends/web/package.json'
      - name: Build web
        working-directory: frontends/web
        run: npm ci && NODE_ENV=production npm run build

  verify-generated:
    name: Verify Generated Code
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Install buf
        uses: bufbuild/buf-setup-action@v1
      - name: Install forge
        # Version is stamped at scaffold time from the forge binary that
        # produced the project. CI installs that exact ref so this step is
        # reproducible:
        #   1. Tagged/pseudo-version build → pin by module version.
        #   2. Local `dev` build with a known git SHA → pin by SHA
        #      (`go install ...@<sha>` is a valid ref).
        #   3. Neither available → fall back to @main (regenerate from a
        #      tagged release to eliminate this branch).
        run: go install github.com/reliant-labs/forge/cmd/forge@v0.0.0-test
      - name: Generate code
        run: forge generate
      - name: Check for uncommitted changes
        run: |
          if ! git diff --exit-code; then
            echo "::error::Generated code is out of date. Run 'forge generate' and commit the changes."
            exit 1
          fi

  validate-kcl:
    name: Validate KCL
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install KCL
        run: |
          curl -fsSL https://kcl-lang.io/script/install-cli.sh | bash
          echo "$HOME/.kcl/bin" >> $GITHUB_PATH
      - name: Validate dev manifests
        run: kcl run deploy/kcl/dev/main.k > /dev/null
      - name: Validate staging manifests
        run: kcl run deploy/kcl/staging/main.k > /dev/null
      - name: Validate prod manifests
        run: kcl run deploy/kcl/prod/main.k > /dev/null

  vuln-scan:
    name: Vulnerability Scan
    needs: [lint, test]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Install govulncheck
        # Pinned explicitly: @latest makes CI non-reproducible and lets a
        # compromised upstream release silently alter scan results. The
        # Dependabot config watches this file so bumps arrive as PRs.
        run: go install golang.org/x/vuln/cmd/govulncheck@v1.1.4
      - name: Go vulnerability check
        run: govulncheck ./...
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          # Single source of truth: the first frontend's package.json
          # `engines.node` field. Keeps CI, the Dockerfile, and local
          # dev aligned without a duplicated Node version in the workflow.
          node-version-file: 'frontends/web/package.json'
      - name: NPM audit web
        working-directory: frontends/web
        run: npm ci && npm audit --audit-level=high

  docker-build:
    name: Docker Build
    needs: [build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Build project image
        run: |
          if [ -f "Dockerfile" ]; then
            echo "Building demo"
            docker buildx build --load -f Dockerfile -t "demo:ci" .
          fi
      - name: Trivy scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: 'demo:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL
      - name: Build web image
        run: |
          if [ -f "frontends/web/Dockerfile" ]; then
            docker buildx build --load -f "frontends/web/Dockerfile" -t "demo/web:ci" "frontends/web"
          fi
      - name: Trivy scan web
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: 'demo/web:ci'
          format: table
          exit-code: '1'
          severity: HIGH,CRITICAL

  e2e:
    name: E2E Tests
    needs: [docker-build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run E2E tests
        run: docker compose -f docker-compose.e2e.yml up --abort-on-container-exit --exit-code-from e2e
      - name: Upload test artifacts
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-results
          path: test-results/