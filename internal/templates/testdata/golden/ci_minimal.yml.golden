# Code generated by forge. DO NOT EDIT.
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

# Go version is read from go.mod's `go` directive via setup-go's
# `go-version-file` input so CI stays in sync with the project's declared
# version without a duplicate env var that drifts.

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
          args: --timeout=5m
          only-new-issues: true

  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go tests
        run: go test -race -count=1 ./...

  build:
    name: Build
    needs: [lint, test]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Go build
        # -trimpath makes builds reproducible across runners;
        # -buildvcs=true stamps the commit/dirty flag into runtime
        # debug/buildinfo so deployed binaries can be correlated to a
        # source commit without a separate manifest. Both flags must
        # match the Dockerfile / Taskfile so CI, Docker, and local
        # binaries hash identically from the same source.
        run: go build -trimpath -buildvcs=true ./cmd/...

  verify-generated:
    name: Verify Generated Code
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
      - name: Install forge
        # Version is stamped at scaffold time from the forge binary that
        # produced the project. CI installs that exact ref so this step is
        # reproducible:
        #   1. Tagged/pseudo-version build → pin by module version.
        #   2. Local `dev` build with a known git SHA → pin by SHA
        #      (`go install ...@<sha>` is a valid ref).
        #   3. Neither available → fall back to @main (regenerate from a
        #      tagged release to eliminate this branch).
        run: go install github.com/reliant-labs/forge/cmd/forge@v0.0.0-test
      - name: Generate code
        run: forge generate
      - name: Check for uncommitted changes
        run: |
          if ! git diff --exit-code; then
            echo "::error::Generated code is out of date. Run 'forge generate' and commit the changes."
            exit 1
          fi

  docker-build:
    name: Docker Build
    needs: [build]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Build project image
        run: |
          if [ -f "Dockerfile" ]; then
            echo "Building demo"
            docker buildx build --load -f Dockerfile -t "demo:ci" .
          fi