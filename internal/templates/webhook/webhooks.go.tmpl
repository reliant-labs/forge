const (
	// webhookMaxBodySize is the maximum allowed webhook payload size.
	webhookMaxBodySize = 1 << 20 // 1MB
)

// webhookEvent represents a received webhook event.
type webhookEvent struct {
	// ID is the unique identifier for this event (used for idempotency).
	ID string
	// Source identifies the webhook provider.
	Source string
	// Headers contains the original request headers.
	Headers http.Header
	// Body contains the raw request body.
	Body []byte
	// ReceivedAt is when the webhook was received.
	ReceivedAt time.Time
}

// handleWebhook{{.Name | pascalCase}} handles incoming {{.Name}} webhooks.
//
// Routes are auto-registered via webhook_routes_gen.go.
// Ensure RegisterHTTP calls s.RegisterWebhookRoutes(mux, stack).
func (s *Service) handleWebhook{{.Name | pascalCase}}(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "method not allowed", http.StatusMethodNotAllowed)
		return
	}

	body, err := io.ReadAll(io.LimitReader(r.Body, webhookMaxBodySize))
	if err != nil {
		s.deps.Logger.Error("failed to read webhook body", "error", err)
		http.Error(w, "bad request", http.StatusBadRequest)
		return
	}

	// Verify webhook signature.
	if err := s.verify{{.Name | pascalCase}}Signature(r.Header, body); err != nil {
		s.deps.Logger.Warn("webhook signature verification failed", "error", err)
		http.Error(w, "unauthorized", http.StatusUnauthorized)
		return
	}

	// Extract event ID for idempotency.
	eventID := extractEventID(r.Header)
	if eventID == "" {
		s.deps.Logger.Warn("webhook missing event ID")
		http.Error(w, "missing event ID", http.StatusBadRequest)
		return
	}

	// Idempotency check.
	processed, err := s.isWebhookProcessed(r.Context(), eventID)
	if err != nil {
		s.deps.Logger.Error("failed to check webhook idempotency", "error", err)
		http.Error(w, "internal error", http.StatusInternalServerError)
		return
	}
	if processed {
		s.deps.Logger.Debug("webhook already processed", "event_id", eventID)
		w.WriteHeader(http.StatusOK)
		return
	}

	event := webhookEvent{
		ID:         eventID,
		Source:     "{{.Name}}",
		Headers:    r.Header,
		Body:       body,
		ReceivedAt: time.Now(),
	}

	// Process the webhook.
	if err := s.process{{.Name | pascalCase}}Webhook(r.Context(), event); err != nil {
		s.deps.Logger.Error("webhook processing failed", "event_id", eventID, "error", err)
		http.Error(w, "internal error", http.StatusInternalServerError)
		return
	}

	// Mark as processed.
	if err := s.markWebhookProcessed(r.Context(), eventID, "{{.Name}}"); err != nil {
		s.deps.Logger.Error("failed to mark webhook as processed", "event_id", eventID, "error", err)
	}

	w.WriteHeader(http.StatusOK)
}

