//go:build ignore

package {{.ServiceName | lower}}

import (
	"context"
	"sync"
)

// webhookStore provides idempotency checking for webhooks.
// Replace this in-memory implementation with a database-backed one for production.
type webhookStore struct {
	mu        sync.RWMutex
	processed map[string]bool
}

// globalWebhookStore is the package-level webhook idempotency store.
// In production, replace this with a database-backed implementation.
var globalWebhookStore = &webhookStore{
	processed: make(map[string]bool),
}

func (s *Service) isWebhookProcessed(_ context.Context, eventID string) (bool, error) {
	globalWebhookStore.mu.RLock()
	defer globalWebhookStore.mu.RUnlock()
	return globalWebhookStore.processed[eventID], nil
}

func (s *Service) markWebhookProcessed(_ context.Context, eventID, source string) error {
	globalWebhookStore.mu.Lock()
	defer globalWebhookStore.mu.Unlock()
	globalWebhookStore.processed[eventID] = true
	return nil
}
