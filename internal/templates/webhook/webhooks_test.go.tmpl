func TestWebhook{{.Name | pascalCase}}RejectsNonPOST(t *testing.T) {
	svc, err := New(Deps{
		Logger:     slog.Default(),
		Config:     &config.Config{},
		Authorizer: NewAuthorizer(),
	})
	if err != nil {
		t.Fatalf("New: %v", err)
	}

	req := httptest.NewRequest(http.MethodGet, "/webhooks/{{.Name | kebabCase}}", nil)
	w := httptest.NewRecorder()
	svc.handleWebhook{{.Name | pascalCase}}(w, req)
	if w.Code != http.StatusMethodNotAllowed {
		t.Errorf("got status %d, want %d", w.Code, http.StatusMethodNotAllowed)
	}
}

func TestWebhook{{.Name | pascalCase}}RejectsMissingEventID(t *testing.T) {
	svc, err := New(Deps{
		Logger:     slog.Default(),
		Config:     &config.Config{},
		Authorizer: NewAuthorizer(),
	})
	if err != nil {
		t.Fatalf("New: %v", err)
	}

	body := strings.NewReader(`{"type":"test"}`)
	req := httptest.NewRequest(http.MethodPost, "/webhooks/{{.Name | kebabCase}}", body)
	w := httptest.NewRecorder()
	svc.handleWebhook{{.Name | pascalCase}}(w, req)
	// Signature verification runs before event ID extraction, so expect 401.
	if w.Code != http.StatusUnauthorized {
		t.Errorf("got status %d, want %d", w.Code, http.StatusUnauthorized)
	}
}

func TestWebhook{{.Name | pascalCase}}DeduplicatesEvents(t *testing.T) {
	svc, err := New(Deps{
		Logger:     slog.Default(),
		Config:     &config.Config{},
		Authorizer: NewAuthorizer(),
	})
	if err != nil {
		t.Fatalf("New: %v", err)
	}

	// Mark an event as processed.
	_ = svc.markWebhookProcessed(nil, "evt-123", "{{.Name}}")

	body := strings.NewReader(`{"type":"test"}`)
	req := httptest.NewRequest(http.MethodPost, "/webhooks/{{.Name | kebabCase}}", body)
	req.Header.Set("X-Event-ID", "evt-123")
	w := httptest.NewRecorder()
	svc.handleWebhook{{.Name | pascalCase}}(w, req)
	// Signature verification runs first, so this will be 401 until verification is implemented.
	// Once you implement verify{{.Name | pascalCase}}Signature, duplicate events return 200.
	if w.Code != http.StatusUnauthorized {
		t.Errorf("got status %d, want %d for duplicate event", w.Code, http.StatusUnauthorized)
	}
}
