//go:build ignore

package {{.Name | lower}}

import (
	"context"
	"log/slog"

	"github.com/robfig/cron/v3"

	"{{.Module}}/pkg/config"
)

// Schedule is the cron expression that controls how often Run executes.
const Schedule = "{{.Schedule}}"

// Deps contains the dependencies for the {{.Name}} cron worker.
type Deps struct {
	Logger *slog.Logger
	Config *config.Config
}

// Worker implements a cron-scheduled background worker for {{.Name}}.
type Worker struct {
	deps Deps
	cron *cron.Cron
}

// New creates a new {{.Name}} cron worker.
func New(deps Deps) *Worker {
	return &Worker{deps: deps}
}

// Name returns the worker's identifier.
func (w *Worker) Name() string { return "{{.Name | kebabCase}}" }

// Start sets up the cron scheduler and blocks until ctx is cancelled.
func (w *Worker) Start(ctx context.Context) error {
	w.deps.Logger.Info("cron worker started", "worker", w.Name(), "schedule", Schedule)

	w.cron = cron.New()
	if _, err := w.cron.AddFunc(Schedule, w.Run); err != nil {
		return err
	}
	w.cron.Start()

	<-ctx.Done()
	return nil
}

// Stop gracefully shuts down the cron scheduler, waiting for any running job to finish.
func (w *Worker) Stop(ctx context.Context) error {
	w.deps.Logger.Info("cron worker stopping", "worker", w.Name())
	if w.cron != nil {
		stopCtx := w.cron.Stop()
		select {
		case <-stopCtx.Done():
		case <-ctx.Done():
		}
	}
	return nil
}

// Run is invoked on the cron schedule. Implement your logic here.
func (w *Worker) Run() {
	w.deps.Logger.Info("cron job executing", "worker", w.Name())

	// TODO: Implement your scheduled job logic here.
}
