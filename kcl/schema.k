"""
Forge KCL — typed entity schemas.

Four typed entities (Service / Operator / Frontend / CronJob) capture
the orchestration shapes a forge project deploys. Plus six shared
sub-schemas (EnvVar / Resources / Ingress / ClusterRBAC / HealthCheck /
BuildVariant / SecurityContext) and a polymorphic deploy union
(HostDeploy | K8sCluster | External | Compose | BuildOnly) discriminated
by a `type` field on the deploy subschema itself — KCL emits the
discriminator into JSON automatically so the consumer can dispatch
without a side channel.

JSON contract (stable; missing optional fields project as `null`):

    {
      "services": [
        { "name", "image", "deploy", "env_vars", "command", "ports",
          "namespaced_rbac" }
      ],
      "operators": [
        { "name", "image", "crds", "cluster_rbac", "leader_election",
          "replicas", "platform", "env_vars" }
      ],
      "frontends": [
        { "name", "type", "path", "dev_runner", "port", "env_file" }
      ],
      "cronjobs": [
        { "name", "schedule", "image", "platform", "command", "env_vars" }
      ]
    }

For Service.deploy the dispatch keys are:

    { "type": "host",       "runner", "air_config",
                            "env_vars", "secrets_file", "delve_port",
                            "working_dir" }
    { "type": "cluster",    "replicas", "ingress", "resources", "platform", "ports",
                            "app_protocols", "cluster_rbac", "image_pull_secrets" }
    { "type": "build-only", "build_variants" }

HostDeploy splits per-env config from secrets:

  * `env_vars` — KCL-declared, version-controlled config (DATABASE_URL,
    NATS_URL, LOG_LEVEL, …). Composes with `base.DB_ENV` /
    `cfg.APP_ENV` the same way K8sCluster services do, so host and
    cluster services see the same per-env config source.
  * `secrets_file` — path (gitignored) to a `KEY=VALUE` dotenv carrying
    JUST the secrets (STRIPE_*, SUPABASE_*, JWT_PUBLIC_KEY, …). The
    forge CLI loads it first, then layers `env_vars` on top — KCL wins
    on conflict so config is reproducible across machines.

KCL v0.11 quirk — schema literals in lambda bodies
==================================================

KCL v0.11 rejects fully-qualified schema literals
(e.g. `schema.X { ... }`) inside lambda bodies. The parser only
accepts bare identifiers for schema instantiation there. Module-level
helpers in this module use `_X = X` aliases to work around it. Project
code that imports `forge` and references `forge.Service { ... }`
OUTSIDE a lambda body is fine; only lambda-internal instantiation
needs the alias trick.
"""

import json

# ---------------------------------------------------------------------------
# Shared sub-structures.
# ---------------------------------------------------------------------------

schema EnvVar:
    """An environment variable.

    Three projection channels:

      * `value = "..."` — inline literal. Empty string is a LEGAL value
        — pass `value = ""` to render `{name: "FOO", value: ""}` in the
        manifest. (The validator treats "explicitly empty" as set; only
        an omitted `value` field with no other channel is rejected.)
      * `secret_ref` + `secret_key` — projected from a Secret (Secret
        itself is NOT generated by forge; provision out-of-band).
      * `config_map_ref` + `config_map_key` — projected from a
        forge-generated ConfigMap.

    Secret-override syntax (config-contract)
    ----------------------------------------
    You rarely hand-write `secret_ref` for a SENSITIVE config field. Mark
    the field `sensitive: true` in the config proto and forge's config
    codegen emits the `secret_ref`/`secret_key` EnvVar for you into
    `deploy/kcl/<env>/config_gen.k`, defaulting to
    `secret_ref = "<project>-secrets", secret_key = "<env_var lowercased>"`.

    To point a field at a DIFFERENT existing cluster Secret / key, set the
    field's value in the per-env `config.<env>.yaml` to a DOLLAR-BRACE
    reference. (Written below as `D{...}` because KCL's docstring lexer reads
    a literal dollar-brace as string interpolation — in YAML write a real `$`
    immediately followed by the `{...}`.)

        "D{SECRET_NAME}"         -> secret_ref = "SECRET_NAME"
                                    (secret_key = codegen default)
        "D{SECRET_NAME#KEY}"     -> secret_ref = "SECRET_NAME", secret_key = "KEY"

    e.g. config.<env>.yaml line
        internal_service_secret: "D{control-plane-internal#secret}"
    (with D replaced by `$`) binds that field to the `secret` key of the
    `control-plane-internal` Secret. The `#KEY` form is for cluster secrets
    whose keys are kebab-case (e.g. `D{db-credentials#database-url}`) and
    don't match forge's lowercase-env-var default. The Secret itself is
    provisioned out-of-band. See kcl/README.md "Secrets" for the copy-paste
    YAML example (with the real `$`).

    Empty-value rationale: callers use empty strings as "disable"
    sentinels (e.g. RUNTIME_CLASS_NAME="" to skip runtimeClassName on
    Pod spec; webhook secrets="" to disable env-gated features). KCL
    distinguishes "field absent" from "field present but empty" only
    when the field is optional (no default), so `value` is declared
    optional. Downstream renderers MUST check `value != Undefined` —
    NOT `if ev.value` — to preserve the empty-string distinction.
    """
    name: str
    value?: str
    secret_ref: str = ""
    secret_key: str = ""
    config_map_ref: str = ""
    config_map_key: str = ""
    # Downward-API channel: a k8s pod/container field path
    # ("metadata.name", "status.podIP", "spec.nodeName") projected to
    # `valueFrom.fieldRef.fieldPath`. Empty => not a fieldRef var. This is
    # the k8s-adapter target of the agnostic `EnvSource.from_field`.
    field_ref: str = ""

    check:
        name, "EnvVar.name is required"
        value != Undefined or secret_ref or config_map_ref or field_ref, \
            "EnvVar must set value (empty string is OK), secret_ref, config_map_ref, or field_ref"

schema EnvFromSource:
    """A whole Secret / ConfigMap imported into a container's env — the k8s
    `envFrom[]` entry shape.

    Where `EnvVar` names ONE variable (from a literal, or one KEY of a
    secret/configmap), `EnvFromSource` bulk-imports EVERY key of a whole
    Secret or ConfigMap as env vars. It is the k8s-adapter target of the
    agnostic-core `core.EnvFrom` (kcl/core/service.k).

      * `secret_ref`     — a Secret NAME; projects to `envFrom.secretRef`.
      * `config_map_ref` — a ConfigMap NAME; projects to
                           `envFrom.configMapRef`.
      * `prefix`         — optional string prepended to every imported key
                           (k8s `envFrom[].prefix`). Empty => no prefix.

    EXACTLY ONE of secret_ref / config_map_ref must be set. Precedence:
    container `env` (env_vars) overrides an `envFrom` value of the same
    name — native k8s semantics, so the renderer emits both untouched.
    """
    secret_ref: str = ""
    config_map_ref: str = ""
    prefix: str = ""

    check:
        len([_c for _c in [secret_ref, config_map_ref] if _c]) == 1, \
            "EnvFromSource must set EXACTLY ONE of: secret_ref | config_map_ref"

schema Volume:
    """A pod volume + its single container mount.

    The escape hatch for forge's restricted-PSA securityContext, which
    sets `readOnlyRootFilesystem = true` on every container. A workload
    that legitimately writes to disk (a service writing TLS certs to
    /data, a tool populating ~/.config, a scratch cache) dies at runtime
    with "mkdir <path>: read-only file system" unless it is given a
    WRITABLE volume mounted at that path. `type = "empty_dir"` (the
    default) is exactly that — a pod-lifetime scratch volume — and is
    the critical case. `config_map` / `secret` cover the read-only
    projection of forge-generated ConfigMaps / out-of-band Secrets onto
    a path (e.g. a config file the app reads from /etc/app).

    One `Volume` models BOTH the pod-level `spec.volumes[*]` entry and
    the container's `spec.containers[*].volumeMounts[*]` entry — they
    share a `name`, so collapsing them into one declaration keeps the
    common one-mount-per-volume case a single line. The render layer
    (lib/services.k) splits it back into the two k8s arrays.

    Fields:
      * `name`       — volume name; ties the pod volume to its mount.
      * `mount_path` — absolute container path the volume mounts at.
      * `sub_path`   — optional sub-path WITHIN the volume to mount (k8s
                       `subPath`); omit to mount the volume root.
      * `read_only`  — mount read-only. Defaults False for empty_dir
                       (the writable-scratch case), but config_map /
                       secret mounts are conventionally read-only — set
                       it True for those.
      * `type`       — "empty_dir" (default) | "config_map" | "secret" |
                       "pvc" (an existing PersistentVolumeClaim, for
                       durable per-workload storage).
      * `source`     — ConfigMap / Secret / PVC NAME to project. Required
                       when type != "empty_dir"; must be empty for empty_dir.
    """
    name: str
    mount_path: str
    sub_path?: str
    read_only: bool = False
    type: str = "empty_dir"
    source?: str

    check:
        name, "Volume.name is required"
        mount_path, "Volume.mount_path is required"
        mount_path.startswith("/"), "Volume.mount_path must be absolute (start with '/')"
        type in ["empty_dir", "config_map", "secret", "pvc"], \
            "Volume.type must be 'empty_dir' | 'config_map' | 'secret' | 'pvc'"
        type == "empty_dir" or source, \
            "Volume.source (ConfigMap/Secret/PVC name) is required when type is 'config_map', 'secret', or 'pvc'"
        type != "empty_dir" or source == Undefined, \
            "Volume.source must be unset when type is 'empty_dir'"

schema Resources:
    """CPU / memory requests + limits in TARGET-NEUTRAL units.

    CPU is MILLICORES (int); memory is BYTES (int). Neither carries a target
    dialect — k8s milli-cpu + Mi/Gi binary suffixes and compose decimal cores
    are BOTH adapter concerns, so each adapter FORMATS these neutral values
    for its target (lib/quantity.k), exactly as env is a neutral map each
    adapter projects. Bytes is the unambiguous neutral memory unit (Mi is
    k8s-binary, M is compose-decimal); storing bytes lets each adapter choose.

    Author with the helpers rather than raw millicores / bytes:
        resources = forge.Resources {
            cpu_request_millicores = forge.cpu(0.25)   # 250
            cpu_limit_millicores   = forge.cpu(1)      # 1000
            memory_request_bytes   = forge.mib(256)    # 268435456
            memory_limit_bytes     = forge.gib(1)      # 1073741824
        }

    Defaults are 100m / 500m CPU and 128Mi / 512Mi memory expressed neutrally.
    """
    cpu_request_millicores: int = 100
    cpu_limit_millicores: int = 500
    memory_request_bytes: int = 134217728   # 128 * 1024 * 1024  (128Mi)
    memory_limit_bytes: int = 536870912     # 512 * 1024 * 1024  (512Mi)

# Author-facing helpers that PRODUCE Resources' neutral values, so nobody
# writes raw millicores / bytes. Surfaced top-level as forge.cpu / forge.mcpu
# / forge.mib / forge.gib. The adapter-facing inverse (neutral -> target
# string) is lib/quantity.k's formatters.
#
#   cpu(0.25) = 250 millicores   mcpu(250) = 250 (millicores passthrough)
#   mib(256)  = 268435456 bytes  gib(1)    = 1073741824 bytes
cpu = lambda cores: float -> int {
    int(cores * 1000 + 0.5)   # cores -> millicores (rounded)
}
mcpu = lambda millicores: int -> int {
    millicores               # already millicores
}
mib = lambda n: int -> int {
    n * 1024 * 1024          # mebibytes -> bytes
}
gib = lambda n: int -> int {
    n * 1024 * 1024 * 1024   # gibibytes -> bytes
}

schema RuntimeClass:
    """A node.k8s.io/v1 RuntimeClass declaration.

    Bundle.runtime_classes lets a project declare RuntimeClass objects
    forge applies on `forge deploy`. The two common cases:

      1. Real handlers in prod/staging (gvisor, kata-qemu, runc): the
         underlying handler binary is installed on cluster nodes by an
         operator or DaemonSet outside forge's scope. The RuntimeClass
         object just BINDS a name to that handler so workloads can
         select it via `runtimeClassName` on their Pod spec.

      2. Dev / k3d "alias" stubs: dev clusters frequently lack the
         specialty runtime (gvisor isn't installed on k3d), so Pods
         with `runtimeClassName = "gvisor"` stay Pending. Declaring a
         dev-only RuntimeClass with the same NAME ("gvisor") but the
         vanilla `runc` handler keeps the manifest unchanged across
         envs while making the dev cluster schedulable.

    Pre-2026-06: cp-forge's dev cluster needed a manual
    `kubectl apply` of a gvisor→runc alias every time the cluster
    was rebuilt. Declaring it here lets `forge deploy <env>` own the
    apply via the standard render-and-apply pipeline.

    `overhead` is an optional pod overhead spec; `scheduling` is an
    optional nodeSelector + tolerations block. Both pass through to
    the RuntimeClass manifest as-is (raw dicts) so future K8s API
    fields don't require a schema bump.
    """
    name: str
    handler: str
    overhead?: {str: any}
    scheduling?: {str: any}

    check:
        name, "RuntimeClass.name is required"
        handler, "RuntimeClass.handler is required (e.g. 'runc', 'gvisor', 'kata-qemu')"

schema ClusterRBAC:
    """Cluster-scoped RBAC for Operators that watch resources
    across namespaces. `rules` are PolicyRule dicts in the standard
    rbac.authorization.k8s.io/v1 shape:
        { apiGroups: [...], resources: [...], verbs: [...] }
    Forge always adds a default rule for reading the operator's own
    config (configmaps/secrets get/list/watch) so callers usually only
    need to supply CRD-specific rules.
    """
    rules: [{str: any}] = []

schema HealthCheck:
    """Liveness + readiness probe configuration.

    For non-HTTP workloads (workers / brokers) set
    `exec_command = ["pgrep", "-f", "..."]` — the render layer emits
    an `exec:` probe and ignores the HTTP fields.
    """
    liveness_path: str = "/healthz"
    readiness_path: str = "/readyz"
    http_port: int = 8080
    exec_command: [str] = []
    initial_delay: int = 5
    period: int = 10
    timeout: int = 3
    failure_threshold: int = 3

    check:
        initial_delay >= 0, "initial_delay must be non-negative"
        period > 0, "period must be positive"
        timeout > 0, "timeout must be positive"
        failure_threshold > 0, "failure_threshold must be positive"

schema BuildVariant:
    """One Go build variant. Used by Service.deploy = BuildOnly for
    multi-variant builds (e.g. `dev`, `prod` ldflag matrix)."""
    name: str
    ldflags: [str] = []
    tags: [str] = []
    goos: str = ""
    goarch: str = ""

    check:
        name, "BuildVariant.name is required"

schema ConfigMap:
    """A Kubernetes ConfigMap — non-sensitive key/value pairs.

    Generated by `forge generate` from `(forge.v1.config)`-annotated
    proto fields and the merged per-env `forge.yaml -> environments[*].config`
    map. The render layer projects this into a ConfigMap manifest
    alongside the Deployments that reference it.
    """
    name: str
    namespace: str = ""
    data: {str: str} = {}
    labels: {str: str} = {}
    annotations: {str: str} = {}

    check:
        name, "ConfigMap.name is required"

# ---------------------------------------------------------------------------
# Gateway API ingress.
#
# Forge's ingress story is Kubernetes Gateway API — first-class
# Gateway / HTTPRoute / GRPCRoute resources rendered alongside the
# typed entities. A project declares a top-level `deploy/kcl/ingress.k`
# with its gateway topology, and per-env files in
# `deploy/kcl/<env>/ingress.k` override hosts / TLS / ports. The env's
# main.k wires `gateways` / `http_routes` / `grpc_routes` into the
# Bundle.
#
# The GatewayClass resource is cluster-scoped and NOT rendered here —
# `forge dev cluster up` applies it (and any provider install YAML,
# e.g. pinned Traefik) once per cluster. Each Gateway references the
# GatewayClass by `gateway_class_name`.
#
# Routes attach to a Gateway+Listener via the `gateway` (name) +
# `listener` (section name) fields, mirroring Gateway API's
# `parentRefs[*].name` + `parentRefs[*].sectionName`. A service with no
# route is unreachable from the host — that is the v1 contract,
# `forge dev port-forward` having been retired in favor of this model.
# ---------------------------------------------------------------------------

schema GatewayListener:
    """One listener on a Gateway. Maps to Gateway API
    spec.listeners[*].

    Protocol values:

      * HTTP  — plaintext HTTP/1.1 + HTTP/2 (no TLS).
      * HTTPS — TLS-terminated HTTP. Requires the parent Gateway to
                declare `tls`.
      * H2C   — HTTP/2 cleartext. Use this for gRPC routes in dev
                where TLS is not yet wired; flip to HTTPS in the prod
                env override.
    """
    name: str
    port: int
    protocol: "HTTP" | "HTTPS" | "H2C"
    # path_prefix is prepended to every route attached to this listener.
    # Use it for multi-worktree dev where two namespaces share a host
    # port and route by path. Empty in prod where each env owns its
    # own hostname.
    path_prefix: str = ""

    check:
        name, "GatewayListener.name is required"
        port > 0 and port < 65536, "GatewayListener.port must be 1..65535"
        path_prefix == "" or path_prefix.startswith("/"), \
            "GatewayListener.path_prefix must start with '/' when set"

schema GatewayTLS:
    """TLS config for a Gateway.

    The cert-manager / mkcert modes share the same cluster-side shape
    (Gateway listener is HTTPS, references the Secret by name); only how
    the Secret gets populated differs. The gke_certmap mode is a
    different cluster-side shape entirely (no Secret, no certificateRefs;
    GCP terminates via a Certificate Manager map):

      * mode = "cert_manager" (default) — cert-manager.io/v1 Certificate
        is emitted alongside the Gateway; cert-manager watches it and
        writes the cert+key into the Secret. cert_issuer names a
        cluster-scoped ClusterIssuer. secret_name is required.

      * mode = "mkcert" — Secret is populated host-side by `forge dev
        cluster up`, which shells out to mkcert (host-trusted CA in the
        OS keychain → browser-trusted certs without `-k` / warnings).
        No Certificate resource is emitted; cert_issuer is unused and
        should be left empty. secret_name is required.

      * mode = "gke_certmap" — TLS is terminated by a GCP Certificate
        Manager certificate map, NOT cert-manager. forge stamps the
        `networking.gke.io/certmap: <certmap>` annotation on the Gateway
        and renders the HTTPS listener with NO tls block (no
        certificateRefs, no mode) — the certmap supplies the cert. No
        Certificate is emitted and no Secret is referenced, so
        cert_issuer / secret_name are unused and should be left empty. A
        certmap Gateway typically serves MANY hostnames (the map maps
        each to its cert) so it usually has no single `host`; the
        attached routes' `hostnames` select the listener.
    """
    cert_issuer: str = ""
    # Required for cert_manager / mkcert (names the Secret the HTTPS
    # listener references); unused for gke_certmap (no Secret).
    secret_name: str = ""
    # GCP Certificate Manager map name — required for gke_certmap, unused
    # otherwise. Stamped as `networking.gke.io/certmap` on the Gateway.
    certmap: str = ""
    mode: "cert_manager" | "mkcert" | "gke_certmap" = "cert_manager"

    check:
        mode == "gke_certmap" or secret_name, \
            "GatewayTLS.secret_name is required when mode is 'cert_manager' or 'mkcert'"
        mode != "cert_manager" or cert_issuer, \
            "GatewayTLS.cert_issuer is required when mode == 'cert_manager'"
        mode != "gke_certmap" or certmap, \
            "GatewayTLS.certmap is required when mode == 'gke_certmap'"

schema GatewayAddress:
    """One entry in a Gateway's `spec.addresses` — pins the Gateway to a
    specific load-balancer address so it survives delete/recreate.

    The Gateway API standard supports `type = "IPAddress"` (a literal IP)
    and `type = "Hostname"`. On GKE the cloud Gateway controller adds a
    provider extension `type = "NamedAddress"`, whose `value` is the NAME
    of a reserved global static IP reservation (NOT the IP literal). With
    a NamedAddress the GKE load balancer keeps that reserved IP across
    Gateway recreation, which keeps DNS stable. forge models NamedAddress
    (the GKE reserved-IP case we need) and IPAddress (a literal IP).
    """
    # NamedAddress (GKE reserved-IP reservation name) or IPAddress (a
    # literal IP). Defaults to NamedAddress — the GKE static-IP case.
    type: "NamedAddress" | "IPAddress" = "NamedAddress"
    # The reservation name (NamedAddress) or literal IP (IPAddress).
    value: str

    check:
        value, "GatewayAddress.value is required (reservation name or IP)"

schema Gateway:
    """A Gateway API Gateway. One Gateway exposes one or more listeners
    on the cluster's load balancer (or k3d host port) and is referenced
    by HTTPRoute / GRPCRoute parentRefs.

    Multiple Gateways per project are supported and encouraged —
    public / internal / webhooks each typically gets its own Gateway
    with its own listeners and TLS.

    `gateway_class_name` names the GatewayClass the Gateway controller
    installs. forge is OPINIONATED on Envoy Gateway as the SINGLE Gateway
    API controller — local k3d AND cloud — so this defaults to `eg` (the
    GatewayClass the Envoy Gateway install creates, controllerName
    `gateway.envoyproxy.io/gatewayclass-controller`). Envoy Gateway
    serves HTTPRoute AND GRPCRoute natively (native gRPC bidi streams),
    so one controller covers every forge ingress shape — there is no
    reason for an env to silently pick a second controller.

    `forge cluster up` / `forge up --env=<env>` install the SAME Envoy
    Gateway helm chart into the local k3d cluster that the cloud envs
    run, so the default `eg` is correct EVERYWHERE — no per-env pin, no
    local-dev exception. (Earlier forge installed Traefik for local dev,
    which required dev/e2e envs to pin `gateway_class_name = "traefik"`;
    that exception is gone — every env now uses the `eg` default.)

    `host` is the default hostname for routes on this gateway. Per-
    route `host:` overrides win. `raw_policy` is the v1 escape hatch
    for provider-specific policy CRDs (Envoy Gateway
    BackendTrafficPolicy / ClientTrafficPolicy, etc.) — emitted
    verbatim alongside the route.

    `addresses` pins the Gateway to specific load-balancer addresses
    (Gateway API `spec.addresses`). On GKE, reference a reserved global
    static IP by its reservation name via a NamedAddress GatewayAddress
    so the Gateway keeps its IP across delete/recreate (otherwise a
    recreated Gateway gets a fresh ephemeral IP and breaks DNS). Empty
    by default — the controller assigns an ephemeral address.

    `cluster` pins this Gateway to ONE cluster in a multi-cluster env. It
    is a REFERENCE to the `forge.Cluster` instance — NOT a bare name —
    which removes the name-vs-context ambiguity that bit consumers: the
    deploy-time scoper matches the routing label against a group's kubectl
    CONTEXT (`k3d-<name>`), so the builder DENORMALIZES the referenced
    Cluster's `.context` into the `forge.dev/cluster: k3d-<name>` label.
    Passing the object (`cluster = control_plane`) means the context is
    derived from the Cluster, never re-spelled. When set, forge's
    deploy-time scoper (internal/cluster.ScopeManifestsToGroup) routes the
    rendered Gateway manifest to that cluster ONLY and drops it from every
    sibling — the first-class replacement for the older trick of stamping
    an unrelated service's `app.kubernetes.io/name` label to piggyback its
    routing. Unset (the common single-cluster case) leaves routing
    unchanged.
    """
    name: str
    listeners: [GatewayListener]
    gateway_class_name: str = "eg"
    host: str = ""
    tls?: GatewayTLS
    raw_policy: str = ""
    addresses: [GatewayAddress] = []
    cluster?: Cluster

    check:
        name, "Gateway.name is required"
        len(listeners) > 0, "Gateway must declare at least one listener"
        len({l.name: l for l in listeners}) == len(listeners), \
            "Gateway.listeners[*].name must be unique within a gateway"
        len({str(l.port): l for l in listeners}) == len(listeners), \
            "Gateway.listeners[*].port must be unique within a gateway"

schema HTTPRoute:
    """An HTTPRoute attached to a Gateway+listener. Forwards HTTP
    traffic to a backend Service (referenced by name; matches a
    forge.Service.name in the same env).

    The full request path is `<listener.path_prefix>/<path>`. Empty
    `path` means the listener's prefix is the only match — useful for
    a service that owns the listener's path namespace entirely.

    `cluster` pins this route to ONE cluster in a multi-cluster env (see
    Gateway.cluster). Like Gateway.cluster it is a REFERENCE to the
    `forge.Cluster` instance — the builder denormalizes its `.context`
    into a `forge.dev/cluster: k3d-<name>` label that routes the rendered
    HTTPRoute manifest to that cluster only.
    """
    name: str
    gateway: str
    listener: str
    service: str
    port: int
    host: str = ""
    path: str = ""
    raw_policy: str = ""
    cluster?: Cluster

    check:
        name, "HTTPRoute.name is required"
        gateway, "HTTPRoute.gateway is required (target Gateway.name)"
        listener, "HTTPRoute.listener is required (target GatewayListener.name)"
        service, "HTTPRoute.service is required (backend Service.name)"
        port > 0 and port < 65536, "HTTPRoute.port must be 1..65535"
        path == "" or path.startswith("/"), \
            "HTTPRoute.path must start with '/' when set"

schema GRPCRoute:
    """A GRPCRoute attached to a Gateway+listener. Forwards gRPC
    traffic to a backend Service. The target listener must be H2C or
    HTTPS — gRPC over HTTP/1.1 isn't a thing.

    `cluster` pins this route to ONE cluster in a multi-cluster env (see
    Gateway.cluster). Like Gateway.cluster it is a REFERENCE to the
    `forge.Cluster` instance — the builder denormalizes its `.context`
    into a `forge.dev/cluster: k3d-<name>` label that routes the rendered
    GRPCRoute manifest to that cluster only.
    """
    name: str
    gateway: str
    listener: str
    service: str
    port: int
    host: str = ""
    path: str = ""
    raw_policy: str = ""
    cluster?: Cluster

    check:
        name, "GRPCRoute.name is required"
        gateway, "GRPCRoute.gateway is required (target Gateway.name)"
        listener, "GRPCRoute.listener is required (target GatewayListener.name)"
        service, "GRPCRoute.service is required (backend Service.name)"
        port > 0 and port < 65536, "GRPCRoute.port must be 1..65535"
        path == "" or path.startswith("/"), \
            "GRPCRoute.path must start with '/' when set"

schema SecurityContext:
    """Pod + container security settings. Sane forge defaults
    (non-root, RO root FS, drop-all caps, RuntimeDefault seccomp)
    are applied automatically by render.k when not overridden."""
    run_as_non_root: bool = True
    run_as_user: int = 65532
    run_as_group: int = 65532
    read_only_root_filesystem: bool = True
    allow_privilege_escalation: bool = False
    drop_capabilities: [str] = ["ALL"]
    seccomp_profile: str = "RuntimeDefault"

# ---------------------------------------------------------------------------
# Polymorphic deploy union.
#
# The `type` discriminator lives on the deploy subschema so the JSON
# output is self-describing. KCL union types let `Service.deploy:
# HostDeploy | K8sCluster | External | Compose | BuildOnly` accept any
# of the variants at instantiation; the consumer dispatches on
# `deploy.type`.
# ---------------------------------------------------------------------------

schema HostDeploy:
    """Service runs on the developer's host machine (outside k8s).

    Forge's `forge run`/`forge up` loop launches this directly:
      * runner = "go-run" — `go run ./cmd/...`
      * runner = "air"    — `air -c <air_config>` for live-reload
      * runner = "binary" — pre-built binary in ./bin
      * runner = "delve"  — `dlv exec --headless` for debugging

    Env composition splits config from secrets:
      * `env_vars` — KCL-declared per-env config. Reproducible,
        version-controlled, mergeable with `base.DB_ENV`/`cfg.APP_ENV`.
        Same source K8sCluster services see via the Deployment's `env`.
      * `secrets_file` — gitignored dotenv with JUST the secrets.
        Loaded first by the runner; `env_vars` is layered on top
        (KCL wins on conflict so per-env config can't drift between
        developer machines).
    """
    type: str = "host"
    runner: str = "go-run"
    air_config?: str
    env_vars: [EnvVar] = []
    secrets_file?: str
    delve_port: int = 2345
    working_dir?: str
    """Working directory for the launched process. Relative paths are resolved against the project root. Use this for cross-repo binaries whose runner config (e.g. Air's build_cmd paths) resolves relative to a sibling repo. Default: project root."""

    check:
        type == "host", "HostDeploy.type must be 'host'"
        runner in ["go-run", "air", "binary", "delve"], \
            "HostDeploy.runner must be 'go-run' | 'air' | 'binary' | 'delve'"
        air_config == Undefined or runner == "air", \
            "HostDeploy.air_config is only valid when runner = 'air'"
        delve_port > 0 and delve_port < 65536, \
            "HostDeploy.delve_port must be 1..65535"

schema ClusterTarget:
    """The env-wide Kubernetes facts, stated ONCE.

    A `ClusterTarget` is the single source of truth for the coordinates
    that are identical across every workload in a deploy group: the
    kubectl `cluster` context, the `namespace`, the image `registry`, the
    `image_pull_secrets`, the build `platform`, and the env-wide
    `image_tag`. The `Bundle` carries it once (`Bundle.cluster_target`);
    every service REFERENCES it for its per-service `deploy` block rather
    than restating those facts:

        _prod = forge.ClusterTarget {
            cluster = "prod-cluster"
            namespace = "kalshi-prod"
            registry = "ghcr.io/reliant/kalshi"
            domain = "kalshi.com"
        }

        forge.Service { name = "trader", deploy = _prod.deploy }
        forge.Service { name = "admin",  deploy = _prod.deploy | { replicas = 5 } }

        forge.Bundle { cluster_target = _prod, services = [...] }

    This replaces the old normalize→denormalize inversion (the env-wide
    knobs copied into every service's `K8sCluster` block, then re-derived
    by a Go "pull them off the first service in the group" heuristic): the
    env-wide facts are first-class on the Bundle, and `render_manifests`
    reads namespace/registry/tag/platform/pull_secrets straight off the
    target. A second target (a different cluster) lets ONE service ride a
    different group — the multi-cluster split — without the env-wide facts
    drifting, because each service still references a single target.

    `deploy` is the DERIVED per-service `K8sCluster` this target seeds:
    its env-wide fields are pre-filled from the target, its per-service
    knobs (replicas/resources/ports/env_vars/…) keep their defaults so a
    service overlays only what differs (`_prod.deploy | { ports = [...] }`).
    """
    cluster: str
    namespace: str
    registry: str
    domain?: str
    # Env-wide build arch (GOARCH / --platform). Same node arch for every
    # workload the env renders. Unset => the build falls through to the
    # host arch.
    platform?: str
    # Names of EXISTING image-pull Secrets, applied to every workload's
    # generated ServiceAccount. Env-wide (the registry is env-wide, so its
    # pull secret is too). Unset => no imagePullSecrets.
    image_pull_secrets?: [str]
    # Env-wide image tag (the per-build override CI passes via
    # `-D image_tag=<sha>`). A per-service `image_tag` pin still wins (a
    # no-op sibling image pinned to the tag it WAS pushed under).
    image_tag: str = "latest"
    # Derived: the per-service K8sCluster deploy block this target seeds,
    # pre-filled with the env-wide coordinates. A service references it
    # (`target.deploy | { ports = [...] }`) instead of restating them.
    deploy: K8sCluster = K8sCluster {
        cluster = cluster
        namespace = namespace
        registry = registry
        domain = domain if domain else Undefined
        platform = platform if platform else Undefined
        image_pull_secrets = image_pull_secrets if image_pull_secrets else Undefined
    }

    check:
        cluster, "ClusterTarget.cluster is required (kubectl context name)"
        namespace, "ClusterTarget.namespace is required"
        # registry is a REQUIRED input — empty is a load-time failure, NOT a
        # deploy-time ImagePullBackOff. This is the guard that bites the
        # cloud-env footgun: a typo'd / unset `-D registry=` that resolves to
        # "" (no consumer-side `or <default>` to mask it) is rejected HERE,
        # at KCL load, instead of rendering manifests with an image reference
        # missing its registry that only fails when kubelet tries to pull.
        # The companion build-platform guard lives on Bundle (it needs the
        # services list to see whether any external image build is declared).
        registry, "ClusterTarget.registry is required (image registry, e.g. ghcr.io/org/proj) — a cloud env MUST state it; an unset/typo'd `-D registry=` that resolves to empty is rejected here rather than producing an ImagePullBackOff at deploy"

schema K8sCluster:
    """Service runs in-cluster as a Deployment + Service on a specific
    Kubernetes cluster. The PER-SERVICE deploy block: it carries the
    per-service knobs (replicas/resources/ports/env_vars/…) AND the
    env-wide coordinates (cluster/namespace/registry/domain/platform/
    image_pull_secrets) that route + identify it.

    Don't construct this directly with the env-wide coordinates spelled
    out per service — that's the denormalization the `ClusterTarget` split
    removes. Instead declare a `ClusterTarget` once and reference its
    derived `.deploy`:

        _prod = forge.ClusterTarget {
            cluster = "prod-cluster"
            namespace = "kalshi-prod"
            registry = "ghcr.io/reliant/kalshi"
        }

        forge.Service { name = "trader", deploy = _prod.deploy }
        forge.Service { name = "admin",  deploy = _prod.deploy | { replicas = 5 } }

    The env-wide fields remain ON this block because the rendered JSON
    contract is per-service (the Go deploy dispatcher reads each service's
    cluster/namespace/registry to group + route it, which is what lets ONE
    service ride a second `ClusterTarget` — the multi-cluster split). They
    are SOURCED from the target, not restated.
    """
    type: str = "cluster"
    # Env-wide coordinates — sourced from a ClusterTarget (the SSOT), NOT
    # restated per service. Present on the per-service block because the
    # rendered JSON contract is per-service: the deploy dispatcher routes
    # each service by them.
    cluster: str
    namespace: str
    registry: str
    domain?: str
    # Per-service knobs.
    replicas: int = 1
    resources?: Resources
    health_check?: HealthCheck
    security_context?: SecurityContext
    env_vars: [EnvVar] = []
    ports: [int] = []
    # Optional per-port `appProtocol` for the generated Service ports,
    # keyed by port number (as a string — KCL dict keys must be strings).
    # `appProtocol` is a Kubernetes-standard hint the Service exposes so
    # Gateway/Ingress controllers negotiate the backend wire protocol —
    # e.g. `kubernetes.io/h2c` for an h2c/gRPC backend sitting behind a
    # cloud Gateway controller:
    #
    #     ports = [8080]
    #     app_protocols = {"8080" = "kubernetes.io/h2c"}
    #
    # Keyed by port so the int-shorthand `ports = [int]` stays untouched;
    # a port absent from this map renders exactly as before (no
    # `appProtocol` field). appProtocol is a Service-port-only concept —
    # it is NOT projected onto the Deployment's containerPorts.
    # Unset/empty => omitted.
    app_protocols: {str: str} = {}
    platform?: str
    cluster_rbac?: ClusterRBAC
    # Names of EXISTING image-pull Secrets (kubernetes.io/dockerconfigjson)
    # used to pull this deploy group's images from a private registry.
    # forge does NOT create these Secrets — provision them out-of-band
    # (the same out-of-band model EnvVar.secret_ref uses). Env-wide:
    # because the registry is an env-wide knob, the pull secret is too,
    # so it's declared once on the K8sCluster ref and applied to every
    # workload (Service / Operator / CronJob) in the group.
    #
    # Injection point: the forge-GENERATED ServiceAccount each workload
    # binds (see lib/rbac.k). Putting `imagePullSecrets` on the SA
    # rather than each pod spec is the durable choice — it also covers
    # the Jobs/CronJobs an operator or the workload may spawn, which a
    # pod-spec-only injection would miss. Unset => field omitted entirely.
    image_pull_secrets?: [str]

    check:
        type == "cluster", "K8sCluster.type must be 'cluster'"
        cluster, "K8sCluster.cluster is required (kubectl context name)"
        namespace, "K8sCluster.namespace is required"
        registry, "K8sCluster.registry is required (image registry, e.g. ghcr.io/org/proj)"
        replicas > 0, "K8sCluster.replicas must be positive"

schema External:
    """Generic shell-command deploy target. Use this for any deploy
    target driven by a CLI: Fly.io (`flyctl`), Cloudflare Workers
    (`wrangler`), Cloud Run (`gcloud run`), AWS ECS (`aws ecs`),
    Vercel, Railway, systemd-on-VM, etc.

    The provider exec's `deploy_cmd` via `sh -c` after substituting
    the following tokens:

      * ${IMAGE}        forge-built image name
      * ${TAG}          current tag (build-resolved or overridden)
      * ${CODE_VERSION} == ${TAG}; the canonical version to stamp into
                        the running container (e.g.
                        `docker run -e CODE_VERSION=${CODE_VERSION}` or a
                        `--label`) so the binary's reported code_version
                        always matches the image tag.
      * ${PIPELINE}     deployer id ("forge"); label the container with it
                        (`--label forge.pipeline=${PIPELINE}`) to keep a
                        forge-deployed container distinguishable from one a
                        manual script placed under the same name.
      * ${LAST_TAG}     previously deployed tag from the state file (the
                        prior forge deploy on a deploy; the rollback target
                        on a rollback). Empty on the first deploy.
      * ${SERVICE}      Service.name
      * ${ENV}          env name (e.g. dev, staging, prod)
      * ${ENV_FILE}     path declared in env_file (if any)
      * ${PROJECT_DIR}  project root
      * Any keys declared in `env`.

    `rollback_cmd` is optional — forge rollback errors loudly when it
    isn't set rather than guessing. `health_cmd` runs after a
    successful deploy; failures short-circuit before the state-file
    write so the recorded last-good tag stays clean.

    BUILD side: to build (and push) this service's image via a shell
    command, declare a `build = forge.ShellBuild { cmd = ... }` on the
    Service — build and deploy are orthogonal, so the build hatch lives on
    `Service.build` (the polymorphic build union) regardless of deploy
    target. (This replaces the former `External.build_cmd` deploy-block
    mirror, which was a second shell escape hatch with the same semantics
    as ShellBuild; there is now ONE.)
    """
    type: str = "external"
    deploy_cmd: str
    rollback_cmd?: str
    health_cmd?: str
    env_file?: str
    env?: {str: str}

    check:
        type == "external", "External.type must be 'external'"
        deploy_cmd, "External.deploy_cmd is required"

schema Compose:
    """Service runs under docker-compose on the target host. forge
    invokes `docker compose pull` + `docker compose up -d` against the
    declared compose file. Rollback writes a temporary override file
    pinning the previous image:tag.

    `service` defaults to the parent Service.name when unset.
    """
    type: str = "compose"
    compose_file: str = "docker-compose.yml"
    service?: str
    env_file?: str

    check:
        type == "compose", "Compose.type must be 'compose'"

schema DotenvSecrets:
    """Dev/local secret provider. Values come from a gitignored dotenv
    (keyed by env-var NAME). forge resolves declared secret_refs from it
    and, for k8s targets, RENDERS Secret objects from it on the CLI side —
    so it is for LOCAL clusters only. Prod/staging must use ExternalSecrets.
    KCL never sees the values; only this declaration is rendered."""
    type: str = "dotenv"
    path: str = ".env"
    check:
        type == "dotenv", "DotenvSecrets.type must be 'dotenv'"
        path, "DotenvSecrets.path is required"

schema ExternalSecrets:
    """Prod/staging secret provider. forge does NOT see values: k8s
    references pre-existing Secrets (External Secrets Operator / sealed),
    host & external runtimes obtain secrets via workload identity or
    ambient env. forge only validates the secretKeyRef wiring."""
    type: str = "external"
    check:
        type == "external", "ExternalSecrets.type must be 'external'"

schema RenderedSecretKey:
    """One key within a RenderedSecrets Secret.

    `from` selects the value SOURCE:
      * "dotenv"  — read the value at apply time from the gitignored
                    `.env.<env>` (keyed by `key`). The value NEVER enters
                    KCL render output — only the reference (from + key).
      * "literal" — an inline literal `value`. GATED to dev/e2e only (a
                    check below + a Go guard) — rejected for any other
                    env. Use for non-sensitive fixed test values
                    (a test JWKS issuer URL, a fixed e2e password) where
                    a dotenv round-trip is pure friction.

    A "dotenv" key carries NO value (forge resolves it); a "literal" key
    carries `value` and NO dotenv `key`.
    """
    from: str = "dotenv"
    key?: str
    value?: str

    check:
        from in ["dotenv", "literal"], \
            "RenderedSecretKey.from must be 'dotenv' or 'literal'"
        from != "dotenv" or key, \
            "RenderedSecretKey(from='dotenv') requires `key` (the dotenv key to read)"
        from != "literal" or value != Undefined, \
            "RenderedSecretKey(from='literal') requires `value`"
        from != "literal" or value == Undefined or option("env") in ["dev", "e2e"], \
            "RenderedSecretKey(from='literal') is only allowed in dev/e2e — other envs must not inline secret values; use from='dotenv'"

schema RenderedSecret:
    """A single k8s Secret forge renders + applies from declared
    sources. `name` is the Secret name; `keys` maps each in-Secret key
    to its value source (RenderedSecretKey)."""
    name: str
    keys: {str: RenderedSecretKey}

    check:
        name, "RenderedSecret.name is required"
        len(keys) > 0, "RenderedSecret.keys must declare at least one key"

schema RenderedSecrets:
    """Dev/e2e secret provider that RENDERS named k8s Secrets from
    declared sources (a gitignored `.env.<env>` for `from='dotenv'`, or
    inline literals for `from='literal'`, the latter gated to dev/e2e).

    Like DotenvSecrets this is for LOCAL clusters only — forge renders
    PLAINTEXT Secret objects CLI-side. The difference: DotenvSecrets
    projects the env-var-keyed dotenv onto the secret_refs declared on
    services; RenderedSecrets declares the Secrets EXPLICITLY (name +
    keys + per-key source), so per-cluster, multi-Secret seeding is a
    first-class declaration. Each rendered Secret is applied ONLY into
    the cluster(s) whose services reference it — never projected across
    the trust boundary.

    Values NEVER enter KCL render output except `from='literal'`, which
    is dev/e2e-only (a per-key check + a Go guard)."""
    type: str = "rendered"
    secrets: [RenderedSecret] = []

    check:
        type == "rendered", "RenderedSecrets.type must be 'rendered'"
        len(secrets) > 0, "RenderedSecrets.secrets must declare at least one Secret"

schema DotenvRef:
    """A reference to a value in the gitignored `.env.<env>` (keyed by
    `key`). The CLI resolves it before render; the VALUE never enters KCL
    render output (only the reference). Used where a render-time builder
    needs a secret-sourced value it must NOT echo — e.g. TestJWKS's
    ES256 private key, which is read to derive the PUBLIC JWK but never
    published."""
    from: str = "dotenv"
    key: str

    check:
        from == "dotenv", "DotenvRef.from must be 'dotenv'"
        key, "DotenvRef.key is required"

schema TestJWKS:
    """An in-cluster JWKS endpoint serving the PUBLIC half of a test
    ES256 key, so services that validate JWTs against it exercise the
    REAL validation path (a normal in-cluster dependency: an HTTPS-less
    `http://<name>.<ns>/.well-known/jwks.json` URL) instead of a
    host-port boot race or a dev auth-bypass.

    The PUBLIC JWK is derived from the ES256 PRIVATE key PEM at render
    time via the `forge.derive_jwk` plugin, so the served JWKS can NEVER
    drift from whatever signs the tokens (same key, two halves). The
    private key is sourced from `.env.<env>` (DotenvRef) — the CLI reads
    it, passes it to the JWKS builder, and it never appears in the
    rendered output (only the derived public JWK does).

    Render with `forge.test_jwks_manifests(jwks, namespace, private_pem)`
    in a Bundle's `additional_manifests` (or a service's owned
    `manifests`, to pin it to a specific cluster) — it emits a ConfigMap
    (the JWKS JSON) + a tiny static-file Deployment + Service serving
    `/.well-known/jwks.json`.

    Fields:
      * `name`        — base name for the ConfigMap / Deployment / Service.
      * `kid`         — the JWK key id (matches the signer's kid).
      * `alg`         — JWK algorithm (default "ES256").
      * `private_key` — DotenvRef to the ES256 private-key PEM in
                        `.env.<env>`. Read at render time to derive the
                        public JWK; never published.
    """
    name: str
    kid: str
    alg: str = "ES256"
    private_key: DotenvRef

    check:
        name, "TestJWKS.name is required"
        kid, "TestJWKS.kid is required (the JWK key id; must match the signer's kid)"
        alg == "ES256", "TestJWKS.alg must be 'ES256' (the only supported test-JWKS algorithm today)"

schema Cluster:
    """A k3d cluster forge ensures exists before deploying into it.

    An env declares a LIST of these (Bundle.clusters); `forge up
    --env=<env>` reconciles each at the head of the run: if a cluster
    of the given `name` is absent, forge runs `k3d cluster create` with
    the declared flags; if present, it's a no-op (idempotent on warm
    runs). This is the declarative replacement for the dev-only,
    single-cluster `ensureDevCluster` bootstrap — an env that stands up
    several clusters (e.g. a control-plane cluster + a workload cluster)
    declares them all here, with NO imperative glue.

    Multi-cluster ownership is a REFERENCE. There is no "primary"
    cluster: a secondary cluster names its `owner` — a reference to the
    owner Cluster INSTANCE — and forge derives BOTH the docker network it
    joins (`k3d-<owner.name>`) AND the registry-inherit behavior from that
    one reference. The owner cluster declares no `owner` — forge creates
    its own network/registry. There is no most-X heuristic anywhere;
    ownership is exactly the `owner` edge.

    Stating the owner ONCE (rather than restating the stringly
    `network = "k3d-<owner>"` + `registry_mirror = "inherit"` pair) keeps
    cross-cluster wiring DRY and unforgeable: the derived `.network` can
    never disagree with the owner's actual k3d network name, and a
    consumer that needs the owner's kubectl context references
    `<owner>.context` instead of re-spelling the `k3d-` prefix.

    Computed/derived properties (read by consumers + the render layer):
      * `.context`          — the kubectl context string, `k3d-<name>`
                              (k3d's own convention). Reference it from a
                              ClusterClient / KubeconfigSecret wiring
                              instead of re-spelling the prefix.
      * `.network`          — the docker network this cluster joins.
                              Derived as `k3d-<owner.name>` when `owner`
                              is set (a secondary joins the owner's
                              auto-created network so their nodes share a
                              bridge and reach each other by container IP);
                              Undefined for an owner cluster (k3d creates
                              its own network).
      * `.registry_inherit` — True when `owner` is set: forge writes the
                              owner's registries.yaml onto this cluster's
                              node and restarts it to reload (so in-cluster
                              pulls of `localhost:<port>/...` resolve to
                              the shared registry). False for an owner
                              cluster (it owns its registry via `config`,
                              or pulls from a real registry).

    Fields:
      * `name`     — k3d cluster name. `.context` is `k3d-<name>`.
      * `owner`    — reference to the OWNER Cluster instance. Set on a
                     SECONDARY cluster to join the owner's network +
                     inherit its registry (both DERIVED, see above). Unset
                     on an owner cluster.
      * `config`   — path to a k3d Simple-config YAML. When set, forge
                     runs `k3d cluster create --config <config>` and the
                     servers/agents/api_port/network flags are ignored
                     (the config file is authoritative). Relative paths
                     resolve against the project root.
      * `servers`  — control-plane node count (default 1).
      * `agents`   — worker node count (default 0).
      * `api_port` — host port to bind the cluster's API server to
                     (`k3d cluster create --api-port 0.0.0.0:<port>`).
                     Distinct per cluster so several clusters coexist on
                     one host. Unset => k3d picks a random free port.
      * `ingress`  — install the Gateway API stack (pinned Gateway-API
                     CRDs + the vendored Traefik controller + the
                     `traefik` GatewayClass) into THIS cluster after it's
                     ensured. A fresh `k3d cluster create` ships none of
                     these, so a cluster that hosts the env's Gateway /
                     HTTPRoute / GRPCRoute resources needs it on or their
                     apply fails ("no matches for kind Gateway in
                     gateway.networking.k8s.io/v1"). The install is
                     idempotent (kubectl apply + a CRD-cache), so re-runs
                     no-op. Default False — a cluster with no ingress
                     resources (reached via port-forward) leaves it off.

                     `ingress` is the IMPERATIVE install. An env that
                     declares its Gateway API controller DECLARATIVELY as a
                     `forge.HelmChart` platform dep (Bundle.helm_charts, the
                     helm-as-a-RENDERER model the cloud envs use) leaves
                     `ingress = False` and sets `host_ports = True` instead —
                     the chart is applied in the deploy phase, but the k3d
                     host-port mapping still needs to happen at CREATE time.
      * `host_ports` — merge the generated `deploy/k3d-ports.yaml` Gateway
                     listener host-port fragment into the k3d config at
                     `cluster create` time. The Gateway's listeners (e.g.
                     grpc :29190 for daemon dial-out) need host ports mapped
                     through the k3d loadbalancer at CREATE time, or
                     in-cluster→host→cluster traffic (host.k3d.internal:<port>)
                     finds nothing listening. `ingress = True` IMPLIES this
                     (an imperatively-installed Gateway also needs the ports);
                     set `host_ports = True` EXPLICITLY when the controller is
                     installed declaratively (ingress = False) but the cluster
                     still hosts a Gateway whose listeners must be host-mapped.
                     Default False. No-op when the cluster has no `config` or
                     no deploy/k3d-ports.yaml fragment.
    """
    name: str
    owner?: Cluster
    config?: str
    servers: int = 1
    agents: int = 0
    api_port?: int
    ingress: bool = False
    host_ports: bool = False
    # Derived: kubectl context (k3d-<name>). Computed from `name` so
    # consumers reference `<cluster>.context` rather than re-spelling the
    # `k3d-` prefix. Always present.
    context: str = "k3d-" + name
    # Derived: the docker network this cluster joins. `k3d-<owner.name>`
    # when `owner` is set (join the owner's auto-created network);
    # Undefined for an owner cluster (k3d creates its own). Projects to
    # JSON `null` for an owner cluster, the owner's network for a
    # secondary.
    network?: str = ("k3d-" + owner.name) if owner else Undefined
    # Derived: True when `owner` is set — forge mirrors the owner's
    # registry onto this cluster's node (the registry-inherit behavior
    # the stringly `registry_mirror = "inherit"` used to request). False
    # for an owner cluster.
    registry_inherit: bool = True if owner else False

    check:
        name, "Cluster.name is required"
        servers > 0, "Cluster.servers must be positive"
        agents >= 0, "Cluster.agents must be non-negative"

schema KubeconfigSecret:
    """A cross-cluster kubeconfig, minted FRESH each `forge up` and
    stored as a k8s Secret so a workload in one cluster can talk to
    another cluster's API server.

    This kills the IP-drift footgun: in a multi-k3d-cluster dev/e2e env,
    the target cluster's serverlb container gets a fresh docker-network
    IP on every `k3d cluster create`. A kubeconfig with that IP baked in
    and committed to git goes stale the moment the cluster is recreated.
    Instead forge resolves the endpoint at mint time (never persisting
    the IP) and writes the kubeconfig into a Secret the workload mounts.

    Minting (at the cluster→deploy boundary, after clusters exist):
      1. `k3d kubeconfig get <target_cluster>`.
      2. For reachability == "in-network", resolve the target's API
         endpoint FRESH from docker — the serverlb container's IP on the
         OWNER network — and rewrite the kubeconfig's cluster.server to
         `https://<ip>:6443`, unset the CA, set insecure-skip-tls-verify
         (the serverlb cert doesn't cover the container IP). The IP is
         resolved every run and never written to a committed file.
      3. Rename the context to `context_name` (stable name the workload
         selects).
      4. EnsureNamespace(in_cluster, namespace) + apply the Secret into
         in_cluster.

    Fields:
      * `name`           — the k8s Secret name (in `in_cluster`).
      * `in_cluster`     — kubectl context of the cluster the Secret is
                           CREATED in (where the consuming workload runs).
      * `target_cluster` — k3d cluster name whose kubeconfig is minted
                           (the cluster the workload will REACH).
      * `context_name`   — context name written into the kubeconfig (the
                           workload selects it by this stable name).
      * `key`            — key within the Secret holding the kubeconfig
                           YAML (default "kubeconfig").
      * `namespace`      — namespace for the Secret in `in_cluster`
                           (default: the env's namespace).
      * `reachability`   — "in-network" (default): in-docker-network IP
                           rewrite + insecure TLS (the dev/e2e seam).
                           "endpoint": use the kubeconfig's own endpoint
                           verbatim (prod, where the API server has a
                           stable reachable address + valid cert). Only
                           "in-network" needs the insecure rewrite path.
    """
    name: str
    in_cluster: str
    target_cluster: str
    context_name: str
    key: str = "kubeconfig"
    namespace?: str
    reachability: str = "in-network"

    check:
        name, "KubeconfigSecret.name is required"
        in_cluster, "KubeconfigSecret.in_cluster is required (kubectl context the Secret lands in)"
        target_cluster, "KubeconfigSecret.target_cluster is required (k3d cluster to mint a kubeconfig for)"
        context_name, "KubeconfigSecret.context_name is required (stable context name the workload selects)"
        reachability in ["in-network", "endpoint"], \
            "KubeconfigSecret.reachability must be 'in-network' (dev/e2e IP rewrite) or 'endpoint' (verbatim)"

schema ClusterClient:
    """A workload's cross-cluster client wiring, stated ONCE.

    A workload that reaches ANOTHER cluster's API server today restates
    the same three things by hand, with hand-correlated names/paths/
    contexts that must agree or the workload silently breaks:

      1. a `KubeconfigSecret` minting the target cluster's kubeconfig into
         the workload's cluster;
      2. a `Volume` mounting that Secret at a path;
      3. a consumer config value — the JSON the workload reads (e.g.
         `CLUSTER_CONFIGS = '[{"id","kubeconfigPath","context"}]'`) — whose
         `kubeconfigPath` must equal the Volume's mount_path + the Secret
         key, and whose `context` must equal the Secret's context_name.

    `ClusterClient` DERIVES all three from `cluster` (the Cluster to
    reach, a reference), `in_cluster` (the Cluster the workload runs in,
    a reference), and `mount_path`. The consumer then references:

      * `.secret`      — the minted KubeconfigSecret (emit it in the
                         Bundle's `kubeconfig_secrets`).
      * `.volume`      — the Volume to attach to the consuming workload
                         (`volumes = [link.volume]`).
      * `.config_json` — the single-element JSON array string the workload
                         reads (drop into the `CLUSTER_CONFIGS` EnvVar).
      * `.config_entry`— the raw `{id, kubeconfigPath, context}` dict, for
                         a workload that aggregates SEVERAL clients into
                         one array (`json.encode([a.config_entry,
                         b.config_entry])`).

    Because the kubeconfigPath inside `.config_json` is computed from the
    SAME `mount_path` + `key` the `.volume`/`.secret` use, the three can't
    drift. The `id` is the stable handle the workload keys on (the
    CLUSTER_CONFIGS entry `id` AND the kubeconfig context name).

    Two provisioning modes
    ======================

    `external` selects WHERE the kubeconfig Secret comes from:

      * `external = False` (default, the dev/e2e k3d case) — forge MINTS
        the Secret via `k3d kubeconfig get <cluster>` at the cluster→deploy
        boundary. `.secret` is the KubeconfigSecret to emit in the Bundle's
        `kubeconfig_secrets`; `.volume` sources that minted Secret.

      * `external = True` — the kubeconfig Secret is provided OUT-OF-BAND
        (a bootstrap script writes it in dev; GKE / a real cluster supplies
        it in prod, where `reachability = "endpoint"`). forge does NOT mint:
        `.secret` is None (Undefined — nothing lands in `kubeconfig_secrets`,
        so the Go mint step has nothing to do) and `.volume` sources the
        pre-existing Secret named by `volume_name`. There is no in-network
        IP rewrite and no k3d mint in this mode.

    `volume_name` decouples the Secret/Volume name from the `<id>-kubeconfig`
    derivation. In minting mode it defaults to `<id>-kubeconfig` (the minted
    Secret's name) so `.volume` sources exactly what `.secret` mints —
    render-equivalent to before. In external mode set it to the NAME of the
    pre-existing kubeconfig Secret (and pod volume) — this is what lets a
    dev/prod consumer that already mounts a hand-named Secret migrate to
    ClusterClient render-EQUIVALENTLY (the emitted volume keeps its existing
    name + source). `.config_json` / `.config_entry` derive from `mount_path`
    + `key` in BOTH modes, unchanged.

    Fields:
      * `id`          — stable client id. Used as the CLUSTER_CONFIGS
                        entry id, the minted kubeconfig context name, and
                        (when `volume_name` is unset) the Secret/Volume base
                        name (`<id>-kubeconfig`).
      * `cluster`     — reference to the Cluster the workload REACHES
                        (kubeconfig is minted FOR this cluster; ignored for
                        the Secret in external mode, still used for context).
      * `in_cluster`  — reference to the Cluster the workload RUNS in
                        (the Secret/Volume land here).
      * `mount_path`  — absolute dir the kubeconfig Secret mounts at; the
                        kubeconfig file is `<mount_path>/<key>`.
      * `key`         — key within the Secret holding the kubeconfig YAML
                        (default "kubeconfig"); also the mounted filename.
      * `namespace`   — namespace for the minted Secret in `in_cluster`
                        (default: the env's namespace, resolved Go-side).
      * `reachability`— passed through to the minted KubeconfigSecret
                        ("in-network" dev/e2e IP rewrite, "endpoint" prod /
                        external where the endpoint is reachable verbatim).
      * `external`    — reference a pre-existing Secret instead of minting
                        (default False — keep minting).
      * `volume_name` — name of the pod volume the `.volume` declares.
                        Default `<id>-kubeconfig`. Pin an EXISTING name here to
                        migrate render-equivalently.
      * `secret_name` — name of the kubeconfig Secret the `.volume` SOURCES (and
                        the minted Secret's name). Default `volume_name`. Set it
                        when the existing pod volume NAME differs from the
                        sourced Secret NAME (e.g. dev/prod, where the volume is
                        `daemon-cluster-kubeconfig` but the out-of-band Secret is
                        `cp-daemon-kubeconfig`).
    """
    id: str
    cluster: Cluster
    in_cluster: Cluster
    mount_path: str
    key: str = "kubeconfig"
    namespace?: str
    reachability: str = "in-network"
    # external = True references a pre-existing Secret (no k3d mint); the
    # default keeps the minting behaviour the e2e path relies on.
    external: bool = False
    # The pod volume name. Defaults to the <id>-kubeconfig derivation; override
    # to pin an existing volume name (render-equivalent migration).
    volume_name?: str
    # The kubeconfig Secret name the volume sources (and the minted Secret's
    # name). Defaults to volume_name; set it when the existing volume name and
    # the sourced/minted Secret name differ (dev/prod external Secrets).
    secret_name?: str
    # Derived names/paths — the single source the emitted things share.
    # The pod VOLUME's name: default `<id>-kubeconfig`, overridable via volume_name.
    _volume_name: str = volume_name if volume_name else id + "-kubeconfig"
    # The SECRET name the volume sources / the mint targets: defaults to the
    # volume name (minting mode stays self-consistent), overridable via secret_name.
    _secret_name: str = secret_name if secret_name else _volume_name
    _kubeconfig_path: str = mount_path + "/" + key
    # The minted cross-cluster kubeconfig Secret (in_cluster -> cluster).
    # Named `_secret_name` so the minted Secret and `.volume`'s source ALWAYS
    # agree (the volume sources exactly what's minted). Undefined in external
    # mode — forge mints NOTHING, the Secret is provided out-of-band; `.secret`
    # projects to null and contributes no entry to the Bundle's kubeconfig_secrets.
    secret?: KubeconfigSecret = KubeconfigSecret {
        name = _secret_name
        in_cluster = in_cluster.context
        target_cluster = cluster.name
        context_name = id
        key = key
        namespace = namespace
        reachability = reachability
    } if not external else Undefined
    # The Volume the consuming workload mounts to read the kubeconfig. Its NAME
    # is `_volume_name`; it SOURCES the Secret `_secret_name` (the minted Secret
    # in minting mode, the pre-existing Secret in external mode). The two default
    # equal, so unset secret_name keeps name == source render-equivalent to before.
    volume: Volume = Volume {
        name = _volume_name
        mount_path = mount_path
        type = "secret"
        source = _secret_name
        read_only = True
    }
    # The CLUSTER_CONFIGS entry the workload reads — id + the derived
    # kubeconfig path + the context the kubeconfig was renamed to.
    config_entry: {str: str} = {
        id = id
        kubeconfigPath = _kubeconfig_path
        context = id
    }
    # The single-element JSON array form for the common one-client case;
    # drop straight into the CLUSTER_CONFIGS EnvVar value.
    config_json: str = json.encode([config_entry])

    check:
        id, "ClusterClient.id is required"
        mount_path, "ClusterClient.mount_path is required"
        mount_path.startswith("/"), "ClusterClient.mount_path must be absolute (start with '/')"
        reachability in ["in-network", "endpoint"], \
            "ClusterClient.reachability must be 'in-network' or 'endpoint'"

schema BuildOnly:
    """Service is built but not auto-orchestrated.

    Use for CLIs and library binaries — forge builds the artifact
    (optionally with multiple ldflag variants) but never schedules it.
    """
    type: str = "build-only"
    build_variants: [BuildVariant] = []

    check:
        type == "build-only", "BuildOnly.type must be 'build-only'"

# ---------------------------------------------------------------------------
# Polymorphic BUILD union.
#
# Build is the per-service answer to "HOW is this service's artifact
# produced". It is a POLYMORPHIC UNION of concrete build-type schemas —
# GoBuild | DockerBuild | ShellBuild — each inheriting the `Build` base
# and discriminated by a `type` field on the subschema, IDENTICAL in
# shape to the deploy union above. KCL emits the discriminator into the
# rendered JSON automatically so forge's Go (build.go) dispatches on
# `build.type` exactly the way it dispatches on `deploy.type` — no
# side channel, no hardcoded `./cmd`, no built-in auto-docker step.
#
# `Service.build` carries one of these per service and is per-env
# overridable through the existing `deploy/kcl/<env>/` overlay
# mechanism (an env's main.k can switch a service's build entirely —
# e.g. e2e sets flags=["-cover"], prod sets goos/goarch + stripped
# ldflags). The default is a GoBuild (the dominant case); the bridge
# supplies `cmd = "./cmd/<name>"` so the default stays self-contained
# without a schema-level reference to `self.name` (KCL can't default a
# field from a sibling field).
# ---------------------------------------------------------------------------

schema Build:
    """Base build concept. Concrete build types (GoBuild / DockerBuild /
    ShellBuild) inherit this. Discriminated by `type` in the rendered
    JSON (mirrors the deploy union). `output_name` optionally overrides
    the produced artifact's basename (default: the service name)."""
    type: str
    output_name: str = ""

schema GoBuild(Build):
    """Build the service with `go build`. `cmd` is the build target
    package (e.g. "./cmd/trader") — REQUIRED, so there is no hardcoded
    `./cmd` anywhere in forge's Go. goos/goarch cross-compile;
    ldflags/tags/flags are passed through to `go build` verbatim;
    env is build-time process env (e.g. {"CGO_ENABLED": "0"})."""
    type: str = "go"
    cmd: str
    goos: str = ""
    goarch: str = ""
    ldflags: [str] = []
    tags: [str] = []
    flags: [str] = []
    env: {str: str} = {}

    check:
        type == "go", "GoBuild.type must be 'go'"
        cmd, "GoBuild.cmd is required (the go build target, e.g. './cmd/<name>')"

schema DockerBuild(Build):
    """Build the service as a container image via `docker build`. Reuses
    forge's existing docker primitives (tag/registry/push/build-contexts)
    as this type's behavior — a DockerBuild service is the ONLY way forge
    builds an image; there is no unconditional auto-docker step.
    dockerfile/platform/target/build_args map to the corresponding
    `docker build` flags.

    The per-service `docker` facts — `registry` (the push/tag target for
    THIS service's image) and `build_contexts` (the named
    `--build-context name=value` entries THIS service's Dockerfile
    `COPY --from=`s) — live HERE because they are NOT expressible in the
    Dockerfile itself, and KCL renders per env so they are per-service AND
    per-env. Each is OPTIONAL and falls back to the project-level
    forge.yaml `docker.registry` / `docker.build_contexts` when unset, so a
    single-image project declares them once at the top level.

    forge is base-image-AGNOSTIC: it does NOT discover, mirror, pin, or
    inject base images. A Dockerfile's `FROM` lines are the whole story —
    pin them with `FROM …@sha256:…` in the Dockerfile if reproducibility is
    wanted."""
    type: str = "docker"
    dockerfile: str = "Dockerfile"
    platform: str = ""
    target: str = ""
    build_args: {str: str} = {}
    # Push/tag target for THIS service's image (registry-host[/namespace]).
    # Empty falls back to forge.yaml docker.registry (then the project name).
    registry: str = ""
    # Named build contexts THIS service's Dockerfile needs, each a
    # `docker buildx --build-context name=value` entry (a sibling-checkout
    # path the Dockerfile `COPY --from=name`s, a `docker-image://` override,
    # …). Declare ONLY what this Dockerfile actually consumes. Empty falls
    # back to forge.yaml docker.build_contexts.
    build_contexts: {str: str} = {}

    check:
        type == "docker", "DockerBuild.type must be 'docker'"
        dockerfile, "DockerBuild.dockerfile is required"

schema ShellBuild(Build):
    """Build the service by running `cmd` verbatim via `sh -c`. The ONE
    shell escape hatch — cross-repo builds, language runtimes forge
    doesn't natively build, pre-built image re-pushes, sibling-repo
    binaries. The command owns the WHOLE build AND any push (forge does
    NOT run `docker push` afterwards).

    This is the single way to declare "run this shell command to produce
    (and push) this artifact." It replaces the former second hatch — the
    flat `Service.build_cmd` / `build_cwd` / `build_env` trio (and the
    `External.build_cmd` deploy-block mirror) — which had the same
    execution semantics but a different, surprising declaration surface.
    Build and deploy are orthogonal: a service can carry a `ShellBuild`
    (built externally) AND a `deploy = forge.External {...}` /
    `forge.K8sCluster {...}` (deployed however) at the same time.

    Execution contract (ONE documented contract):

      * cwd — `cwd` resolved against the project root (relative paths join
        the dir holding forge.yaml; absolute pass through). Unset => the
        project root itself. Set it to a sibling-repo path (e.g.
        `cwd = "../reliant"`) for a cross-repo build whose relative paths
        resolve there. A `cwd` that doesn't exist on disk is a HARD build
        failure (naming the missing path) — a build that was supposed to
        run can't, and a following deploy would reference an unpushed
        image.
      * substitution — before exec forge substitutes these ${X} tokens
        into `cmd`: ${IMAGE} ${TAG} ${CODE_VERSION} ${SERVICE}
        ${TARGETARCH} ${REGISTRY} ${PROJECT_DIR} ${ENV} ${BUILD_CWD}, plus
        any keys declared in `env` (the built-in tokens win on conflict).
      * env — extra env vars merged into the command's PROCESS environment
        AND added to the ${X} substitution map (built-ins win on conflict).
      * state/digest — on success forge captures the pushed image's
        content-addressed digest (best-effort) and writes the build-state
        file so a subsequent `forge deploy <env>` pins the same
        tag/digest, exactly as the project docker build does.

    A no-op ShellBuild (`cmd = "true"`) is the idiomatic way to suppress
    forge's default `./cmd/<name>` Go build for a service whose artifact
    is built out-of-band (e.g. a sibling-repo binary pulled as a prebuilt
    image): it pushes nothing, so the digest lookup finds nothing and
    deploy falls through to the env tag, unchanged."""
    type: str = "shell"
    cmd: str
    # Working directory the command runs from. Relative paths resolve
    # against the project root; absolute pass through. Unset => the
    # project root. A missing-on-disk cwd is a hard build failure.
    cwd: str = ""
    # Extra env vars merged into the command's process environment AND the
    # ${X} substitution map (built-in tokens win on conflict).
    env: {str: str} = {}

    check:
        type == "shell", "ShellBuild.type must be 'shell'"
        cmd, "ShellBuild.cmd is required"

# ---------------------------------------------------------------------------
# Frontend deploy union.
#
# Frontends have their own deploy discriminator (parallel to the Service
# one) because their deploy targets differ: a static export ships to a
# CDN / Firebase Hosting / Vercel, not a Deployment. The first variant is
# FirebaseHosting; FirebaseHosting / (future) Vercel share the `type`
# discriminator so the consumer dispatches on `deploy.type`.
# ---------------------------------------------------------------------------

schema FirebaseBundleDir:
    """An extra static directory assembled into a Firebase Hosting site
    alongside the frontend's own build output.

    Use it to co-locate a sibling repo's already-built static SPA under
    the same hosting site as the forge frontend — e.g. a Vite SPA at the
    site root (`dest = ""`) with the forge Next.js admin export mounted
    under `/admin` (the frontend's own `base_path`).

      * `src`  — directory on disk holding the pre-built static files
                 (relative paths resolve against the project root). It is
                 NOT built by forge; the caller is expected to have run
                 the sibling build already (or to wire it via a separate
                 forge.Service `build = forge.ShellBuild {...}`).
      * `dest` — sub-path under the hosting site's public root to copy
                 `src` into. Empty (the default) means the site root.
                 A leading "/" is tolerated and stripped.
    """
    src: str
    dest: str = ""

    check:
        src, "FirebaseBundleDir.src is required"

schema FirebaseHosting:
    """Deploy a frontend's static build output to Firebase Hosting.

    forge builds the frontend (`<dev_runner> install` + `npm run build`)
    with the frontend's `env_vars` injected as build-time environment
    (NEXT_PUBLIC_* / VITE_*), assembles `public_dir` (plus any `bundle`
    dirs) into a staging directory honoring `base_path`, writes a
    firebase.json + .firebaserc targeting `project`/`site`, then runs
    `firebase deploy --project <project> --only hosting:<target>`.

    Fields:
      * `project`    — Firebase / GCP project id (e.g. reliant-prod-475814).
                       Per-env values are supplied either by declaring a
                       distinct deploy ref per env's main.k or via `-D`.
      * `site`       — Firebase Hosting site id (e.g. reliant-prod).
      * `target`     — hosting target alias used in `--only hosting:<target>`
                       and in `firebase target:apply`. Defaults to `site`.
      * `public_dir` — the frontend build's static output directory,
                       relative to the frontend `path` (e.g. "out" for a
                       Next.js static export, "dist" for Vite).
      * `base_path`  — sub-path under the hosting site root to mount the
                       frontend's own output under (e.g. "/admin"). Empty
                       means the site root. Mirrors Frontend base_path so
                       the deployed URL matches the dev mount.
      * `bundle`     — extra pre-built static dirs assembled into the same
                       site (see FirebaseBundleDir). Use to co-host a
                       sibling SPA at the root with this frontend under
                       base_path.
      * `rewrites`   — Firebase Hosting rewrites passed through verbatim
                       into the generated firebase.json `hosting.rewrites`
                       (SPA fallback, etc.). Empty omits the key.
    """
    type: str = "firebase"
    project: str
    site: str
    target?: str
    public_dir: str
    base_path?: str
    bundle: [FirebaseBundleDir] = []
    rewrites: [{str: any}] = []

    check:
        type == "firebase", "FirebaseHosting.type must be 'firebase'"
        project, "FirebaseHosting.project is required (Firebase/GCP project id)"
        site, "FirebaseHosting.site is required (Firebase Hosting site id)"
        public_dir, "FirebaseHosting.public_dir is required (frontend build output dir, e.g. 'out' or 'dist')"
        base_path == Undefined or base_path.startswith("/"), \
            "FirebaseHosting.base_path must start with '/' (e.g. '/admin'); omit for the site root"

# ---------------------------------------------------------------------------
# Typed entities — each captures ONE orchestration shape.
# ---------------------------------------------------------------------------

schema K8sWorkload:
    """DEMOTED / ADAPTER-INTERNAL — the k8s-shaped projection target.

    This is the OLD user-facing `forge.Service` shape, renamed and demoted
    by the agnostic-core collapse (FORGE_KCL_IDIOMS.md). It is NO LONGER what
    a user authors: the ONE user-facing workload schema is now the
    target-agnostic `forge.Service` (kcl/core.k). This schema is the k8s
    ADAPTER's projection target — `forge._service_to_k8s` (kcl/core.k)
    projects an agnostic `forge.Service` onto a `K8sWorkload`, and the render
    pipeline (render_manifests / render) consumes `K8sWorkload` unchanged.

    It stays EXPORTED (not `_`-prefixed) because it is still the carrier of
    the full deploy/build machinery the JSON contract + Go CLI depend on
    (host / external / compose / build-only deploy modes, the polymorphic
    `build`, `image_tag`, `namespaced_rbac`, `volumes`, owned `manifests`) —
    machinery the agnostic Service deliberately does NOT model. A KCL
    `_`-private schema is not importable cross-package, which would break
    forge's own example/fixtures and any hand-authored Bundle. Treat it as
    plumbing: author agnostic `forge.Service`s (into `Bundle.workloads`); the
    render layer projects them here for you.

    The `deploy` field's runtime type decides intent:
      * HostDeploy  — forge launches it on the host.
      * K8sCluster  — forge deploys to a Kubernetes cluster as
                       Deployment + Service.
      * External    — forge runs a user-supplied CLI command
                       (Fly.io, Cloud Run, Cloudflare Workers, ECS, …).
      * Compose     — forge runs docker-compose up -d.
      * BuildOnly   — forge builds the artifact only (CLI shape).

    `deploy = None` (or omitting `deploy` entirely) is the explicit
    BUILD-ONLY mode: forge runs this service's `build` (building AND
    pushing its image when the build is a DockerBuild/ShellBuild) but
    renders NO Deployment / Service / RBAC / owned manifests — it is not
    orchestrated. Use it for an IMAGE other workloads reference at
    runtime (a base image baked once and pulled by per-user pods, a
    sidecar image), or a CLI binary shipped in a release artifact. The
    render layer projects an explicit `{ "type": "build-only" }` deploy
    block so the Go consumer dispatches it the same way as a
    `forge.BuildOnly` deploy: in the build set, out of the deploy set.

    This is distinct from the IMAGE-LESS infra-bundle path (a service
    with a `K8sCluster` deploy and NO `image`, which renders only its
    owned `manifests` onto a specific cluster). `deploy = None` skips the
    deploy phase ENTIRELY; an image-less cluster service still
    participates in the deploy phase to pin its owned manifests.

    Build side — `build` (the polymorphic build union):

      `build` declares HOW this service's artifact is produced — one of
      GoBuild (the default: `go build ./cmd/<name>`), DockerBuild (an
      image via `docker build`), or ShellBuild (a verbatim `sh -c`
      command that owns the whole build + push). ShellBuild is the SINGLE
      shell escape hatch for sibling-repo binaries forge doesn't compile,
      third-party pre-built images re-pushed under your registry, and
      language runtimes forge doesn't natively build — see ShellBuild for
      its cwd / substitution / env / digest contract.
    """
    name: str
    image?: str
    # Per-service image-tag PIN. When set, this service's rendered image
    # is tagged with THIS value instead of the env-wide tag
    # (RenderEnv.image_tag, typically `git describe --dirty`). Use it for
    # a sibling image that forge does NOT build under the env-wide tag —
    # e.g. a no-op ShellBuild service whose image was pushed under its own
    # release tag. Without the pin, deploy fans the env-wide git tag onto
    # every image, producing a tag that was never pushed for that image →
    # ErrImagePull. Ignored when `image` already carries its own
    # `:tag`/`@sha256:` (an explicitly-pinned reference always wins).
    # Unset => the service uses the env-wide tag (single-image envs
    # unchanged).
    image_tag?: str
    command: [str] = []
    env_vars: [EnvVar] = []
    # Whole Secrets / ConfigMaps bulk-imported into the container env (k8s
    # `envFrom`). Additive: default empty => the container renders exactly
    # as before (no `envFrom` key). Each entry imports EVERY key of one
    # Secret/ConfigMap; per-var `env_vars` entries override same-named keys
    # (native k8s precedence). Only meaningful for a K8sCluster deploy.
    env_from: [EnvFromSource] = []
    deploy?: HostDeploy | K8sCluster | External | Compose | BuildOnly
    # Polymorphic build declaration — HOW this service's artifact is
    # produced. One of GoBuild | DockerBuild | ShellBuild, discriminated
    # by `build.type` in the rendered JSON (mirrors the deploy union).
    # forge build dispatches on it; there is no hardcoded `./cmd` and no
    # auto-docker step. Per-env overridable via the deploy/kcl/<env>/
    # overlay (an env can switch the build type or tune flags/arch).
    # Optional at the schema level: the deploy-as-data bridge supplies a
    # `GoBuild { cmd = "./cmd/<name>" }` default per component so a plain
    # service never has to spell it out, while a hand-authored
    # forge.Service may set it explicitly.
    build?: GoBuild | DockerBuild | ShellBuild
    # Extra namespaced RBAC rules appended to this Service's forge-
    # generated Role (lib/rbac.k always grants configmaps/secrets read;
    # these rules add to that). Use it when a Service runs a controller-
    # runtime manager or otherwise needs in-namespace perms beyond config
    # reads — e.g. coordination.k8s.io/leases for leader election. Same
    # PolicyRule dict shape as Operator.cluster_rbac.rules:
    #   { apiGroups: [...], resources: [...], verbs: [...] }
    # This is the namespaced-Role analogue of Operator.cluster_rbac;
    # Operators get cluster-scoped rules, Services get namespaced ones.
    # Only valid for a K8sCluster (cluster) deploy — ignored otherwise.
    # Unset => no extra rules (Role keeps just the default config-read).
    namespaced_rbac?: [{str: any}]
    # ── k8s pod-spec escape-hatch knobs ─────────────────────────────────
    # These are the projection targets of the agnostic `Service.k8s`
    # (K8sOverrides) block — the k8s adapter (`_service_to_k8s`) maps the
    # typed overrides onto these fields; render_k8s_service threads them
    # into the Deployment pod spec. They are ALSO settable directly on a
    # hand-authored K8sWorkload. All default to "absent" so a workload that
    # sets none renders byte-identically to before.
    #
    # `service_account` overrides the pod's serviceAccountName (default:
    # the workload name — the forge-generated per-service SA). Use it to
    # bind an EXISTING out-of-band SA (e.g. one with a cloud IAM
    # workload-identity annotation). `pod_annotations` are stamped on the
    # pod template metadata (GKE / mesh / prometheus hints).
    # `node_selector` + `tolerations` pin the pod to a node pool (the
    # control-plane kata daemon-pool pinning case). Only meaningful for a
    # K8sCluster deploy.
    service_account?: str
    pod_annotations: {str: str} = {}
    node_selector: {str: str} = {}
    tolerations: [{str: any}] = []
    # Pod volumes + their container mounts (see Volume). The escape
    # hatch for the restricted-PSA `readOnlyRootFilesystem = true`
    # baseline: declare an empty_dir volume at the writable path the
    # service needs (e.g. /data for TLS certs, ~/.config for a tool's
    # state). The render layer emits pod-level `spec.volumes` +
    # container `volumeMounts`; the readOnlyRootFilesystem container
    # securityContext is UNCHANGED, so only the mounted paths are
    # writable. Only meaningful for a K8sCluster (cluster) deploy.
    # Unset => no volumes (field omitted from the manifest entirely).
    volumes?: [Volume]
    # Raw k8s manifests OWNED by this service. Each is rendered tagged with
    # this service's app.kubernetes.io/name (lib/services.k
    # render_owned_manifests) so the deploy layer routes it to this
    # service's DECLARED cluster — the load-bearing primitive for
    # declared-cluster-only multi-cluster routing (there is NO
    # primary-cluster / most-services heuristic; a manifest lands on the
    # cluster of its owning service, nowhere else).
    #
    # Two ownership shapes:
    #   1. A workload service attaches its CRD / extra RBAC here — those
    #      land on the SAME cluster as the workload.
    #   2. An IMAGE-LESS "infra service" (this field + a
    #      `deploy = forge.K8sCluster {...}` and NO `image`) declares
    #      env-level / ownerless resources (Namespace, Gateways,
    #      ClusterIssuers, bootstrap) onto a specific cluster. An
    #      image-less cluster service renders NO Deployment/Service/RBAC —
    #      only its stamped manifests (see render.k render_manifests).
    #
    # Each entry is a raw manifest dict (same shape as
    # Bundle.additional_manifests). Unset => no owned manifests.
    manifests: [any] = []
    # ── securityContext override (projection target of Service.security) ──
    # A SecurityOverrides (kcl/core.k) carrying OPTIONAL pod/container
    # securityContext deltas. render_k8s_service merges each set field over
    # the restricted-PSA default; unset => the hardcoded default is emitted
    # UNCHANGED (byte-identical to before). The single knob that lets NATS
    # (fsGroup), temporal (root), and litellm (writable rootfs) fold into the
    # agnostic model instead of being raw Deployments.
    security_override?: SecurityOverrides
    # ── health probe (projection target of Service.health) ──
    # A HealthProbe (kcl/core.k) rendered by render_k8s_service as BOTH
    # livenessProbe and readinessProbe on the primary container. Unset =>
    # NO probes emitted (byte-identical to before — closes the red-team's
    # dead-HealthCheck / zero-probe gap for the agnostic path).
    health_probe?: HealthProbe
    # ── sidecar / init containers (projection targets of Service.sidecars /
    # Service.init) ──
    # Each entry is the neutral dict `_project_container` emits: {name, image,
    # command (folded argv), env_vars: [EnvVar], ports: [int]}.
    # render_k8s_service (`_render_extra_container`) resolves each image ref +
    # pull policy + the restricted-PSA container securityContext, appends
    # `sidecars` to the pod's `containers` AFTER the primary, and emits `init`
    # as `initContainers`. Both default empty => a single-container workload
    # renders BYTE-IDENTICALLY (containers == [primary], no initContainers).
    sidecars: [any] = []
    init_containers: [any] = []

    check:
        name, "K8sWorkload.name is required"

schema Operator:
    """A cluster-scoped controller that reconciles CRDs.

    Always cluster-deployed — the host story doesn't apply to
    controllers that watch the API server. The `crds` list is the
    set of CRD kind names this operator owns (e.g. ["Workspace"]).
    `cluster_rbac` is required because operators by definition need
    cluster-scoped RBAC.
    """
    name: str
    image: str
    # Per-operator image-tag pin (see Service.image_tag). Unset => the
    # env-wide tag.
    image_tag?: str
    replicas: int = 1
    platform?: str
    crds: [str] = []
    cluster_rbac: ClusterRBAC = ClusterRBAC {}
    leader_election: bool = True
    env_vars: [EnvVar] = []
    # Pod volumes + container mounts — same escape hatch as
    # Service.volumes (writable empty_dir paths under the
    # readOnlyRootFilesystem baseline, or config_map / secret
    # projections). Unset => no volumes. See Volume.
    volumes?: [Volume]

    check:
        name, "Operator.name is required"
        image, "Operator.image is required"
        len(crds) > 0, \
            "Operator.crds must list at least one CRD kind"

schema Frontend:
    """A web or mobile frontend.

    Dev runs on the host via `<dev_runner> dev`. Production deploys
    vary by `type`:
      * nextjs — server-rendered, ships as a container.
      * vite   — static SPA, deploys to CDN / object store.
      * rn     — React Native; no in-cluster deploy.

    The optional `deploy` block declares a first-class production deploy
    target the same way Service.deploy does. Today the only variant is
    FirebaseHosting (static export → Firebase Hosting). Omit `deploy`
    to keep the legacy behaviour — the frontend is dev-served / built
    only, never auto-shipped by `forge deploy`.
    """
    name: str
    type: str = "nextjs"
    path: str
    dev_runner: str = "npm"
    port: int = 3000
    env_file?: str
    # KCL-declared per-env vars, layered on top of env_file at dev launch
    # (same EnvVar shape services use). Values may be composed
    # declaratively — e.g. forge.resolve_port(...) for a host port — so the
    # dev URLs a frontend needs live in KCL, not a launcher script.
    #
    # For a `deploy = forge.FirebaseHosting { ... }` frontend these are
    # ALSO injected as build-time env (NEXT_PUBLIC_* / VITE_*) so per-env
    # config lives in KCL, not hardcoded in CI.
    env_vars: [EnvVar] = []
    deploy?: FirebaseHosting

    check:
        name, "Frontend.name is required"
        path, "Frontend.path is required"
        type in ["nextjs", "vite", "rn"], \
            "Frontend.type must be 'nextjs' | 'vite' | 'rn'"
        dev_runner in ["npm", "pnpm", "yarn"], \
            "Frontend.dev_runner must be 'npm' | 'pnpm' | 'yarn'"
        port > 0 and port < 65536, "Frontend.port must be 1..65535"

schema CronJob:
    """A scheduled or one-shot job.

    With `schedule` set — renders as a Kubernetes CronJob.
    With `schedule = ""` — renders as a one-shot Kubernetes Job.

    `schedule` accepts standard cron syntax ("0 * * * *") or named
    expressions ("@hourly", "@daily", "@weekly", "@monthly", "@yearly").
    """
    name: str
    image: str
    # Per-cronjob image-tag pin (see Service.image_tag). Unset => the
    # env-wide tag.
    image_tag?: str
    schedule: str = ""
    platform?: str
    command: [str] = []
    env_vars: [EnvVar] = []
    # Pod volumes + container mounts — same escape hatch as
    # Service.volumes (writable empty_dir paths under the
    # readOnlyRootFilesystem baseline, or config_map / secret
    # projections). Unset => no volumes. See Volume.
    volumes?: [Volume]

    check:
        name, "CronJob.name is required"
        image, "CronJob.image is required"
        schedule == "" or schedule in ["@hourly", "@daily", "@weekly", "@monthly", "@yearly"] or \
            len(schedule.split(" ")) == 5, \
            "CronJob.schedule must be '' (one-shot Job), a named expression ('@hourly', ...), or a 5-field cron expression"

# ---------------------------------------------------------------------------
# Platform dependency — a helm chart rendered (NOT installed) by forge.
# ---------------------------------------------------------------------------

schema HelmChart:
    """A platform dependency rendered from a helm chart.

    THE MODEL: helm is a RENDERER, not an installer. forge runs
    `helm template <chart> --version <version> --values <vals>
    -n <namespace> --skip-crds` to expand the chart to a manifest list,
    then folds those manifests into the SAME render → kubectl-apply →
    wait pipeline every other forge entity flows through. There is no
    `helm install`, no helm-managed release, no imperative installer — a
    platform dep is just another renderable.

    SELECTION IS `--target`. A HelmChart is a renderable with a NAME, in
    the SAME env Bundle as the app — it differs from the app only in which
    `--target` you pick. forge stamps `app.kubernetes.io/name = <name>` on
    every manifest the chart renders, so the EXISTING `--target` /
    FilterManifestsByApp axis selects it:

        forge deploy <env> --target <name>   # apply ONLY this platform dep
        forge deploy <env>                   # apply the app (no platform target)

    cert-manager and Envoy Gateway are declared as two such HelmCharts the
    consumer lists per env; applying them with `--target` leaves the
    cluster with their CRDs Established + controllers Deployed, so a
    subsequent `forge deploy <env>` (the app) finds the CRDs present.

    DECLARATIVE UPGRADES are allowed: bump `version` (or edit `values`)
    and re-apply via `--target`; the render → apply reconciles it. There
    is no never-upgrade guardrail.

    APPLY ORDERING. The chart's own CRDs are deliberately EXCLUDED from
    the render (`--skip-crds`) — letting a chart's bundled (often older /
    experimental-channel) CRDs hit the cluster makes the Gateway-API
    `safe-upgrades` ValidatingAdmissionPolicy self-deny. forge instead
    supplies the correct CRDs itself (the pinned standard Gateway API CRDs
    + cert-manager's CRDs at the matching chart version) and applies them
    FIRST, waiting until Established before the chart's controller
    manifests. `crds` selects which forge-owned CRD bundle to supply.

    Fields:
      * `name`      — the platform dep's NAME; the `--target` selector and
                      the `app.kubernetes.io/name` stamped on every
                      rendered manifest.
      * `chart`     — chart name (repo charts: the chart name, e.g.
                      "cert-manager"; OCI charts: ignored, `oci` carries
                      the full ref).
      * `repo`      — chart repository URL (e.g. "https://charts.jetstack.io").
                      Mutually exclusive with `oci`.
      * `oci`       — OCI chart ref (e.g.
                      "oci://docker.io/envoyproxy/gateway-helm"). Mutually
                      exclusive with `repo`.
      * `version`   — pinned chart version (e.g. "v1.20.1"). REQUIRED — a
                      platform dep is always version-pinned.
      * `namespace` — namespace to render the chart into (`helm template
                      -n <namespace>`). The chart's namespaced resources
                      land here.
      * `values`    — helm values (the `--values` overlay), a raw dict
                      passed through verbatim. Empty => chart defaults.
      * `crds`      — which forge-owned CRD bundle to apply FIRST (before
                      the chart's controllers), Established-gated:
                        "" (default) — none; the chart needs no forge CRDs.
                        "gateway-api" — the pinned standard-channel Gateway
                          API CRDs (Envoy Gateway).
                        "cert-manager" — cert-manager's CRDs at `version`.
    """
    name: str
    chart: str = ""
    repo: str = ""
    oci: str = ""
    version: str
    namespace: str
    values: {str: any} = {}
    crds: "" | "gateway-api" | "cert-manager" = ""
    # Raw k8s manifests that ride WITH this platform dep: applied (and
    # excluded from a bare `forge deploy <env>`) on the SAME `--target=<name>`
    # axis as the chart, stamped with the chart's `app.kubernetes.io/name` and
    # applied AFTER the chart's controllers (so a controller is Deployed
    # before its instances). The natural home for the small cluster-scoped
    # instances a chart's controller reconciles but the chart itself does not
    # ship — e.g. the `eg` GatewayClass for envoy-gateway, or cert-manager
    # ClusterIssuers. UNLIKE Bundle.additional_manifests (which renders into
    # the env's main stream and so DOES apply on a bare app deploy), these are
    # platform-only: a bare `forge deploy <env>` renders none of them. Each
    # entry is a raw manifest dict. Empty => none.
    manifests: [any] = []

    check:
        name, "HelmChart.name is required (the --target selector)"
        version, "HelmChart.version is required (a platform dep is always version-pinned)"
        namespace, "HelmChart.namespace is required (helm template -n <namespace>)"
        repo or oci, "HelmChart must set `repo` (a chart-repo URL) or `oci` (an OCI chart ref)"
        not (repo and oci), "HelmChart.repo and HelmChart.oci are mutually exclusive"
        oci or chart, "HelmChart.chart is required for a repo chart (the chart name)"

# ---------------------------------------------------------------------------
# Declared external prerequisites.
#
# THE PROBLEM: a deploy depends on facts forge does NOT (and must not)
# create — an out-of-band Secret (the `cloudflare-api-token` in the
# `cert-manager` namespace), per-host DNS A-records pointing at the
# ingress load balancer, the load-bearing `*.workspaces` wildcard record.
# Today these live ONLY in KCL docstrings: `forge deploy` renders
# successfully, applies, and THEN cert-manager's ACME challenge or the
# workspace-proxy DNS silently hangs because the prereq was never
# satisfied. The failure surfaces minutes later, far from its cause, with
# no signal pointing back at the unmet requirement.
#
# THE MODEL: declare each prerequisite as a first-class entity in
# `Bundle.requires`. Two kinds today (a `type`-discriminated union,
# mirroring the deploy / build unions so a new prereq kind is additive):
#
#   * ExternalSecret — an out-of-band k8s Secret + the keys it must carry.
#     forge does NOT render or create it (that's the whole point — it's
#     out-of-band); the declaration drives a RENDER-TIME checklist AND a
#     deploy preflight that BLOCKS when the declared-required Secret/key is
#     absent on the LIVE target (reusing the same SecretGetter the existing
#     secretKeyRef preflight uses).
#
#   * DNSRecord — a DNS record (A / AAAA / CNAME / wildcard) the deploy
#     depends on. forge cannot verify arbitrary DNS authoritatively, so
#     this surfaces as a render-time checklist line (and a `--check`
#     preflight note) rather than a hard block — the load-bearing
#     `*.workspaces` wildcard is exactly the record whose omission hangs
#     ACME+proxy silently, so MODELING it (vs a docstring) is the win.
#
# CROSS-SECRET BYTE-MATCH: when ONE logical secret value is projected to N
# different Secret refs (the same Cloudflare token wanted under two names,
# a JWT key shared across services), declare the group with a shared
# `value_group` id on each ExternalSecret. forge's audit then asserts the
# group is INTERNALLY consistent at render (every member names the same
# logical value), and the preflight byte-compares the live Secret values
# so a drifted copy (same id, different bytes) is caught BEFORE it ships a
# half-rotated credential. An ExternalSecret with NO `value_group` is a
# standalone prereq (the common case) — the byte-match machinery is inert.
# ---------------------------------------------------------------------------

schema ExternalSecret:
    """An out-of-band Kubernetes Secret a deploy DEPENDS ON but forge does
    NOT create — the declarative replacement for a "provision this Secret
    yourself" docstring.

    The motivating case: cert-manager's DNS-01 ClusterIssuer reads a
    `cloudflare-api-token` Secret (key `api-token`) in the `cert-manager`
    namespace to write `_acme-challenge` TXT records. forge renders the
    ClusterIssuer that REFERENCES that Secret, but the Secret itself is
    provisioned out-of-band; if it's absent, render + apply both succeed
    and then every ACME challenge silently fails. Declaring it here turns
    that into a render-time checklist line and a deploy-preflight BLOCK.

    Fields:
      * `name`        — the Secret's metadata.name.
      * `namespace`   — the namespace it must exist in. This is OFTEN NOT
                        the deploy's own namespace (cert-manager's Secret
                        lives in `cert-manager`), so it's required + explicit
                        rather than defaulted — the cross-namespace case is
                        the norm for the prereqs this models.
      * `keys`        — the data keys the consumer reads (e.g. ["api-token"]).
                        At least one. The preflight verifies each exists.
      * `reason`      — a short human note: WHY the deploy needs it (shown in
                        the checklist so the operator knows what breaks if it's
                        absent). e.g. "cert-manager DNS-01 Cloudflare API token".
      * `value_group` — OPTIONAL shared id tying this Secret to OTHER
                        ExternalSecrets that must carry the SAME logical
                        value under (possibly) different name/key. Drives the
                        cross-secret byte-match audit + preflight. Unset =>
                        a standalone prereq (no byte-match group).
    """
    type: str = "secret"
    name: str
    namespace: str
    keys: [str]
    reason: str = ""
    value_group: str = ""

    check:
        type == "secret", "ExternalSecret.type must be 'secret'"
        name, "ExternalSecret.name is required"
        namespace, "ExternalSecret.namespace is required (the namespace the out-of-band Secret must exist in — often NOT the deploy namespace, e.g. 'cert-manager')"
        len(keys) > 0, "ExternalSecret.keys must list at least one data key the consumer reads (e.g. ['api-token'])"

schema DNSRecord:
    """A DNS record a deploy DEPENDS ON — the declarative replacement for a
    "point DNS at the LB IP" docstring.

    forge cannot authoritatively verify arbitrary external DNS at deploy
    time (the record may not have propagated; the resolver forge runs under
    may differ from the cluster's), so this is a render-time CHECKLIST entry
    (and a `forge deploy --check` note), NOT a hard block. The value is
    MODELING the requirement: the load-bearing `*.workspaces` wildcard
    A-record — whose omission hangs both the DNS-01 wildcard cert and all
    workspace-proxy traffic — is exactly the silent-failure prereq that
    belongs in the bundle, not a comment.

    Fields:
      * `host`   — the record name (e.g. "api.reliantapi.com" or the
                   wildcard "*.workspaces.reliantapi.com").
      * `type`   — record type: "A" | "AAAA" | "CNAME". Default "A".
      * `target` — OPTIONAL expected value: the LB IP for an A/AAAA record,
                   or the CNAME target. Often unknown at author time (the
                   Envoy LB takes an ephemeral IP), so optional — when set,
                   the checklist shows the expected value; when unset, the
                   checklist just names the record that must exist.
      * `reason` — short human note: what breaks if the record is absent.
    """
    host: str
    type: "A" | "AAAA" | "CNAME" = "A"
    target: str = ""
    reason: str = ""

    check:
        host, "DNSRecord.host is required (e.g. 'api.example.com' or '*.workspaces.example.com')"
        type in ["A", "AAAA", "CNAME"], "DNSRecord.type must be 'A' | 'AAAA' | 'CNAME'"

# ---------------------------------------------------------------------------
# Bundle — the project-level container forge.render() consumes.
# ---------------------------------------------------------------------------

schema Bundle:
    """The set of typed entities a project declares per environment.

    A project's `deploy/kcl/<env>/main.k` constructs a Bundle and
    passes it to `forge.render(...)`. The output is the JSON contract
    documented at the top of this file.
    """
    # k3d clusters forge ensures exist before deploying. An env that
    # stands up several clusters (a control-plane cluster + a workload
    # cluster) declares them here; `forge up` reconciles each at the
    # head of the run (create-if-absent, no-op if present). Empty =>
    # forge ensures no cluster (today's `forge up --env=e2e` behavior,
    # or a single dev cluster bootstrapped the legacy way). Ownership is
    # a REFERENCE: a secondary names its `owner` Cluster and forge derives
    # the joined network + registry-inherit from it — there is no
    # "primary" cluster.
    clusters: [Cluster] = []
    # The env-wide Kubernetes facts, stated ONCE (cluster context /
    # namespace / registry / image_pull_secrets / platform / image_tag).
    # `render_manifests` reads namespace/registry/platform/pull_secrets off
    # this target instead of the old "pull them off the first cluster
    # service" heuristic, and each service references `cluster_target.deploy`
    # for its per-service deploy block. Optional so a manifests-free /
    # host-only / External-only Bundle (no in-cluster workloads) need not
    # declare one; `render_manifests` requires it.
    cluster_target?: ClusterTarget
    # Cross-cluster kubeconfigs minted FRESH each `forge up` and stored
    # as k8s Secrets (so a workload in one cluster can reach another's
    # API server without a committed, IP-drifting kubeconfig). Minted at
    # the cluster→deploy boundary. Empty => none. See KubeconfigSecret.
    kubeconfig_secrets: [KubeconfigSecret] = []
    # AGNOSTIC user-facing workloads (the ONE user Service — kcl/core.k). The
    # render layer projects each onto a `K8sWorkload` INTERNALLY via
    # `forge._service_to_k8s(w, cluster_target)` before emitting manifests /
    # the JSON contract, so the user NEVER calls the adapter. This is the
    # authoring entry a project uses now.
    workloads: [Service] = []
    # DEMOTED / adapter-internal: the k8s-shaped projection carrier (host /
    # external / compose / build-only deploy modes + build machinery the
    # agnostic Service doesn't model). `_service_to_k8s` emits these from
    # `workloads`; a project may still place pre-projected `K8sWorkload`s here
    # for the non-cluster deploy modes until those are folded into the core.
    services: [K8sWorkload] = []
    operators: [Operator] = []
    frontends: [Frontend] = []
    cronjobs: [CronJob] = []
    # Generated by `forge generate` from `(forge.v1.config)`-annotated
    # config proto fields and `forge.yaml -> environments[*].config`.
    # Rendered into ConfigMap manifests by `forge.render_manifests`.
    config_maps: [ConfigMap] = []
    # Gateway API ingress topology. Declared in `deploy/kcl/ingress.k`
    # at project level and per-env-overridden in
    # `deploy/kcl/<env>/ingress.k`. Routes attach to a Gateway+listener
    # by name. The GatewayClass is NOT in the Bundle — it's
    # cluster-scoped and installed by `forge dev cluster up`.
    gateways: [Gateway] = []
    http_routes: [HTTPRoute] = []
    grpc_routes: [GRPCRoute] = []
    # Arbitrary extra k8s resources rendered alongside the typed
    # entities. Use for ClusterIssuers, SealedSecrets, hand-typed CRDs
    # — anything that doesn't fit a typed entity. Each entry is a
    # raw manifest dict.
    additional_manifests: [any] = []
    # Per-env secret PROVIDER declaration: WHERE secret values come from.
    # Absent = today's behavior (no provider). "dotenv" (dev/local) lets
    # forge resolve declared secret_refs from a gitignored dotenv and
    # render Secret objects CLI-side; "external" (prod/staging) means
    # forge never sees values — k8s references pre-existing Secrets.
    # KCL only emits this DECLARATION; secret VALUES never enter KCL.
    secret_provider?: DotenvSecrets | ExternalSecrets | RenderedSecrets
    # Cluster-scoped node.k8s.io/v1 RuntimeClass declarations. Used to
    # bind a workload-facing name ("gvisor", "kata-qemu") to a
    # node-installed handler, OR to declare a dev-cluster alias that
    # maps a name pods reference (e.g. "gvisor") to the vanilla "runc"
    # handler so Pods stay schedulable when the real runtime isn't
    # installed. See RuntimeClass docstring for the full rationale.
    runtime_classes: [RuntimeClass] = []
    # Platform dependencies rendered from helm charts (helm-as-a-RENDERER:
    # `helm template --skip-crds` → manifests folded into the normal apply
    # pipeline; NO `helm install`). Each is a renderable with a NAME the
    # EXISTING `--target` axis selects: `forge deploy <env> --target <name>`
    # applies that platform dep; `forge deploy <env>` (no platform target)
    # applies the app. cert-manager + Envoy Gateway are declared here per
    # env. See HelmChart. Empty => no platform deps (the app-only default).
    helm_charts: [HelmChart] = []
    # Declared external PREREQUISITES — out-of-band facts the deploy depends
    # on that forge does NOT (and must not) create: an out-of-band Secret
    # (cert-manager's `cloudflare-api-token`), per-host DNS A-records, the
    # load-bearing `*.workspaces` wildcard. MODELING them here (vs a docstring)
    # makes them a render-time checklist AND a deploy preflight: an
    # `ExternalSecret` that's declared-required but ABSENT on the live target
    # BLOCKS the deploy (reusing the secretKeyRef preflight's SecretGetter)
    # instead of letting ACME/DNS hang silently minutes after a green apply.
    # `required_dns` surfaces as a checklist note (forge can't authoritatively
    # verify external DNS). Empty => no declared prereqs (today's behavior).
    required_secrets: [ExternalSecret] = []
    required_dns: [DNSRecord] = []

    check:
        # Agnostic `workloads` are cluster-only today: `_service_to_k8s`
        # projects each onto a K8sWorkload seeded from `cluster_target`, so a
        # workload without a target dereferences an Undefined `target.deploy`
        # and fails with a confusing projection error deep in the adapter.
        # Reject it at load with a clear message instead. (Host / external /
        # compose workloads still go in `services` as pre-projected
        # K8sWorkloads until those deploy modes are folded into the core.)
        len(workloads) == 0 or cluster_target, \
            "Bundle.workloads require a cluster_target: agnostic workloads are cluster-only today and are projected onto the env-wide ClusterTarget. Declare Bundle.cluster_target, or use Bundle.services for host/external/compose (pre-projected K8sWorkload) workloads."
        # value_group consistency: every ExternalSecret in a byte-match group
        # must agree on the KEY SET it projects, so the cross-secret byte
        # comparison (preflight) compares like for like. A group whose members
        # disagree on which keys carry the shared value is a modeling error —
        # caught here at load, not as a confusing preflight diff. Standalone
        # secrets (empty value_group) are exempt. The dict comprehension keys
        # each group id to the DISTINCT key-set signatures its members declare;
        # a consistent group collapses to exactly one signature.
        all g, sigs in {
            s.value_group: [
                ",".join([k for k in sorted(s2.keys)])
                for s2 in required_secrets if s2.value_group == s.value_group
            ] for s in required_secrets if s.value_group
        } {
            len({sig: sig for sig in sigs}) == 1
        }, "Bundle.required_secrets: ExternalSecrets sharing a value_group must declare the SAME key set (the bytes under those keys are compared across the group); a group whose members project different keys can't be byte-matched"
        # `platform` is REQUIRED on a CLOUD cluster_target whenever ANY
        # service ships a REAL external image build (a DockerBuild or a
        # non-no-op ShellBuild — see forge.builds_an_image). Those builds
        # interpolate the env's `platform` as ${TARGETARCH} / the docker
        # `--platform`; WITHOUT it the build pipeline falls through to the
        # dev HOST's arch (resolveExternalBuildTargetArch → runtime.GOARCH),
        # so a `forge build` from an arm64 Mac pushes arm64 images that
        # exec-format-error / ImagePullBackOff on amd64 cloud nodes — the
        # class that broke prod. Making it a LOAD-time failure (naming the
        # field) converts that silent deploy-time break into an author-time
        # one.
        #
        # The registry is the authoritative local-vs-cloud signal: a LOCAL
        # k3d target rides a host-local registry (localhost:/registry.localhost:)
        # whose nodes share the dev-host arch, so an omitted platform
        # correctly tracks the host — the dev/e2e path that legitimately omits
        # it stays exempt. A CLOUD target (any real remote registry) whose
        # nodes have a FIXED arch must state it. Using the registry (not the
        # cluster name) keeps the signal reliable: a localhost registry can
        # only be served to the host's own cluster, period.
        not cluster_target or cluster_target.platform \
            or is_local_registry(cluster_target.registry) \
            or all s in services { not builds_an_image(s) }, \
            "Bundle.cluster_target.platform is required: this env deploys to a cloud target (a non-local registry) AND declares a service with a real external image build (DockerBuild / non-no-op ShellBuild), but states no build platform. Set platform (e.g. 'amd64') on the ClusterTarget so external builds cross-compile for the cloud node arch instead of silently falling through to the dev host arch (the arm64-image-on-amd64-node ImagePullBackOff/exec-format-error class)."
